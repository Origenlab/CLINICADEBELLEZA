---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import HeroNavBar from '../components/HeroNavBar.astro';
import RelatedCategories from '../components/RelatedCategories.astro';
import { SITE, CONTACT, BRANCHES, PARTNERS, catHref } from '../consts';

const yearsCount = new Date().getFullYear() - parseInt(SITE.founded);
const wa = `https://wa.me/${CONTACT.whatsapp}?text=${encodeURIComponent('Hola CLIBEL, quiero agendar valoración sin costo.')}`;

// ============ HITOS DE HISTORIA ============
const milestones = [
  {
    when: '1981',
    label: 'Fundación',
    text: 'CLIBEL abre su primer consultorio en Ciudad de México con enfoque pionero: medicina estética con respaldo clínico documentado, en una época en que la categoría se confundía con cosmética sin criterio.',
  },
  {
    when: '1995',
    label: 'Profesionalización clínica',
    text: 'Incorporación de personal médico con cédula y certificaciones específicas como estándar mínimo. Inicio del expediente clínico documentado para cada paciente — antes de que fuera obligatorio en estética.',
  },
  {
    when: '2008',
    label: 'Expansión tecnológica',
    text: 'Inversión en plataformas láser de tres tecnologías (Alexandrita, Nd:YAG, Diodo) para cubrir todos los fototipos. Radiofrecuencia bipolar/multipolar para corporal. Tricoscopia digital para capilar.',
  },
  {
    when: '2018',
    label: 'Coordinación inter-especialidad',
    text: 'Formalización de red clínica con ginecología, endocrinología, dermatología capilar y cirugía plástica. Casos complejos derivados con documentación — no improvisamos especialidad ajena.',
  },
  {
    when: '2024',
    label: 'Expediente digital + WhatsApp clínico',
    text: 'Migración completa a expediente digital con foto comparativa multi-ángulo, lote de productos COFEPRIS, parámetros por sesión. Línea WhatsApp clínico directa con personal médico para complicaciones.',
  },
  {
    when: `${new Date().getFullYear()}`,
    label: `${yearsCount} años atendiendo CDMX`,
    text: `Más de 5,000 pacientes atendidas, 25+ tratamientos en catálogo, cinco categorías clínicas. La continuidad de ${yearsCount} años se sostiene en una sola cosa: criterio médico antes que decisión comercial.`,
  },
];

// ============ PILARES (6 ahora, ampliado) ============
const pillars = [
  {
    n: '01',
    title: 'Diagnóstico antes que tratamiento',
    text: 'Cada plan parte de valoración clínica documentada — no de venta directa. Si el caso no es candidato a lo que ofrecemos, derivamos a especialista sin cobrar la consulta. La medicina seria empieza por reconocer límites.',
  },
  {
    n: '02',
    title: 'Productos con trazabilidad real',
    text: 'Exclusivamente marcas con registro COFEPRIS (Allergan, Galderma, Merz, Sinclair, Teoxane, Regen Lab). Mostramos lote, fecha y empaque al paciente antes de aplicar. La trazabilidad no es extra — es estándar mínimo no negociable.',
  },
  {
    n: '03',
    title: 'Médico inyector certificado',
    text: 'Todos los inyectables (AH, toxina, hilos, PRP) los aplica MÉDICO con cédula profesional y certificación específica en medicina estética. No técnico, no esteticista, no enfermera con curso corto. Distinción regulatoria y de seguridad.',
  },
  {
    n: '04',
    title: 'Filosofía conservadora',
    text: 'Preferimos sub-corregir y volver, antes que sobre-corregir y arrepentirnos. Dosis bajas, técnica fraccionada, revisión a 14 días sin costo para ajuste fino. La armonización natural es el estándar — no la transformación radical.',
  },
  {
    n: '05',
    title: 'Coordinación inter-especialidad',
    text: 'Trabajamos en red con ginecología, endocrinología, dermatología capilar y cirugía plástica. Si tu caso exceds nuestro alcance —alopecia cicatrizal, descolgamiento severo, hiperandrogenismo activo— derivamos honestamente con especialista de confianza.',
  },
  {
    n: '06',
    title: 'Trato cálido sin presión comercial',
    text: 'Atención humana real, no guion de venta. Te explicamos todo, respetamos tus tiempos, te dejamos decidir con información completa. Si necesitas pensar, agendar después o no hacer nada por ahora, todo es legítimo.',
  },
];

// ============ INFRAESTRUCTURA DE SEGURIDAD CLÍNICA ============
const infrastructure = [
  {
    title: 'Hialuronidasa en cabina',
    text: 'Antagonista de AH disponible inmediatamente para revertir cualquier aplicación en 24–72 h. Estándar mínimo en clínicas de medicina estética seria — y rareza en spas.',
    icon: '⚕',
  },
  {
    title: 'Apraclonidina tópica',
    text: 'Para manejo de ptosis palpebral por toxina botulínica. Disponible para uso inmediato en complicaciones del neuromodulador.',
    icon: '⚕',
  },
  {
    title: 'Kit estéril certificado para PRP',
    text: 'Regen Lab, Arthrex o Ycellbio single-use con certificación regulatoria. Sin protocolos manuales abiertos — concentración plaquetaria consistente garantizada.',
    icon: '🧪',
  },
  {
    title: 'Dermatoscopio digital tricológico',
    text: 'Aumento ×20 a ×200 para diagnóstico de alopecia y descarte de patología cicatrizal. Foto basal documentada para seguimiento objetivo.',
    icon: '🔍',
  },
  {
    title: 'Expediente clínico digital',
    text: 'Cada sesión documenta producto, lote, dosis, parámetros, técnica, respuesta cutánea y foto comparativa. Trazabilidad clínica disponible para consulta del paciente.',
    icon: '📋',
  },
  {
    title: 'WhatsApp clínico 24/7',
    text: 'Línea directa con personal médico responsable durante la ventana sensible post-procedimiento. Respuesta clínica en menos de 2 horas en horario consulta, manejo de urgencias fuera de horario.',
    icon: '📞',
  },
  {
    title: 'Tres tecnologías láser',
    text: 'Alexandrita (755 nm), Nd:YAG (1064 nm), Diodo (810 nm) para cubrir todos los fototipos Fitzpatrick I–VI con seguridad. La piel mexicana es heterogénea — un solo equipo no basta.',
    icon: '⚡',
  },
  {
    title: 'Protocolo de complicaciones',
    text: 'Manejo escrito y documentado para cada complicación posible (embolia vascular, ptosis, infección, granuloma, dimpling). Personal capacitado en reanimación y derivación inmediata a especialista cuando aplica.',
    icon: '⚕',
  },
];

// ============ CONFIANZA Y MARCAS ============
const trust = [
  { kicker: 'COFEPRIS', value: 'Registro vigente', detail: 'Productos con trazabilidad de lote · personal médico documentado' },
  { kicker: 'Allergan', value: 'Juvéderm · Botox', detail: 'Certificación MD Codes · acceso directo a fabricante' },
  { kicker: 'Galderma', value: 'Restylane · Dysport · Sculptra', detail: 'Galderma GAIN entrenamiento continuo' },
  { kicker: 'Merz', value: 'Belotero · Xeomin · Radiesse', detail: 'Certificación específica del laboratorio' },
  { kicker: 'Teoxane', value: 'Teosyal RHA', detail: 'Productos suizos de última generación' },
  { kicker: 'Regen Lab', value: 'Kit PRP estéril', detail: 'Trazabilidad single-use · concentración consistente' },
];

// ============ COMPROMISOS DE EXPERIENCIA ============
const commitments = [
  {
    title: 'Valoración inicial sin costo',
    text: 'La primera consulta orientativa de 15–30 min es sin costo. La consulta diagnóstica completa con dermatoscopio, anamnesis exhaustiva y plan terapéutico por escrito tiene costo — pero se deduce si decides iniciar plan.',
    weight: 'Imprescindible',
  },
  {
    title: 'Presupuesto por escrito antes de cobrar',
    text: 'Recibes plan completo con cantidad de sesiones, productos a aplicar, costos totales y mantenimiento esperado por escrito antes de cualquier compromiso económico. Sin sorpresas en facturación.',
    weight: 'Imprescindible',
  },
  {
    title: 'Revisión a 14 días sin costo',
    text: 'Para inyectables, cita de revisión obligatoria a 14 días con foto comparativa y retoque sin costo adicional si requiere ajuste fino. La medicina seria se compromete con el resultado, no con la primera sesión.',
    weight: 'Imprescindible',
  },
  {
    title: 'Honestidad sobre limitaciones',
    text: 'Si tu caso no es candidato a lo que ofrecemos, te derivamos sin cobrar plan. Si tu expectativa no es realista, te lo decimos antes de cobrar. Si tu cuadro exige otro especialista, lo coordinamos.',
    weight: 'Imprescindible',
  },
  {
    title: 'Sin presión comercial',
    text: 'No hay descuentos relámpago de 24 horas, no hay paquetes que "se vencen mañana", no hay venta cruzada agresiva. Si necesitas pensar, agendar después o no hacer nada por ahora, todo es legítimo.',
    weight: 'Recomendado',
  },
];

// ============ FAQs DE LA CLÍNICA ============
const faqs: { q: string; answerHtml: string }[] = [
  {
    q: '¿Por qué CLIBEL no es la opción más barata del mercado?',
    answerHtml: 'Por dos razones concretas: productos con registro COFEPRIS y trazabilidad real (más caros que genéricos sin origen) + personal médico con cédula y certificación específica (más caro que técnico con curso corto). Lo barato en medicina estética suele significar: producto falsificado, técnica incorrecta, sin manejo de complicaciones. <a href="/equipo">Conoce al equipo →</a>',
  },
  {
    q: '¿Cuánto cuesta una valoración inicial?',
    answerHtml: 'La consulta orientativa de 15–30 min es <strong>sin costo</strong> y sin presión comercial. La consulta diagnóstica completa (con dermatoscopio, anamnesis exhaustiva, plan terapéutico por escrito) tiene costo — pero se deduce si decides iniciar plan. <a href="/contacto">Agendar valoración →</a>',
  },
  {
    q: '¿Trabajan con productos originales o pueden ser falsificados?',
    answerHtml: 'Exclusivamente productos con registro COFEPRIS vigente: Allergan (Juvéderm, Botox), Galderma (Restylane, Sculptra, Dysport), Merz (Belotero, Xeomin), Sinclair (Silhouette Soft), Teoxane (RHA), Regen Lab (kits PRP). Te mostramos lote y empaque cerrado antes de aplicar — trazabilidad real, no marketing.',
  },
  {
    q: '¿Qué pasa si tengo una complicación post-procedimiento?',
    answerHtml: 'Tienes acceso directo a tu médico via <strong>WhatsApp clínico</strong> 24/7. Hay protocolo escrito para cada complicación: hialuronidasa para AH, apraclonidina para ptosis, antibiótico para infecciones, derivación inmediata a dermatología o cirugía si la situación lo exige. La <a href="/equipo">infraestructura de seguridad</a> es estándar, no extra.',
  },
  {
    q: '¿Atienden a hombres? ¿A adolescentes?',
    answerHtml: 'Hombres: sí, regularmente — armonización facial masculina, depilación corporal, capilar. Adolescentes: desde los 14 años con autorización de madre/padre (depilación láser, antiacné, limpieza facial). Procedimientos inyectables solo a partir de los 18 años. Cada perfil se valora individualmente.',
  },
  {
    q: '¿Cuántas sucursales tienen?',
    answerHtml: `Operamos <strong>${BRANCHES.length} sucursales</strong> en CDMX. La coordinadora de pacientes te asigna la sucursal más cercana o conveniente para tu rutina. <a href="/contacto">Ver ubicaciones y mapa →</a>`,
  },
  {
    q: '¿Cómo agendo una cita?',
    answerHtml: 'Por <strong>WhatsApp clínico</strong> directo, <a href="/contacto">formulario de contacto</a> en el sitio o por teléfono. La <a href="/equipo">coordinadora de pacientes</a> te orienta sobre qué especialista necesitas según tu motivo y agenda con quien corresponda. Respuesta en menos de 2 horas en horario clínica.',
  },
  {
    q: '¿Aceptan pagos en plazos o solo efectivo?',
    answerHtml: 'Aceptamos efectivo, débito, crédito (Visa, MasterCard, Amex) y transferencias. Para planes integrales (corporal, capilar, medicina estética) manejamos pagos por sesión o paquetes con descuento progresivo. Sin comisiones ocultas, todo presupuestado por escrito antes.',
  },
];
---

<BaseLayout
  title={`Sobre CLIBEL · ${yearsCount} Años de Medicina Estética en CDMX`}
  description={`CLIBEL nació en ${SITE.founded}. ${yearsCount} años combinando criterio médico, productos COFEPRIS con trazabilidad y filosofía conservadora. Conoce la historia, filosofía y compromisos clínicos.`}
>
  <!-- ============================ BREADCRUMB ============================ -->
  <Breadcrumb
    kicker="Sobre CLIBEL · Clínica de Belleza"
    items={[
      { label: 'Sobre nosotros' },
    ]}
  />

  <!-- ============================ HERO 2-col ============================ -->
  <section class="cat-hero">
    <div aria-hidden="true" class="cat-hero-bg"></div>
    <div aria-hidden="true" class="cat-hero-blob cat-hero-blob-1"></div>
    <div aria-hidden="true" class="cat-hero-blob cat-hero-blob-2"></div>
    <div aria-hidden="true" class="cat-hero-grain"></div>

    <div class="container-x relative">
      <div class="cat-hero-grid">
        <div class="cat-hero-col cat-hero-col--left fade-up">
          <span class="eyebrow-tag">
            <span class="dot" aria-hidden="true"></span>
            Desde {SITE.founded} · {yearsCount} años en CDMX
          </span>

          <h1 class="cat-hero-headline">
            <span class="cat-hero-headline-line">Belleza con</span>
            <span class="cat-hero-headline-line"><em>criterio</em> médico.</span>
          </h1>

          <p class="cat-hero-lede">
            <strong>CLIBEL</strong> es una clínica de belleza con respaldo
            médico fundada en {SITE.founded}. {yearsCount} años combinando
            diagnóstico clínico documentado, productos con registro COFEPRIS,
            personal médico con cédula y filosofía conservadora — la medicina
            estética seria no es la que más promete, es la que más sostiene
            a largo plazo.
          </p>

          <div class="cat-hero-trust">
            <span class="cat-hero-trust-label">Laboratorios certificados</span>
            <div class="cat-hero-trust-list">
              <span>Allergan</span><span aria-hidden="true">·</span>
              <span>Galderma</span><span aria-hidden="true">·</span>
              <span>Merz</span><span aria-hidden="true">·</span>
              <span>Sinclair</span><span aria-hidden="true">·</span>
              <span>Teoxane</span>
            </div>
          </div>
        </div>

        <div class="cat-hero-col cat-hero-col--right fade-up-delay-2">
          <span class="cat-hero-kicker">Qué hace CLIBEL distinto</span>

          <p class="cat-hero-paragraph">
            La diferencia entre un buen resultado y uno catastrófico en
            medicina estética <strong>no es el producto</strong> que se aplica
            — es el criterio médico detrás de cada decisión clínica. CLIBEL
            opera bajo seis principios no negociables: diagnóstico antes que
            tratamiento, productos con trazabilidad real, médico inyector
            certificado, filosofía conservadora, coordinación
            inter-especialidad y trato cálido sin presión comercial.
          </p>

          <p class="cat-hero-paragraph">
            Si buscas resultados milagrosos en una sola sesión, descuentos
            relámpago de 24 horas o cambios faciales radicales, <strong>CLIBEL
            no es tu clínica</strong> — y eso te lo decimos honestamente en
            valoración antes de cobrar. Si buscas medicina seria a largo
            plazo, te ves descansada y mantenes tu identidad facial,
            entonces sí estamos en la misma página. Explora la
            <a href={catHref('facial')}>categoría facial</a>,
            <a href={catHref('corporal')}>corporal</a>,
            <a href={catHref('medicina-estetica')}>medicina estética</a>,
            <a href={catHref('laser')}>láser</a> o
            <a href={catHref('capilar')}>capilar</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================ HERONAVBAR ============================ -->
  <HeroNavBar
    label="Sobre CLIBEL"
    ariaLabel="Navegación interna sobre CLIBEL"
    variant="cream"
    links={[
      { label: 'Historia',           href: '#historia' },
      { label: 'Filosofía',          href: '#filosofia' },
      { label: 'Pilares clínicos',   href: '#pilares' },
      { label: 'Infraestructura',    href: '#infraestructura' },
      { label: 'Compromisos',        href: '#compromisos' },
      { label: 'FAQs',               href: '#faqs' },
    ]}
    cta={{ label: 'Agendar valoración', href: '/contacto' }}
  />

  <!-- ============================ STAT STRIP CLÍNICO ============================ -->
  <section class="svc-stat-strip">
    <div class="container-x">
      <dl class="nos-stats">
        <div>
          <dt>Años atendiendo</dt>
          <dd><em>{yearsCount}</em></dd>
        </div>
        <div>
          <dt>Pacientes atendidas</dt>
          <dd><em>5</em><span>,000+</span></dd>
        </div>
        <div>
          <dt>Categorías clínicas</dt>
          <dd><em>05</em></dd>
        </div>
        <div>
          <dt>Sucursales</dt>
          <dd><em>{BRANCHES.length}</em><span class="nos-stats-loc">CDMX</span></dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- ============================ HISTORIA EDITORIAL (timeline) ============================ -->
  <section class="section bg-white" id="historia">
    <div class="container-x">
      <SectionHeader
        marginBottom="md"
        kicker="Historia · Cronología"
        title={`Desde ${SITE.founded}, <em>criterio</em><br/>antes que decisión comercial.`}
        paragraphs={[
          `<strong>CLIBEL</strong> nació hace ${yearsCount} años con una convicción simple: la medicina estética debe operar como medicina —diagnóstico, evidencia, documentación— y no como cosmética sin criterio. Cada hito captura una <strong>elección clínica</strong> antes que comercial.`,
        ]}
      />

      <ol class="hist-grid">
        {milestones.map((m, i) => (
          <li class="hist-card">
            <span class="hist-card-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <div class="hist-card-year-wrap" aria-hidden="true">
              <span class="hist-card-year">{m.when}</span>
              <span class="hist-card-line"></span>
            </div>
            <h3 class="hist-card-label">{m.label}</h3>
            <p class="hist-card-text">{m.text}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============================ PULL-QUOTE FILOSOFÍA ============================ -->
  <section class="svc-pullquote" id="filosofia">
    <div class="container-x">
      <blockquote class="nos-quote">
        <span class="nos-quote-mark" aria-hidden="true">&ldquo;</span>
        <p class="nos-quote-text">
          La medicina estética seria <em>no es</em> la que más promete.
          Es la que más <strong>sostiene a largo plazo</strong> — la que
          se compromete con tu rostro a 10 años, no con la facturación
          del próximo trimestre.
        </p>
        <cite class="nos-quote-cite">Filosofía CLIBEL · {yearsCount} años</cite>
      </blockquote>
    </div>
  </section>

  <!-- ============================ 6 PILARES (dark) ============================ -->
  <section class="section nos-philosophy" id="pilares">
    <div aria-hidden="true" class="nos-philosophy-bg"></div>

    <div class="container-x relative">
      <SectionHeader
        kicker="Pilares clínicos"
        title="Seis principios<br/><em>no negociables</em>."
        variant="dark"
        paragraphs={[
          'Los seis pilares que <strong>CLIBEL</strong> opera sin excepción comercial. Si alguno de estos se relaja para cerrar una venta, no es medicina estética seria — es polivalencia disfrazada de servicio premium.',
          'Estos principios definen cómo abordamos cada paciente que llega buscando un tratamiento. No son slogan: son la práctica clínica diaria documentada en expediente.',
        ]}
      />

      <ol class="pillars-list">
        {pillars.map((p) => (
          <li class="pillar reveal">
            <span class="pillar-num" aria-hidden="true">{p.n}</span>
            <div class="pillar-body">
              <h3 class="pillar-title">{p.title}</h3>
              <p class="pillar-text">{p.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============================ INFRAESTRUCTURA DE SEGURIDAD ============================ -->
  <section class="section bg-white" id="infraestructura">
    <div class="container-x">
      <SectionHeader
        kicker="Infraestructura clínica"
        title="Lo que <em>CLIBEL</em><br/>tiene listo en cabina."
        paragraphs={[
          'La medicina estética seria exige <strong>infraestructura real</strong> de seguridad — no solo equipos cosméticos. Estos son los recursos clínicos que CLIBEL mantiene operativos para que el manejo de cualquier escenario sea documentado y rápido.',
          'No es marketing — es lo que separa medicina estética profesional de servicio cosmético con jeringas. Pídelos en cualquier momento: te mostramos hialuronidasa, kits, dermatoscopio o expediente.',
        ]}
      />

      <ol class="infra-list">
        {infrastructure.map((item, i) => (
          <li class="infra-item">
            <span class="infra-icon" aria-hidden="true">{item.icon}</span>
            <div class="infra-body">
              <span class="infra-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="infra-title">{item.title}</h3>
              <p class="infra-text">{item.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============================ MARCAS Y CERTIFICACIONES ============================ -->
  <section class="section bg-[color:var(--color-brand-50)]">
    <div class="container-x">
      <SectionHeader
        kicker="Marcas certificadas"
        title="Productos con <em>trazabilidad</em><br/>real, no marketing."
        paragraphs={[
          '<strong>CLIBEL</strong> aplica exclusivamente productos con registro COFEPRIS vigente y lote verificable. No negociamos con productos baratos sin trazabilidad — porque en medicina estética, lo barato suele significar producto falsificado o sin garantía clínica.',
          'Te mostramos el empaque sellado, el lote y la fecha de caducidad antes de aplicar. La trazabilidad es protocolo, no upgrade premium.',
        ]}
      />

      <div class="trust-grid">
        {trust.map((t, i) => (
          <article class="trust-card">
            <span class="trust-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <span class="trust-kicker">{t.kicker}</span>
            <h3 class="trust-value">{t.value}</h3>
            <p class="trust-detail">{t.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================ COMPROMISOS DE EXPERIENCIA ============================ -->
  <section class="section bg-white" id="compromisos">
    <div class="container-x">
      <SectionHeader
        kicker="Compromisos con el paciente"
        title="Lo que <em>CLIBEL</em><br/>se compromete contigo."
        paragraphs={[
          'Estos compromisos son la experiencia del paciente <strong>CLIBEL</strong>, no la lista de productos que ofrecemos. Definen cómo te recibimos, cómo cobramos, cómo damos seguimiento y cómo manejamos los casos cuando algo no sale como esperabas.',
          'No son slogans — son protocolo escrito que la coordinadora de pacientes opera en cada agendamiento. La medicina estética seria es la que se compromete con tu experiencia integral, no solo con el procedimiento aislado.',
        ]}
      />

      <ol class="commit-list">
        {commitments.map((c, i) => (
          <li class:list={['commit-item', `commit-item--${c.weight.toLowerCase()}`]}>
            <header class="commit-head">
              <span class="commit-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <span class={`commit-weight commit-weight--${c.weight.toLowerCase()}`}>
