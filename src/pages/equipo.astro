---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import HeroNavBar from '../components/HeroNavBar.astro';
import RelatedCategories from '../components/RelatedCategories.astro';
import { SITE, CONTACT, catHref } from '../consts';

const wa = `https://wa.me/${CONTACT.whatsapp}?text=${encodeURIComponent('Hola CLIBEL, me interesa agendar valoración con el equipo médico.')}`;

// ============ EQUIPO MÉDICO ============
const team = [
  {
    initials: 'DJ',
    name: 'Dra. Jimena Reyes',
    role: 'Directora médica',
    specialty: 'Medicina estética y armonización facial',
    bio: 'Médica cirujana con especialidad en Medicina Estética y certificaciones internacionales por Merz Aesthetics y Allergan (MD Codes). Líder del equipo clínico desde 2014. Ponente regular en congresos AMWC y Congreso Mexicano de Medicina Estética. Filosofía conservadora: prefiere sub-corregir y volver, antes que sobre-corregir.',
    years: '14 años',
    certs: ['Cédula 0000000', 'Merz Aesthetics', 'MD Codes Allergan', 'Galderma GAIN'],
    treatments: [
      { label: 'Ácido Hialurónico', href: '/servicios/acido-hialuronico' },
      { label: 'Toxina Botulínica', href: '/servicios/toxina-botulinica' },
      { label: 'Hilos Tensores', href: '/servicios/hilos-tensores' },
    ],
    accent: 'mauve',
    initials_bg: ['#8B5A6B', '#C9A961'],
  },
  {
    initials: 'AM',
    name: 'Dr. Andrés Martínez',
    role: 'Medicina estética avanzada',
    specialty: 'Bioestimulación · Armonización masculina',
    bio: 'Médico estético con formación en Sculptra (Galderma), Radiesse y hilos tensores PDO/PCL. Experto en bioestimulación de colágeno y armonización masculina (definición mandibular, mentón, ángulo facial). Más de 8 años de práctica clínica en CDMX.',
    years: '8 años',
    certs: ['Cédula 0000001', 'Sculptra Certified', 'Radiesse', 'Hilos PDO/PCL'],
    treatments: [
      { label: 'Hilos Tensores', href: '/servicios/hilos-tensores' },
      { label: 'Ácido Hialurónico', href: '/servicios/acido-hialuronico' },
      { label: 'PRP', href: '/servicios/plasma-rico-plaquetas' },
    ],
    accent: 'gold',
    initials_bg: ['#5C3946', '#B8923F'],
  },
  {
    initials: 'PS',
    name: 'Dra. Paola Sánchez',
    role: 'Dermatología clínica',
    specialty: 'Dermatocosmética · Acné · Pigmentación',
    bio: 'Dermatóloga con subespecialidad en dermatocosmética. Especialista en manchas, melasma, rosácea, acné severo y planes de cuidado preventivo. Lidera el protocolo dermatocosmético de CLIBEL — incluyendo el manejo coordinado de pacientes con causa hormonal o autoinmune.',
    years: '10 años',
    certs: ['Cédula 0000002', 'Sociedad Mexicana de Dermatología', 'Diplomado en Dermatocosmética'],
    treatments: [
      { label: 'Tratamiento Antiacné', href: '/servicios/tratamiento-antiacne' },
      { label: 'Peelings Químicos', href: '/servicios/peelings-quimicos' },
      { label: 'Tricología Clínica', href: '/servicios/tricologia-clinica' },
    ],
    accent: 'rose',
    initials_bg: ['#BC8E9C', '#C9A961'],
  },
  {
    initials: 'RC',
    name: 'Lic. Renata Cordero',
    role: 'Cosmetología clínica',
    specialty: 'Faciales y corporales no médicos',
    bio: 'Licenciada en Cosmetología con certificaciones en aparatología avanzada, microneedling, peelings químicos y drenaje linfático. Responsable del área de tratamientos faciales no médicos y de la integración con los planes médicos del resto del equipo.',
    years: '7 años',
    certs: ['Microneedling certificado', 'Peelings médicos', 'Drenaje linfático Vodder', 'Aparatología avanzada'],
    treatments: [
      { label: 'Limpieza Facial Profunda', href: '/servicios/limpieza-facial-profunda' },
      { label: 'Rejuvenecimiento Facial', href: '/servicios/rejuvenecimiento-facial' },
      { label: 'Drenaje Linfático', href: '/servicios/drenaje-linfatico' },
    ],
    accent: 'gold',
    initials_bg: ['#D9BC9C', '#8B5A6B'],
  },
  {
    initials: 'MN',
    name: 'TSU Mónica Nava',
    role: 'Técnica en láser',
    specialty: 'Depilación profesional · Fototipos I–VI',
    bio: 'Técnica certificada en operación de plataformas láser (Alexandrita, Nd:YAG, Diodo). Especializada en depilación para todo tipo de piel y vello, con seguimiento personalizado por paciente y zona. Coordinación clínica directa con personal médico del equipo.',
    years: '6 años',
    certs: ['Operación láser certificada', 'Protocolos por fototipo', 'Manejo de complicaciones'],
    treatments: [
      { label: 'Depilación Láser Profesional', href: '/servicios/depilacion-laser' },
      { label: 'Láser Rostro Completo', href: '/servicios/depilacion-laser-rostro-completo' },
      { label: 'Láser Axilas e Ingle', href: '/servicios/depilacion-laser-axilas-ingle' },
    ],
    accent: 'mauve',
    initials_bg: ['#C9A961', '#5C3946'],
  },
  {
    initials: 'IA',
    name: 'Lic. Isabella Acosta',
    role: 'Coordinadora de pacientes',
    specialty: 'Atención clínica · Coordinación',
    bio: 'Tu primer punto de contacto con CLIBEL. Coordina valoraciones, agenda, seguimiento posterior a cada sesión y cualquier ajuste al plan. Conoce cada protocolo del catálogo y te orienta sin presión comercial — su trabajo es asegurar que llegues a la valoración correcta.',
    years: '5 años',
    certs: ['Atención al paciente', 'Coordinación clínica', 'Manejo de expediente digital'],
    treatments: [],
    accent: 'rose',
    initials_bg: ['#8B5A6B', '#BC8E9C'],
  },
];

// ============ FILOSOFÍA DEL EQUIPO (4 principios) ============
const principles = [
  {
    n: '01',
    title: 'Médico antes que técnico',
    text: 'Los procedimientos invasivos (ácido hialurónico, toxina, hilos, PRP) los aplica exclusivamente personal MÉDICO con cédula profesional. Los técnicos (láser, cosmetología) trabajan bajo supervisión médica directa. No improvisamos especialidad ajena.',
  },
  {
    n: '02',
    title: 'Certificación específica',
    text: 'Cada miembro del equipo tiene certificación específica en su área de aplicación — no formación genérica con curso de fin de semana. Mostramos las certificaciones a quien lo pida, en cualquier momento.',
  },
  {
    n: '03',
    title: 'Educación continua',
    text: 'Asistencia regular a congresos AMWC, IMCAS, Congreso Mexicano de Medicina Estética y entrenamientos de laboratorios (Allergan, Galderma, Merz). La medicina estética avanza rápido — el equipo se forma cada año, no descansa en el título inicial.',
  },
  {
    n: '04',
    title: 'Coordinación inter-especialidad',
    text: 'Trabajamos en red con ginecología, endocrinología, dermatología capilar y cirugía plástica cuando un caso lo requiere. CLIBEL no improvisa especialidad ajena — coordina con el especialista correspondiente.',
  },
];

// ============ QUIÉN APLICA QUÉ — MAPA POR CATEGORÍA ============
const whoApplies = [
  {
    cat: 'Faciales',
    catShort: 'Facial',
    href: catHref('facial'),
    applied: 'Personal MÉDICO + Cosmetología clínica',
    detail: 'Tratamientos no invasivos (limpieza, peelings superficiales) por cosmetóloga certificada. Peelings medios, microneedling y planes antiacné severos por dermatóloga.',
    members: ['Dra. Paola Sánchez', 'Lic. Renata Cordero'],
  },
  {
    cat: 'Corporales',
    catShort: 'Corporal',
    href: catHref('corporal'),
    applied: 'Cosmetología clínica + supervisión médica',
    detail: 'Aparatología corporal (radiofrecuencia, criolipólisis, HIFU) y técnicas manuales por cosmetóloga certificada. Valoración médica previa obligatoria para descartar contraindicaciones.',
    members: ['Lic. Renata Cordero', 'Dra. Jimena Reyes (valoración)'],
  },
  {
    cat: 'Depilación Láser',
    catShort: 'Láser',
    href: catHref('laser'),
    applied: 'Técnica certificada + supervisión médica',
    detail: 'Aplicación por técnica certificada en operación de plataformas láser. Valoración del fototipo y prueba de parche por personal médico antes del plan completo. Manejo de complicaciones por médico del equipo.',
    members: ['TSU Mónica Nava', 'Personal médico (valoración + complicaciones)'],
  },
  {
    cat: 'Medicina Estética',
    catShort: 'Medicina',
    href: catHref('medicina-estetica'),
    applied: 'Médico inyector exclusivamente',
    detail: 'Todos los inyectables (AH, toxina, PRP, hilos) los aplica MÉDICO con cédula profesional y certificación específica en medicina estética. Sin excepciones — ni técnico, ni esteticista, ni enfermera con curso corto.',
    members: ['Dra. Jimena Reyes', 'Dr. Andrés Martínez'],
  },
  {
    cat: 'Capilares',
    catShort: 'Capilar',
    href: catHref('capilar'),
    applied: 'Dermatología + médico inyector',
    detail: 'Tricología clínica y diagnóstico por dermatóloga. PRP y mesoterapia capilar por personal médico. Coordinación con dermatología capilar especializada si el caso lo requiere.',
    members: ['Dra. Paola Sánchez', 'Dra. Jimena Reyes'],
  },
];

// ============ COMPARATIVA QUIÉN TE ATIENDE ============
const comparison = [
  {
    aspect: 'Aplicación de inyectables (AH, toxina, hilos)',
    home: 'Auto-aplicación NUNCA recomendada (riesgo ceguera, necrosis)',
    spa: 'Esteticista, enfermera o técnico con curso corto',
    clibel: 'Médico inyector con cédula profesional + certificación específica',
  },
  {
    aspect: 'Operación de equipos láser',
    home: 'Dispositivos IPL caseros sin penetración real',
    spa: 'Técnico con curso corto sin valoración previa',
    clibel: 'Técnica certificada + valoración médica previa + prueba de parche',
  },
  {
    aspect: 'Valoración médica previa',
    home: 'Auto-evaluación',
    spa: 'Charla comercial sin diagnóstico',
    clibel: 'Diagnóstico clínico documentado por personal médico antes de cualquier plan',
  },
  {
    aspect: 'Coordinación inter-especialidad',
    home: '—',
    spa: 'Sin red clínica',
    clibel: 'Derivación a ginecología, endocrinología, dermatología capilar o cirugía cuando aplica',
  },
  {
    aspect: 'Manejo de complicaciones',
    home: '—',
    spa: 'Derivación a urgencias externas',
    clibel: 'Protocolo escrito + hialuronidasa/apraclonidina disponibles + médico capacitado',
  },
  {
    aspect: 'Educación continua del personal',
    home: '—',
    spa: 'Frecuentemente personal sin formación reciente',
    clibel: 'Asistencia regular a congresos AMWC, IMCAS, entrenamientos de laboratorios',
  },
  {
    aspect: 'Cédula y certificaciones visibles',
    home: '—',
    spa: 'No suele mostrar credenciales',
    clibel: 'Cédula profesional visible · certificaciones documentadas por solicitud',
  },
];

// ============ FAQs DEL EQUIPO ============
const faqs: { q: string; answerHtml: string }[] = [
  {
    q: '¿Puedo pedir credenciales antes de mi sesión?',
    answerHtml: 'Sí, y CLIBEL lo recomienda activamente. La cédula profesional es pública y puedes verificarla en la <a href="https://cedulaprofesional.sep.gob.mx/cedula/" target="_blank" rel="noopener">SEP</a>. Las certificaciones de laboratorios (Allergan, Galderma, Merz) están en el expediente del consultorio — pídelas en cualquier momento.',
  },
  {
    q: '¿Quién va a aplicarme el tratamiento específico que me interesa?',
    answerHtml: 'Depende del tratamiento. Inyectables (<a href="/servicios/acido-hialuronico">AH</a>, <a href="/servicios/toxina-botulinica">toxina</a>, <a href="/servicios/hilos-tensores">hilos</a>, <a href="/servicios/plasma-rico-plaquetas">PRP</a>): Dra. Jimena o Dr. Andrés. Acné, peelings, dermatocosmética: Dra. Paola. Tratamientos no médicos: Lic. Renata. Láser: TSU Mónica con supervisión médica. En valoración te decimos exactamente quién será.',
  },
  {
    q: '¿Puedo elegir con quién quiero tratarme?',
    answerHtml: 'Sí, dentro de la especialidad. Si tu tratamiento es facial dermatocosmético, lo hará la Dra. Paola; si es inyectable, lo elegirás entre Dra. Jimena o Dr. Andrés. No mezclamos especialidades — pero sí respetamos tu preferencia dentro de la especialidad correcta.',
  },
  {
    q: '¿El equipo se mantiene actualizado?',
    answerHtml: 'Sí, es parte del estándar. Asistimos regularmente a AMWC (Aesthetic & Anti-aging World Congress en Mónaco), IMCAS, Congreso Mexicano de Medicina Estética y entrenamientos específicos de laboratorios (Merz, Allergan, Galderma). La medicina estética avanza rápido — descansar en el título inicial no es opción.',
  },
  {
    q: '¿Qué pasa si tengo una complicación post-procedimiento?',
    answerHtml: 'Tienes acceso directo a tu médico vía WhatsApp clínico (no atención telefónica genérica). Hay protocolo escrito para cada complicación posible: hialuronidasa para AH, apraclonidina para ptosis palpebral, antibiótico para infecciones, derivación inmediata a dermatología o cirugía maxilofacial si la situación lo exige.',
  },
  {
    q: '¿Atienden a hombres?',
    answerHtml: 'Sí, regularmente. El Dr. Andrés se especializa en armonización masculina (definición mandibular, mentón, hilos tensores en cuello). El resto del equipo atiende hombres en todas las categorías. La depilación láser masculina (espalda, pecho, ingle) se aplica con la misma discreción que en pacientes femeninas.',
  },
  {
    q: '¿Cómo agendo una valoración?',
    answerHtml: 'Por WhatsApp clínico o el formulario de <a href="/contacto">contacto</a>. La Lic. Isabella Acosta (coordinadora de pacientes) te orienta sobre qué especialista necesitas según tu motivo de consulta. La primera valoración orientativa es <strong>sin costo</strong> y sin presión comercial.',
  },
];
---

<BaseLayout
  title="Equipo Médico Certificado · CLIBEL CDMX"
  description="Equipo médico de CLIBEL: 6 especialistas con cédula vigente, certificaciones internacionales por Allergan/Galderma/Merz, educación continua y coordinación inter-especialidad para atención clínica seria en CDMX."
>
  <!-- ============================ BREADCRUMB ============================ -->
  <Breadcrumb
    kicker="Quién te atiende · CLIBEL"
    items={[
      { label: 'Equipo médico' },
    ]}
  />

  <!-- ============================ HERO 2-col ============================ -->
  <section class="cat-hero">
    <div aria-hidden="true" class="cat-hero-bg"></div>
    <div aria-hidden="true" class="cat-hero-blob cat-hero-blob-1"></div>
    <div aria-hidden="true" class="cat-hero-blob cat-hero-blob-2"></div>
    <div aria-hidden="true" class="cat-hero-grain"></div>

    <div class="container-x relative">
      <div class="cat-hero-grid">
        <div class="cat-hero-col cat-hero-col--left fade-up">
          <span class="eyebrow-tag">
            <span class="dot" aria-hidden="true"></span>
            Equipo médico · {team.length} especialistas
          </span>

          <h1 class="cat-hero-headline">
            <span class="cat-hero-headline-line">Quien te</span>
            <span class="cat-hero-headline-line"><em>atiende</em> importa.</span>
          </h1>

          <p class="cat-hero-lede">
            Cada miembro del equipo CLIBEL tiene <strong>cédula vigente</strong>,
            certificaciones específicas de laboratorios líderes (Allergan,
            Galderma, Merz) y formación continua. La estética seria empieza
            por saber quién está detrás del procedimiento — sin esto, no
            hay medicina, hay improvisación cosmética.
          </p>

          <div class="cat-hero-trust">
            <span class="cat-hero-trust-label">Certificaciones</span>
            <div class="cat-hero-trust-list">
              <span>AMWC</span><span aria-hidden="true">·</span>
              <span>IMCAS</span><span aria-hidden="true">·</span>
              <span>Allergan</span><span aria-hidden="true">·</span>
              <span>Galderma</span><span aria-hidden="true">·</span>
              <span>Merz</span>
            </div>
          </div>
        </div>

        <div class="cat-hero-col cat-hero-col--right fade-up-delay-2">
          <span class="cat-hero-kicker">Cómo trabaja el equipo CLIBEL</span>

          <p class="cat-hero-paragraph">
            <strong>CLIBEL</strong> opera con seis especialistas distintos
            porque la medicina estética seria exige separación de
            especialidades. Los inyectables los aplica MÉDICO con cédula y
            certificación; los tratamientos no médicos los aplica
            cosmetología clínica certificada; el láser, técnica capacitada
            con supervisión médica. Cada herramienta exige formación
            específica — no improvisamos especialidad ajena.
          </p>

          <p class="cat-hero-paragraph">
            Trabajamos en <strong>red inter-especialidad</strong> con
            ginecología, endocrinología, dermatología capilar y cirugía
            plástica cuando un caso lo requiere. Si tu cuadro exceds
            nuestro alcance —alopecia cicatrizal, descolgamiento facial
            severo, hiperandrogenismo activo— te derivamos honestamente
            con especialista de confianza. La honestidad clínica es
            estándar, no extra premium.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================ HERONAVBAR ============================ -->
  <HeroNavBar
    label="Quién aplica qué"
    ariaLabel="Navegación rápida del equipo"
    variant="cream"
    links={[
      { label: 'Equipo médico',    href: '#equipo' },
      { label: 'Filosofía',        href: '#filosofia' },
      { label: 'Quién aplica qué', href: '#aplica' },
      { label: 'Comparativa',      href: '#comparativa' },
      { label: 'FAQs',             href: '#faqs' },
    ]}
    cta={{ label: 'Agendar valoración', href: '/contacto' }}
  />

  <!-- ============================ STAT STRIP CLÍNICO ============================ -->
  <section class="svc-stat-strip">
    <div class="container-x">
      <dl class="equipo-stats">
        <div>
          <dt>Especialistas</dt>
          <dd><em>{team.length}</em></dd>
        </div>
        <div>
          <dt>Años CLIBEL</dt>
          <dd><em>{new Date().getFullYear() - parseInt(SITE.founded)}</em></dd>
        </div>
        <div>
          <dt>Médicos inyectores</dt>
          <dd class="equipo-stats-text">Cédula + certificación específica</dd>
        </div>
        <div>
          <dt>Coordinación</dt>
          <dd class="equipo-stats-text">Inter-especialidad documentada</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- ============================ EQUIPO · CARDS EDITORIALES ============================ -->
  <section class="section bg-white" id="equipo">
    <div class="container-x">
      <SectionHeader
        kicker="Conoce al equipo"
        title="Seis especialistas,<br/>una <em>filosofía</em>."
        paragraphs={[
          'Cada miembro del equipo <strong>CLIBEL</strong> aporta su especialidad al plan integral. No somos un médico que hace de todo — somos seis especialistas que coordinan según el caso. Esa separación de especialidades es lo que distingue medicina estética seria de polivalencia comercial.',
          'Si tu tratamiento exige más de una especialidad (ej. <a href="/servicios/tratamiento-antiacne">antiacné hormonal</a> con manejo dermatológico + ginecológico), <strong>CLIBEL</strong> coordina el plan integrado — no te manda a tres clínicas distintas para hacer lo que se puede coordinar en una.',
        ]}
        cta={{ label: 'Agendar valoración', href: '/contacto', variant: 'primary' }}
      />

      <ol class="team-list">
        {team.map((m, i) => (
          <li class:list={['team-card', `team-card--${m.accent}`]}>
            <div class="team-card-visual"
                 style={`background: linear-gradient(135deg, ${m.initials_bg[0]}, ${m.initials_bg[1]});`}
                 aria-hidden="true">
              <span class="team-card-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="team-card-initials">{m.initials}</span>
              <span class="team-card-years">{m.years} en CLIBEL</span>
            </div>
            <div class="team-card-body">
              <header class="team-card-head">
                <span class="team-card-role">{m.role}</span>
                <h3 class="team-card-name">{m.name}</h3>
                <span class="team-card-specialty">{m.specialty}</span>
              </header>

              <p class="team-card-bio">{m.bio}</p>

              {m.treatments.length > 0 && (
                <div class="team-card-treatments">
                  <span class="team-card-treatments-label">Aplica</span>
                  <ul>
                    {m.treatments.map((t) => (
                      <li><a href={t.href}>{t.label}</a></li>
                    ))}
                  </ul>
                </div>
              )}

              <div class="team-card-certs">
                <span class="team-card-certs-label">Certificaciones</span>
                <div class="team-card-certs-list">
                  {m.certs.map((c) => (
                    <span class="team-card-cert">{c}</span>
                  ))}
                </div>
              </div>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============================ FILOSOFÍA DEL EQUIPO (4 principios) ============================ -->
  <section class="section equipo-philosophy" id="filosofia">
    <div aria-hidden="true" class="equipo-philosophy-bg"></div>

    <div class="container-x relative">
      <SectionHeader
        kicker="Filosofía clínica del equipo"
        title="Cuatro principios<br/><em>no negociables</em>."
        variant="dark"
        paragraphs={[
          'La diferencia entre un equipo serio de medicina estética y un grupo de cosméticos polivalentes no está en el discurso — está en la disciplina de aplicar estos cuatro principios <strong>siempre</strong>. <strong>CLIBEL</strong> los opera sin excepción comercial.',
          'Si un equipo te ofrece inyectables sin médico, técnicos sin certificación específica o "tratamiento integral" sin coordinación inter-especialidad, te están vendiendo polivalencia disfrazada de servicio premium.',
        ]}
      />

      <ol class="principles-list">
        {principles.map((p) => (
          <li class="principle reveal">
            <span class="principle-num" aria-hidden="true">{p.n}</span>
            <div class="principle-body">
              <h3 class="principle-title">{p.title}</h3>
              <p class="principle-text">{p.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============================ QUIÉN APLICA QUÉ — interlinking ============================ -->
  <section class="section bg-white" id="aplica">
    <div class="container-x">
      <SectionHeader
        kicker="Mapa de aplicación"
        title="Quién aplica <em>qué</em><br/>en cada categoría."
        paragraphs={[
          'Cada categoría de servicios <strong>CLIBEL</strong> tiene un perfil de profesional específico que la aplica. La separación no es burocrática — es regulatoria y clínica. Los inyectables exigen médico; los tratamientos no médicos exigen cosmetología certificada; el láser, técnica capacitada con supervisión médica.',
