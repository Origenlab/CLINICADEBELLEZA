---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CONTACT } from '../consts';
---

<BaseLayout
  title="Agenda tu Valoración"
  description="Agenda una valoración estética sin costo en CDMX. Envíanos el formulario de contacto y te respondemos a la brevedad en horario clínica."
>
  <!-- Header -->
  <section class="bg-gradient-to-br from-[color:var(--color-brand-100)] to-[color:var(--color-brand-200)]/40">
    <div class="container-x section">
      <div class="mx-auto max-w-3xl text-center">
      <span class="kicker">Contacto</span>
      <span class="divider-gold"></span>
      <h1 class="font-display text-5xl sm:text-6xl">Hablemos de tu próximo tratamiento</h1>
      <p class="mt-5 text-lg text-[color:var(--color-ink-700)]">
        Envíanos el formulario con tu caso. Te responderemos a la brevedad para agendar tu valoración.
      </p>
      </div>
    </div>
  </section>

  <!-- Grid contact -->
  <section class="section">
    <div class="container-x grid lg:grid-cols-2 gap-10">
      <!-- Form -->
      <div class="card p-8">
        <h2 class="font-display text-3xl mb-2">Envíanos un mensaje</h2>
        <p class="text-[color:var(--color-ink-500)] mb-6 text-sm">Todos los campos son obligatorios.</p>

        <form action="#" method="POST" class="space-y-4">
          <div>
            <label for="nombre" class="block text-sm font-medium mb-1">Nombre completo</label>
            <input id="nombre" name="nombre" required type="text"
              class="w-full px-4 py-3 rounded-xl border border-[color:var(--color-brand-200)] bg-[color:var(--color-brand-50)] focus:border-[color:var(--color-mauve-500)] focus:bg-white outline-none transition" />
          </div>
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="email" class="block text-sm font-medium mb-1">Correo electrónico</label>
              <input id="email" name="email" required type="email"
                class="w-full px-4 py-3 rounded-xl border border-[color:var(--color-brand-200)] bg-[color:var(--color-brand-50)] focus:border-[color:var(--color-mauve-500)] focus:bg-white outline-none transition" />
            </div>
            <div>
              <label for="tel" class="block text-sm font-medium mb-1">Teléfono</label>
              <input id="tel" name="tel" required type="tel"
                class="w-full px-4 py-3 rounded-xl border border-[color:var(--color-brand-200)] bg-[color:var(--color-brand-50)] focus:border-[color:var(--color-mauve-500)] focus:bg-white outline-none transition" />
            </div>
          </div>
          <div>
            <label for="servicio" class="block text-sm font-medium mb-1">Tratamiento de interés</label>
            <select id="servicio" name="servicio"
              class="w-full px-4 py-3 rounded-xl border border-[color:var(--color-brand-200)] bg-[color:var(--color-brand-50)] focus:border-[color:var(--color-mauve-500)] focus:bg-white outline-none transition">
              <option>Tratamientos faciales</option>
              <option>Tratamientos corporales</option>
              <option>Depilación láser</option>
              <option>Medicina estética</option>
              <option>Tratamientos capilares</option>
              <option>Otro / no estoy segura</option>
            </select>
          </div>
          <div>
            <label for="mensaje" class="block text-sm font-medium mb-1">Mensaje</label>
            <textarea id="mensaje" name="mensaje" required rows="4"
              class="w-full px-4 py-3 rounded-xl border border-[color:var(--color-brand-200)] bg-[color:var(--color-brand-50)] focus:border-[color:var(--color-mauve-500)] focus:bg-white outline-none transition"></textarea>
          </div>
          <label class="flex items-start gap-2 text-xs text-[color:var(--color-ink-500)]">
            <input required type="checkbox" class="mt-1" />
            <span>Acepto el <a href="/aviso-de-privacidad" class="text-[color:var(--color-mauve-500)] underline">Aviso de Privacidad</a> y autorizo el contacto.</span>
          </label>
          <button type="submit" class="btn btn-primary w-full">Enviar mensaje</button>
        </form>
      </div>

      <!-- Info -->
      <div class="space-y-6">
        <div class="card p-7">
          <h3 class="font-display text-2xl mb-4">Información directa</h3>
          <ul class="space-y-4 text-sm">
            <li class="flex items-start gap-3">
              <span class="w-10 h-10 grid place-items-center rounded-full bg-[color:var(--color-brand-100)] text-[color:var(--color-mauve-500)] shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </span>
              <div>
                <p class="text-xs uppercase tracking-wider text-[color:var(--color-ink-500)]">Dirección</p>
                <p class="font-medium">{CONTACT.addressFull}</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-10 h-10 grid place-items-center rounded-full bg-[color:var(--color-brand-100)] text-[color:var(--color-mauve-500)] shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </span>
              <div>
                <p class="text-xs uppercase tracking-wider text-[color:var(--color-ink-500)]">Horario</p>
                <p class="font-medium">{CONTACT.hours}</p>
              </div>
            </li>
          </ul>

          <p class="mt-6 pt-5 border-t border-[color:var(--color-brand-200)] text-sm text-[color:var(--color-ink-500)]">
            La forma más rápida de agendar es el formulario de esta página: cuéntanos tu caso y te respondemos a la brevedad en horario clínica.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
