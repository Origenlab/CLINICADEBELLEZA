---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import PartnersMarquee from '../components/PartnersMarquee.astro';

const techs = [
  {
    cat: 'Diagnóstico',
    name: 'Análisis facial digital',
    text: 'Sistema de medición de arrugas, manchas, textura, hidratación, poros y elasticidad. Comparativos antes/después documentados en tu expediente.',
    benefits: ['Diagnóstico objetivo', 'Comparativos visibles', 'Personalización extrema'],
  },
  {
    cat: 'Facial / Corporal',
    name: 'Radiofrecuencia multipolar',
    text: 'Estimula la producción natural de colágeno y elastina con calor controlado en capas profundas. Ideal para flacidez facial, papada, abdomen, brazos y glúteos.',
    benefits: ['Sin agujas', 'Resultados progresivos', 'Sin tiempo de recuperación'],
  },
  {
    cat: 'Facial',
    name: 'Microneedling profesional',
    text: 'Microagujas que inducen regeneración cutánea. Mejora textura, cicatrices superficiales, poros y combinable con PRP o factores de crecimiento.',
    benefits: ['Mejora cicatrices', 'Estimula colágeno', 'Apto para todo fototipo'],
  },
  {
    cat: 'Láser',
    name: 'Depilación láser de última generación',
    text: 'Plataforma adaptable a diferentes tipos de piel y vello, con sistema de enfriamiento integrado para sesiones más cómodas y resultados visibles desde la 2ª sesión.',
    benefits: ['Apto pieles oscuras', 'Casi indoloro', 'Eficacia 80-95%'],
  },
  {
    cat: 'Facial',
    name: 'Peelings químicos médicos',
    text: 'Soluciones de AHA, BHA y TCA en concentraciones controladas. Renovación cutánea para manchas, melasma, cicatrices y textura irregular.',
    benefits: ['Distintas profundidades', 'Protocolo personalizado', 'Resultados visibles'],
  },
  {
    cat: 'Corporal',
    name: 'Cavitación + criolipólisis',
    text: 'Tecnología combinada para reducción de grasa localizada sin cirugía. Especialmente útil en abdomen, flancos, espalda y muslos.',
    benefits: ['No invasivo', 'Sin anestesia', 'Resultados desde 3ª sesión'],
  },
  {
    cat: 'Capilar',
    name: 'Mesoterapia capilar',
    text: 'Aplicación de vitaminas, péptidos y bioactivos directo en cuero cabelludo. Estímulo folicular para densidad y fortaleza capilar.',
    benefits: ['Combinable con PRP', 'Mínimas molestias', 'Plan 6-8 sesiones'],
  },
  {
    cat: 'Medicina estética',
    name: 'Bioestimuladores de colágeno',
    text: 'Sculptra (ácido poli-L-láctico) y Radiesse (hidroxiapatita de calcio). Resultados naturales y progresivos en flacidez y volumen.',
    benefits: ['Resultados de 2 años+', 'Naturalidad', 'Indicado a partir de 35 años'],
  },
];

const certs = [
  { label: 'COFEPRIS', text: 'Permisos vigentes para publicidad y operación clínica.' },
  { label: 'Productos originales', text: 'Compra directa a laboratorios autorizados. Trazabilidad completa de lote.' },
  { label: 'Médicos certificados', text: 'Cédula profesional y certificación de cada laboratorio (Allergan, Galderma, Merz, Sinclair).' },
  { label: 'Expediente digital', text: 'Cada procedimiento, dosis, lote y profesional documentado en tu historial.' },
];
---

<BaseLayout
  title="Tecnología y Equipos Médicos"
  description="Radiofrecuencia, láser de última generación, microneedling, criolipólisis y bioestimuladores. Equipos certificados COFEPRIS de marcas internacionales."
>
  <!-- Hero -->
  <section class="gradient-soft relative overflow-hidden">
    <div aria-hidden="true" class="absolute top-0 right-0 w-[40rem] h-[40rem] rounded-full bg-[color:var(--color-brand-300)]/30 blur-3xl pointer-events-none"></div>
    <div class="container-x relative section">
      <span class="kicker-line">Tecnología CLIBEL</span>
      <h1 class="mt-4 h-display text-5xl sm:text-6xl lg:text-7xl max-w-4xl">
        Equipos clínicos de <em>marcas reconocidas</em>,<br/>
        operados por <span class="text-gradient">profesionales certificados.</span>
      </h1>
      <p class="mt-6 text-lg text-[color:var(--color-ink-700)] max-w-2xl leading-relaxed">
        El equipo correcto en manos del especialista correcto. Trabajamos con plataformas
        de referencia internacional y mantenemos formación continua para garantizar
        protocolos seguros y resultados duraderos.
      </p>
    </div>
  </section>

  <PartnersMarquee />

  <!-- Tech grid -->
  <section class="section bg-white">
    <div class="container-x">
      <div class="max-w-2xl mb-12 reveal">
        <span class="kicker-line">Catálogo técnico</span>
        <h2 class="mt-4 h-display text-4xl sm:text-5xl">8 plataformas, un solo lugar</h2>
        <p class="mt-4 text-[color:var(--color-ink-500)] leading-relaxed">
          Centralizamos diagnóstico, tratamiento y seguimiento bajo el mismo techo, con
          tecnologías que se complementan en cada protocolo personalizado.
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {techs.map((t) => (
          <article class="card p-7 h-full flex flex-col reveal">
            <span class="text-[10px] uppercase tracking-[0.18em] text-[color:var(--color-brand-500)] font-semibold">{t.cat}</span>
            <h3 class="font-display text-xl mt-2 mb-3 leading-tight">{t.name}</h3>
            <p class="text-sm text-[color:var(--color-ink-500)] leading-relaxed mb-5 flex-1">{t.text}</p>
            <ul class="space-y-1.5 pt-4 border-t border-[color:var(--color-brand-200)]">
              {t.benefits.map((b) => (
                <li class="flex items-start gap-1.5 text-xs text-[color:var(--color-ink-700)]">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="mt-0.5 shrink-0 text-[color:var(--color-brand-500)]"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Certs -->
  <section class="section bg-[color:var(--color-brand-50)]">
    <div class="container-x">
      <div class="grid lg:grid-cols-[1fr_1fr] gap-10 items-center">
        <div class="reveal">
          <span class="kicker-line">Garantías clínicas</span>
          <h2 class="mt-4 h-display text-4xl sm:text-5xl">
            Calidad <em>verificable</em>,<br/>no prometida.
          </h2>
          <p class="mt-5 text-[color:var(--color-ink-500)] leading-relaxed">
            En estética el riesgo no es solo cosmético, es clínico. Por eso documentamos
            todo lo que entra en tu cuerpo: marca, lote, dosis, fecha y profesional
            responsable. Si nos lo pides, te entregamos copia.
          </p>
        </div>
        <div class="grid sm:grid-cols-2 gap-5 reveal">
          {certs.map(c => (
            <div class="card p-6 h-full">
              <p class="font-display text-2xl text-[color:var(--color-mauve-500)] mb-2">{c.label}</p>
              <p class="text-sm text-[color:var(--color-ink-500)] leading-relaxed">{c.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTA
    title="¿Quieres conocer nuestra clínica?"
    subtitle="Agenda una visita y conoce nuestros equipos, instalaciones y al equipo médico que estaría a cargo de tu plan."
  />
</BaseLayout>
