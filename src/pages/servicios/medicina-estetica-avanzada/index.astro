  <script is:inline define:vars={{ waBase: `https://wa.me/${CONTACT.whatsapp}` }}>
    (function () {
      const form = document.getElementById('medWaForm');
      if (!form) return;
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const d = new FormData(form);
        const g = (k) => (d.get(k) || '').toString().trim();
        const nombre = g('nombre'), tel = g('telefono'), email = g('email');
        const interes = g('interes'), zona = g('zona'), msg = g('mensaje');
        const acepto = form.querySelector('[name="privacidad"]').checked;
        if (!nombre || !tel || !acepto) { form.classList.add('is-invalid'); return; }
        form.classList.remove('is-invalid');
        const lines = [
          'Hola CLIBEL, vengo desde la página de Medicina Estética Avanzada.',
          '',
          'Nombre: ' + nombre,
          'Teléfono: ' + tel,
        ];
        if (email)   lines.push('Email: ' + email);
        if (interes) lines.push('Me interesa: ' + interes);
        if (zona)    lines.push('Zona / objetivo: ' + zona);
        if (msg)     lines.push('', 'Comentario: ' + msg);
        window.open(waBase + '?text=' + encodeURIComponent(lines.join('\n')), '_blank', 'noopener');
      });
    })();
  </script>

