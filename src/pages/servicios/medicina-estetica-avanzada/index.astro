    font-size: clamp(1.2rem, 1.4vw, 1.4rem);
    color: var(--color-ink-900);
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.015em;
  }
  .dur-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem 1.5rem;
    padding-block: 0.5rem;
    border-block: 1px dashed rgba(201, 169, 97, 0.3);
  }
  .dur-meta-item { display: flex; flex-direction: column; gap: 0.15rem; }
  .dur-meta-label {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-brand-500);
  }
  .dur-meta-value {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--color-ink-900);
    letter-spacing: -0.005em;
  }
  .dur-rev {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.18rem 0.5rem;
    border-radius: 999px;
  }
  .dur-rev--yes {
    background: rgba(46, 125, 50, 0.12);
    color: #2e7d32;
    border: 1px solid rgba(46, 125, 50, 0.3);
  }
  .dur-rev--partial {
    background: rgba(201, 169, 97, 0.15);
    color: var(--color-brand-600);
    border: 1px solid rgba(201, 169, 97, 0.4);
  }
  .dur-rev--no {
    background: rgba(139, 90, 107, 0.12);
    color: var(--color-mauve-700);
    border: 1px solid rgba(139, 90, 107, 0.3);
  }
  .dur-detail {
    margin: 0;
    font-size: 0.83rem;
    line-height: 1.55;
    color: var(--color-ink-500);
    font-style: italic;
  }

  /* ============= Protocolos (dark) ============= */
  .svc-protocols {
    background: var(--color-ink-900);
    color: var(--color-brand-100);
    position: relative;
    isolation: isolate;
  }
  .protocol-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 900px) {
    .protocol-grid { grid-template-columns: 1fr 1fr; gap: 1.75rem; }
  }
  .protocol {
    padding: clamp(1.5rem, 2vw, 2rem);
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1.25rem;
    transition: all 0.4s ease !important;
  }
  .protocol:hover {
    background: rgba(255,255,255,0.055);
    border-color: rgba(201, 169, 97, 0.45);
    transform: translateY(-4px);
  }
  .protocol-head { display: flex; align-items: baseline; gap: 0.9rem; margin-bottom: 1.25rem; }
  .protocol-tag {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
  }
  .protocol-tag--pre {
    background: rgba(201, 169, 97, 0.15);
    color: var(--color-brand-400);
    border: 1px solid rgba(201, 169, 97, 0.4);
  }
  .protocol-tag--post {
    background: rgba(139, 90, 107, 0.2);
    color: var(--color-mauve-300);
    border: 1px solid rgba(188, 142, 156, 0.45);
  }
  .protocol-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.4rem, 1.8vw, 1.75rem);
    color: white;
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.015em;
  }
  .protocol-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .protocol-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding-block: 0.65rem;
    border-top: 1px dashed rgba(201, 169, 97, 0.18);
    font-size: 0.92rem;
    line-height: 1.5;
    color: rgba(242, 235, 223, 0.85);
  }
  .protocol-list li:first-child { border-top: 0; padding-top: 0; }
  .protocol-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 0.95rem;
    color: var(--color-brand-400);
    line-height: 1.45;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    min-width: 24px;
  }

  /* ============= FAQ + Form ============= */
  .faq-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 3vw, 2.75rem);
    align-items: start;
  }
  @media (min-width: 1024px) {
    .faq-grid { grid-template-columns: 1.15fr 0.85fr; gap: clamp(2.5rem, 4vw, 3.5rem); }
  }
  .faq-col-label {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-brand-500);
    margin-bottom: 1.1rem;
  }
  .faq-list { display: flex; flex-direction: column; gap: 0.6rem; }
  .faq {
    background: var(--color-brand-50);
    border: 1px solid rgba(201, 169, 97, 0.22);
    border-radius: 1rem;
    overflow: hidden;
    transition: border-color 0.3s ease, background 0.3s ease !important;
  }
  .faq[open] { background: white; border-color: var(--color-mauve-500); }
  .faq-sum {
    list-style: none;
    cursor: pointer;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1rem;
    align-items: center;
    padding: 1.1rem 1.25rem;
  }
  .faq-sum::-webkit-details-marker { display: none; }
  .faq-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1rem;
    color: var(--color-brand-500);
    letter-spacing: 0.04em;
    line-height: 1;
    opacity: 0.8;
    min-width: 24px;
  }
  .faq-q {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1rem, 1.1vw, 1.12rem);
    color: var(--color-ink-900);
    line-height: 1.3;
    letter-spacing: -0.005em;
  }
  .faq-plus {
    width: 32px; height: 32px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: var(--color-brand-100);
    color: var(--color-mauve-500);
    transition: transform 0.35s cubic-bezier(.2,.8,.2,1), background 0.3s ease, color 0.3s ease !important;
  }
  .faq[open] .faq-plus {
    transform: rotate(45deg);
    background: var(--color-mauve-500);
    color: white;
  }
  .faq-a {
    padding: 0 1.25rem 1.25rem clamp(3.5rem, 6vw, 4rem);
    font-size: 0.92rem;
    line-height: 1.65;
    color: var(--color-ink-700);
  }

  /* Form WhatsApp */
  .faq-form-wrap { position: relative; }
  @media (min-width: 1024px) { .faq-form-wrap { position: sticky; top: clamp(6rem, 10vh, 7.5rem); } }
  .faq-form {
    background: linear-gradient(180deg, #FFFFFF 0%, var(--color-brand-50) 100%);
    border: 1px solid rgba(201, 169, 97, 0.3);
    border-radius: 1.25rem;
    padding: clamp(1.5rem, 2vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 0.95rem;
    box-shadow:
      0 1px 2px rgba(31, 20, 24, 0.03),
      0 24px 56px -28px rgba(31, 20, 24, 0.18);
  }
  .faq-form-kicker {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mauve-500);
  }
  .faq-form-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.45rem, 2vw, 1.85rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-ink-900);
    margin: 0;
  }
  .faq-form-title em { font-style: italic; color: var(--color-mauve-500); font-weight: 400; }
  .faq-form-sub {
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--color-ink-500);
    margin: 0 0 0.5rem;
  }
  .faq-form-sub strong { color: var(--color-ink-900); font-weight: 600; }
  .faq-form-row { display: flex; flex-direction: column; gap: 0.32rem; }
  .faq-form-grid-2 {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
  }
  @media (min-width: 520px) { .faq-form-grid-2 { grid-template-columns: 1fr 1fr; } }
  .faq-form-row label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-ink-700);
    letter-spacing: 0.02em;
  }
  .faq-form-row label span[aria-hidden] { color: var(--color-mauve-500); margin-left: 2px; }
  .faq-form input,
  .faq-form select,
  .faq-form textarea {
    width: 100%;
    padding: 0.7rem 0.9rem;
    font-family: var(--font-sans);
    font-size: 0.92rem;
    color: var(--color-ink-900);
    background: white;
    border: 1px solid rgba(201, 169, 97, 0.35);
    border-radius: 0.65rem;
    outline: none;
    transition: border-color 0.25s ease, box-shadow 0.25s ease, background 0.25s ease !important;
    appearance: none;
    line-height: 1.4;
  }
  .faq-form select {
    background-image:
      linear-gradient(45deg, transparent 50%, var(--color-mauve-500) 50%),
      linear-gradient(135deg, var(--color-mauve-500) 50%, transparent 50%);
    background-position: calc(100% - 18px) calc(50% - 2px), calc(100% - 13px) calc(50% - 2px);
    background-size: 5px 5px;
    background-repeat: no-repeat;
    padding-right: 2rem;
    cursor: pointer;
  }
  .faq-form textarea { resize: vertical; min-height: 80px; }
  .faq-form input:focus,
  .faq-form select:focus,
  .faq-form textarea:focus {
    border-color: var(--color-mauve-500);
    box-shadow: 0 0 0 3px rgba(139, 90, 107, 0.12);
    background: var(--color-brand-50);
  }
  .faq-form.is-invalid input:required:invalid { border-color: #c62b3e; }
  .faq-form-check {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    margin-top: 0.25rem;
    font-size: 0.78rem;
    line-height: 1.45;
    color: var(--color-ink-500);
    cursor: pointer;
  }
  .faq-form-check input[type="checkbox"] {
    width: 16px;
    height: 16px;
    margin-top: 2px;
    accent-color: var(--color-mauve-500);
    flex-shrink: 0;
    cursor: pointer;
  }
  .faq-form-check a { color: var(--color-mauve-500); text-decoration: underline; text-underline-offset: 2px; }
  .faq-form-check a:hover { color: var(--color-mauve-700); }
  .faq-form-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    padding: 0.95rem 1.25rem;
    margin-top: 0.5rem;
    background: #25D366;
    color: white;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.01em;
    border: 0;
    border-radius: 999px;
    cursor: pointer;
    box-shadow:
      0 10px 24px -10px rgba(37, 211, 102, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.25);
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease !important;
  }
  .faq-form-submit:hover {
    background: #1FB855;
    transform: translateY(-2px);
    box-shadow:
      0 16px 32px -10px rgba(37, 211, 102, 0.7),
      inset 0 1px 0 rgba(255, 255, 255, 0.3);
  }
  .faq-form-foot {
    margin: 0;
    text-align: center;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-500);
    opacity: 0.85;
  }
  @media (max-width: 640px) { .faq-form { padding: 1.25rem; } }

  /* ============= Hero links inline ============= */
  .cat-hero-paragraph a {
    color: var(--color-mauve-500);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: color 0.25s ease !important;
  }
  .cat-hero-paragraph a:hover { color: var(--color-mauve-700); }
  .cat-hero-paragraph a strong { color: inherit; font-weight: 600; }

  /* ============= FAQ links inline ============= */
  .faq-a a {
    color: var(--color-mauve-500);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    font-weight: 500;
  }
  .faq-a a:hover { color: var(--color-mauve-700); }

  /* ============= STAT STRIP CLÍNICO ============= */
  .svc-stat-strip {
    background: var(--color-brand-50);
    padding-block: clamp(2rem, 3.5vw, 3rem);
    border-bottom: 1px solid rgba(201, 169, 97, 0.22);
  }
  .medest-stats {
    margin: 0; padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }
  @media (min-width: 720px) { .medest-stats { grid-template-columns: repeat(4, 1fr); } }
  .medest-stats > div {
    padding: 1rem 1.25rem;
    border-right: 1px solid rgba(201, 169, 97, 0.22);
    border-bottom: 1px solid rgba(201, 169, 97, 0.22);
  }
  .medest-stats > div:first-child { padding-left: 0; }
  @media (min-width: 720px) {
    .medest-stats > div { border-bottom: 0; }
    .medest-stats > div:last-child { border-right: 0; }
  }
  @media (max-width: 719px) {
    .medest-stats > div:nth-child(2n) { border-right: 0; }
    .medest-stats > div:nth-last-child(-n+2) { border-bottom: 0; }
  }
  .medest-stats dt {
    font-family: var(--font-sans);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mauve-500);
    margin-bottom: 0.4rem;
  }
  .medest-stats dd {
    margin: 0;
    font-family: var(--font-display);
    line-height: 1;
    color: var(--color-ink-900);
    letter-spacing: -0.02em;
    display: flex;
    align-items: baseline;
    gap: 0.15rem;
    flex-wrap: wrap;
  }
  .medest-stats dd em {
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2.2rem, 3.5vw, 3.25rem);
    background: linear-gradient(180deg, var(--color-brand-500), var(--color-mauve-700));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .medest-stats-list {
    font-family: var(--font-display) !important;
    font-style: italic;
    font-size: 0.75rem !important;
    color: var(--color-ink-500) !important;
    margin-left: 0.45rem;
    line-height: 1.3;
  }
  .medest-stats .medest-stats-text {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(0.9rem, 1vw, 1.05rem);
    line-height: 1.25;
    color: var(--color-ink-900);
    letter-spacing: -0.005em;
  }

  /* ============= PROFUNDIZA — editorial spotlight ============= */
  .spot-list {
    list-style: none;
    padding: 0;
    margin: clamp(2rem, 3vw, 2.75rem) 0 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .spot {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    padding-block: clamp(2rem, 3vw, 2.75rem);
    border-top: 1px solid rgba(201, 169, 97, 0.32);
    align-items: start;
  }
  .spot:first-child { border-top: 0; padding-top: 0; }
  .spot:last-child { padding-bottom: 0; }
  @media (min-width: 820px) {
    .spot { grid-template-columns: clamp(80px, 11vw, 130px) 1fr; gap: clamp(1.5rem, 3vw, 3rem); }
  }
  .spot-num-wrap { display: flex; align-items: baseline; gap: 0.85rem; }
  @media (min-width: 820px) {
    .spot-num-wrap { flex-direction: column; align-items: flex-start; gap: 0.75rem; padding-top: 0.3rem; }
  }
  .spot-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(3rem, 5vw, 4.5rem);
    line-height: 0.85;
    background: linear-gradient(180deg, var(--color-brand-500), var(--color-mauve-500));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.02em;
  }
  .spot-num-line {
    width: 32px;
    height: 1.5px;
    background: linear-gradient(90deg, var(--color-brand-400), var(--color-mauve-500));
    border-radius: 2px;
  }
  @media (max-width: 819px) { .spot-num-line { display: none; } }
  .spot-body { display: flex; flex-direction: column; gap: 1rem; min-width: 0; }
  .spot-head { display: flex; flex-direction: column; gap: 0.5rem; }
  .spot-kicker {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mauve-500);
  }
  .spot-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.75rem, 2.6vw, 2.4rem);
    line-height: 1.08;
    letter-spacing: -0.022em;
    color: var(--color-ink-900);
    margin: 0;
    max-width: 26ch;
  }
  .spot-title a {
    color: inherit;
    text-decoration: none;
    background-image: linear-gradient(90deg, var(--color-brand-400), var(--color-mauve-500));
    background-repeat: no-repeat;
    background-size: 0 2px;
    background-position: 0 100%;
    transition: background-size 0.4s cubic-bezier(.2,.8,.2,1) !important;
    padding-bottom: 2px;
  }
  .spot-title a:hover { background-size: 100% 2px; }
  .spot-meta {
    margin: 0;
    padding: 0.85rem 0;
    border-block: 1px dashed rgba(201, 169, 97, 0.3);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }
  @media (min-width: 700px) { .spot-meta { grid-template-columns: repeat(4, 1fr); } }
  .spot-meta > div { padding: 0; }
  .spot-meta > div + div {
    padding-left: clamp(0.75rem, 1.5vw, 1.25rem);
    border-left: 1px dashed rgba(201, 169, 97, 0.3);
  }
  .spot-meta dt {
    font-family: var(--font-sans);
    font-size: 0.56rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-brand-500);
    margin-bottom: 0.25rem;
  }
  .spot-meta dd {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(0.92rem, 1vw, 1.05rem);
    line-height: 1.2;
    color: var(--color-ink-900);
    letter-spacing: -0.005em;
  }
  .spot-lede {
    margin: 0;
    font-size: clamp(0.98rem, 1.05vw, 1.1rem);
    line-height: 1.7;
    color: var(--color-ink-700);
    max-width: 68ch;
  }
  .spot-benefits {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: 1fr; gap: 0.45rem;
  }
  @media (min-width: 700px) { .spot-benefits { grid-template-columns: 1fr 1fr; gap: 0.65rem 1.5rem; } }
  .spot-benefits li {
    display: flex; align-items: flex-start; gap: 0.6rem;
    font-size: 0.92rem; line-height: 1.5;
    color: var(--color-ink-700);
  }
  .spot-benefits li svg { flex-shrink: 0; margin-top: 4px; color: var(--color-brand-500); }
  .spot-actions { display: flex; flex-wrap: wrap; gap: 0.85rem; align-items: center; padding-top: 0.5rem; }
  .spot-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.2rem;
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(.2,.8,.2,1) !important;
    border: 1.5px solid transparent;
  }
  .spot-cta--primary { background: var(--color-ink-900); color: var(--color-brand-50); }
  .spot-cta--primary:hover {
    background: var(--color-mauve-700);
    transform: translateY(-2px);
    box-shadow: 0 10px 22px -10px rgba(31, 20, 24, 0.4);
  }
  .spot-cta--primary svg { transition: transform 0.25s ease !important; }
  .spot-cta--primary:hover svg { transform: translateX(3px); }
  .spot-cta--wa {
    background: rgba(37, 211, 102, 0.1);
    color: #1B7A3F;
    border: 1.5px solid rgba(37, 211, 102, 0.35);
  }
  .spot-cta--wa:hover {
    background: #25D366;
    color: white;
    border-color: #25D366;
    transform: translateY(-2px);
  }

  /* ============= PULL-QUOTE EDITORIAL ============= */
  .svc-pullquote {
    background: white;
    padding-block: clamp(3rem, 5vw, 5rem);
    border-block: 1px solid rgba(201, 169, 97, 0.22);
  }
  .medest-quote {
    position: relative;
