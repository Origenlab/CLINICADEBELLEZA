---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import HeroNavBar from '../../../components/HeroNavBar.astro';
import RelatedCategories from '../../../components/RelatedCategories.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, SITE, CONTACT, catHref } from '../../../consts';

const cat = CATEGORIES['medicina-estetica'];

const all = await getCollection('servicios');
const items = all
  .filter((s) => s.data.category === 'medicina-estetica')
  .sort((a, b) => a.data.order - b.data.order);

const wa = `https://wa.me/${CONTACT.whatsapp}?text=${encodeURIComponent('Hola, me gustaría agendar una valoración de medicina estética avanzada en CLIBEL.')}`;

// ============ SCHEMAS SEO ============
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Servicios', item: `${SITE.url}/servicios` },
    { '@type': 'ListItem', position: 3, name: 'Medicina Estética Avanzada', item: `${SITE.url}/servicios/medicina-estetica-avanzada` },
  ],
};
const catalogSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalSpecialty',
  name: 'Medicina Estética Avanzada — CLIBEL',
  description: 'Ácido hialurónico, toxina botulínica, plasma rico en plaquetas e hilos tensores con médicos certificados en CDMX.',
  url: `${SITE.url}/servicios/medicina-estetica-avanzada`,
  provider: { '@id': `${SITE.url}/#clinic` },
  relevantSpecialty: ['CosmeticDermatology', 'PlasticSurgery'],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Catálogo de medicina estética CLIBEL',
    itemListElement: items.map((s) => ({
      '@type': 'MedicalProcedure',
      name: s.data.title,
      description: s.data.description,
      url: `${SITE.url}/servicios/${s.id}`,
    })),
  },
};

// ============ Editorial leds por L4 (humanizados · sección Profundiza) ============
const editorialLedes: Record<string, { lede: string; readMore: string }> = {
  'acido-hialuronico': {
    lede: 'La herramienta más versátil de la medicina estética facial y la más malinterpretada. CLIBEL aplica con criterio anatómico, marcas certificadas (Juvéderm, Restylane, Belotero, Teosyal) y hialuronidasa disponible en cabina — la reversibilidad es el estándar mínimo, no extra premium.',
    readMore: 'Ver protocolo AH completo',
  },
  'toxina-botulinica': {
    lede: 'El inyectable más vendido y más responsable de los resultados artificiales que han contaminado la percepción de la medicina estética. CLIBEL aplica con filosofía expresión conservada — suavizar líneas dinámicas sin congelar el rostro, dosis precisas por punto anatómico.',
    readMore: 'Ver protocolo toxina',
  },
  'plasma-rico-plaquetas': {
    lede: 'El único inyectable que NO puede causar reacción alérgica ni rechazo: viene de tu propia sangre. CLIBEL procesa en cabina con kit estéril certificado (Regen Lab, Arthrex, Ycellbio) y aplica los factores de crecimiento autólogos. Biología regenerativa paciente.',
    readMore: 'Ver protocolo PRP',
  },
  'hilos-tensores': {
    lede: 'El procedimiento más cercano al lifting quirúrgico — pero solo cuando el descolgamiento es leve a moderado. CLIBEL deriva a cirugía honesto cuando el caso lo amerita y aplica hilos solo donde funcionan. Aptos, Mint, Silhouette Soft, NovaThreads.',
    readMore: 'Ver protocolo hilos',
  },
};

// ============ Comparativa clínica especialidad ============
const specialtyComparison: { aspect: string; spa?: string; cosmetica?: string; clibel: string }[] = [
  {
    aspect: 'Quién aplica',
    cosmetica: 'Centro estético sin médico inyector',
    spa: 'Enfermera o técnico con curso corto',
    clibel: 'Médico inyector con cédula profesional + certificación específica en medicina estética',
  },
  {
    aspect: 'Productos utilizados',
    cosmetica: 'Sin marca o con falsificaciones',
    spa: 'Productos sin trazabilidad de lote',
    clibel: 'Solo Allergan, Galderma, Merz, Sinclair, Teoxane con lote COFEPRIS visible',
  },
  {
    aspect: 'Reversibilidad disponible',
    cosmetica: '—',
    spa: 'Sin hialuronidasa en cabina',
    clibel: 'Hialuronidasa disponible inmediatamente para revertir AH en 24–72 h',
  },
  {
    aspect: 'Manejo de complicaciones',
    cosmetica: 'Sin protocolo',
    spa: 'Derivación a clínica externa',
    clibel: 'Protocolo escrito + apraclonidina + coordinación con dermatología/cirugía maxilofacial',
  },
  {
    aspect: 'Documentación clínica',
    cosmetica: 'Sin expediente',
    spa: 'Sin foto basal ni seguimiento',
    clibel: 'Foto multi-ángulo basal + cita revisión 14 días + expediente digital con lote producto',
  },
  {
    aspect: 'Filosofía de aplicación',
    cosmetica: 'Cantidad para maximizar ticket',
    spa: 'Dosis maximalistas "efecto wow"',
    clibel: 'Conservadora · dosis bajas · revisión 14 días sin costo · ajuste sin costo adicional',
  },
  {
    aspect: 'Honestidad sobre indicación',
    cosmetica: 'Vende todo a todos',
    spa: 'Aplica donde le pidan',
    clibel: 'Deriva a cirugía si caso lo amerita · declina si expectativa no es realista',
  },
];

// ============ FILOSOFÍA CLIBEL (NUEVO) ============
const principles = [
  {
    n: '01',
    title: 'Análisis facial primero',
    text: 'CLIBEL nunca aplica un procedimiento sin estudiar primero la arquitectura facial completa. Analizamos tercios faciales, simetría, proyección, soporte óseo y dinámica muscular antes de tocar la jeringa.',
  },
  {
    n: '02',
    title: 'Conservadurismo clínico',
    text: 'En CLIBEL preferimos hacer menos y volver, antes que más y arrepentirse. Trabajamos con dosis bajas, técnica fraccionada y revisión a las 2 semanas para ajustar — porque sub-corregir es reversible, sobre-corregir no.',
  },
  {
    n: '03',
    title: 'Respeto a la expresión',
    text: 'CLIBEL aplica neuromoduladores para suavizar líneas dinámicas sin congelar la cara. Tu rostro debe seguir expresando alegría, sorpresa, concentración — solo que sin las marcas excesivas que dejan estos gestos en el tiempo.',
  },
  {
    n: '04',
    title: 'Producto original, trazabilidad',
    text: 'CLIBEL trabaja exclusivamente con marcas referentes (Allergan, Galderma, Merz, Sinclair, Sculptra). Mostramos lote, fecha y caja al paciente antes de aplicar. La trazabilidad no es opcional — es parte del estándar clínico.',
  },
];

// ============ ANÁLISIS FACIAL POR TERCIOS (NUEVO) ============
const facialZones = [
  {
    tier: 'Tercio superior',
    coverage: 'De la línea del cabello a las cejas',
    zones: [
      { name: 'Frente', treatment: 'Toxina botulínica', detail: 'Líneas horizontales dinámicas' },
      { name: 'Entrecejo', treatment: 'Toxina botulínica', detail: 'Líneas verticales y horizontales' },
      { name: 'Sienes', treatment: 'Ácido hialurónico / Sculptra', detail: 'Restaurar volumen perdido por edad' },
      { name: 'Cejas', treatment: 'Toxina (browlift)', detail: 'Elevación discreta del extremo lateral' },
    ],
  },
  {
    tier: 'Tercio medio',
    coverage: 'De las cejas a la base de la nariz',
    zones: [
      { name: 'Ojeras (valle lagrimal)', treatment: 'Ácido hialurónico', detail: 'Producto específico, técnica fina' },
      { name: 'Pómulos', treatment: 'Ácido hialurónico (Voluma)', detail: 'Definición y proyección' },
      { name: 'Surcos nasogenianos', treatment: 'Ácido hialurónico', detail: 'Suavizar sin sobre-rellenar' },
      { name: 'Patas de gallo', treatment: 'Toxina botulínica', detail: 'Líneas dinámicas peri-oculares' },
    ],
  },
  {
    tier: 'Tercio inferior',
    coverage: 'De la base de la nariz al mentón',
    zones: [
      { name: 'Labios', treatment: 'Ácido hialurónico', detail: 'Hidratación, definición o aumento sutil' },
      { name: 'Código de barras', treatment: 'AH + toxina', detail: 'Líneas verticales peri-bucales' },
      { name: 'Comisuras labiales', treatment: 'Ácido hialurónico', detail: 'Elevar caídas de la sonrisa' },
      { name: 'Mentón', treatment: 'Ácido hialurónico', detail: 'Proyección y armonización del perfil' },
      { name: 'Ángulo mandibular', treatment: 'AH / hilos tensores', detail: 'Definir contorno facial' },
      { name: 'Maseteros', treatment: 'Toxina botulínica', detail: 'Reducir cara cuadrada por bruxismo' },
    ],
  },
];

// ============ MATRIZ DE PRODUCTOS POR MARCA (NUEVO) ============
const productMatrix = [
  { brand: 'Allergan', product: 'Juvéderm Voluma', type: 'Ácido hialurónico', use: 'Volumen profundo: pómulos, mentón, ángulo mandibular', duration: '18–24 m' },
  { brand: 'Allergan', product: 'Juvéderm Volift', type: 'Ácido hialurónico', use: 'Surcos nasogenianos, comisuras', duration: '12–15 m' },
  { brand: 'Allergan', product: 'Vistabel / Bocouture', type: 'Toxina botulínica', use: 'Líneas dinámicas: frente, entrecejo, patas de gallo', duration: '4–6 m' },
  { brand: 'Galderma', product: 'Restylane Defyne', type: 'Ácido hialurónico', use: 'Surcos profundos y mentón con dinámica', duration: '12–18 m' },
  { brand: 'Galderma', product: 'Restylane Kysse', type: 'Ácido hialurónico', use: 'Labios con definición y movimiento natural', duration: '10–12 m' },
  { brand: 'Galderma', product: 'Sculptra', type: 'Bioestimulador', use: 'Volumen facial generalizado, estimula colágeno', duration: '24+ m' },
  { brand: 'Merz', product: 'Belotero Volume', type: 'Ácido hialurónico', use: 'Restauración volumétrica suave', duration: '12–18 m' },
  { brand: 'Merz', product: 'Bocouture', type: 'Toxina botulínica', use: 'Neuromodulador sin proteínas accesorias', duration: '4–6 m' },
  { brand: 'Sinclair', product: 'Silhouette Soft', type: 'Hilos tensores', use: 'Reposicionamiento tisular: mejillas, mandíbula, cuello', duration: '12–18 m' },
];

// ============ CASOS CLÍNICOS / PLANES DE ARMONIZACIÓN (NUEVO) ============
const cases = [
  {
    name: 'Ojos descansados',
    duration: 'Sesión única · 60 min',
    combo: ['Toxina en patas de gallo', 'Ácido hialurónico en valle lagrimal'],
    target: 'Mirada fresca sin alterar la expresión. CLIBEL ataca la línea dinámica y la depresión bajo el ojo en la misma cita.',
    accent: 'gold',
  },
  {
    name: 'Código de barras corregido',
    duration: 'Sesión única · 45 min',
    combo: ['Toxina en orbicular labial', 'Hidratación AH peri-bucal'],
    target: 'Suavizar líneas verticales del labio superior sin afectar fonación ni sonrisa. Técnica de microdosis CLIBEL.',
    accent: 'mauve',
  },
  {
    name: 'Ovalado facial definido',
    duration: '2 sesiones · 45 días',
    combo: ['Ácido hialurónico en mentón', 'AH en ángulo mandibular', 'Toxina en maseteros'],
    target: 'Recuperar contorno mandibular perdido por edad o reducir cara cuadrada por bruxismo. Plan estructural CLIBEL.',
    accent: 'rose',
  },
  {
    name: 'Glow integral',
    duration: '3 sesiones · 90 días',
    combo: ['PRP facial', 'Skinbooster con AH ligero', 'Toxina preventiva en dosis bajas'],
    target: 'Mejorar textura, luminosidad y prevenir signos. CLIBEL lo recomienda como protocolo antiedad temprano (28–38 años).',
    accent: 'gold',
  },
];

// ============ DURACIÓN Y REVERSIBILIDAD (NUEVO) ============
const durability = [
  { product: 'Ácido hialurónico', duration: '12–18 meses', reversible: true, reversibleDetail: 'Disolvible con hialuronidasa en cualquier momento' },
  { product: 'Toxina botulínica', duration: '4–6 meses', reversible: 'parcial', reversibleDetail: 'No revertible directamente, se metaboliza progresivamente' },
  { product: 'Plasma Rico en Plaquetas', duration: '12–18 meses (gradual)', reversible: false, reversibleDetail: 'Es tu propia sangre — sin antagonista, sin riesgo de rechazo' },
  { product: 'Hilos tensores', duration: '12–18 meses', reversible: false, reversibleDetail: 'Reabsorbibles, no requieren retiro quirúrgico' },
  { product: 'Sculptra (bioestimulador)', duration: '24+ meses', reversible: false, reversibleDetail: 'Estimula colágeno propio, efecto progresivo y duradero' },
];

// ============ PRE / POST sesión ============
const protocols = {
  pre: [
    'Suspender anticoagulantes (aspirina, ibuprofeno) 5 días antes',
    'Evitar alcohol 24 h previas y 24 h posteriores',
    'No aplicar maquillaje denso el día del procedimiento',
    'Asistir hidratada y con desayuno ligero',
    'Avisar a CLIBEL de cualquier medicamento, alergia o embarazo',
  ],
  post: [
    'No tocar ni masajear la zona tratada 24 h',
    'Sin ejercicio intenso, sauna ni piscina 48 h',
    'Dormir boca arriba primera noche (sobre todo si fue labios o ojos)',
    'Compresas frías si hay leve inflamación',
    'Revisión a los 14 días para evaluar resultado y ajustar si requiere',
  ],
};

// ============ FAQs específicas medicina estética (humanizadas + interlinking) ============
const faqs: { q: string; answerHtml: string }[] = [
  {
    q: '¿En qué se diferencia CLIBEL de cualquier clínica que ofrece estos procedimientos?',
    answerHtml: '<strong>CLIBEL</strong> es atendida por médicos con cédula profesional + certificación específica en medicina estética, no por técnicos. Cada procedimiento parte de análisis facial completo. Trabajamos exclusivamente con marcas <strong>Allergan, Galderma, Merz, Sinclair y Teoxane</strong> con trazabilidad visible. Aplicamos filosofía conservadora — preferimos sub-corregir y volver, antes que sobre-corregir.',
  },
  {
    q: '¿Se nota que me hice un procedimiento?',
    answerHtml: 'CLIBEL trabaja para que NO se note. Aplicamos dosis bajas, técnica fraccionada y revisión a las 2 semanas. Buscamos que la gente diga "te ves descansada" no "te hiciste algo". La armonización natural es nuestro estándar — no la transformación.',
  },
  {
    q: '¿Cuánto duele? ¿Necesito anestesia?',
    answerHtml: 'CLIBEL aplica crema anestésica 20 minutos antes de cualquier procedimiento invasivo. Las jeringas son extra-finas. La <a href="/servicios/toxina-botulinica">toxina botulínica</a> es prácticamente indolora. El <a href="/servicios/acido-hialuronico">ácido hialurónico</a> en labios es la zona más sensible — usamos producto con lidocaína incorporada.',
  },
  {
    q: '¿Puedo volver a mi vida normal el mismo día?',
    answerHtml: 'Sí en la mayoría de los casos. AH y toxina: vida normal saliendo de CLIBEL. <a href="/servicios/hilos-tensores">Hilos tensores</a>: 5–7 días de inflamación y tirantez (no necesariamente reposo absoluto pero sí actividad reducida). <a href="/servicios/plasma-rico-plaquetas">PRP</a>: 24–48 h de eritema. Evita ejercicio intenso, sauna y alcohol 48 h en todos los casos.',
  },
  {
    q: '¿Qué pasa si no me gusta el resultado del ácido hialurónico?',
    answerHtml: 'El AH es 100% reversible. CLIBEL mantiene <strong>hialuronidasa disponible en cabina</strong> para disolverlo en 24–72 h. Por eso es nuestro material preferido para empezar — la reversibilidad da confianza al paciente y al médico para iterar. <a href="/servicios/acido-hialuronico">Conoce el protocolo completo →</a>',
  },
  {
    q: '¿Cuánto cuesta un tratamiento de medicina estética?',
    answerHtml: 'Depende del producto, marca, zona y cantidad necesaria — varía mucho entre 1 zona pequeña con toxina y un plan integral con varios procedimientos. CLIBEL ofrece valoración sin costo donde recibes presupuesto detallado por escrito antes de cualquier decisión.',
  },
  {
    q: '¿A qué edad debo empezar?',
    answerHtml: 'CLIBEL recomienda <a href="/servicios/toxina-botulinica">toxina preventiva</a> en microdosis a partir de los 28–32 años si ya hay líneas dinámicas marcadas. Para <a href="/servicios/acido-hialuronico">ácido hialurónico</a> no hay edad — depende de tu anatomía. <a href="/servicios/plasma-rico-plaquetas">PRP</a> funciona a cualquier edad como mantenimiento. Hilos tensores típicamente 40+ con descolgamiento documentable.',
  },
  {
    q: '¿Qué pasa si ocurre una complicación?',
    answerHtml: 'CLIBEL tiene protocolo escrito de manejo de complicaciones: <strong>hialuronidasa disponible</strong> para revertir AH, <strong>apraclonidina</strong> para ptosis palpebral por toxina, protocolo de retirada para hilos si requiere, coordinación inmediata con dermatología o cirugía maxilofacial si la situación lo exige. La seguridad clínica empieza antes de aplicar.',
  },
];
---

<BaseLayout
  title={`Medicina Estética Avanzada en CDMX | CLIBEL`}
  description={`Medicina estética en CLIBEL: ácido hialurónico, toxina botulínica, plasma rico en plaquetas e hilos tensores aplicados por médicos certificados con marcas originales Allergan, Galderma, Merz y Sinclair en CDMX.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(catalogSchema)} />

  <!-- ============================ BREADCRUMB ============================ -->
  <Breadcrumb
    kicker="Categoría 04 · Medicina estética"
    items={[
      { label: 'Servicios', href: '/servicios' },
      { label: 'Medicina Estética Avanzada' },
    ]}
  />

  <!-- ============================ HERO ============================ -->
  <section class="cat-hero">
    <div aria-hidden="true" class="cat-hero-bg"></div>
    <div aria-hidden="true" class="cat-hero-blob cat-hero-blob-1"></div>
    <div aria-hidden="true" class="cat-hero-blob cat-hero-blob-2"></div>
    <div aria-hidden="true" class="cat-hero-grain"></div>

    <div class="container-x relative">
      <div class="cat-hero-grid">
        <div class="cat-hero-col cat-hero-col--left fade-up">
          <span class="eyebrow-tag">
            <span class="dot" aria-hidden="true"></span>
            Categoría 04 · {cat.badgeLabel} · {items.length}+ procedimientos
          </span>

          <h1 class="cat-hero-headline">
            <span class="cat-hero-headline-line">Medicina estética</span>
            <span class="cat-hero-headline-line"><em>avanzada</em> en CDMX.</span>
          </h1>

          <p class="cat-hero-lede">
            Aplicada exclusivamente por <strong>médicos certificados</strong>
            con productos originales Allergan, Galderma, Merz y Sinclair.
            CLIBEL analiza primero, aplica después — armonización natural,
            no transformación.
          </p>

          <div class="cat-hero-trust">
            <span class="cat-hero-trust-label">Marcas originales</span>
            <div class="cat-hero-trust-list">
              <span>Allergan</span><span aria-hidden="true">·</span>
              <span>Galderma</span><span aria-hidden="true">·</span>
              <span>Merz</span><span aria-hidden="true">·</span>
              <span>Sinclair</span><span aria-hidden="true">·</span>
              <span>Sculptra</span>
            </div>
          </div>
        </div>

        <div class="cat-hero-col cat-hero-col--right fade-up-delay-2">
          <span class="cat-hero-kicker">Qué hace CLIBEL en medicina estética</span>

          <p class="cat-hero-paragraph">
            <strong>CLIBEL</strong> es una clínica de belleza con médicos
            certificados especializados en medicina estética avanzada en
            Ciudad de México. A diferencia de spas y salas de belleza, cada
            procedimiento invasivo lo aplica un médico con cédula profesional
            — no un técnico ni esteticista. Esa distinción no es cosmética:
            es regulatoria, clínica y de seguridad para tu rostro.
          </p>

          <p class="cat-hero-paragraph">
            En esta categoría reunimos los cuatro procedimientos más
            solicitados: <a href="/servicios/acido-hialuronico"><strong>ácido hialurónico</strong></a>
            con hialuronidasa disponible en cabina,
            <a href="/servicios/toxina-botulinica"><strong>toxina botulínica</strong></a>
            con filosofía 'expresión conservada',
            <a href="/servicios/plasma-rico-plaquetas"><strong>plasma rico en plaquetas</strong></a>
            autólogo con kit certificado, y
            <a href="/servicios/hilos-tensores"><strong>hilos tensores</strong></a>
            cuando el descolgamiento lo amerita. Cada aplicación queda
            documentada con producto, lote y zona — trazabilidad como
            estándar mínimo, no extra premium.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================ NAV TOP ============================ -->
  <HeroNavBar
    label="Otras categorías"
    ariaLabel="Otras categorías de tratamientos CLIBEL"
    variant="cream"
    links={[
      { label: 'Faciales',         href: catHref('facial') },
      { label: 'Corporales',       href: catHref('corporal') },
      { label: 'Depilación láser', href: catHref('laser') },
      { label: 'Capilares',        href: catHref('capilar') },
    ]}
    cta={{ label: 'Volver al catálogo', href: '/servicios' }}
  />

  <!-- ============================ CATÁLOGO ============================ -->
  <section class="section bg-white">
    <div class="container-x">
      <SectionHeader
        kicker={`Catálogo · ${items.length} procedimientos`}
        title="Medicina estética en <em>CLIBEL</em>."
        paragraphs={[
          '<strong>CLIBEL</strong> aplica medicina estética avanzada como práctica clínica seria: cada procedimiento parte de análisis facial completo, se documenta sesión a sesión y se revisa a las 2 semanas. CLIBEL nunca vende un procedimiento aislado sin haber valorado primero la arquitectura facial del paciente.',
          'Cada aplicación en <strong>CLIBEL</strong> registra producto, lote, fecha de caducidad, cantidad y zona en expediente clínico digital. Esta trazabilidad es responsabilidad legal del médico tratante y derecho del paciente — en CLIBEL es transparente desde el primer minuto.',
        ]}
        cta={{ label: 'Solicitar análisis facial gratuito', href: '/contacto', variant: 'primary' }}
      />

      <div class="cat-grid">
        {items.map((s) => (
          <ServiceCard
            href={`/servicios/${s.id}`}
            title={s.data.title}
            description={s.data.description}
            category={s.data.category}
            duration={s.data.duration}
            sessions={s.data.sessions}
            icon={s.data.icon}
            featured={s.data.featured}
            benefits={s.data.benefits}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ============================ STAT STRIP CLÍNICO ============================ -->
  <section class="svc-stat-strip">
    <div class="container-x">
      <dl class="medest-stats">
        <div>
          <dt>Procedimientos</dt>
          <dd><em>{items.length}</em></dd>
        </div>
        <div>
          <dt>Marcas certificadas</dt>
          <dd><em>05</em><span class="medest-stats-list">Allergan · Galderma · Merz · Sinclair · Teoxane</span></dd>
        </div>
        <div>
          <dt>Aplicación</dt>
          <dd class="medest-stats-text">Médico inyector</dd>
