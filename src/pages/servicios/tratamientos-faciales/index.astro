    .stack-item:nth-child(2n) { border-left: 1px solid rgba(201, 169, 97, 0.25); }
  }
  @media (min-width: 1100px) {
    .stack-item:nth-child(2n) { border-left: 0; }
    .stack-item:not(:nth-child(3n+1)) { border-left: 1px solid rgba(201, 169, 97, 0.25); }
  }
  .stack-item:hover { background: var(--color-brand-50); }
  .stack-kicker {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-brand-500);
    margin-bottom: 0.65rem;
  }
  .stack-value {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.2rem, 1.4vw, 1.45rem);
    color: var(--color-ink-900);
    margin: 0 0 0.4rem;
    line-height: 1.2;
    letter-spacing: -0.015em;
  }
  .stack-detail {
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--color-ink-500);
    margin: 0;
  }
  .stack-num {
    position: absolute;
    top: 1.5rem;
    right: 1.25rem;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1rem;
    color: var(--color-brand-400);
    opacity: 0.6;
    transition: opacity 0.3s ease !important;
  }
  .stack-item:hover .stack-num { opacity: 1; }

  /* ============= NEW: Diagnóstico (dark) ============= */
  .svc-diag {
    background: var(--color-ink-900);
    color: var(--color-brand-100);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }
  .svc-diag-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(60% 50% at 100% 0%, rgba(201,169,97,0.08), transparent 60%),
      radial-gradient(50% 50% at 0% 100%, rgba(139,90,107,0.1), transparent 60%);
    pointer-events: none;
    z-index: 0;
  }
  .diag-list {
    list-style: none;
    padding: 0;
    margin: clamp(2rem, 4vw, 3rem) 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  @media (min-width: 768px) { .diag-list { grid-template-columns: repeat(2, 1fr); } }
  .diag-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(1rem, 2vw, 1.75rem);
    padding: clamp(1.5rem, 2.5vw, 2.25rem) clamp(0.5rem, 1.5vw, 1.5rem);
    border-top: 1px solid rgba(201, 169, 97, 0.22);
    align-items: start;
  }
  @media (min-width: 768px) {
    .diag-item:nth-child(odd)  { padding-right: clamp(1rem, 2vw, 2rem); border-right: 1px solid rgba(201, 169, 97, 0.18); }
    .diag-item:nth-child(even) { padding-left:  clamp(1rem, 2vw, 2rem); }
    .diag-item:nth-child(1), .diag-item:nth-child(2) { border-top: 0; padding-top: 0; }
  }
  .diag-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 0.85;
    background: linear-gradient(180deg, var(--color-brand-400), var(--color-mauve-300));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.02em;
    flex-shrink: 0;
    min-width: 2.5rem;
  }
  .diag-body { display: flex; flex-direction: column; gap: 0.5rem; max-width: 56ch; }
  .diag-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.25rem, 1.8vw, 1.55rem);
    color: white;
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.015em;
  }
  .diag-text {
    font-size: clamp(0.92rem, 1vw, 1.02rem);
    line-height: 1.65;
    color: rgba(242, 235, 223, 0.78);
    margin: 0;
  }

  /* ============= NEW: Cases / Planes ============= */
  .cases-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 768px) { .cases-grid { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; } }
  .case {
    position: relative;
    background: white;
    border: 1px solid rgba(201, 169, 97, 0.28);
    border-radius: 1.25rem;
    padding: clamp(1.5rem, 2vw, 1.85rem);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    overflow: hidden;
    transition: transform 0.5s cubic-bezier(.2,.8,.2,1), box-shadow 0.5s ease, border-color 0.4s ease !important;
  }
  .case::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: var(--accent-color, var(--color-brand-400));
    transition: height 0.4s cubic-bezier(.2,.8,.2,1) !important;
  }
  .case:hover {
    transform: translateY(-6px);
    border-color: rgba(139, 90, 107, 0.45);
    box-shadow: 0 32px 56px -22px rgba(31,20,24,0.22);
  }
  .case:hover::before { height: 6px; }
  .case--gold  { --accent-color: var(--color-brand-500); }
  .case--mauve { --accent-color: var(--color-mauve-500); }
  .case--rose  { --accent-color: var(--color-mauve-300); }
  .case-head { display: flex; align-items: flex-start; gap: 1rem; }
  .case-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2rem, 3vw, 2.75rem);
    color: var(--accent-color, var(--color-brand-500));
    line-height: 0.85;
    letter-spacing: -0.02em;
    flex-shrink: 0;
  }
  .case-kicker {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-brand-500);
    opacity: 0.85;
    margin-bottom: 0.2rem;
  }
  .case-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.4rem, 1.8vw, 1.7rem);
    color: var(--color-ink-900);
    margin: 0 0 0.2rem;
    line-height: 1.15;
    letter-spacing: -0.018em;
  }
  .case-duration {
    display: inline-block;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.88rem;
    color: var(--color-ink-500);
  }
  .case-profile {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.6rem 0.85rem;
    background: var(--color-brand-50);
    border: 1px solid rgba(201, 169, 97, 0.25);
    border-radius: 0.6rem;
  }
  .case-profile-label {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-mauve-500);
  }
  .case-profile-value {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.92rem;
    color: var(--color-ink-800);
    letter-spacing: -0.005em;
  }
  .case-combo { display: flex; flex-direction: column; gap: 0.5rem; padding-block: 0.85rem; border-block: 1px dashed rgba(201, 169, 97, 0.3); }
  .case-combo-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-mauve-500);
  }
  .case-combo ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .case-combo li {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    font-size: 0.9rem;
    line-height: 1.45;
    color: var(--color-ink-700);
  }
  .case-combo li a {
    color: var(--color-mauve-500);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    font-weight: 500;
    transition: color 0.25s ease !important;
  }
  .case-combo li a:hover { color: var(--color-mauve-700); }
  .case-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.85rem;
    padding-top: 0.85rem;
    border-top: 1px dashed rgba(201, 169, 97, 0.32);
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-mauve-500);
    text-decoration: none;
    transition: gap 0.25s ease, color 0.25s ease !important;
  }
  .case-link:hover {
    color: var(--color-mauve-700);
    gap: 0.65rem;
  }
  .case-link svg { transition: transform 0.25s ease !important; }
  .case-link:hover svg { transform: translateX(3px); }
  .case-combo li svg {
    flex-shrink: 0;
    margin-top: 0.18rem;
    color: var(--accent-color, var(--color-mauve-500));
  }
  .case-target {
    margin: 0;
    padding: 0.85rem 0.95rem;
    background: var(--color-brand-50);
    border-left: 3px solid var(--accent-color, var(--color-brand-400));
    border-radius: 0 0.55rem 0.55rem 0;
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--color-ink-700);
    font-style: italic;
  }

  /* ============= NEW: Protocolos pre/post (dark) ============= */
  .svc-protocols {
    background: var(--color-ink-900);
    color: var(--color-brand-100);
    position: relative;
    isolation: isolate;
  }
  .protocol-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 900px) { .protocol-grid { grid-template-columns: 1fr 1fr; gap: 1.75rem; } }
  .protocol {
    padding: clamp(1.5rem, 2vw, 2rem);
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1.25rem;
    transition: all 0.4s ease !important;
  }
  .protocol:hover {
    background: rgba(255,255,255,0.055);
    border-color: rgba(201, 169, 97, 0.45);
    transform: translateY(-4px);
  }
  .protocol-head { display: flex; align-items: baseline; gap: 0.9rem; margin-bottom: 1.25rem; }
  .protocol-tag {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
  }
  .protocol-tag--pre {
    background: rgba(201, 169, 97, 0.15);
    color: var(--color-brand-400);
    border: 1px solid rgba(201, 169, 97, 0.4);
  }
  .protocol-tag--post {
    background: rgba(139, 90, 107, 0.2);
    color: var(--color-mauve-300);
    border: 1px solid rgba(188, 142, 156, 0.45);
  }
  .protocol-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.4rem, 1.8vw, 1.75rem);
    color: white;
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.015em;
  }
  .protocol-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .protocol-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding-block: 0.65rem;
    border-top: 1px dashed rgba(201, 169, 97, 0.18);
    font-size: 0.92rem;
    line-height: 1.5;
    color: rgba(242, 235, 223, 0.85);
  }
  .protocol-list li:first-child { border-top: 0; padding-top: 0; }
  .protocol-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 0.95rem;
    color: var(--color-brand-400);
    line-height: 1.45;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    min-width: 24px;
  }

  /* ============= Aftercare ============= */
  .svc-aftercare {
    background: var(--color-ink-900);
    color: var(--color-brand-100);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }
  .svc-aftercare-bg {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(to right, rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 80px 80px;
    opacity: 0.7;
    pointer-events: none;
    z-index: 0;
  }
  .svc-aftercare-blob {
    position: absolute;
    top: -10rem; right: -8rem;
    width: 32rem; height: 32rem;
    border-radius: 999px;
    background: rgba(92, 57, 70, 0.35);
    filter: blur(120px);
    pointer-events: none;
    z-index: 0;
  }

  .after-list {
    list-style: none;
    padding: 0;
    margin: clamp(2rem, 4vw, 3rem) 0 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .after-item {
    display: grid;
    grid-template-columns: clamp(70px, 12vw, 130px) 1fr;
    gap: clamp(1.25rem, 2.5vw, 2.5rem);
    padding-block: clamp(1.5rem, 2.5vw, 2.25rem);
    border-top: 1px dashed rgba(201, 169, 97, 0.22);
    align-items: start;
  }
  .after-item:first-child { border-top: 0; padding-top: 0; }
  .after-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2.75rem, 5.5vw, 4.5rem);
    line-height: 0.9;
    background: linear-gradient(180deg, var(--color-brand-400), var(--color-mauve-300));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.015em;
  }
  .after-body { display: flex; flex-direction: column; gap: 0.5rem; max-width: 64ch; }
  .after-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.25rem, 1.8vw, 1.65rem);
    color: white;
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.015em;
  }
  .after-text {
    font-size: clamp(0.92rem, 1vw, 1.02rem);
    line-height: 1.7;
    color: rgba(242, 235, 223, 0.78);
    margin: 0;
  }

  /* ============= FAQ + Formulario WhatsApp (grid 2-col) ============= */
  .faq-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 3vw, 2.75rem);
    align-items: start;
  }
  @media (min-width: 1024px) {
    .faq-grid {
      grid-template-columns: 1.15fr 0.85fr;
      gap: clamp(2.5rem, 4vw, 3.5rem);
    }
  }
  .faq-col-label {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-brand-500);
    margin-bottom: 1.1rem;
  }

  /* ===== FAQ específica ===== */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .faq {
    background: var(--color-brand-50);
    border: 1px solid rgba(201, 169, 97, 0.22);
    border-radius: 1rem;
    overflow: hidden;
    transition: border-color 0.3s ease, background 0.3s ease !important;
  }
  .faq[open] {
    background: white;
    border-color: var(--color-mauve-500);
  }
  .faq-sum {
    list-style: none;
    cursor: pointer;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1rem;
    align-items: center;
    padding: 1.1rem 1.25rem;
  }
  .faq-sum::-webkit-details-marker { display: none; }
  .faq-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1rem;
    color: var(--color-brand-500);
    letter-spacing: 0.04em;
    line-height: 1;
    opacity: 0.8;
    min-width: 24px;
  }
  .faq-q {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1rem, 1.1vw, 1.12rem);
    color: var(--color-ink-900);
    line-height: 1.3;
    letter-spacing: -0.005em;
  }
  .faq-plus {
    width: 32px; height: 32px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: var(--color-brand-100);
    color: var(--color-mauve-500);
    transition: transform 0.35s cubic-bezier(.2,.8,.2,1), background 0.3s ease, color 0.3s ease !important;
  }
  .faq[open] .faq-plus {
    transform: rotate(45deg);
    background: var(--color-mauve-500);
    color: white;
  }
  .faq-a {
    padding: 0 1.25rem 1.25rem clamp(3.5rem, 6vw, 4rem);
    font-size: 0.92rem;
    line-height: 1.65;
    color: var(--color-ink-700);
  }
  .faq-a a {
    color: var(--color-mauve-500);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    font-weight: 500;
    transition: color 0.25s ease !important;
  }
  .faq-a a:hover { color: var(--color-mauve-700); }

  /* ===== Formulario WhatsApp ===== */
  .faq-form-wrap {
    position: relative;
  }
  @media (min-width: 1024px) {
    .faq-form-wrap {
      position: sticky;
      top: clamp(6rem, 10vh, 7.5rem);
    }
  }
  .faq-form {
    background: linear-gradient(180deg, #FFFFFF 0%, var(--color-brand-50) 100%);
    border: 1px solid rgba(201, 169, 97, 0.3);
    border-radius: 1.25rem;
    padding: clamp(1.5rem, 2vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 0.95rem;
    box-shadow:
      0 1px 2px rgba(31, 20, 24, 0.03),
      0 24px 56px -28px rgba(31, 20, 24, 0.18);
  }
  .faq-form-kicker {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mauve-500);
  }
  .faq-form-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.45rem, 2vw, 1.85rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-ink-900);
    margin: 0;
  }
  .faq-form-title em {
    font-style: italic;
    color: var(--color-mauve-500);
    font-weight: 400;
  }
  .faq-form-sub {
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--color-ink-500);
    margin: 0 0 0.5rem;
  }
  .faq-form-sub strong { color: var(--color-ink-900); font-weight: 600; }

  .faq-form-row {
    display: flex;
    flex-direction: column;
    gap: 0.32rem;
  }
  .faq-form-grid-2 {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
  }
  @media (min-width: 520px) {
    .faq-form-grid-2 { grid-template-columns: 1fr 1fr; }
  }
  .faq-form-row label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-ink-700);
    letter-spacing: 0.02em;
  }
  .faq-form-row label span[aria-hidden] {
    color: var(--color-mauve-500);
    margin-left: 2px;
  }
  .faq-form input,
  .faq-form select,
  .faq-form textarea {
    width: 100%;
    padding: 0.7rem 0.9rem;
    font-family: var(--font-sans);
    font-size: 0.92rem;
    color: var(--color-ink-900);
    background: white;
    border: 1px solid rgba(201, 169, 97, 0.35);
    border-radius: 0.65rem;
    outline: none;
    transition: border-color 0.25s ease, box-shadow 0.25s ease, background 0.25s ease !important;
    appearance: none;
    line-height: 1.4;
  }
  .faq-form select {
    background-image: linear-gradient(45deg, transparent 50%, var(--color-mauve-500) 50%),
                      linear-gradient(135deg, var(--color-mauve-500) 50%, transparent 50%);
    background-position: calc(100% - 18px) calc(50% - 2px), calc(100% - 13px) calc(50% - 2px);
    background-size: 5px 5px;
    background-repeat: no-repeat;
    padding-right: 2rem;
    cursor: pointer;
  }
  .faq-form textarea {
    resize: vertical;
    min-height: 80px;
  }
  .faq-form input:focus,
  .faq-form select:focus,
  .faq-form textarea:focus {
    border-color: var(--color-mauve-500);
    box-shadow: 0 0 0 3px rgba(139, 90, 107, 0.12);
    background: var(--color-brand-50);
  }
  .faq-form.is-invalid input:required:invalid,
  .faq-form.is-invalid input[type="checkbox"]:invalid + span {
    border-color: #c62b3e;
  }

  .faq-form-check {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    margin-top: 0.25rem;
    font-size: 0.78rem;
    line-height: 1.45;
    color: var(--color-ink-500);
    cursor: pointer;
  }
  .faq-form-check input[type="checkbox"] {
    width: 16px;
    height: 16px;
    margin-top: 2px;
    accent-color: var(--color-mauve-500);
    flex-shrink: 0;
    cursor: pointer;
  }
  .faq-form-check a {
    color: var(--color-mauve-500);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
