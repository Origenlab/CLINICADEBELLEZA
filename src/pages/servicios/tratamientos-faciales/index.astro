---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import HeroNavBar from '../../../components/HeroNavBar.astro';
import RelatedCategories from '../../../components/RelatedCategories.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, SITE, CONTACT, catHref } from '../../../consts';

const cat = CATEGORIES.facial;

const all = await getCollection('servicios');
const items = all
  .filter((s) => s.data.category === 'facial')
  .sort((a, b) => a.data.order - b.data.order);

const wa = `https://wa.me/${CONTACT.whatsapp}?text=${encodeURIComponent('Hola, me gustaría agendar una cita en CLIBEL para tratamientos faciales.')}`;

// Schemas
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Servicios', item: `${SITE.url}/servicios` },
    { '@type': 'ListItem', position: 3, name: 'Tratamientos Faciales', item: `${SITE.url}/servicios/tratamientos-faciales` },
  ],
};
const catalogSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalSpecialty',
  name: 'Tratamientos Faciales — CLIBEL',
  description: 'Limpieza facial profunda, rejuvenecimiento, peelings químicos y tratamiento antiacné con respaldo médico en CDMX.',
  url: `${SITE.url}/servicios/tratamientos-faciales`,
  provider: { '@id': `${SITE.url}/#clinic` },
  relevantSpecialty: 'Dermatology',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Catálogo de tratamientos faciales CLIBEL',
    itemListElement: items.map((s) => ({
      '@type': 'MedicalProcedure',
      name: s.data.title,
      description: s.data.description,
      url: `${SITE.url}/servicios/${s.id}`,
    })),
  },
};

// === Diagnóstico dermatológico previo (NUEVO — homologa con otros L3) ===
const diagnosis = [
  {
    n: '01',
    title: 'Análisis cutáneo profesional',
    text: 'CLIBEL evalúa con diagnóstico digital tu tipo de piel, fototipo, hidratación, sensibilidad, daño solar y poros. Sin este paso ningún protocolo facial se ajusta a tu realidad clínica.',
  },
  {
    n: '02',
    title: 'Historia clínica completa',
    text: 'Antecedentes alérgicos, hormonales, medicamentos fotosensibles, dermatitis previas y embarazo. CLIBEL pregunta antes de aplicar — la seguridad cutánea empieza en la conversación.',
  },
  {
    n: '03',
    title: 'Identificación de motivos',
    text: 'Acné, manchas, rosácea, líneas, opacidad, deshidratación — cada uno requiere protocolo distinto. CLIBEL prioriza el motivo principal y aborda secundarios sin sobrecargar la piel.',
  },
  {
    n: '04',
    title: 'Plan documentado por escrito',
    text: 'Diagnóstico, plan de sesiones, rutina domiciliaria y expectativas realistas. CLIBEL entrega todo por escrito antes de empezar — para que decidas con información completa.',
  },
];

// === Casos clínicos / planes faciales por objetivo (NUEVO) ===
const cases = [
  {
    name: 'Plan piel grasa con acné',
    duration: '4–6 sesiones · 3 meses',
    profile: 'Pieles 18–35 años con brotes activos',
    combo: ['Limpiezas profundas mensuales', 'Peeling salicílico fraccionado', 'Rutina domiciliaria con retinoides supervisados'],
    target: 'Controlar brotes, regular sebo y prevenir cicatrices post-acné. CLIBEL combina técnica clínica + cosmecéuticos compatibles para resultado sostenido.',
    accent: 'gold',
  },
  {
    name: 'Plan antimanchas y luminosidad',
    duration: '6 sesiones · 4 meses',
    profile: 'Pieles 30+ con melasma o fotoenvejecimiento',
    combo: ['Peelings despigmentantes progresivos', 'Hidratación clínica intermedia', 'Protección solar y rutina domiciliaria estricta'],
    target: 'Uniformar tono cutáneo, atenuar manchas y prevenir recidiva. CLIBEL trabaja con paciencia clínica — la pigmentación no responde al apuro.',
    accent: 'mauve',
  },
  {
    name: 'Plan rejuvenecimiento integral',
    duration: '5 sesiones · 3 meses',
    profile: 'Pieles 35+ con primeras líneas',
    combo: ['Rejuvenecimiento facial profesional', 'Microneedling con activos', 'Radiofrecuencia facial reafirmante'],
    target: 'Mejorar textura, firmeza y luminosidad. CLIBEL diseña progresión sin invasividad y con resultados verificables en fotografía clínica.',
    accent: 'rose',
  },
  {
    name: 'Plan mantenimiento mensual',
    duration: 'Indefinido · 1 sesión / mes',
    profile: 'Pacientes con plan consolidado',
    combo: ['Limpieza facial profunda mensual', 'Hidratación enzimática', 'Revisión y ajuste de rutina'],
    target: 'Sostener calidad cutánea como rutina clínica ligera. CLIBEL lo recomienda tras completar plan intensivo para mantener resultados.',
    accent: 'gold',
  },
];

// === Pre / Post sesión protocolos (NUEVO) ===
const protocols = {
  pre: [
    'Suspender retinoides y ácidos exfoliantes 5–7 días antes',
    'Sin exposición solar intensa 48 h previas',
    'Asistir sin maquillaje denso ni cremas oclusivas',
    'Hidratación tópica diaria los días previos',
    'Avisar a CLIBEL si tomas medicamentos fotosensibles o tienes herpes recurrente',
  ],
  post: [
    'SPF 50+ obligatorio diariamente durante todo el plan',
    'Limpiadores suaves sin sulfatos las primeras 48 h',
    'Sin sauna, vapor ni piscina 24 h',
    'No exfoliar mecánicamente 5–7 días según protocolo',
    'Reportar a CLIBEL cualquier reacción inesperada por WhatsApp clínico',
  ],
};

// === Qué resolvemos en faciales ===
const concerns = [
  {
    title: 'Acné y brotes hormonales',
    text: 'CLIBEL diseña protocolos antiacné combinando peelings, fotomedicina y rutina domiciliaria personalizada para controlar brotes y prevenir cicatrices.',
  },
  {
    title: 'Manchas e hiperpigmentación',
    text: 'En CLIBEL atendemos melasma, fotoenvejecimiento e hiperpigmentación posinflamatoria con peelings progresivos, despigmentantes médicos y protección solar clínica.',
  },
  {
    title: 'Líneas de expresión y arrugas',
    text: 'CLIBEL emplea radiofrecuencia facial, peelings de renovación, microneedling y bioestimuladores para suavizar líneas finas sin congelar la expresión.',
  },
  {
    title: 'Poros dilatados y exceso de grasa',
    text: 'Protocolos de limpieza profunda y peelings ácidos calibrados por CLIBEL para regular sebo, depurar poros y mejorar la textura visible.',
  },
  {
    title: 'Piel apagada y deshidratada',
    text: 'CLIBEL aplica hidratación profunda, exfoliación enzimática y vitaminas tópicas para devolver luminosidad sin agredir la barrera cutánea.',
  },
  {
    title: 'Rosácea y sensibilidad cutánea',
    text: 'En CLIBEL trabajamos pieles reactivas con protocolos suaves, calmantes profesionales y diagnóstico dermatológico previo para evitar irritación.',
  },
];

// === Tecnología y productos usados en faciales ===
const stack = [
  { kicker: 'Equipos clínicos', value: 'Radiofrecuencia facial', detail: 'Estimulación de colágeno y reafirmación' },
  { kicker: 'Equipos clínicos', value: 'Microneedling profesional', detail: 'Renovación cutánea controlada' },
  { kicker: 'Equipos clínicos', value: 'Diagnóstico digital de piel', detail: 'Evaluación cuantitativa antes de cada plan' },
  { kicker: 'Productos', value: 'Peelings médicos', detail: 'AHA, BHA, retinol controlado por concentración' },
  { kicker: 'Productos', value: 'Cosmecéuticos profesionales', detail: 'Marcas dermo-cosméticas con registro COFEPRIS' },
  { kicker: 'Productos', value: 'Despigmentantes médicos', detail: 'Aplicación supervisada en consulta' },
];

// === Aftercare ===
const aftercare = [
  {
    n: '01',
    title: 'Protección solar diaria',
    text: 'CLIBEL te entrega protocolo escrito: SPF 50+ aplicado cada mañana es la condición no negociable de cualquier tratamiento facial.',
  },
  {
    n: '02',
    title: 'Hidratación clínica',
    text: 'Rutina de hidratación y reparación de barrera diseñada por CLIBEL según tu tipo de piel y la fase del tratamiento.',
  },
  {
    n: '03',
    title: 'Suspensiones y precauciones',
    text: 'CLIBEL indica por escrito qué activos suspender (retinoides, ácidos, exfoliantes) y por cuánto tiempo según el procedimiento.',
  },
  {
    n: '04',
    title: 'Seguimiento programado',
    text: 'CLIBEL agenda revisiones a 7, 30 y 90 días con fotografía clínica comparativa para validar resultados y ajustar el plan.',
  },
];

// === FAQs específicas faciales ===
const faqs = [
  { q: '¿Con qué frecuencia debo hacerme una limpieza facial profunda?', a: 'En CLIBEL recomendamos una sesión mensual de mantenimiento para pieles sanas y cada 15-21 días si tu piel es grasa, mixta o tiene tendencia comedónica. La frecuencia exacta sale de tu valoración inicial.' },
  { q: '¿Los peelings químicos descaman mucho?', a: 'Depende de la profundidad. Los peelings superficiales que aplicamos en CLIBEL provocan descamación leve y discreta. Para peelings medios entregamos protocolo de recuperación con cuidados específicos y línea telefónica directa con tu médico.' },
  { q: '¿En cuántas sesiones desaparecen mis manchas?', a: 'El melasma y la hiperpigmentación responden gradualmente. CLIBEL trabaja en planes de 4-6 sesiones espaciadas, con activos domiciliarios y protección solar estricta. Los resultados se documentan con fotografía clínica.' },
  { q: '¿Puedo combinar varios tratamientos faciales?', a: 'Sí, y normalmente es lo más eficaz. CLIBEL diseña planes combinados — limpieza + peeling + radiofrecuencia — respetando tiempos clínicos y la respuesta de tu piel sesión a sesión.' },
  { q: '¿Los tratamientos faciales son seguros durante el embarazo?', a: 'Muchos sí (limpieza facial, hidratación, drenaje), otros no (peelings medios, retinoides, microneedling profundo). En CLIBEL valoramos cada caso por separado y adaptamos un plan seguro durante embarazo y lactancia.' },
];
---

<BaseLayout
  title={`${cat.label} en CDMX | CLIBEL`}
  description={`${cat.label} en CLIBEL: limpieza facial profunda, rejuvenecimiento, peelings químicos y antiacné con respaldo médico, productos COFEPRIS y diagnóstico previo gratuito en CDMX.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(catalogSchema)} />

  <!-- ============================ BREADCRUMB ============================ -->
  <Breadcrumb
    kicker="Categoría 01 · Faciales"
    items={[
      { label: 'Servicios', href: '/servicios' },
      { label: 'Tratamientos Faciales' },
    ]}
  />

  <!-- ============================ HERO ============================ -->
  <section class="cat-hero">
    <div aria-hidden="true" class="cat-hero-bg"></div>
    <div aria-hidden="true" class="cat-hero-blob cat-hero-blob-1"></div>
    <div aria-hidden="true" class="cat-hero-blob cat-hero-blob-2"></div>
    <div aria-hidden="true" class="cat-hero-grain"></div>

    <div class="container-x relative">
      <div class="cat-hero-grid">
        <!-- LEFT — brand statement -->
        <div class="cat-hero-col cat-hero-col--left fade-up">
          <span class="eyebrow-tag">
            <span class="dot" aria-hidden="true"></span>
            Categoría 01 · {cat.badgeLabel} · {items.length} tratamientos
          </span>

          <h1 class="cat-hero-headline">
            <span class="cat-hero-headline-line">Tratamientos</span>
            <span class="cat-hero-headline-line"><em>faciales</em> en CDMX.</span>
          </h1>

          <p class="cat-hero-lede">
            Renovación, luminosidad y salud de la piel con
            <strong>respaldo médico real</strong>. CLIBEL atiende cada
            rostro con diagnóstico previo, productos certificados y planes
            documentados sesión a sesión.
          </p>

          <div class="cat-hero-trust">
            <span class="cat-hero-trust-label">Trabajamos con</span>
            <div class="cat-hero-trust-list">
              <span>Allergan</span><span aria-hidden="true">·</span>
              <span>Galderma</span><span aria-hidden="true">·</span>
              <span>Merz</span><span aria-hidden="true">·</span>
              <span>SkinCeuticals</span><span aria-hidden="true">·</span>
              <span>Mesoestetic</span>
            </div>
          </div>
        </div>

        <!-- RIGHT — 2 párrafos explicativos CLIBEL -->
        <div class="cat-hero-col cat-hero-col--right fade-up-delay-2">
          <span class="cat-hero-kicker">Qué hace CLIBEL en faciales</span>

          <p class="cat-hero-paragraph">
            <strong>CLIBEL</strong> es una clínica de belleza con criterio
            médico especializada en cuidado facial profesional en Ciudad
            de México. Diseñamos cada protocolo facial tras una valoración
            dermatológica que evalúa fototipo, sensibilidad, antecedentes y
            objetivos, combinando técnicas clínicas con cosmecéuticos
            certificados por COFEPRIS y supervisión médica directa.
          </p>

          <p class="cat-hero-paragraph">
            En esta categoría <strong>CLIBEL</strong> reúne sus protocolos
            faciales más solicitados: <strong>limpieza facial profunda</strong>,
            <strong>rejuvenecimiento</strong>, <strong>peelings químicos</strong>
            controlados y <strong>tratamiento antiacné</strong>. Cada sesión
            queda documentada en expediente clínico digital con producto,
            lote, dosis, técnica y respuesta cutánea — para que el plan se
            afine sesión a sesión hasta el resultado.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================ NAV TOP — otras categorías ============================ -->
  <HeroNavBar
    label="Otras categorías"
    ariaLabel="Otras categorías de tratamientos CLIBEL"
    variant="cream"
    links={[
      { label: 'Corporales',         href: catHref('corporal') },
      { label: 'Depilación láser',   href: catHref('laser') },
      { label: 'Medicina estética',  href: catHref('medicina-estetica') },
      { label: 'Capilares',          href: catHref('capilar') },
    ]}
    cta={{ label: 'Volver al catálogo', href: '/servicios' }}
  />

  <!-- ============================ CATÁLOGO FACIAL ============================ -->
  <section class="section bg-white">
    <div class="container-x">
      <SectionHeader
        kicker={`Catálogo · ${items.length} tratamientos`}
        title="Tratamientos faciales en <em>CLIBEL</em>."
        paragraphs={[
          '<strong>CLIBEL</strong> realiza tratamientos faciales con grado clínico: cada protocolo se diseña a medida tras valoración médica, con productos certificados por COFEPRIS y técnicos capacitados bajo supervisión profesional. CLIBEL aborda piel grasa, mixta, sensible, con manchas, acné, signos de edad o todo lo anterior.',
          'Cada tratamiento facial en <strong>CLIBEL</strong> documenta producto, lote, parámetros y respuesta cutánea en tu expediente digital. Esto permite a CLIBEL ajustar el plan sesión a sesión y validar resultados con fotografía clínica comparativa.',
        ]}
        cta={{ label: 'Solicitar valoración', href: '/contacto', variant: 'primary' }}
      />

      <div class="cat-grid">
        {items.map((s) => (
          <ServiceCard
            href={`/servicios/${s.id}`}
            title={s.data.title}
            description={s.data.description}
            category={s.data.category}
            duration={s.data.duration}
            sessions={s.data.sessions}
            icon={s.data.icon}
            featured={s.data.featured}
            benefits={s.data.benefits}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ============================ CONCERNS ============================ -->
  <section class="section bg-[color:var(--color-brand-50)]">
    <div class="container-x">
      <SectionHeader
        kicker="Qué resolvemos"
        title="Problemas faciales que atendemos en <em>CLIBEL</em>."
        paragraphs={[
          '<strong>CLIBEL</strong> trata las preocupaciones dermatológicas más comunes en piel mexicana: acné hormonal, melasma y manchas, signos de edad, poros dilatados, opacidad cutánea y rosácea. Cada motivo de consulta llega con su propio protocolo clínico — no aplicamos plantillas.',
          'En <strong>CLIBEL</strong> la valoración define el plan: combinamos limpieza, peelings, radiofrecuencia, microneedling y rutina domiciliaria según lo que tu piel realmente necesita. Sin sobre-tratar, sin recetar lo que no aporta resultado.',
        ]}
      />

      <div class="concern-grid">
        {concerns.map((c, i) => (
          <article class="concern reveal">
            <span class="concern-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="concern-title">{c.title}</h3>
            <p class="concern-text">{c.text}</p>
            <span class="concern-line" aria-hidden="true"></span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================ TECNOLOGÍA Y PRODUCTOS ============================ -->
  <section class="section bg-white">
    <div class="container-x">
      <SectionHeader
        kicker="Tecnología y productos"
        title="Lo que <em>CLIBEL</em> usa en cada sesión facial."
        paragraphs={[
          '<strong>CLIBEL</strong> opera con plataformas clínicas de marcas certificadas y productos con registro sanitario COFEPRIS visible. Cada paciente puede consultar lote, fecha y trazabilidad de los insumos aplicados en su sesión — la transparencia es parte del protocolo.',
          'En <strong>CLIBEL</strong> no improvisamos parámetros ni concentraciones: cada equipo se calibra antes de la sesión y cada producto se documenta en expediente. Esto convierte a CLIBEL en una alternativa segura frente a spas y salas de belleza sin respaldo médico.',
        ]}
      />

      <div class="stack-grid">
        {stack.map((item, i) => (
          <article class="stack-item reveal">
            <span class="stack-kicker">{item.kicker}</span>
            <h3 class="stack-value">{item.value}</h3>
            <p class="stack-detail">{item.detail}</p>
            <span class="stack-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================ DIAGNÓSTICO DERMATOLÓGICO ============================ -->
  <section class="section svc-diag">
    <div aria-hidden="true" class="svc-diag-bg"></div>

    <div class="container-x relative">
      <SectionHeader
        kicker="Diagnóstico dermatológico"
        title="4 pasos antes de tocar tu <em>piel</em>."
        variant="dark"
        paragraphs={[
          'La diferencia entre <strong>CLIBEL</strong> y una clínica facial promedio empieza ANTES del tratamiento. Aplicar peeling o limpieza sin diagnóstico es como recetar antibiótico sin saber qué bacteria. CLIBEL no improvisa: primero diagnostica, después trata.',
          'Este proceso de 4 pasos diagnósticos es <strong>obligatorio</strong> en CLIBEL para cualquier plan facial. Si una clínica te ofrece tratamiento sin pasar por esto, el resultado será mediocre y posiblemente contraindicado para tu tipo de piel.',
        ]}
      />

      <ol class="diag-list">
        {diagnosis.map((d) => (
          <li class="diag-item reveal">
            <span class="diag-num" aria-hidden="true">{d.n}</span>
            <div class="diag-body">
              <h3 class="diag-title">{d.title}</h3>
              <p class="diag-text">{d.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============================ CASOS CLÍNICOS / PLANES ============================ -->
  <section class="section bg-[color:var(--color-brand-50)]">
    <div class="container-x">
      <SectionHeader
        kicker="Planes por objetivo"
        title="Casos clínicos que aborda <em>CLIBEL</em>."
        paragraphs={[
          '<strong>CLIBEL</strong> diseña planes faciales según objetivo clínico específico: control de acné, atenuación de manchas, rejuvenecimiento progresivo o mantenimiento de piel sana. Cada plan combina técnicas, frecuencia y seguimiento ajustado al perfil del paciente.',
          'Estos planes son <strong>orientativos</strong>. CLIBEL siempre personaliza tras diagnóstico dermatológico real — si tu caso no encaja en ninguno, diseñamos uno a medida basado en evidencia clínica y respuesta de tu piel.',
        ]}
      />

      <div class="cases-grid">
        {cases.map((c, i) => (
          <article class={`case case--${c.accent} reveal`}>
            <header class="case-head">
              <span class="case-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <div>
                <span class="case-kicker">Plan facial</span>
                <h3 class="case-name">{c.name}</h3>
                <span class="case-duration">{c.duration}</span>
              </div>
            </header>

            <div class="case-profile">
              <span class="case-profile-label">Perfil</span>
              <span class="case-profile-value">{c.profile}</span>
            </div>

            <div class="case-combo">
              <span class="case-combo-label">Incluye</span>
              <ul>
                {c.combo.map((proc) => (
                  <li>
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    {proc}
                  </li>
                ))}
              </ul>
            </div>

            <p class="case-target">{c.target}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================ PRE / POST PROTOCOLOS ============================ -->
  <section class="section svc-protocols">
    <div class="container-x">
      <SectionHeader
        kicker="Protocolos pre / post sesión"
        title="Lo que <em>CLIBEL</em> indica antes y después."
        variant="dark"
        paragraphs={[
          '<strong>CLIBEL</strong> entrega protocolo pre y post sesión por escrito. Seguirlo no es opcional: la eficacia del tratamiento facial y tu seguridad cutánea dependen de cumplir estas indicaciones. CLIBEL prefiere reagendar antes que aplicar sobre piel mal preparada.',
          'En <strong>CLIBEL</strong> tu médico revisa el cumplimiento antes de cada sesión. Si tu piel no está lista o tienes contraindicación temporal, reagendamos sin penalización — es responsabilidad clínica, no comercial.',
        ]}
      />

      <div class="protocol-grid">
        <article class="protocol reveal">
          <header class="protocol-head">
            <span class="protocol-tag protocol-tag--pre">Antes</span>
            <h3 class="protocol-title">Pre-sesión</h3>
          </header>
          <ol class="protocol-list">
            {protocols.pre.map((p, i) => (
              <li>
                <span class="protocol-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                <span>{p}</span>
              </li>
            ))}
          </ol>
        </article>

        <article class="protocol reveal">
          <header class="protocol-head">
            <span class="protocol-tag protocol-tag--post">Después</span>
            <h3 class="protocol-title">Post-sesión</h3>
          </header>
          <ol class="protocol-list">
            {protocols.post.map((p, i) => (
              <li>
                <span class="protocol-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                <span>{p}</span>
              </li>
            ))}
          </ol>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================ AFTERCARE ============================ -->
  <section class="section svc-aftercare">
    <div aria-hidden="true" class="svc-aftercare-bg"></div>
