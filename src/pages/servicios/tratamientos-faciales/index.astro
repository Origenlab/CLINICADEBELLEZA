  <script is:inline define:vars={{ waBase: `https://wa.me/${CONTACT.whatsapp}` }}>
    (function () {
      const form = document.getElementById('facialWaForm');
      if (!form) return;

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const data = new FormData(form);
        const nombre  = (data.get('nombre')   || '').toString().trim();
        const tel     = (data.get('telefono') || '').toString().trim();
        const email   = (data.get('email')    || '').toString().trim();
        const interes = (data.get('interes')  || '').toString().trim();
        const msg     = (data.get('mensaje')  || '').toString().trim();
        const acepto  = data.get('privacidad') === 'on' || form.querySelector('[name="privacidad"]').checked;

        if (!nombre || !tel || !acepto) {
          form.classList.add('is-invalid');
          return;
        }
        form.classList.remove('is-invalid');

        const lines = [
          'Hola CLIBEL, vengo desde la página de Tratamientos Faciales.',
          '',
          'Nombre: ' + nombre,
          'Teléfono: ' + tel,
        ];
        if (email)   lines.push('Email: ' + email);
        if (interes) lines.push('Me interesa: ' + interes);
        if (msg)     lines.push('', 'Comentario: ' + msg);

        const text = encodeURIComponent(lines.join('\n'));
        const url = waBase + '?text=' + text;
        window.open(url, '_blank', 'noopener');
      });
    })();
  </script>

