---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import HeroNavBar from '../../../components/HeroNavBar.astro';
import RelatedCategories from '../../../components/RelatedCategories.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, SITE, catHref } from '../../../consts';

const cat = CATEGORIES.facial;

const all = await getCollection('servicios');
const items = all
  .filter((s) => s.data.category === 'facial')
  .sort((a, b) => a.data.order - b.data.order);

// Schemas
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Servicios', item: `${SITE.url}/servicios` },
    { '@type': 'ListItem', position: 3, name: 'Tratamientos Faciales', item: `${SITE.url}/servicios/tratamientos-faciales` },
  ],
};
const catalogSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalSpecialty',
  name: 'Tratamientos Faciales — CLIBEL',
  description: 'Limpieza facial profunda, rejuvenecimiento, peelings químicos y tratamiento antiacné con respaldo médico en CDMX.',
  url: `${SITE.url}/servicios/tratamientos-faciales`,
  provider: { '@id': `${SITE.url}/#clinic` },
  relevantSpecialty: 'Dermatology',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Catálogo de tratamientos faciales CLIBEL',
    itemListElement: items.map((s) => ({
      '@type': 'MedicalProcedure',
      name: s.data.title,
      description: s.data.description,
      url: `${SITE.url}/servicios/${s.id}`,
    })),
  },
};

// === Editorial leads por L4 (humanizados, originales · usados en sección Profundiza) ===
const editorialLedes: Record<string, { lede: string; readMore: string }> = {
  'limpieza-facial-profunda': {
    lede: 'El reset clínico que cualquier rostro pide al menos una vez al mes. No es servicio de spa: es el protocolo de siete pasos que mantiene tu piel funcional, sin la acumulación de comedones ni la sensación de "piel cargada" que se vuelve crónica en CDMX.',
    readMore: 'Ver protocolo de 7 pasos',
  },
  'rejuvenecimiento-facial': {
    lede: 'Para cuando la piel pide algo más que limpieza pero aún no quieres inyectables. Radiofrecuencia, mesoterapia con antioxidantes, peelings suaves y LED en un plan progresivo que respeta cómo el colágeno realmente madura — entre seis y doce semanas, no en una sesión milagrosa.',
    readMore: 'Ver protocolo combinado',
  },
  'peelings-quimicos': {
    lede: 'Renovación calibrada por fototipo. AHA para luminosidad, BHA para acné, despigmentantes para melasma, TCA superficial para cicatrices: la modalidad correcta no es la más fuerte, es la mínima eficaz aplicada con monitoreo en tiempo real.',
    readMore: 'Ver las 4 modalidades',
  },
  'tratamiento-antiacne': {
    lede: 'El acné se clasifica antes de tratarse. Grado I a IV, hormonal o no, con o sin marcas residuales — cada cuadro pide protocolo distinto. Peeling salicílico, mesoterapia seborreguladora, LED azul antibacteriano y rutina domiciliaria que se revisa cada cuatro semanas.',
    readMore: 'Ver casos clínicos y grados',
  },
};

// === Diagnóstico dermatológico previo (NUEVO — homologa con otros L3) ===
const diagnosis = [
  {
    n: '01',
    title: 'Análisis cutáneo profesional',
    text: 'CLIBEL evalúa con diagnóstico digital tu tipo de piel, fototipo, hidratación, sensibilidad, daño solar y poros. Sin este paso ningún protocolo facial se ajusta a tu realidad clínica.',
  },
  {
    n: '02',
    title: 'Historia clínica completa',
    text: 'Antecedentes alérgicos, hormonales, medicamentos fotosensibles, dermatitis previas y embarazo. CLIBEL pregunta antes de aplicar — la seguridad cutánea empieza en la conversación.',
  },
  {
    n: '03',
    title: 'Identificación de motivos',
    text: 'Acné, manchas, rosácea, líneas, opacidad, deshidratación — cada uno requiere protocolo distinto. CLIBEL prioriza el motivo principal y aborda secundarios sin sobrecargar la piel.',
  },
  {
    n: '04',
    title: 'Plan documentado por escrito',
    text: 'Diagnóstico, plan de sesiones, rutina domiciliaria y expectativas realistas. CLIBEL entrega todo por escrito antes de empezar — para que decidas con información completa.',
  },
];

// === Casos clínicos / planes faciales por objetivo (combos linkados a L4) ===
const cases: { name: string; duration: string; profile: string; combo: { label: string; href?: string }[]; target: string; accent: 'gold' | 'mauve' | 'rose'; primaryHref?: string }[] = [
  {
    name: 'Plan piel grasa con acné activo',
    duration: '4–6 sesiones · 3 meses',
    profile: 'Pieles 18–35 años con brotes recurrentes',
    combo: [
      { label: 'Limpieza facial profunda mensual', href: '/servicios/limpieza-facial-profunda' },
      { label: 'Peeling salicílico fraccionado', href: '/servicios/peelings-quimicos' },
      { label: 'Mesoterapia seborreguladora', href: '/servicios/tratamiento-antiacne' },
      { label: 'Rutina domiciliaria con BHA supervisada' },
    ],
    target: 'Controlar brotes activos, regular la producción de sebo y prevenir cicatrices post-acné. La rutina domiciliaria es la mitad del plan — sin ella, los resultados no se sostienen.',
    accent: 'gold',
    primaryHref: '/servicios/tratamiento-antiacne',
  },
  {
    name: 'Plan antimanchas y melasma',
    duration: '6 sesiones · 4 meses',
    profile: 'Pieles 30+ con melasma o fotoenvejecimiento',
    combo: [
      { label: 'Peelings despigmentantes progresivos', href: '/servicios/peelings-quimicos' },
      { label: 'Hidratación clínica intermedia' },
      { label: 'Protección solar SPF 50+ estricta', href: '/servicios/peelings-quimicos' },
      { label: 'Rutina domiciliaria con niacinamida + vitamina C' },
    ],
    target: 'Uniformar tono cutáneo, atenuar manchas y prevenir recidiva. La pigmentación responde con paciencia clínica — no con concentraciones agresivas aplicadas de golpe.',
    accent: 'mauve',
    primaryHref: '/servicios/peelings-quimicos',
  },
  {
    name: 'Plan rejuvenecimiento integral',
    duration: '5 sesiones · 3 meses + mantenimiento',
    profile: 'Pieles 35+ con primeras líneas y pérdida de firmeza',
    combo: [
      { label: 'Rejuvenecimiento facial combinado', href: '/servicios/rejuvenecimiento-facial' },
      { label: 'Microneedling con activos' },
      { label: 'Radiofrecuencia facial reafirmante', href: '/servicios/rejuvenecimiento-facial' },
      { label: 'Cosmecéuticos profesionales' },
    ],
    target: 'Mejorar textura, firmeza y luminosidad. Progresión sin invasividad, con resultados verificables en fotografía clínica comparativa al mes 3.',
    accent: 'rose',
    primaryHref: '/servicios/rejuvenecimiento-facial',
  },
  {
    name: 'Plan mantenimiento mensual',
    duration: 'Indefinido · 1 sesión / mes',
    profile: 'Pacientes con plan ya consolidado',
    combo: [
      { label: 'Limpieza facial profunda mensual', href: '/servicios/limpieza-facial-profunda' },
      { label: 'Hidratación enzimática' },
      { label: 'Revisión y ajuste de rutina' },
      { label: 'Fotografía clínica de control' },
    ],
    target: 'Sostener la calidad cutánea con rutina clínica ligera. Recomendado tras completar el plan intensivo para mantener resultados a largo plazo.',
    accent: 'gold',
    primaryHref: '/servicios/limpieza-facial-profunda',
  },
];

// === Pre / Post sesión protocolos (NUEVO) ===
const protocols = {
  pre: [
    'Suspender retinoides y ácidos exfoliantes 5–7 días antes',
    'Sin exposición solar intensa 48 h previas',
    'Asistir sin maquillaje denso ni cremas oclusivas',
    'Hidratación tópica diaria los días previos',
    'Avisar a CLIBEL si tomas medicamentos fotosensibles o tienes herpes recurrente',
  ],
  post: [
    'SPF 50+ obligatorio diariamente durante todo el plan',
    'Limpiadores suaves sin sulfatos las primeras 48 h',
    'Sin sauna, vapor ni piscina 24 h',
    'No exfoliar mecánicamente 5–7 días según protocolo',
    'Reportar a CLIBEL de inmediato cualquier reacción inesperada',
  ],
};

// === Qué resolvemos en faciales (cada concern enlaza al L4 que la atiende) ===
const concerns = [
  {
    title: 'Acné y brotes hormonales',
    text: 'Brotes activos, acné adulto hormonal, marcas residuales: cada cuadro responde a un protocolo distinto. Tu plan se construye sobre diagnóstico del grado clínico, no sobre limpieza facial genérica.',
    href: '/servicios/tratamiento-antiacne',
    linkLabel: 'Ver tratamiento antiacné',
  },
  {
    title: 'Manchas e hiperpigmentación',
    text: 'Melasma, fotoenvejecimiento y pigmentación post-inflamatoria piden paciencia clínica. Trabajamos con peelings despigmentantes progresivos, SPF estricto y rutina domiciliaria — no atajos.',
    href: '/servicios/peelings-quimicos',
    linkLabel: 'Ver peelings químicos',
  },
  {
    title: 'Líneas de expresión y arrugas',
    text: 'Para las primeras líneas y la pérdida de firmeza, antes de pensar en inyectables. Radiofrecuencia, mesoterapia con antioxidantes, peelings suaves y LED en un plan progresivo.',
    href: '/servicios/rejuvenecimiento-facial',
    linkLabel: 'Ver rejuvenecimiento facial',
  },
  {
    title: 'Poros dilatados y exceso de grasa',
    text: 'Comedones, sebo crónico y la sensación de "piel cargada" típica de Ciudad de México. La limpieza facial profunda es el punto de partida — siete pasos clínicos, no cosmética rápida.',
    href: '/servicios/limpieza-facial-profunda',
    linkLabel: 'Ver limpieza facial profunda',
  },
  {
    title: 'Piel apagada y deshidratada',
    text: 'Cuando la piel se ve cansada sin razón aparente: rutina rota, barrera deshidratada o falta de renovación celular. Combinación de limpieza profunda mensual con hidratación clínica y vitaminas tópicas.',
    href: '/servicios/limpieza-facial-profunda',
    linkLabel: 'Empezar con limpieza profunda',
  },
  {
    title: 'Rosácea y sensibilidad cutánea',
    text: 'Pieles reactivas exigen criterio antes que técnica. Calmantes profesionales, protocolos suaves y, sobre todo, diagnóstico previo que descarte qué activos disparan tu reacción.',
    href: '/contacto',
    linkLabel: 'Solicitar valoración',
  },
];

// === Tecnología y productos usados en faciales ===
const stack = [
  { kicker: 'Equipos clínicos', value: 'Radiofrecuencia facial', detail: 'Estimulación de colágeno y reafirmación' },
  { kicker: 'Equipos clínicos', value: 'Microneedling profesional', detail: 'Renovación cutánea controlada' },
  { kicker: 'Equipos clínicos', value: 'Diagnóstico digital de piel', detail: 'Evaluación cuantitativa antes de cada plan' },
  { kicker: 'Productos', value: 'Peelings médicos', detail: 'AHA, BHA, retinol controlado por concentración' },
  { kicker: 'Productos', value: 'Cosmecéuticos profesionales', detail: 'Marcas dermo-cosméticas con registro COFEPRIS' },
  { kicker: 'Productos', value: 'Despigmentantes médicos', detail: 'Aplicación supervisada en consulta' },
];

// === Aftercare ===
const aftercare = [
  {
    n: '01',
    title: 'Protección solar diaria',
    text: 'SPF 50+ aplicado cada mañana es la condición no negociable de cualquier tratamiento facial — sin él, las manchas vuelven y el daño solar borra el avance clínico. CLIBEL entrega producto compatible con tu tipo de piel.',
  },
  {
    n: '02',
    title: 'Hidratación clínica diaria',
    text: 'Rutina de hidratación y reparación de barrera diseñada según tu tipo de piel y la fase del tratamiento. La barrera dérmica sana es la base de cualquier resultado facial sostenido.',
  },
  {
    n: '03',
    title: 'Suspensiones y precauciones',
    text: 'CLIBEL te indica por escrito qué activos suspender — retinoides, ácidos exfoliantes, retinol cosmético — y por cuánto tiempo según el procedimiento aplicado. Sin esa información, la sesión siguiente puede ser contraindicada.',
  },
  {
    n: '04',
    title: 'Seguimiento programado',
    text: 'Agendamos revisiones a 7, 30 y 90 días con fotografía clínica comparativa. Validamos resultado con evidencia objetiva, no con percepción subjetiva, y ajustamos el plan si la piel no responde como esperábamos.',
  },
];

// === FAQs específicas faciales (humanizadas + interlinking a L4s vía answerHtml) ===
const faqs: { q: string; answerHtml: string }[] = [
  {
    q: '¿Con qué frecuencia debo hacerme una limpieza facial profunda?',
    answerHtml: 'Una sesión al mes es la base para piel sana; cada 15–21 días si tu piel es grasa, mixta o con tendencia comedónica activa. La frecuencia final sale de tu valoración, no de un calendario genérico. <a href="/servicios/limpieza-facial-profunda">Conoce el protocolo de 7 pasos →</a>',
  },
  {
    q: '¿Los peelings químicos descaman mucho?',
    answerHtml: 'Depende de la modalidad. Los AHA superficiales que usamos producen descamación fina, casi imperceptible. Los BHA y despigmentantes son medios — descamación visible 3 a 5 días. El TCA superficial se reserva para casos específicos con downtime documentado. <a href="/servicios/peelings-quimicos">Mira las 4 modalidades →</a>',
  },
  {
    q: '¿En cuántas sesiones desaparecen mis manchas?',
    answerHtml: 'El melasma y la pigmentación post-inflamatoria responden con paciencia clínica: 4 a 6 sesiones espaciadas, SPF 50+ obligatorio diario y rutina domiciliaria estricta. Documentamos con foto comparativa basal y cualquier promesa de "manchas borradas en 2 sesiones" es marketing, no medicina estética.',
  },
  {
    q: '¿Puedo combinar varios tratamientos faciales en un plan?',
    answerHtml: 'Sí — de hecho es la forma más eficaz para casos complejos. Combinamos <a href="/servicios/limpieza-facial-profunda">limpieza profunda</a> mensual + <a href="/servicios/peelings-quimicos">peeling</a> quincenal + <a href="/servicios/rejuvenecimiento-facial">rejuvenecimiento</a> según diagnóstico. El plan se diseña respetando ventanas de recuperación cutánea: nunca sobrecargamos la barrera dérmica.',
  },
  {
    q: '¿Cuál es la diferencia entre un facial de spa y este protocolo?',
    answerHtml: 'Diagnóstico previo, productos con registro COFEPRIS, técnica supervisada por personal capacitado, manejo clínico de la inflamación, expediente fotográfico y ajustes cada 4 semanas. Un spa cumple para mantenimiento cosmético rápido; CLIBEL trabaja para resultado clínico documentable.',
  },
  {
    q: '¿Los tratamientos faciales son seguros durante el embarazo?',
    answerHtml: 'La <a href="/servicios/limpieza-facial-profunda">limpieza facial</a> y la hidratación clínica son seguras en la mayoría de los casos. Los peelings con activos contraindicados (retinoides, salicílico medio, despigmentantes con hidroquinona) y la mesoterapia se posponen. Valoramos cada caso por separado y adaptamos un plan compatible con embarazo o lactancia.',
  },
  {
    q: 'Tengo acné moderado, ¿por dónde empiezo?',
    answerHtml: 'Por la valoración: lo primero es clasificar el grado clínico (I a IV) y descartar causa hormonal subyacente. El <a href="/servicios/tratamiento-antiacne">tratamiento antiacné CLIBEL</a> combina limpieza profunda, peeling salicílico, mesoterapia seborreguladora y LED azul antibacteriano — ajustado a tu cuadro real, no a un paquete promocional.',
  },
];
---

<BaseLayout
  title={`${cat.label} en CDMX | CLIBEL`}
  description={`${cat.label} en CLIBEL: limpieza facial profunda, rejuvenecimiento, peelings químicos y antiacné con respaldo médico, productos COFEPRIS y diagnóstico previo gratuito en CDMX.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(catalogSchema)} />

  <!-- ============================ BREADCRUMB ============================ -->
  <Breadcrumb
    kicker="Categoría 01 · Faciales"
    items={[
      { label: 'Servicios', href: '/servicios' },
      { label: 'Tratamientos Faciales' },
    ]}
  />

  <!-- ============================ HERO ============================ -->
  <section class="cat-hero">
    <div aria-hidden="true" class="cat-hero-bg"></div>
    <div aria-hidden="true" class="cat-hero-blob cat-hero-blob-1"></div>
    <div aria-hidden="true" class="cat-hero-blob cat-hero-blob-2"></div>
    <div aria-hidden="true" class="cat-hero-grain"></div>

    <div class="container-x relative">
      <div class="cat-hero-grid">
        <!-- LEFT — brand statement -->
        <div class="cat-hero-col cat-hero-col--left fade-up">
          <span class="eyebrow-tag">
            <span class="dot" aria-hidden="true"></span>
            Categoría 01 · {cat.badgeLabel} · {items.length} tratamientos
          </span>

          <h1 class="cat-hero-headline">
            <span class="cat-hero-headline-line">Tratamientos</span>
            <span class="cat-hero-headline-line"><em>faciales</em> en CDMX.</span>
          </h1>

          <p class="cat-hero-lede">
            Renovación, luminosidad y salud de la piel con
            <strong>respaldo médico real</strong>. CLIBEL atiende cada
            rostro con diagnóstico previo, productos certificados y planes
            documentados sesión a sesión.
          </p>

          <div class="cat-hero-trust">
            <span class="cat-hero-trust-label">Trabajamos con</span>
            <div class="cat-hero-trust-list">
              <span>Allergan</span><span aria-hidden="true">·</span>
              <span>Galderma</span><span aria-hidden="true">·</span>
              <span>Merz</span><span aria-hidden="true">·</span>
              <span>SkinCeuticals</span><span aria-hidden="true">·</span>
              <span>Mesoestetic</span>
            </div>
          </div>
        </div>

        <!-- RIGHT — 2 párrafos explicativos CLIBEL -->
        <div class="cat-hero-col cat-hero-col--right fade-up-delay-2">
          <span class="cat-hero-kicker">Qué hace CLIBEL en faciales</span>

          <p class="cat-hero-paragraph">
            <strong>CLIBEL</strong> es una clínica de belleza con criterio
            médico, especializada en cuidado facial profesional en Ciudad
            de México. Cada protocolo nace de una valoración real
            — fototipo, sensibilidad, antecedentes hormonales, motivo
            principal — y se construye con cosmecéuticos certificados por
            COFEPRIS y supervisión médica directa. Sin paquetes prearmados
            ni plantillas de cabina.
          </p>

          <p class="cat-hero-paragraph">
            En esta categoría reunimos los cuatro protocolos faciales más
            solicitados: <a href="/servicios/limpieza-facial-profunda"><strong>limpieza facial profunda</strong></a>,
            <a href="/servicios/rejuvenecimiento-facial"><strong>rejuvenecimiento</strong></a>,
            <a href="/servicios/peelings-quimicos"><strong>peelings químicos</strong></a>
            calibrados y <a href="/servicios/tratamiento-antiacne"><strong>tratamiento antiacné</strong></a>.
            Cada sesión queda documentada en expediente digital con producto,
            lote, dosis, técnica y respuesta cutánea — para que el plan se
            afine sesión a sesión hasta el resultado.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================ NAV TOP — otras categorías ============================ -->
  <HeroNavBar
    label="Otras categorías"
    ariaLabel="Otras categorías de tratamientos CLIBEL"
    variant="cream"
    links={[
      { label: 'Corporales',         href: catHref('corporal') },
      { label: 'Depilación láser',   href: catHref('laser') },
      { label: 'Medicina estética',  href: catHref('medicina-estetica') },
      { label: 'Capilares',          href: catHref('capilar') },
    ]}
    cta={{ label: 'Volver al catálogo', href: '/servicios' }}
  />

  <!-- ============================ CATÁLOGO FACIAL ============================ -->
  <section class="section bg-white">
    <div class="container-x">
      <SectionHeader
        kicker={`Catálogo · ${items.length} tratamientos`}
        title="Los protocolos faciales<br/>que aplica <em>CLIBEL</em>."
        paragraphs={[
          'Cada protocolo facial de <strong>CLIBEL</strong> nace de un diagnóstico real, no de una plantilla. Trabajamos piel grasa, mixta o sensible; manchas, acné, signos de edad o todo lo anterior — siempre con productos COFEPRIS y técnica supervisada por personal médico.',
          'Cada sesión documenta producto, lote, parámetros y respuesta cutánea en tu expediente digital. Eso es lo que permite a <strong>CLIBEL</strong> ajustar el plan sesión a sesión y validar resultados con fotografía clínica comparativa — no con percepción subjetiva.',
        ]}
        cta={{ label: 'Solicitar valoración', href: '/contacto', variant: 'primary' }}
      />

      <div class="cat-grid">
        {items.map((s) => (
          <ServiceCard
            href={`/servicios/${s.id}`}
            title={s.data.title}
            description={s.data.description}
            category={s.data.category}
            duration={s.data.duration}
            sessions={s.data.sessions}
            icon={s.data.icon}
            featured={s.data.featured}
            benefits={s.data.benefits}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ============================ PROFUNDIZA · interlinking L3 → L4 ============================ -->
  <section class="section bg-[color:var(--color-brand-50)]">
    <div class="container-x">
      <SectionHeader
        marginBottom="md"
        kicker="Profundiza en cada protocolo"
        title="Cada tratamiento facial<br/>en <em>CLIBEL</em>, en detalle."
        paragraphs={[
          'Estos son los protocolos faciales que <strong>CLIBEL</strong> aplica como base de la categoría. Cada uno tiene su propia página clínica con pasos, modalidades, comparativas y casos reales — para que llegues a tu valoración con información completa, no con marketing.',
          'Si no sabes por dónde empezar, la <strong>limpieza facial profunda</strong> mensual es la entrada lógica para casi cualquier perfil. Lo demás se construye encima en función de tu motivo de consulta.',
        ]}
      />

      <ol class="spot-list">
        {items.map((s, i) => {
          const meta = editorialLedes[s.id];
          const topBen = (s.data.benefits ?? []).slice(0, 2);
          return (
            <li class="spot reveal">
              <div class="spot-num-wrap" aria-hidden="true">
                <span class="spot-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="spot-num-line"></span>
              </div>

              <div class="spot-body">
                <header class="spot-head">
                  <span class="spot-kicker">{s.data.icon ?? '✦'} {cat.short} · Protocolo {String(i + 1).padStart(2, '0')}</span>
                  <h3 class="spot-title">
                    <a href={`/servicios/${s.id}`}>{s.data.title}</a>
                  </h3>
                </header>

                <dl class="spot-meta">
                  {s.data.duration && (
                    <div>
                      <dt>Duración</dt>
                      <dd>{s.data.duration}</dd>
                    </div>
                  )}
                  {s.data.sessions && (
                    <div>
                      <dt>Frecuencia</dt>
                      <dd>{s.data.sessions.split('·')[0].trim()}</dd>
                    </div>
                  )}
                  {(s.data.protocolSteps?.length ?? 0) > 0 && (
                    <div>
                      <dt>Pasos clínicos</dt>
