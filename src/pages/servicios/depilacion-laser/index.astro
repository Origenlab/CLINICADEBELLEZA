---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import HeroNavBar from '../../../components/HeroNavBar.astro';
import RelatedCategories from '../../../components/RelatedCategories.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, SITE, CONTACT, catHref } from '../../../consts';

const cat = CATEGORIES.laser;

const all = await getCollection('servicios');
const items = all
  .filter((s) => s.data.category === 'laser')
  .sort((a, b) => a.data.order - b.data.order);

const wa = `https://wa.me/${CONTACT.whatsapp}?text=${encodeURIComponent('Hola, me gustaría agendar mi sesión de depilación láser en CLIBEL.')}`;

// ============ SCHEMAS SEO ============
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Servicios', item: `${SITE.url}/servicios` },
    { '@type': 'ListItem', position: 3, name: 'Depilación Láser', item: `${SITE.url}/servicios/depilacion-laser` },
  ],
};
const catalogSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalSpecialty',
  name: 'Depilación Láser — CLIBEL',
  description: 'Depilación láser profesional para todas las zonas del cuerpo con tecnología Alexandrita y Nd:YAG, segura para todos los fototipos.',
  url: `${SITE.url}/servicios/depilacion-laser`,
  provider: { '@id': `${SITE.url}/#clinic` },
  relevantSpecialty: ['Dermatology'],
};

// ============ ZONAS — catálogo por área anatómica (NUEVO) ============
const zones = [
  { area: 'Rostro',  zone: 'Bigote',          duration: '10 min', sessions: '6–8',  note: 'Hormonal' },
  { area: 'Rostro',  zone: 'Mentón',          duration: '10 min', sessions: '6–10', note: 'Hormonal' },
  { area: 'Rostro',  zone: 'Patillas',        duration: '10 min', sessions: '6–8',  note: '' },
  { area: 'Rostro',  zone: 'Rostro completo', duration: '25 min', sessions: '6–8',  note: 'Combinación zonas' },
  { area: 'Tronco',  zone: 'Axilas',          duration: '15 min', sessions: '6–8',  note: 'Más solicitada' },
  { area: 'Tronco',  zone: 'Espalda completa',duration: '40 min', sessions: '6–8',  note: '' },
  { area: 'Tronco',  zone: 'Pecho',           duration: '25 min', sessions: '6–8',  note: '' },
  { area: 'Tronco',  zone: 'Abdomen',         duration: '20 min', sessions: '6–8',  note: 'Línea o completo' },
  { area: 'Inguinal',zone: 'Bikini básico',   duration: '15 min', sessions: '6–8',  note: '' },
  { area: 'Inguinal',zone: 'Brasileño completo', duration: '25 min', sessions: '6–10', note: 'Hormonal' },
  { area: 'Piernas', zone: 'Piernas completas',  duration: '50 min', sessions: '6–8',  note: '' },
  { area: 'Piernas', zone: 'Medias piernas',  duration: '30 min', sessions: '6–8',  note: '' },
];

// ============ TECNOLOGÍAS LÁSER (NUEVO — comparación clínica) ============
const lasers = [
  {
    name: 'Alexandrita',
    wavelength: '755 nm',
    fototipo: 'I, II, III',
    target: 'Pieles claras a medias con vello oscuro',
    detail: 'Mayor afinidad por melanina del folículo, sesiones más rápidas en pieles claras. CLIBEL la usa como primera línea en fototipos I-III.',
    accent: 'gold',
  },
  {
    name: 'Nd:YAG',
    wavelength: '1064 nm',
    fototipo: 'IV, V, VI',
    target: 'Pieles morenas, latinas e indígenas con todo tipo de vello',
    detail: 'Penetración más profunda con menor absorción en la epidermis. CLIBEL la prioriza en pieles morenas para evitar quemaduras o hipopigmentación.',
    accent: 'mauve',
  },
  {
    name: 'Diodo',
    wavelength: '810 nm',
    fototipo: 'II, III, IV (versátil)',
    target: 'Pieles intermedias con vello grueso a fino',
    detail: 'Compromiso entre velocidad y seguridad. CLIBEL lo emplea cuando el fototipo es intermedio o cuando hay variación entre zonas del cuerpo.',
    accent: 'rose',
  },
];

// ============ FOTOTIPOS — guía Fitzpatrick (NUEVO) ============
const fototipos = [
  { code: 'I',   label: 'Muy clara',  detail: 'Se quema siempre, nunca broncea',  laser: 'Alexandrita' },
  { code: 'II',  label: 'Clara',      detail: 'Se quema fácil, broncea mínimo',  laser: 'Alexandrita' },
  { code: 'III', label: 'Intermedia', detail: 'Se quema a veces, broncea progresivo', laser: 'Alexandrita / Diodo' },
  { code: 'IV',  label: 'Trigueña',   detail: 'Rara vez se quema, broncea fácil', laser: 'Diodo / Nd:YAG' },
  { code: 'V',   label: 'Morena',     detail: 'Casi nunca se quema, muy morena', laser: 'Nd:YAG' },
  { code: 'VI',  label: 'Negra',      detail: 'Nunca se quema, profundamente morena', laser: 'Nd:YAG' },
];

// ============ CICLO DE CRECIMIENTO (NUEVO) ============
const cycle = [
  {
    phase: 'Anágena',
    coverage: '~30%',
    text: 'Fase de crecimiento activo donde el folículo tiene mayor concentración de melanina. Es la única fase donde el láser destruye eficazmente el folículo.',
  },
  {
    phase: 'Catágena',
    coverage: '~2%',
    text: 'Fase de transición breve. El folículo se desconecta de la papila y empieza a involucionar. Respuesta limitada al láser.',
  },
  {
    phase: 'Telógena',
    coverage: '~68%',
    text: 'Fase de reposo. El vello no está conectado a la melanina activa. Por eso CLIBEL espacia las sesiones cada 5–8 semanas para que más folículos entren en anágena.',
  },
];

// ============ Calendario visual del plan (8 sesiones · 6 meses) ============
const calendar = [
  { mes: 'Mes 01', sesion: '01', label: 'Inicio del plan', text: 'Primera sesión completa. Prueba de parche ya validada en valoración. Documentación basal: foto multi-ángulo, fluencia y respuesta inmediata.', accent: 'gold' },
  { mes: 'Mes 02', sesion: '02', label: 'Confirmación de respuesta', text: 'Folículos en anágena del segundo lote. Reducción visible del 20–30% del vello total. Ajuste de fluencia si la zona lo permite.', accent: 'gold' },
  { mes: 'Mes 03', sesion: '03', label: 'Reducción progresiva', text: 'Tercera sesión. Reducción acumulada típica del 40–50%. El folículo destruido no vuelve; los nuevos en anágena se tratan ahora.', accent: 'mauve' },
  { mes: 'Mes 04', sesion: '04', label: 'Hito clínico medio', text: 'Punto formal de evaluación con foto comparativa. Si la respuesta es lenta, ajustamos fluencia o tecnología. Si va bien, mantenemos parámetros.', accent: 'mauve' },
  { mes: 'Mes 05', sesion: '05', label: 'Folículos rebeldes', text: 'Trabajo de folículos más resistentes — bigote y brasileño suelen requerir fluencia ligeramente mayor en esta sesión. Reducción acumulada 65–75%.', accent: 'rose' },
  { mes: 'Mes 06', sesion: '06', label: 'Consolidación del plan', text: 'Reducción acumulada típica del 80–90% en zonas estándar. Cierre del plan inicial. CLIBEL evalúa necesidad de sesiones 07–08 según zona.', accent: 'rose' },
  { mes: 'Mes 08', sesion: '07', label: 'Sesión de cierre (si aplica)', text: 'Solo para zonas hormonales o de alta densidad folicular. Foco en folículos remanentes activados después del plan inicial.', accent: 'gold' },
  { mes: 'Mes 10', sesion: '08', label: 'Última sesión (zonas hormonales)', text: 'Cierre completo para bigote, mentón o brasileño. Después, plan de mantenimiento bimestral solo si el folículo hormonal lo requiere.', accent: 'gold' },
];

// ============ Compromisos del paciente (lo que aportas tú) ============
const commitments: { title: string; text: string; weight: 'Imprescindible' | 'Recomendado' | 'Opcional' }[] = [
  {
    title: 'Sin sol ni bronceado durante el plan',
    text: 'El sol activa melanina y aumenta riesgo de hiperpigmentación post-láser. SPF 50+ diario obligatorio en las zonas tratadas. Si te bronceas, el plan se pausa hasta que la piel vuelva a su tono basal.',
    weight: 'Imprescindible',
  },
  {
    title: 'Rasurar 24 h antes de cada sesión',
    text: 'La zona debe llegar rasurada — no con cera, no con pinzas, no con depilatorios químicos. El vello superficial absorbe energía y reduce eficacia; los métodos que arrancan eliminan el folículo (target del láser).',
    weight: 'Imprescindible',
  },
  {
    title: 'NO cera ni pinzas entre sesiones',
    text: 'Cera y pinzas extraen el folículo entero, eliminando el target del láser para la siguiente sesión. Entre sesiones solo se permite rasurado. Si necesitas reducir vello visible, espera al día de la cita.',
    weight: 'Imprescindible',
  },
  {
    title: 'Constancia con el calendario',
    text: 'Saltarse sesiones pierde sincronía con la fase anágena del folículo. El plan se puede alargar y retomar con criterio, pero la constancia acorta el resultado final y mejora la respuesta documentada.',
    weight: 'Recomendado',
  },
  {
    title: 'Cosmecéuticos calmantes en casa',
    text: 'Aloe vera puro, geles con avena o pantenol los primeros 2 días post-sesión potencian la recuperación cutánea. CLIBEL los recomienda según tu tipo de piel — no son obligatorios, sí potencian.',
    weight: 'Opcional',
  },
];

// ============ Comparativa clínica (vs casa / spa / CLIBEL) ============
const comparison: { aspect: string; home?: string; spa?: string; clibel: string }[] = [
  {
    aspect: 'Valoración previa',
    home: 'Auto-evaluación sin clasificación de fototipo',
    spa: 'Visual rápido sin prueba de parche',
    clibel: 'Fototipo Fitzpatrick documentado + prueba de parche obligatoria + revisión de antecedentes',
  },
  {
    aspect: 'Tecnología disponible',
    home: 'Dispositivos IPL caseros (no son láser real)',
    spa: 'Una sola tecnología por equipo, sin ajuste por fototipo',
    clibel: 'Tres láseres (Alexandrita, Nd:YAG, Diodo) — se asigna por fototipo, no por disponibilidad',
  },
  {
    aspect: 'Manejo de fototipos altos (IV–VI)',
    home: 'Riesgo alto de hiperpigmentación',
    spa: 'Sin ajuste de equipo, riesgo de quemadura',
    clibel: 'Nd:YAG exclusivamente con fluencia conservadora inicial',
  },
  {
    aspect: 'Sistema de enfriamiento',
    home: 'Sin enfriamiento, sensación muy molesta',
    spa: 'Enfriamiento por aire o gel intermitente',
    clibel: 'Enfriamiento por contacto continuo en todo el cabezal',
  },
  {
    aspect: 'Documentación del plan',
    home: 'Sin métricas objetivas',
    spa: 'Sin expediente clínico',
    clibel: 'Fluencia, fototipo, zona, respuesta y % de reducción documentados sesión a sesión',
  },
  {
    aspect: 'Manejo de complicaciones',
    home: 'Sin recurso clínico',
    spa: 'Derivación a dermatólogo externo',
    clibel: 'Personal médico supervisa, WhatsApp clínico activo durante todo el plan',
  },
  {
    aspect: 'Honestidad sobre limitaciones',
    home: '—',
    spa: 'Promesas de "piel sin vello para siempre"',
    clibel: 'Honestidad sobre componente hormonal, vello rubio/cano y necesidad de mantenimiento en zonas específicas',
  },
];

// ============ Complementa tu plan láser (cross-link a otras categorías) ============
const complements: { title: string; text: string; href: string; linkLabel: string; cat: string }[] = [
  {
    title: 'Cuidado facial post-láser',
    text: 'Después de zonas faciales (bigote, mentón, rostro completo), la piel agradece protocolos suaves de limpieza y reparación. Sin exfoliantes agresivos las primeras 48 h — y limpieza profunda mensual a partir del día 7.',
    href: '/servicios/limpieza-facial-profunda',
    linkLabel: 'Ver limpieza facial profunda',
    cat: 'Facial',
  },
  {
    title: 'Pigmentación residual',
    text: 'Si te queda pigmentación post-inflamatoria después de algunas sesiones (especialmente fototipos altos), trabajamos peelings despigmentantes calibrados a tu piel — no concentraciones agresivas que empeoren el cuadro.',
    href: '/servicios/peelings-quimicos',
    linkLabel: 'Ver peelings despigmentantes',
    cat: 'Facial',
  },
  {
    title: 'Plan corporal integral',
    text: 'Si tu plan láser cubre piernas, abdomen o espalda, la piel post-tratamiento puede beneficiarse de radiofrecuencia para tonicidad o drenaje para edema asociado al calor. CLIBEL coordina las sesiones sin conflicto entre tecnologías.',
    href: '/servicios/radiofrecuencia-corporal',
    linkLabel: 'Ver radiofrecuencia corporal',
    cat: 'Corporal',
  },
  {
    title: 'Vello hormonal de origen',
    text: 'Si tu motivo es vello facial recurrente (bigote/mentón), brasileño que no termina de reducirse o cuadro tipo hirsutismo, la causa hormonal merece evaluación complementaria. Coordinamos derivación a ginecología/endocrinología si aplica.',
    href: '/contacto',
    linkLabel: 'Solicitar valoración integral',
    cat: 'Cross-link',
  },
];

// ============ PRE / POST sesión ============
const prepProtocol = {
  pre: [
    'Sin exposición solar 15 días antes',
    'Rasurar la zona 24 h antes (NO cera, NO pinzas)',
    'Suspender retinoides 7 días previos',
    'Asistir sin maquillaje, cremas ni desodorante',
    'Avisar a CLIBEL si tomas medicamentos fotosensibles',
  ],
  post: [
    'SPF 50+ obligatorio en zona tratada',
    'Sin sauna, vapor ni ejercicio intenso 24 h',
    'Aplicar calmante o gel post-láser indicado por CLIBEL',
    'No exfoliar la zona durante 5 días',
    'No depilar con cera entre sesiones — solo rasurar',
  ],
};

// ============ MITOS vs REALIDAD (NUEVO) ============
const myths = [
  {
    myth: 'El láser quema la piel morena',
    truth: 'Falso con tecnología correcta. CLIBEL aplica Nd:YAG en fototipos IV-VI, que es seguro y eficaz en piel latina. Lo que quema es usar Alexandrita en piel oscura sin valoración.',
  },
  {
    myth: 'El vello vuelve a crecer después',
    truth: 'CLIBEL aclara: el láser destruye permanentemente el folículo tratado, pero pueden activarse folículos nuevos por causas hormonales. Por eso bigote y brasileño requieren más sesiones y mantenimiento.',
  },
  {
    myth: 'Es muy doloroso',
    truth: 'Falso. Los equipos modernos que usa CLIBEL incluyen sistema de enfriamiento por contacto. La sensación es de "ligas calientes" — incómodo pero tolerable. No requiere anestesia tópica.',
  },
  {
    myth: 'Con 1–2 sesiones es suficiente',
    truth: 'Imposible biológicamente. Solo el 30% del vello está en fase anágena en cada momento. CLIBEL trabaja protocolos de 6–8 sesiones espaciadas para tratar todos los folículos.',
  },
];

// ============ FAQs específicas láser (humanizadas + interlinking) ============
const faqs: { q: string; answerHtml: string }[] = [
  {
    q: '¿Es seguro el láser durante el embarazo o lactancia?',
    answerHtml: 'En embarazo <strong>CLIBEL</strong> no aplica láser por principio de precaución, aunque no hay evidencia documentada de daño. En lactancia sí es seguro, pero los cambios hormonales pueden requerir más sesiones para resultados estables — pausa y retoma con tu ciclo hormonal regularizado para resultado más limpio.',
  },
  {
    q: '¿Cada cuánto tengo que ir a sesión?',
    answerHtml: 'Las sesiones se espacian según ciclo de crecimiento del vello en cada zona: <strong>rostro</strong> 4–5 semanas, <strong>axilas/inglés</strong> 6–8 semanas, <strong>piernas/espalda</strong> 8–10 semanas. <strong>CLIBEL</strong> ajusta tu calendario según respuesta documentada — no aplica protocolo rígido si tu folículo responde más lento o más rápido.',
  },
  {
    q: '¿Funciona con vello rubio, blanco o cano?',
    answerHtml: 'El láser requiere melanina en el folículo para funcionar. Vello blanco o cano: no tiene melanina, no responde. Vello rubio muy claro: respuesta limitada, evaluamos en parche. Vello rubio oscuro a castaño: responde bien. <strong>CLIBEL</strong> te confirma viabilidad en valoración antes de venderte plan que no funcionará.',
  },
  {
    q: '¿Cuánto cuesta una sesión?',
    answerHtml: 'El precio depende de la zona (15–60 min) y de la tecnología necesaria según tu fototipo. La valoración inicial en <strong>CLIBEL</strong> es sin costo y recibes presupuesto por escrito con el plan completo de sesiones. <a href="/contacto">Agenda tu valoración →</a>',
  },
  {
    q: '¿Puedo broncearme mientras hago el tratamiento?',
    answerHtml: 'Evita bronceado durante todo el plan láser. El sol aumenta el riesgo de hiperpigmentación post-tratamiento y reduce la eficacia del láser. Si te broncearas accidentalmente, <strong>CLIBEL</strong> pospone la sesión 3–4 semanas hasta que la piel regrese a su tono basal — no negociamos en eso, es seguridad clínica.',
  },
  {
    q: '¿Qué pasa si me salto una sesión?',
    answerHtml: 'No pasa nada grave, pero pierdes sincronía con el ciclo de crecimiento del folículo. <strong>CLIBEL</strong> replanifica para que la siguiente sesión coincida con la fase anágena de los folículos que tocaban — tu plan se alarga ligeramente pero el resultado final no se compromete.',
  },
  {
    q: '¿A qué edad puedo empezar?',
    answerHtml: 'A partir de los <strong>14 años con autorización de madre/padre</strong> y prueba de parche obligatoria. En adolescentes con cambios hormonales aún activos, el plan inicial puede requerir mantenimiento posterior — el láser elimina folículos existentes, no impide que cambios hormonales activen nuevos folículos durante la pubertad o embarazos futuros. <strong>CLIBEL</strong> plantea esto con honestidad antes de empezar.',
  },
];
---

<BaseLayout
  title={`Depilación Láser en CDMX | CLIBEL`}
  description={`Depilación láser profesional en CDMX con CLIBEL: Alexandrita, Nd:YAG y Diodo para todos los fototipos. 12+ zonas corporales, planes documentados y valoración sin costo.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(catalogSchema)} />

  <!-- ============================ BREADCRUMB ============================ -->
  <Breadcrumb
    kicker="Categoría 03 · Láser"
    items={[
      { label: 'Servicios', href: '/servicios' },
      { label: 'Depilación Láser' },
    ]}
  />

  <!-- ============================ HERO ============================ -->
  <section class="cat-hero">
    <div aria-hidden="true" class="cat-hero-bg"></div>
    <div aria-hidden="true" class="cat-hero-blob cat-hero-blob-1"></div>
    <div aria-hidden="true" class="cat-hero-blob cat-hero-blob-2"></div>
    <div aria-hidden="true" class="cat-hero-grain"></div>

    <div class="container-x relative">
      <div class="cat-hero-grid">
        <div class="cat-hero-col cat-hero-col--left fade-up">
          <span class="eyebrow-tag">
            <span class="dot" aria-hidden="true"></span>
            Categoría 03 · {cat.badgeLabel} · 12+ zonas
          </span>

          <h1 class="cat-hero-headline">
            <span class="cat-hero-headline-line">Depilación</span>
            <span class="cat-hero-headline-line"><em>láser</em> en CDMX.</span>
          </h1>

          <p class="cat-hero-lede">
            Tecnología láser para <strong>todos los fototipos</strong>:
            Alexandrita, Nd:YAG y Diodo. CLIBEL diseña tu plan completo
            tras valoración con prueba de parche, sin paquetes prearmados
            ni quemaduras por equipo equivocado.
          </p>

          <div class="cat-hero-trust">
            <span class="cat-hero-trust-label">Tecnología</span>
            <div class="cat-hero-trust-list">
              <span>Alexandrita 755nm</span><span aria-hidden="true">·</span>
              <span>Nd:YAG 1064nm</span><span aria-hidden="true">·</span>
              <span>Diodo 810nm</span><span aria-hidden="true">·</span>
              <span>Sistema de enfriamiento</span>
            </div>
          </div>
        </div>

        <div class="cat-hero-col cat-hero-col--right fade-up-delay-2">
          <span class="cat-hero-kicker">Qué hace CLIBEL en láser</span>

          <p class="cat-hero-paragraph">
            <strong>CLIBEL</strong> es una clínica de belleza con respaldo
            médico especializada en depilación láser profesional en Ciudad
            de México. Operamos tres tecnologías —Alexandrita, Nd:YAG y
            Diodo— para cubrir el espectro completo de fototipos
            Fitzpatrick (I a VI). La diferencia entre quemar piel morena
            y depilarla con seguridad es elegir el láser correcto, no el
            que esté libre ese día.
          </p>

          <p class="cat-hero-paragraph">
            Trabajamos más de 12 zonas corporales con planes documentados,
            <strong>prueba de parche obligatoria</strong> en la primera cita
            y técnicos certificados supervisados por personal médico. Cada
            sesión registra fluencia, fototipo, zona, respuesta y porcentaje
            de reducción en tu expediente digital — el plan se afina con
            evidencia, no con conjeturas. Para complementar tu rutina,
            <a href={catHref('facial')}>tratamientos faciales</a> y
            <a href={catHref('corporal')}>corporales</a> se integran sin
            conflicto entre sesiones láser.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================ NAV TOP ============================ -->
  <HeroNavBar
    label="Otras categorías"
    ariaLabel="Otras categorías de tratamientos CLIBEL"
    variant="cream"
    links={[
      { label: 'Faciales',           href: catHref('facial') },
      { label: 'Corporales',         href: catHref('corporal') },
      { label: 'Medicina estética',  href: catHref('medicina-estetica') },
      { label: 'Capilares',          href: catHref('capilar') },
    ]}
    cta={{ label: 'Volver al catálogo', href: '/servicios' }}
  />

  <!-- ============================ STAT STRIP CLÍNICO ============================ -->
  <section class="svc-stat-strip">
    <div class="container-x">
      <dl class="laser-stats">
        <div>
          <dt>Zonas tratadas</dt>
          <dd><em>12</em><span>+</span></dd>
        </div>
        <div>
          <dt>Tecnologías láser</dt>
          <dd><em>03</em></dd>
        </div>
        <div>
          <dt>Fototipos cubiertos</dt>
          <dd><em>I</em><span>–</span><em>VI</em></dd>
        </div>
        <div>
          <dt>Reducción acumulada</dt>
          <dd><em>80</em><span>–</span><em>90</em><span class="laser-stats-pct">%</span></dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- ============================ CATÁLOGO DE SERVICIO ============================ -->
  <section class="section bg-white">
    <div class="container-x">
      <SectionHeader
        kicker={`Catálogo · ${items.length} ${items.length === 1 ? 'tratamiento base' : 'tratamientos'}`}
        title="Depilación láser<br/>clínica en <em>CLIBEL</em>."
