  <script is:inline define:vars={{ waBase: `https://wa.me/${CONTACT.whatsapp}` }}>
    (function () {
      const form = document.getElementById('laserWaForm');
      if (!form) return;
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const d = new FormData(form);
        const g = (k) => (d.get(k) || '').toString().trim();
        const nombre = g('nombre'), tel = g('telefono'), email = g('email');
        const zona = g('zona'), fototipo = g('fototipo'), msg = g('mensaje');
        const acepto = form.querySelector('[name="privacidad"]').checked;

        if (!nombre || !tel || !zona || !acepto) {
          form.classList.add('is-invalid');
          return;
        }
        form.classList.remove('is-invalid');

        const lines = [
          'Hola CLIBEL, vengo desde la página de Depilación Láser.',
          '',
          'Nombre: ' + nombre,
          'Teléfono: ' + tel,
        ];
        if (email)    lines.push('Email: ' + email);
        if (zona)     lines.push('Zona principal: ' + zona);
        if (fototipo) lines.push('Fototipo: ' + fototipo);
        if (msg)      lines.push('', 'Comentario: ' + msg);

        window.open(waBase + '?text=' + encodeURIComponent(lines.join('\n')), '_blank', 'noopener');
      });
    })();
  </script>

