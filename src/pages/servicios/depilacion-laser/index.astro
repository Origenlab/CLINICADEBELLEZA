    border-color: rgba(201, 169, 97, 0.45);
    transform: translateY(-4px);
  }
  .protocol-head {
    display: flex;
    align-items: baseline;
    gap: 0.9rem;
    margin-bottom: 1.25rem;
  }
  .protocol-tag {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
  }
  .protocol-tag--pre {
    background: rgba(201, 169, 97, 0.15);
    color: var(--color-brand-400);
    border: 1px solid rgba(201, 169, 97, 0.4);
  }
  .protocol-tag--post {
    background: rgba(139, 90, 107, 0.2);
    color: var(--color-mauve-300);
    border: 1px solid rgba(188, 142, 156, 0.45);
  }
  .protocol-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.4rem, 1.8vw, 1.75rem);
    color: white;
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.015em;
  }
  .protocol-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .protocol-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding-block: 0.65rem;
    border-top: 1px dashed rgba(201, 169, 97, 0.18);
    font-size: 0.92rem;
    line-height: 1.5;
    color: rgba(242, 235, 223, 0.85);
  }
  .protocol-list li:first-child { border-top: 0; padding-top: 0; }
  .protocol-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 0.95rem;
    color: var(--color-brand-400);
    line-height: 1.45;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    min-width: 24px;
  }

  /* ============= NEW: Mitos vs realidad ============= */
  .myths-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .myth {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    background: white;
    border: 1px solid rgba(201, 169, 97, 0.25);
    border-radius: 1.1rem;
    overflow: hidden;
    transition: all 0.4s ease !important;
  }
  .myth:hover {
    border-color: var(--color-mauve-500);
    box-shadow: 0 18px 36px -22px rgba(31, 20, 24, 0.18);
  }
  @media (min-width: 768px) {
    .myth { grid-template-columns: 1fr 1.4fr; }
  }
  .myth-left {
    padding: 1.4rem 1.4rem 1.4rem 1.4rem;
    background: var(--color-brand-50);
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    border-bottom: 1px dashed rgba(201, 169, 97, 0.3);
  }
  .myth-right {
    padding: 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  @media (min-width: 768px) {
    .myth-left { border-bottom: 0; border-right: 1px dashed rgba(201, 169, 97, 0.3); }
  }
  .myth-tag {
    display: inline-block;
    align-self: flex-start;
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
  }
  .myth-tag--false {
    background: rgba(198, 43, 62, 0.1);
    color: #c62b3e;
    border: 1px solid rgba(198, 43, 62, 0.3);
  }
  .myth-tag--true {
    background: rgba(46, 125, 50, 0.1);
    color: #2e7d32;
    border: 1px solid rgba(46, 125, 50, 0.3);
  }
  .myth-q {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.05rem, 1.25vw, 1.2rem);
    color: var(--color-ink-700);
    margin: 0;
    line-height: 1.35;
  }
  .myth-a {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-ink-800);
    margin: 0;
  }

  /* ============= FAQ + Form (mismo patrón) ============= */
  .faq-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 3vw, 2.75rem);
    align-items: start;
  }
  @media (min-width: 1024px) {
    .faq-grid { grid-template-columns: 1.15fr 0.85fr; gap: clamp(2.5rem, 4vw, 3.5rem); }
  }
  .faq-col-label {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-brand-500);
    margin-bottom: 1.1rem;
  }
  .faq-list { display: flex; flex-direction: column; gap: 0.6rem; }
  .faq {
    background: white;
    border: 1px solid rgba(201, 169, 97, 0.22);
    border-radius: 1rem;
    overflow: hidden;
    transition: border-color 0.3s ease, background 0.3s ease !important;
  }
  .faq[open] { border-color: var(--color-mauve-500); }
  .faq-sum {
    list-style: none;
    cursor: pointer;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1rem;
    align-items: center;
    padding: 1.1rem 1.25rem;
  }
  .faq-sum::-webkit-details-marker { display: none; }
  .faq-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1rem;
    color: var(--color-brand-500);
    letter-spacing: 0.04em;
    line-height: 1;
    opacity: 0.8;
    min-width: 24px;
  }
  .faq-q {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1rem, 1.1vw, 1.12rem);
    color: var(--color-ink-900);
    line-height: 1.3;
    letter-spacing: -0.005em;
  }
  .faq-plus {
    width: 32px; height: 32px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: var(--color-brand-100);
    color: var(--color-mauve-500);
    transition: transform 0.35s cubic-bezier(.2,.8,.2,1), background 0.3s ease, color 0.3s ease !important;
  }
  .faq[open] .faq-plus {
    transform: rotate(45deg);
    background: var(--color-mauve-500);
    color: white;
  }
  .faq-a {
    padding: 0 1.25rem 1.25rem clamp(3.5rem, 6vw, 4rem);
    font-size: 0.92rem;
    line-height: 1.65;
    color: var(--color-ink-700);
  }

  /* Form WhatsApp */
  .faq-form-wrap { position: relative; }
  @media (min-width: 1024px) { .faq-form-wrap { position: sticky; top: clamp(6rem, 10vh, 7.5rem); } }
  .faq-form {
    background: linear-gradient(180deg, #FFFFFF 0%, var(--color-brand-50) 100%);
    border: 1px solid rgba(201, 169, 97, 0.3);
    border-radius: 1.25rem;
    padding: clamp(1.5rem, 2vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 0.95rem;
    box-shadow:
      0 1px 2px rgba(31, 20, 24, 0.03),
      0 24px 56px -28px rgba(31, 20, 24, 0.18);
  }
  .faq-form-kicker {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mauve-500);
  }
  .faq-form-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.45rem, 2vw, 1.85rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-ink-900);
    margin: 0;
  }
  .faq-form-title em {
    font-style: italic;
    color: var(--color-mauve-500);
    font-weight: 400;
  }
  .faq-form-sub {
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--color-ink-500);
    margin: 0 0 0.5rem;
  }
  .faq-form-sub strong { color: var(--color-ink-900); font-weight: 600; }
  .faq-form-row { display: flex; flex-direction: column; gap: 0.32rem; }
  .faq-form-grid-2 {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
  }
  @media (min-width: 520px) {
    .faq-form-grid-2 { grid-template-columns: 1fr 1fr; }
  }
  .faq-form-row label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-ink-700);
    letter-spacing: 0.02em;
  }
  .faq-form-row label span[aria-hidden] { color: var(--color-mauve-500); margin-left: 2px; }
  .faq-form input,
  .faq-form select,
  .faq-form textarea {
    width: 100%;
    padding: 0.7rem 0.9rem;
    font-family: var(--font-sans);
    font-size: 0.92rem;
    color: var(--color-ink-900);
    background: white;
    border: 1px solid rgba(201, 169, 97, 0.35);
    border-radius: 0.65rem;
    outline: none;
    transition: border-color 0.25s ease, box-shadow 0.25s ease, background 0.25s ease !important;
    appearance: none;
    line-height: 1.4;
  }
  .faq-form select {
    background-image:
      linear-gradient(45deg, transparent 50%, var(--color-mauve-500) 50%),
      linear-gradient(135deg, var(--color-mauve-500) 50%, transparent 50%);
    background-position: calc(100% - 18px) calc(50% - 2px), calc(100% - 13px) calc(50% - 2px);
    background-size: 5px 5px;
    background-repeat: no-repeat;
    padding-right: 2rem;
    cursor: pointer;
  }
  .faq-form textarea { resize: vertical; min-height: 80px; }
  .faq-form input:focus,
  .faq-form select:focus,
  .faq-form textarea:focus {
    border-color: var(--color-mauve-500);
    box-shadow: 0 0 0 3px rgba(139, 90, 107, 0.12);
    background: var(--color-brand-50);
  }
  .faq-form.is-invalid input:required:invalid,
  .faq-form.is-invalid select:required:invalid { border-color: #c62b3e; }
  .faq-form-check {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    margin-top: 0.25rem;
    font-size: 0.78rem;
    line-height: 1.45;
    color: var(--color-ink-500);
    cursor: pointer;
  }
  .faq-form-check input[type="checkbox"] {
    width: 16px;
    height: 16px;
    margin-top: 2px;
    accent-color: var(--color-mauve-500);
    flex-shrink: 0;
    cursor: pointer;
  }
  .faq-form-check a { color: var(--color-mauve-500); text-decoration: underline; text-underline-offset: 2px; }
  .faq-form-check a:hover { color: var(--color-mauve-700); }
  .faq-form-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    padding: 0.95rem 1.25rem;
    margin-top: 0.5rem;
    background: #25D366;
    color: white;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.01em;
    border: 0;
    border-radius: 999px;
    cursor: pointer;
    box-shadow:
      0 10px 24px -10px rgba(37, 211, 102, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.25);
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease !important;
  }
  .faq-form-submit:hover {
    background: #1FB855;
    transform: translateY(-2px);
    box-shadow:
      0 16px 32px -10px rgba(37, 211, 102, 0.7),
      inset 0 1px 0 rgba(255, 255, 255, 0.3);
  }
  .faq-form-foot {
    margin: 0;
    text-align: center;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-500);
    opacity: 0.85;
  }
  @media (max-width: 640px) { .faq-form { padding: 1.25rem; } }

  /* ============= Hero links inline ============= */
  .cat-hero-paragraph a {
    color: var(--color-mauve-500);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: color 0.25s ease !important;
  }
  .cat-hero-paragraph a:hover { color: var(--color-mauve-700); }

  /* ============= FAQ answers con links ============= */
  .faq-a a {
    color: var(--color-mauve-500);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    font-weight: 500;
    transition: color 0.25s ease !important;
  }
  .faq-a a:hover { color: var(--color-mauve-700); }

  /* ============= COMPLEMENTA TU PLAN — cross-link cards ============= */
  .complements-grid {
    list-style: none;
    padding: 0;
    margin: clamp(1.5rem, 2.5vw, 2.25rem) 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 720px) { .complements-grid { grid-template-columns: repeat(2, 1fr); gap: 1.15rem; } }
  .complement {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1.5rem 1.5rem 1.4rem;
    background: white;
    border: 1px solid rgba(201, 169, 97, 0.3);
    border-radius: 1rem;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(.2,.8,.2,1) !important;
  }
  .complement::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 3px;
    background: linear-gradient(90deg, var(--color-brand-400), var(--color-mauve-500));
    opacity: 0;
    transition: opacity 0.3s ease !important;
  }
  .complement:hover {
    border-color: var(--color-mauve-500);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -20px rgba(31, 20, 24, 0.18);
  }
  .complement:hover::before { opacity: 1; }
  .complement-head {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: start;
    gap: 1rem;
  }
  .complement-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2.25rem, 3.5vw, 2.85rem);
    line-height: 0.85;
    background: linear-gradient(180deg, var(--color-brand-500), var(--color-mauve-500));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.015em;
  }
  .complement-cat {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mauve-500);
    margin-bottom: 0.3rem;
  }
  .complement-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.2rem, 1.5vw, 1.45rem);
    color: var(--color-ink-900);
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.015em;
  }
  .complement-text {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--color-ink-700);
  }
  .complement-link {
    align-self: flex-start;
    margin-top: auto;
    padding-top: 0.9rem;
    border-top: 1px dashed rgba(201, 169, 97, 0.32);
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-mauve-500);
    text-decoration: none;
    transition: color 0.25s ease, gap 0.25s ease !important;
  }
  .complement-link:hover {
    color: var(--color-mauve-700);
    gap: 0.7rem;
  }
  .complement-link svg { transition: transform 0.25s ease !important; }
  .complement-link:hover svg { transform: translateX(3px); }

  /* ============= CALENDARIO VISUAL — stepper dark ============= */
  .svc-calendar {
    background: var(--color-ink-900);
    color: var(--color-brand-100);
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding-block: clamp(4rem, 6vw, 6.5rem);
  }
  .svc-calendar-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(60% 50% at 80% 0%, rgba(201,169,97,0.10), transparent 60%),
      radial-gradient(50% 50% at 0% 100%, rgba(139,90,107,0.12), transparent 60%);
    pointer-events: none;
    z-index: 0;
  }
  .calendar-list {
    list-style: none;
    padding: 0;
    margin: clamp(2rem, 3vw, 2.75rem) 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 720px) { .calendar-list { grid-template-columns: repeat(2, 1fr); gap: 1.25rem; } }
  @media (min-width: 1100px) { .calendar-list { grid-template-columns: repeat(4, 1fr); gap: 0; } }
  .calendar-step {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1.5rem;
    background: linear-gradient(180deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.015) 100%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    transition: all 0.35s cubic-bezier(.2,.8,.2,1) !important;
  }
  @media (min-width: 1100px) {
    .calendar-step {
      border-radius: 0;
      border: 0;
      background: transparent;
      padding: 2rem 1.25rem 0;
    }
  }
  .calendar-step:hover {
    background: linear-gradient(180deg, rgba(255,255,255,0.07) 0%, rgba(255,255,255,0.025) 100%);
    border-color: rgba(201, 169, 97, 0.42);
    transform: translateY(-3px);
  }
  @media (min-width: 1100px) {
    .calendar-step:hover {
      transform: none;
      background: rgba(255,255,255,0.03);
      border: 0;
    }
    .calendar-step:hover .calendar-dot {
      transform: scale(1.2);
      box-shadow: 0 0 0 5px rgba(201, 169, 97, 0.32), 0 0 0 10px rgba(201, 169, 97, 0.14);
    }
  }
  .calendar-track {
    display: none;
  }
  @media (min-width: 1100px) {
    .calendar-track {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 0.25rem;
    }
    .calendar-line {
      height: 1.5px;
      background: linear-gradient(90deg, rgba(201, 169, 97, 0.4), rgba(201, 169, 97, 0.4));
    }
    .calendar-step:first-child .calendar-line--before { visibility: hidden; }
    .calendar-step:last-child .calendar-line--after { visibility: hidden; }
    .calendar-dot {
      width: 14px;
      height: 14px;
      border-radius: 999px;
      background: var(--color-brand-400);
      box-shadow: 0 0 0 4px rgba(201, 169, 97, 0.22), 0 0 0 8px rgba(201, 169, 97, 0.08);
      transition: transform 0.3s ease, box-shadow 0.3s ease !important;
      justify-self: center;
    }
    .calendar-step--mauve .calendar-dot { background: var(--color-mauve-300); }
    .calendar-step--rose .calendar-dot { background: #d4889a; }
  }
  .calendar-body {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .calendar-mes {
    font-family: var(--font-sans);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-brand-400);
  }
  .calendar-sesion {
    font-family: var(--font-display);
    font-size: 1.2rem;
    line-height: 1;
    color: rgba(242, 235, 223, 0.65);
    letter-spacing: -0.005em;
  }
  .calendar-sesion em {
    font-style: italic;
    font-weight: 300;
    font-size: 2.2rem;
    line-height: 0.85;
    color: white;
    background: linear-gradient(180deg, var(--color-brand-400), var(--color-mauve-300));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-right: 0.2rem;
    letter-spacing: -0.02em;
  }
  .calendar-label {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.05rem, 1.3vw, 1.2rem);
    color: white;
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.012em;
  }
  .calendar-text {
    margin: 0;
    font-size: clamp(0.85rem, 0.92vw, 0.95rem);
    line-height: 1.55;
    color: rgba(242, 235, 223, 0.7);
  }
  .calendar-foot {
    margin: clamp(2rem, 3vw, 2.5rem) 0 0;
    padding-top: clamp(1.5rem, 2vw, 1.85rem);
    border-top: 1px solid rgba(201, 169, 97, 0.22);
    font-size: clamp(0.88rem, 1vw, 1rem);
    line-height: 1.6;
    color: rgba(242, 235, 223, 0.78);
    max-width: 72ch;
  }
  .calendar-foot strong { color: white; font-weight: 600; }

  /* ============= STAT STRIP CLÍNICO (bajo hero) ============= */
  .svc-stat-strip {
    background: var(--color-brand-50);
    padding-block: clamp(2rem, 3.5vw, 3rem);
    border-bottom: 1px solid rgba(201, 169, 97, 0.22);
  }
  .laser-stats {
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }
  @media (min-width: 720px) { .laser-stats { grid-template-columns: repeat(4, 1fr); } }
  .laser-stats > div {
    padding: 1rem 1.25rem;
    border-right: 1px solid rgba(201, 169, 97, 0.22);
