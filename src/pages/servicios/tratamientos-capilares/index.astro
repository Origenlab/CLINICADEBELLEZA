  .habits-col--yes .habits-num { color: #2e7d32; opacity: 0.85; }

  /* ============= FAQ + Form (mismo patrón) ============= */
  .faq-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 3vw, 2.75rem);
    align-items: start;
  }
  @media (min-width: 1024px) {
    .faq-grid { grid-template-columns: 1.15fr 0.85fr; gap: clamp(2.5rem, 4vw, 3.5rem); }
  }
  .faq-col-label {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-brand-500);
    margin-bottom: 1.1rem;
  }
  .faq-list { display: flex; flex-direction: column; gap: 0.6rem; }
  .faq {
    background: var(--color-brand-50);
    border: 1px solid rgba(201, 169, 97, 0.22);
    border-radius: 1rem;
    overflow: hidden;
    transition: border-color 0.3s ease, background 0.3s ease !important;
  }
  .faq[open] { background: white; border-color: var(--color-mauve-500); }
  .faq-sum {
    list-style: none;
    cursor: pointer;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1rem;
    align-items: center;
    padding: 1.1rem 1.25rem;
  }
  .faq-sum::-webkit-details-marker { display: none; }
  .faq-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1rem;
    color: var(--color-brand-500);
    letter-spacing: 0.04em;
    line-height: 1;
    opacity: 0.8;
    min-width: 24px;
