    gap: 1.25rem;
  }
  @media (min-width: 640px) { .cat-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .cat-grid { grid-template-columns: repeat(4, 1fr); gap: 1.5rem; } }

  /* ============= NEW: Diagnóstico tricológico (dark) ============= */
  .svc-diag {
    background: var(--color-ink-900);
    color: var(--color-brand-100);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }
  .svc-diag-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(60% 50% at 100% 0%, rgba(201,169,97,0.08), transparent 60%),
      radial-gradient(50% 50% at 0% 100%, rgba(139,90,107,0.1), transparent 60%);
    pointer-events: none;
    z-index: 0;
  }
  .diag-list {
    list-style: none;
    padding: 0;
    margin: clamp(2rem, 4vw, 3rem) 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  @media (min-width: 768px) { .diag-list { grid-template-columns: repeat(2, 1fr); } }
  .diag-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(1rem, 2vw, 1.75rem);
    padding: clamp(1.5rem, 2.5vw, 2.25rem) clamp(0.5rem, 1.5vw, 1.5rem);
    border-top: 1px solid rgba(201, 169, 97, 0.22);
    align-items: start;
  }
  @media (min-width: 768px) {
    .diag-item:nth-child(odd)  { padding-right: clamp(1rem, 2vw, 2rem); border-right: 1px solid rgba(201, 169, 97, 0.18); }
    .diag-item:nth-child(even) { padding-left:  clamp(1rem, 2vw, 2rem); }
    .diag-item:nth-child(1), .diag-item:nth-child(2) { border-top: 0; padding-top: 0; }
  }
  .diag-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 0.85;
    background: linear-gradient(180deg, var(--color-brand-400), var(--color-mauve-300));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.02em;
    flex-shrink: 0;
    min-width: 2.5rem;
  }
  .diag-body { display: flex; flex-direction: column; gap: 0.5rem; max-width: 56ch; }
  .diag-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.25rem, 1.8vw, 1.55rem);
    color: white;
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.015em;
  }
  .diag-text {
    font-size: clamp(0.92rem, 1vw, 1.02rem);
    line-height: 1.65;
    color: rgba(242, 235, 223, 0.78);
    margin: 0;
  }

  /* ============= NEW: Mapa tipos alopecia ============= */
  .alopecia-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 768px) { .alopecia-grid { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; } }
  @media (min-width: 1200px) { .alopecia-grid { grid-template-columns: repeat(3, 1fr); } }
  .alop {
    position: relative;
    background: white;
    border: 1px solid rgba(201, 169, 97, 0.28);
    border-radius: 1.1rem;
    padding: clamp(1.4rem, 1.8vw, 1.7rem);
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    transition: all 0.45s cubic-bezier(.2,.8,.2,1) !important;
    overflow: hidden;
  }
  .alop::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 4px;
    background: linear-gradient(180deg, var(--color-brand-400), var(--color-mauve-500));
    transition: width 0.4s cubic-bezier(.2,.8,.2,1) !important;
  }
  .alop:hover {
    transform: translateY(-4px);
    border-color: rgba(139, 90, 107, 0.45);
    box-shadow: 0 28px 48px -22px rgba(31, 20, 24, 0.2);
  }
  .alop:hover::before { width: 6px; }
  .alop-head { display: flex; align-items: flex-start; gap: 1rem; }
  .alop-code {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2rem, 2.8vw, 2.5rem);
    color: var(--color-mauve-500);
    line-height: 0.85;
    letter-spacing: -0.02em;
    flex-shrink: 0;
  }
  .alop-head-text { display: flex; flex-direction: column; gap: 0.2rem; min-width: 0; }
  .alop-kicker {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-brand-500);
    opacity: 0.85;
  }
  .alop-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.3rem, 1.6vw, 1.55rem);
    color: var(--color-ink-900);
    margin: 0;
    line-height: 1.15;
    letter-spacing: -0.018em;
  }
  .alop-aka {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.88rem;
    color: var(--color-ink-500);
  }
  .alop-body { display: flex; flex-direction: column; gap: 0.85rem; }
  .alop-row { display: flex; flex-direction: column; gap: 0.25rem; }
  .alop-row-label {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-brand-500);
  }
  .alop-row--treat .alop-row-label { color: var(--color-mauve-500); }
  .alop-row-text {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.55;
    color: var(--color-ink-700);
  }
  .alop-row--treat .alop-row-text {
    padding: 0.65rem 0.85rem;
    background: var(--color-brand-50);
    border-left: 3px solid var(--color-mauve-500);
    border-radius: 0 0.5rem 0.5rem 0;
    color: var(--color-ink-800);
    font-weight: 500;
  }

  /* ============= NEW: Ciclo capilar ============= */
  .cycle-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 768px) { .cycle-grid { grid-template-columns: repeat(3, 1fr); gap: 1.25rem; } }
  .cycle {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.25rem;
    padding: 1.4rem;
    background: linear-gradient(180deg, #FFFFFF 0%, var(--color-brand-100) 100%);
    border: 1px solid rgba(201, 169, 97, 0.3);
    border-radius: 1.1rem;
    align-items: center;
    transition: all 0.4s ease !important;
  }
  .cycle:hover {
    border-color: var(--color-mauve-500);
