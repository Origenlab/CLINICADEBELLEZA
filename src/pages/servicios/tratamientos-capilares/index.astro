    margin-top: 0.4rem;
  }
  .cycle-body { display: flex; flex-direction: column; gap: 0.3rem; min-width: 0; }
  .cycle-num {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-brand-500);
  }
  .cycle-phase {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.2rem;
    color: var(--color-ink-900);
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.012em;
  }
  .cycle-dur {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.85rem;
    color: var(--color-mauve-500);
  }
  .cycle-text {
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--color-ink-700);
    margin: 0.25rem 0 0;
  }

  /* ============= NEW: Cases ============= */
  .cases-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 768px) { .cases-grid { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; } }
  .case {
    position: relative;
    background: white;
    border: 1px solid rgba(201, 169, 97, 0.28);
    border-radius: 1.25rem;
    padding: clamp(1.5rem, 2vw, 1.85rem);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    overflow: hidden;
    transition: transform 0.5s cubic-bezier(.2,.8,.2,1), box-shadow 0.5s ease, border-color 0.4s ease !important;
  }
  .case::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: var(--accent-color, var(--color-brand-400));
    transition: height 0.4s cubic-bezier(.2,.8,.2,1) !important;
  }
  .case:hover {
    transform: translateY(-6px);
    border-color: rgba(139, 90, 107, 0.45);
    box-shadow: 0 32px 56px -22px rgba(31,20,24,0.22);
  }
  .case:hover::before { height: 6px; }
  .case--gold  { --accent-color: var(--color-brand-500); }
  .case--mauve { --accent-color: var(--color-mauve-500); }
  .case--rose  { --accent-color: var(--color-mauve-300); }
  .case-head { display: flex; align-items: flex-start; gap: 1rem; }
  .case-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2rem, 3vw, 2.75rem);
    color: var(--accent-color, var(--color-brand-500));
    line-height: 0.85;
    letter-spacing: -0.02em;
    flex-shrink: 0;
  }
  .case-kicker {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-brand-500);
    opacity: 0.85;
    margin-bottom: 0.2rem;
  }
  .case-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.4rem, 1.8vw, 1.7rem);
    color: var(--color-ink-900);
    margin: 0 0 0.2rem;
    line-height: 1.15;
    letter-spacing: -0.018em;
  }
  .case-duration {
    display: inline-block;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.88rem;
    color: var(--color-ink-500);
  }
  .case-profile {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.6rem 0.85rem;
    background: var(--color-brand-50);
    border: 1px solid rgba(201, 169, 97, 0.25);
    border-radius: 0.6rem;
  }
  .case-profile-label {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-mauve-500);
  }
  .case-profile-value {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.92rem;
    color: var(--color-ink-800);
    letter-spacing: -0.005em;
  }
  .case-combo {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-block: 0.85rem;
    border-block: 1px dashed rgba(201, 169, 97, 0.3);
  }
  .case-combo-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-mauve-500);
  }
  .case-combo ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .case-combo li {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    font-size: 0.9rem;
    line-height: 1.45;
    color: var(--color-ink-700);
  }
  .case-combo li svg {
    flex-shrink: 0;
    margin-top: 0.18rem;
    color: var(--accent-color, var(--color-mauve-500));
  }
  .case-target {
    margin: 0;
    padding: 0.85rem 0.95rem;
    background: var(--color-brand-50);
    border-left: 3px solid var(--accent-color, var(--color-brand-400));
    border-radius: 0 0.55rem 0.55rem 0;
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--color-ink-700);
    font-style: italic;
  }

  /* ============= Timeline ============= */
  .svc-timeline { background: white; }
  .tl-list {
    list-style: none;
    padding: 0;
    margin: clamp(2rem, 4vw, 3rem) 0 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .tl-step {
    display: grid;
    grid-template-columns: clamp(110px, 18vw, 200px) 1fr;
    gap: clamp(1.5rem, 3vw, 3rem);
    padding-block: clamp(1.5rem, 2.5vw, 2.25rem);
    border-top: 1px solid rgba(201, 169, 97, 0.22);
    align-items: start;
  }
  .tl-step:first-child { border-top: 0; padding-top: 0; }
  .tl-step-mark {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    align-items: flex-start;
  }
  .tl-step-when {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.65rem, 2.5vw, 2.25rem);
    color: var(--color-mauve-500);
    line-height: 1;
    letter-spacing: -0.018em;
  }
  .tl-step-dot {
    width: 10px; height: 10px;
    border-radius: 999px;
    background: var(--color-brand-400);
    box-shadow: 0 0 0 4px rgba(201, 169, 97, 0.18), 0 0 0 8px rgba(201, 169, 97, 0.07);
  }
  .tl-step-body {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    max-width: 60ch;
  }
  .tl-step-label {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.25rem, 1.8vw, 1.65rem);
    color: var(--color-ink-900);
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.015em;
  }
  .tl-step-text {
    font-size: clamp(0.92rem, 1vw, 1.02rem);
    line-height: 1.7;
    color: var(--color-ink-700);
    margin: 0;
  }
  @media (max-width: 640px) {
    .tl-step { grid-template-columns: 1fr; gap: 0.75rem; }
    .tl-step-mark { flex-direction: row; align-items: center; gap: 1rem; }
  }

  /* ============= NEW: Hábitos sí / no ============= */
  .habits-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 900px) {
    .habits-grid { grid-template-columns: 1fr 1fr; gap: 1.75rem; }
  }
  .habits-col {
    background: white;
    border: 1px solid rgba(201, 169, 97, 0.25);
    border-radius: 1.25rem;
