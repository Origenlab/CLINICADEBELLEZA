---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import HeroNavBar from '../../../components/HeroNavBar.astro';
import RelatedCategories from '../../../components/RelatedCategories.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, SITE, CONTACT, catHref } from '../../../consts';

const cat = CATEGORIES.capilar;

const all = await getCollection('servicios');
const items = all
  .filter((s) => s.data.category === 'capilar')
  .sort((a, b) => a.data.order - b.data.order);

const wa = `https://wa.me/${CONTACT.whatsapp}?text=${encodeURIComponent('Hola, me gustaría agendar diagnóstico tricológico capilar en CLIBEL.')}`;

// ============ SCHEMAS SEO ============
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Servicios', item: `${SITE.url}/servicios` },
    { '@type': 'ListItem', position: 3, name: 'Tratamientos Capilares', item: `${SITE.url}/servicios/tratamientos-capilares` },
  ],
};
const catalogSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalSpecialty',
  name: 'Tratamientos Capilares — CLIBEL',
  description: 'Tricología clínica, PRP capilar, mesoterapia y diagnóstico tricoscópico para caída y debilitamiento del cabello en CDMX.',
  url: `${SITE.url}/servicios/tratamientos-capilares`,
  provider: { '@id': `${SITE.url}/#clinic` },
  relevantSpecialty: ['Dermatology', 'Trichology'],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Catálogo de tratamientos capilares CLIBEL',
    itemListElement: items.map((s) => ({
      '@type': 'MedicalProcedure',
      name: s.data.title,
      description: s.data.description,
      url: `${SITE.url}/servicios/${s.id}`,
    })),
  },
};

// ============ Editorial leds por L4 (humanizados · sección Profundiza) ============
const editorialLedes: Record<string, { lede: string; readMore: string }> = {
  'tratamiento-capilar': {
    lede: 'El programa integral que combina diagnóstico tricológico + PRP + mesoterapia + coordinación con medicación sistémica según diagnóstico. CLIBEL lo aplica como medicina, no como cosmética — diagnóstico previo, plan personalizado y mantenimiento sostenido como protocolo.',
    readMore: 'Ver programa integral',
  },
  'prp-capilar': {
    lede: 'Probablemente el procedimiento con mejor evidencia clínica para alopecia androgenética temprana a moderada. CLIBEL lo aplica con kit estéril certificado (Regen Lab, Arthrex), tricoscopia comparativa cada sesión y honestidad sobre lo que el PRP puede y no puede hacer.',
    readMore: 'Ver protocolo PRP',
  },
  'mesoterapia-capilar': {
    lede: 'Bioactivos —dutasterida tópica, biotina, vitaminas, minoxidil inyectable— entregados DIRECTAMENTE al folículo vía microinyecciones. Complemento del PRP y de la medicación sistémica. CLIBEL la considera pieza del plan integral, no tratamiento aislado.',
    readMore: 'Ver mesoterapia',
  },
  'tricologia-clinica': {
    lede: 'El filtro clínico obligatorio antes de cualquier plan capilar serio. Tricoscopia digital, clasificación clínica de alopecia, descarte de causa sistémica y plan terapéutico por escrito. Sin tricología no hay tratamiento — solo improvisación cosmética cara.',
    readMore: 'Ver consulta diagnóstica',
  },
};

// ============ DIAGNÓSTICO TRICOLÓGICO (NUEVO) ============
const diagnosis = [
  {
    n: '01',
    title: 'Tricoscopia digital',
    text: 'CLIBEL examina cuero cabelludo con dermatoscopio de aumento 20x–100x para evaluar densidad folicular, miniaturización, inflamación perifolicular y patrones específicos de cada tipo de alopecia.',
  },
  {
    n: '02',
    title: 'Historia clínica completa',
    text: 'Antecedentes hormonales, familiares, eventos detonantes (parto, cirugía, estrés), medicamentos y suplementos. CLIBEL identifica causa probable antes de proponer tratamiento.',
  },
  {
    n: '03',
    title: 'Estudios complementarios',
    text: 'Cuando aplica, CLIBEL solicita perfil hormonal, ferritina, vitamina D, B12 y zinc. La caída de cabello suele tener causa metabólica subyacente que tratamientos tópicos no resuelven.',
  },
  {
    n: '04',
    title: 'Plan documentado por escrito',
    text: 'Diagnóstico, pronóstico realista, plan de sesiones, productos domiciliarios y revisión cada 3 meses con fototricograma comparativo. CLIBEL entrega todo por escrito antes de empezar.',
  },
];

// ============ MAPA DE TIPOS DE ALOPECIA (NUEVO) ============
const alopeciaTypes = [
  {
    code: '01',
    name: 'Androgenética',
    aka: 'Patrón masculino / femenino',
    cause: 'Sensibilidad folicular a la dihidrotestosterona (DHT). Componente genético + hormonal.',
    treatment: 'PRP capilar, mesoterapia, antiandrógenos tópicos, minoxidil supervisado',
  },
  {
    code: '02',
    name: 'Telógena difusa',
    aka: 'Caída por estrés / posparto / fiebre',
    cause: 'Sincronización masiva de folículos hacia fase telógena tras evento estresor (parto, cirugía, dieta restrictiva, COVID).',
    treatment: 'Mesoterapia, suplementación dirigida, manejo de causa raíz',
  },
  {
    code: '03',
    name: 'Areata',
    aka: 'Placas circulares de pérdida',
    cause: 'Autoinmune. Linfocitos atacan folículos en fase anágena. Puede ser por estrés o predisposición.',
    treatment: 'CLIBEL deriva a tricólogo médico especialista; PRP como coadyuvante',
  },
  {
    code: '04',
    name: 'Por tracción',
    aka: 'Peinados tensos crónicos',
    cause: 'Trenzas, coletas tirantes, extensiones permanentes. Lesión folicular mecánica progresiva.',
    treatment: 'Cambio de hábito + PRP + bioestimulación cuando aún hay folículos viables',
  },
  {
    code: '05',
    name: 'Seborreica',
    aka: 'Caída con caspa y picor',
    cause: 'Dermatitis seborreica del cuero cabelludo, inflamación crónica que debilita el folículo.',
    treatment: 'Tratamiento antifúngico tópico + antiinflamatorio + bioactivos regenerativos',
  },
  {
    code: '06',
    name: 'Carencial',
    aka: 'Déficit nutricional',
    cause: 'Anemia ferropénica, déficit de vitamina D, B12 o zinc. Cabello se cae antes de tiempo.',
    treatment: 'CLIBEL coordina con tu médico para corregir déficit + bioestimulación tópica',
  },
];

// ============ ANATOMÍA FOLICULAR (NUEVO) ============
const cycle = [
  {
    phase: 'Anágena',
    duration: '2–6 años',
    coverage: '85–90%',
    text: 'Fase de crecimiento activo. El folículo está conectado a la papila dérmica, alimentado por vasos sanguíneos. PRP y mesoterapia actúan aquí estimulando producción.',
  },
  {
    phase: 'Catágena',
    duration: '2–3 semanas',
    coverage: '1–3%',
    text: 'Fase de transición. El folículo se desprende de la papila y empieza a involucionar. Brevísima, casi siempre asintomática.',
  },
  {
    phase: 'Telógena',
    duration: '2–4 meses',
    coverage: '10–15%',
    text: 'Fase de reposo. Al final el pelo cae y un nuevo folículo entra en anágena. Si la proporción telógena/anágena se invierte, hay caída anormal.',
  },
];

// ============ CASOS CLÍNICOS / PLANES (NUEVO) ============
const cases = [
  {
    name: 'Plan caída temprana',
    duration: '4 sesiones · 3 meses',
    profile: 'Mujeres 25–40 años con caída reciente',
    combo: ['Mesoterapia capilar mensual', 'Bioactivos domiciliarios', 'Análisis hormonal y nutricional'],
    target: 'Atacar la caída antes de que avance. CLIBEL prioriza identificar causa metabólica/hormonal y revertirla con apoyo regenerativo tópico.',
    accent: 'gold',
  },
  {
    name: 'Plan posparto',
    duration: '6 sesiones · 6 meses',
    profile: 'Mamás 2–8 meses posparto',
    combo: ['Mesoterapia bioactivos', 'PRP a partir del 3er mes', 'Suplementación segura en lactancia'],
    target: 'Acompañar el efluvio telógeno posparto con seguridad clínica. CLIBEL trabaja respetando lactancia con activos compatibles.',
    accent: 'rose',
  },
  {
    name: 'Plan androgenética',
    duration: '8 sesiones · 8 meses',
    profile: 'Hombres y mujeres con patrón hereditario',
    combo: ['PRP capilar mensual', 'Mesoterapia con antiandrógenos', 'Minoxidil supervisado domiciliario'],
    target: 'Frenar miniaturización folicular y rescatar folículos viables. CLIBEL define pronóstico realista por tricoscopia antes de empezar.',
    accent: 'mauve',
  },
  {
    name: 'Plan mantenimiento',
    duration: 'Mensual indefinido',
    profile: 'Pacientes con caída controlada',
    combo: ['1 sesión mensual rotativa', 'Revisión tricoscópica trimestral', 'Ajuste de domiciliario según evidencia'],
    target: 'Sostener el resultado a largo plazo. CLIBEL convierte el tratamiento intensivo en rutina ligera con seguimiento clínico documentado.',
    accent: 'gold',
  },
];

// ============ TIMELINE DE RESULTADOS (NUEVO — específico capilar) ============
const timeline = [
  {
    when: 'Mes 01',
    label: 'Caída se estabiliza',
    text: 'CLIBEL evalúa primera respuesta tricoscópica. Es normal que sigas viendo cabello caer — los folículos en telógena ya programados continúan ciclo. La caída anormal se reduce.',
  },
  {
    when: 'Mes 03',
    label: 'Crece pelo nuevo visible',
    text: 'Aparecen pelos cortos y finos en línea de implantación. Fototricograma comparativo en CLIBEL documenta densidad. Es el primer punto donde decides si el plan funciona.',
  },
  {
    when: 'Mes 06',
    label: 'Densidad consolidada',
    text: 'Cabello nuevo alcanza grosor normal. Densidad clínicamente medible. CLIBEL evalúa si pasar a fase de mantenimiento o continuar plan intensivo según respuesta.',
  },
  {
    when: 'Mes 12',
    label: 'Resultado a largo plazo',
    text: 'Cabello recuperado integrado a tu rutina. Mantenimiento con 1 sesión mensual. CLIBEL recomienda fototricograma anual para comparativa de largo plazo.',
  },
];

// ============ HÁBITOS — NUEVO ============
const habits = {
  sabotage: [
    'Lavados con agua muy caliente diariamente',
    'Secadora a temperatura máxima sin protector térmico',
    'Coletas, trenzas y rodetes tensos crónicos',
    'Tintes con amoniaco cada 4 semanas o menos',
    'Dietas restrictivas sin acompañamiento nutricional',
    'Suplementos virales sin diagnóstico (biotina en megadosis, etc.)',
  ],
  helpful: [
    'Lavado con agua tibia, secar palmadeando (no frotar)',
    'Masaje craneal con yemas 5 min al día para activar circulación',
    'Protección solar capilar en exposición prolongada',
    'Tintes sin amoniaco espaciados 6+ semanas',
    'Dieta equilibrada con proteína, hierro y omega-3',
    'Suplementación solo según diagnóstico clínico, no por moda',
  ],
};

// ============ FAQs específicas capilares (humanizadas + interlinking) ============
const faqs: { q: string; answerHtml: string }[] = [
  {
    q: '¿Cuándo empezaré a ver resultados con el tratamiento capilar?',
    answerHtml: 'La caída se estabiliza al mes 1–2. Crecimiento nuevo visible aparece mes 3–4. Densidad consolidada hacia el mes 6. El cabello tiene tiempos biológicos largos que ningún tratamiento puede acortar — quien promete resultados en 30 días miente. <a href="/servicios/tratamiento-capilar">Ver programa integral →</a>',
  },
  {
    q: '¿El PRP capilar duele?',
    answerHtml: 'CLIBEL aplica anestesia tópica en cuero cabelludo 20 min antes. La sensación durante la aplicación es de pequeños piquetes tolerables. Después la zona queda sensible algunas horas, sin dolor real. Es ambulatorio total. <a href="/servicios/prp-capilar">Conoce el protocolo PRP capilar →</a>',
  },
  {
    q: '¿Sirve para alopecia avanzada o calvicie consolidada?',
    answerHtml: 'Honestidad clínica: si el folículo ya está atrofiado (zona brillante sin folículos visibles en tricoscopia), ningún tratamiento médico lo revive. Sí densificamos zonas con folículos miniaturizados aún viables. Para calvicie consolidada lo único es <strong>transplante quirúrgico</strong> — derivamos con cirujano de confianza. La <a href="/servicios/tricologia-clinica">tricología</a> determina candidatura.',
  },
  {
    q: '¿Qué diferencia hay entre PRP y mesoterapia capilar?',
    answerHtml: '<a href="/servicios/prp-capilar"><strong>PRP capilar</strong></a>: tu propia sangre procesada con factores de crecimiento autólogos. Sin riesgo de alergia. <a href="/servicios/mesoterapia-capilar"><strong>Mesoterapia capilar</strong></a>: cócteles farmacéuticos con bioactivos específicos (dutasterida tópica, biotina, vitaminas). Son complementarios — CLIBEL frecuentemente los alterna en plan integral para potenciar efecto.',
  },
  {
    q: '¿El tratamiento sirve igual en hombres y mujeres?',
    answerHtml: 'Los principios biológicos son los mismos pero los planes difieren. CLIBEL personaliza dosis, sustancias y frecuencia según sexo, edad, perfil hormonal y patrón específico. Patrón masculino (Norwood): entradas y vertex. Patrón femenino (Ludwig): difusión centroparietal. En mujer con sospecha hormonal coordinamos con ginecología.',
  },
  {
    q: '¿Puedo combinar tratamiento con minoxidil o finasterida?',
    answerHtml: 'Sí, y de hecho es lo más eficaz. <strong>Minoxidil tópico</strong>: no requiere receta, accesible. <strong>Finasterida oral</strong>: requiere receta médica (CLIBEL puede prescribir si eres candidato). La combinación PRP/mesoterapia + medicación supera al protocolo aislado en evidencia clínica. <a href="/servicios/tratamiento-capilar">Plan integral coordinado →</a>',
  },
  {
    q: '¿Hay efectos secundarios?',
    answerHtml: 'CLIBEL informa todos honestamente: sensibilidad transitoria post-sesión, mínimo enrojecimiento, posible aumento momentáneo de caída en primeras 2 semanas (<strong>shedding efluvio</strong> — señal de que está funcionando, no empeoramiento real), reacciones locales raras. Sin efectos sistémicos relevantes — son tratamientos locales.',
  },
  {
    q: '¿Por qué CLIBEL pide análisis antes del tratamiento?',
    answerHtml: 'Porque muchas alopecias tienen causa subyacente: anemia ferropénica, hipotiroidismo, hiperandrogenismo, déficit de vitamina D. Sin descartar esto, aplicar PRP/mesoterapia es atacar el síntoma sin tratar la causa — el resultado será parcial o nulo. La <a href="/servicios/tricologia-clinica">tricología clínica</a> es el filtro obligatorio.',
  },
];
---

<BaseLayout
  title={`Tratamientos Capilares en CDMX | CLIBEL`}
  description={`Tratamientos capilares en CLIBEL: tricología clínica, PRP capilar y mesoterapia para caída del cabello, alopecia androgenética y debilitamiento. Diagnóstico tricoscópico avanzado en CDMX.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(catalogSchema)} />

  <!-- ============================ BREADCRUMB ============================ -->
  <Breadcrumb
    kicker="Categoría 05 · Capilares"
    items={[
      { label: 'Servicios', href: '/servicios' },
      { label: 'Tratamientos Capilares' },
    ]}
  />

  <!-- ============================ HERO ============================ -->
  <section class="cat-hero">
    <div aria-hidden="true" class="cat-hero-bg"></div>
    <div aria-hidden="true" class="cat-hero-blob cat-hero-blob-1"></div>
    <div aria-hidden="true" class="cat-hero-blob cat-hero-blob-2"></div>
    <div aria-hidden="true" class="cat-hero-grain"></div>

    <div class="container-x relative">
      <div class="cat-hero-grid">
        <div class="cat-hero-col cat-hero-col--left fade-up">
          <span class="eyebrow-tag">
            <span class="dot" aria-hidden="true"></span>
            Categoría 05 · {cat.badgeLabel} · Tricología clínica
          </span>

          <h1 class="cat-hero-headline">
            <span class="cat-hero-headline-line">Tratamientos</span>
            <span class="cat-hero-headline-line"><em>capilares</em> en CDMX.</span>
          </h1>

          <p class="cat-hero-lede">
            Diagnóstico tricoscópico antes de cualquier plan. CLIBEL trata
            la <strong>caída del cabello con criterio médico</strong> — no con
            fórmulas mágicas ni promesas en 30 días. Resultados reales en
            tiempos biológicos honestos.
          </p>

          <div class="cat-hero-trust">
            <span class="cat-hero-trust-label">Tecnología clínica</span>
            <div class="cat-hero-trust-list">
              <span>Dermatoscopia digital</span><span aria-hidden="true">·</span>
              <span>PRP autólogo</span><span aria-hidden="true">·</span>
              <span>Mesoterapia</span><span aria-hidden="true">·</span>
              <span>Fototricograma</span>
            </div>
          </div>
        </div>

        <div class="cat-hero-col cat-hero-col--right fade-up-delay-2">
          <span class="cat-hero-kicker">Qué hace CLIBEL en capilar</span>

          <p class="cat-hero-paragraph">
            <strong>CLIBEL</strong> es una clínica de belleza con respaldo
            médico especializada en tricología clínica en Ciudad de México.
            A diferencia de spas que venden "ampolletas milagrosas", cada
            plan capilar parte de <strong>diagnóstico tricoscópico</strong>
            por dermatoscopio digital y análisis hormonal-nutricional cuando
            aplica. Identificamos el tipo de alopecia antes de proponer
            tratamiento — porque androgenética, telógena, areata y cicatrizal
            requieren protocolos distintos (y algunas NO responden a PRP).
          </p>

          <p class="cat-hero-paragraph">
            En esta categoría reunimos los cuatro protocolos capilares
            integrales: <a href="/servicios/tricologia-clinica"><strong>tricología
            clínica</strong></a> como filtro diagnóstico obligatorio,
            <a href="/servicios/prp-capilar"><strong>PRP capilar autólogo</strong></a>
            con kit certificado, <a href="/servicios/mesoterapia-capilar"><strong>mesoterapia
            con bioactivos</strong></a> y <a href="/servicios/tratamiento-capilar"><strong>tratamiento
            capilar avanzado integral</strong></a> que combina técnicas
            según diagnóstico. Documentamos cada sesión con tricoscopia
            comparativa — evidencia objetiva, no memoria subjetiva.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================ NAV TOP ============================ -->
  <HeroNavBar
    label="Otras categorías"
    ariaLabel="Otras categorías de tratamientos CLIBEL"
    variant="cream"
    links={[
      { label: 'Faciales',         href: catHref('facial') },
      { label: 'Corporales',       href: catHref('corporal') },
      { label: 'Depilación láser', href: catHref('laser') },
      { label: 'Medicina estética',href: catHref('medicina-estetica') },
    ]}
    cta={{ label: 'Volver al catálogo', href: '/servicios' }}
  />

  <!-- ============================ CATÁLOGO ============================ -->
  <section class="section bg-white">
    <div class="container-x">
      <SectionHeader
        kicker={`Catálogo · ${items.length} ${items.length === 1 ? 'protocolo base' : 'protocolos'}`}
        title="Tratamientos capilares en <em>CLIBEL</em>."
        paragraphs={[
          '<strong>CLIBEL</strong> aborda la salud capilar como problema clínico real, no como problema cosmético. Cada plan capilar parte de tricoscopia, historia clínica completa y, cuando aplica, análisis hormonal-nutricional. CLIBEL nunca aplica PRP o mesoterapia sin antes identificar tipo y causa de la alopecia.',
          'El tratamiento base se adapta según diagnóstico. <strong>CLIBEL</strong> documenta densidad folicular inicial con tricoscopia digital y compara con fototricograma trimestral — para que la evidencia hable, no la sensación.',
        ]}
        cta={{ label: 'Solicitar diagnóstico tricológico', href: '/contacto', variant: 'primary' }}
      />

      <div class="cat-grid">
        {items.map((s) => (
          <ServiceCard
            href={`/servicios/${s.id}`}
            title={s.data.title}
            description={s.data.description}
            category={s.data.category}
            duration={s.data.duration}
            sessions={s.data.sessions}
            icon={s.data.icon}
            featured={s.data.featured}
            benefits={s.data.benefits}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ============================ STAT STRIP CLÍNICO ============================ -->
  <section class="svc-stat-strip">
    <div class="container-x">
      <dl class="capilar-stats">
        <div>
          <dt>Protocolos</dt>
          <dd><em>{items.length}</em></dd>
        </div>
        <div>
          <dt>Tipos de alopecia</dt>
          <dd><em>06</em></dd>
        </div>
        <div>
          <dt>Diagnóstico</dt>
          <dd class="capilar-stats-text">Tricoscopia digital</dd>
        </div>
        <div>
          <dt>Documentación</dt>
          <dd class="capilar-stats-text">Foto comparativa basal</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- ============================ PROFUNDIZA · interlinking L3 → L4 ============================ -->
  <section class="section bg-[color:var(--color-brand-50)]">
    <div class="container-x">
      <SectionHeader
        marginBottom="md"
        kicker="Profundiza en cada protocolo"
        title="Cada protocolo capilar<br/>de <em>CLIBEL</em>, en detalle."
        paragraphs={[
          'Los cuatro protocolos capilares de <strong>CLIBEL</strong> tienen su propia página clínica con diagnóstico, pasos, modalidades, casos reales, mitos desmontados y <strong>protocolo de seguridad documentado</strong>. La medicina capilar seria exige decisión informada — aquí está todo lo que necesitas saber.',
          'Si no sabes por dónde empezar, <a href="/servicios/tricologia-clinica"><strong>tricología clínica</strong></a> es el filtro obligatorio: diagnóstico antes de tratamiento. Sin clasificación de tipo de alopecia, aplicar PRP o mesoterapia es improvisación cosmética cara.',
        ]}
      />

      <ol class="spot-list">
        {items.map((s, i) => {
          const meta = editorialLedes[s.id];
          const topBen = (s.data.benefits ?? []).slice(0, 2);
          const waSvc = `https://wa.me/${CONTACT.whatsapp}?text=${encodeURIComponent(`Hola CLIBEL, me interesa el tratamiento ${s.data.title}.`)}`;
          return (
            <li class="spot reveal">
              <div class="spot-num-wrap" aria-hidden="true">
                <span class="spot-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="spot-num-line"></span>
              </div>

              <div class="spot-body">
                <header class="spot-head">
                  <span class="spot-kicker">{s.data.icon ?? '✦'} {cat.short} · Protocolo {String(i + 1).padStart(2, '0')}</span>
                  <h3 class="spot-title">
                    <a href={`/servicios/${s.id}`}>{s.data.title}</a>
                  </h3>
                </header>

                <dl class="spot-meta">
                  {s.data.duration && (
                    <div>
                      <dt>Duración</dt>
                      <dd>{s.data.duration}</dd>
                    </div>
