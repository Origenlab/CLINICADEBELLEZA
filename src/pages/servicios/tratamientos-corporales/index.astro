  .plan-head {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }
  .plan-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2.25rem, 3.5vw, 3rem);
    color: var(--accent-color, var(--color-brand-500));
    line-height: 0.85;
    letter-spacing: -0.02em;
    flex-shrink: 0;
  }
  .plan-title-block {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .plan-kicker {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-brand-500);
    opacity: 0.85;
  }
  .plan-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.4rem, 1.8vw, 1.75rem);
    color: var(--color-ink-900);
    margin: 0;
    line-height: 1.15;
    letter-spacing: -0.018em;
  }

  .plan-meta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    padding-block: 0.85rem;
    border-block: 1px dashed rgba(201, 169, 97, 0.32);
  }
  .plan-meta > div {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .plan-meta-label {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-brand-500);
  }
  .plan-meta-value {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--color-ink-900);
    letter-spacing: -0.005em;
    line-height: 1.25;
  }

  .plan-body { display: flex; flex-direction: column; gap: 0.45rem; }
  .plan-includes-label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-mauve-500);
  }
  .plan-includes {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .plan-includes li {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    font-size: 0.88rem;
    line-height: 1.45;
    color: var(--color-ink-700);
  }
  .plan-includes li svg {
    flex-shrink: 0;
    margin-top: 0.2rem;
    color: var(--accent-color, var(--color-mauve-500));
  }

  .plan-target {
    margin: 0;
    padding: 0.85rem 0.95rem;
    background: var(--color-brand-50);
    border-left: 3px solid var(--accent-color, var(--color-brand-400));
    border-radius: 0 0.55rem 0.55rem 0;
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--color-ink-700);
    font-style: italic;
  }

  /* ============= NEW: Timeline de resultados ============= */
  .svc-timeline { background: white; }
  .tl-list {
    list-style: none;
    padding: 0;
    margin: clamp(2rem, 4vw, 3rem) 0 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
  }
  .tl-step {
    display: grid;
    grid-template-columns: clamp(110px, 18vw, 200px) 1fr;
    gap: clamp(1.5rem, 3vw, 3rem);
    padding-block: clamp(1.5rem, 2.5vw, 2.25rem);
    border-top: 1px solid rgba(201, 169, 97, 0.22);
    align-items: start;
    position: relative;
  }
  .tl-step:first-child { border-top: 0; padding-top: 0; }
  .tl-step-mark {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    align-items: flex-start;
    position: relative;
  }
  .tl-step-when {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.65rem, 2.5vw, 2.25rem);
    color: var(--color-mauve-500);
    line-height: 1;
    letter-spacing: -0.018em;
  }
  .tl-step-dot {
    width: 10px; height: 10px;
    border-radius: 999px;
    background: var(--color-brand-400);
    box-shadow: 0 0 0 4px rgba(201, 169, 97, 0.18), 0 0 0 8px rgba(201, 169, 97, 0.07);
  }
  .tl-step-body {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    max-width: 60ch;
  }
  .tl-step-label {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.25rem, 1.8vw, 1.65rem);
    color: var(--color-ink-900);
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.015em;
  }
  .tl-step-text {
    font-size: clamp(0.92rem, 1vw, 1.02rem);
    line-height: 1.7;
    color: var(--color-ink-700);
    margin: 0;
  }
  @media (max-width: 640px) {
    .tl-step { grid-template-columns: 1fr; gap: 0.75rem; }
    .tl-step-mark { flex-direction: row; align-items: center; gap: 1rem; }
  }

  /* ============= Aftercare por fases (dark) ============= */
  .svc-aftercare {
    background: var(--color-ink-900);
    color: var(--color-brand-100);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }
  .svc-aftercare-bg {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(to right, rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 80px 80px;
    opacity: 0.55;
    pointer-events: none;
    z-index: 0;
  }
  .svc-aftercare-blob {
    position: absolute;
    top: -10rem; right: -8rem;
    width: 32rem; height: 32rem;
    border-radius: 999px;
    background: rgba(92, 57, 70, 0.35);
    filter: blur(120px);
    pointer-events: none;
    z-index: 0;
  }

  .after-list {
    list-style: none;
    padding: 0;
    margin: clamp(2rem, 4vw, 3rem) 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .after-list { grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
  }
  @media (min-width: 1100px) {
    .after-list { grid-template-columns: repeat(4, 1fr); }
  }
  .after-item {
    position: relative;
    padding: 1.5rem 1.5rem 1.6rem;
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.1rem;
    transition: all 0.4s ease !important;
  }
  .after-item:hover {
    background: rgba(255, 255, 255, 0.055);
    border-color: rgba(201, 169, 97, 0.45);
    transform: translateY(-4px);
  }
  .after-phase {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-brand-400);
    padding: 0.3rem 0.7rem;
    background: rgba(201, 169, 97, 0.1);
    border: 1px solid rgba(201, 169, 97, 0.3);
    border-radius: 999px;
    margin-bottom: 1rem;
  }
  .after-body { display: flex; flex-direction: column; gap: 0.45rem; position: relative; }
  .after-step-num {
    position: absolute;
    top: -2.6rem;
    right: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: 2.5rem;
    line-height: 1;
    background: linear-gradient(180deg, var(--color-brand-400), var(--color-mauve-300));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    opacity: 0.55;
    letter-spacing: -0.015em;
  }
  .after-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.2rem;
    color: white;
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.012em;
  }
  .after-text {
    font-size: 0.88rem;
    line-height: 1.6;
    color: rgba(242, 235, 223, 0.78);
    margin: 0;
  }

  /* ============= FAQ + Form ============= */
  .faq-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 3vw, 2.75rem);
    align-items: start;
  }
  @media (min-width: 1024px) {
    .faq-grid {
      grid-template-columns: 1.15fr 0.85fr;
      gap: clamp(2.5rem, 4vw, 3.5rem);
    }
  }
  .faq-col-label {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-brand-500);
    margin-bottom: 1.1rem;
  }
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .faq {
    background: var(--color-brand-50);
    border: 1px solid rgba(201, 169, 97, 0.22);
    border-radius: 1rem;
    overflow: hidden;
    transition: border-color 0.3s ease, background 0.3s ease !important;
  }
  .faq[open] {
    background: white;
    border-color: var(--color-mauve-500);
  }
  .faq-sum {
    list-style: none;
    cursor: pointer;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1rem;
    align-items: center;
    padding: 1.1rem 1.25rem;
  }
  .faq-sum::-webkit-details-marker { display: none; }
  .faq-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1rem;
    color: var(--color-brand-500);
    letter-spacing: 0.04em;
    line-height: 1;
    opacity: 0.8;
    min-width: 24px;
  }
  .faq-q {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1rem, 1.1vw, 1.12rem);
    color: var(--color-ink-900);
    line-height: 1.3;
    letter-spacing: -0.005em;
  }
  .faq-plus {
    width: 32px; height: 32px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: var(--color-brand-100);
    color: var(--color-mauve-500);
    transition: transform 0.35s cubic-bezier(.2,.8,.2,1), background 0.3s ease, color 0.3s ease !important;
  }
  .faq[open] .faq-plus {
    transform: rotate(45deg);
    background: var(--color-mauve-500);
    color: white;
  }
  .faq-a {
    padding: 0 1.25rem 1.25rem clamp(3.5rem, 6vw, 4rem);
    font-size: 0.92rem;
    line-height: 1.65;
    color: var(--color-ink-700);
  }

  /* ===== Form WhatsApp (mismo patrón) ===== */
  .faq-form-wrap { position: relative; }
  @media (min-width: 1024px) {
    .faq-form-wrap { position: sticky; top: clamp(6rem, 10vh, 7.5rem); }
  }
  .faq-form {
    background: linear-gradient(180deg, #FFFFFF 0%, var(--color-brand-50) 100%);
    border: 1px solid rgba(201, 169, 97, 0.3);
    border-radius: 1.25rem;
    padding: clamp(1.5rem, 2vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 0.95rem;
    box-shadow:
      0 1px 2px rgba(31, 20, 24, 0.03),
      0 24px 56px -28px rgba(31, 20, 24, 0.18);
  }
  .faq-form-kicker {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mauve-500);
  }
  .faq-form-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.45rem, 2vw, 1.85rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-ink-900);
    margin: 0;
  }
  .faq-form-title em {
    font-style: italic;
    color: var(--color-mauve-500);
    font-weight: 400;
  }
  .faq-form-sub {
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--color-ink-500);
    margin: 0 0 0.5rem;
  }
  .faq-form-sub strong { color: var(--color-ink-900); font-weight: 600; }
  .faq-form-row { display: flex; flex-direction: column; gap: 0.32rem; }
  .faq-form-grid-2 {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
  }
  @media (min-width: 520px) {
    .faq-form-grid-2 { grid-template-columns: 1fr 1fr; }
  }
  .faq-form-row label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-ink-700);
    letter-spacing: 0.02em;
  }
  .faq-form-row label span[aria-hidden] {
    color: var(--color-mauve-500);
    margin-left: 2px;
  }
  .faq-form input,
  .faq-form select,
  .faq-form textarea {
    width: 100%;
    padding: 0.7rem 0.9rem;
    font-family: var(--font-sans);
    font-size: 0.92rem;
    color: var(--color-ink-900);
    background: white;
    border: 1px solid rgba(201, 169, 97, 0.35);
    border-radius: 0.65rem;
    outline: none;
    transition: border-color 0.25s ease, box-shadow 0.25s ease, background 0.25s ease !important;
    appearance: none;
    line-height: 1.4;
  }
  .faq-form select {
    background-image:
      linear-gradient(45deg, transparent 50%, var(--color-mauve-500) 50%),
      linear-gradient(135deg, var(--color-mauve-500) 50%, transparent 50%);
    background-position: calc(100% - 18px) calc(50% - 2px), calc(100% - 13px) calc(50% - 2px);
    background-size: 5px 5px;
    background-repeat: no-repeat;
    padding-right: 2rem;
    cursor: pointer;
  }
  .faq-form textarea { resize: vertical; min-height: 80px; }
  .faq-form input:focus,
  .faq-form select:focus,
  .faq-form textarea:focus {
    border-color: var(--color-mauve-500);
    box-shadow: 0 0 0 3px rgba(139, 90, 107, 0.12);
    background: var(--color-brand-50);
  }
  .faq-form.is-invalid input:required:invalid,
  .faq-form.is-invalid input[type="checkbox"]:invalid + span { border-color: #c62b3e; }

  .faq-form-check {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    margin-top: 0.25rem;
    font-size: 0.78rem;
    line-height: 1.45;
    color: var(--color-ink-500);
    cursor: pointer;
  }
  .faq-form-check input[type="checkbox"] {
    width: 16px;
    height: 16px;
    margin-top: 2px;
    accent-color: var(--color-mauve-500);
    flex-shrink: 0;
    cursor: pointer;
  }
  .faq-form-check a {
    color: var(--color-mauve-500);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .faq-form-check a:hover { color: var(--color-mauve-700); }
  .faq-form-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    padding: 0.95rem 1.25rem;
    margin-top: 0.5rem;
    background: #25D366;
    color: white;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.01em;
    border: 0;
    border-radius: 999px;
    cursor: pointer;
    box-shadow:
      0 10px 24px -10px rgba(37, 211, 102, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.25);
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease !important;
  }
  .faq-form-submit:hover {
    background: #1FB855;
    transform: translateY(-2px);
    box-shadow:
      0 16px 32px -10px rgba(37, 211, 102, 0.7),
      inset 0 1px 0 rgba(255, 255, 255, 0.3);
  }
  .faq-form-foot {
    margin: 0;
    text-align: center;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-500);
    opacity: 0.85;
  }
  @media (max-width: 640px) { .faq-form { padding: 1.25rem; } }

  /* ============= Hero · links inline en párrafos ============= */
  .cat-hero-paragraph a {
    color: var(--color-mauve-500);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: color 0.25s ease !important;
  }
  .cat-hero-paragraph a:hover { color: var(--color-mauve-700); }
  .cat-hero-paragraph a strong { color: inherit; font-weight: 600; }

  /* ============= PROFUNDIZA — editorial spotlight por L4 ============= */
  .spot-list {
    list-style: none;
    padding: 0;
    margin: clamp(2rem, 3vw, 2.75rem) 0 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .spot {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    padding-block: clamp(2rem, 3vw, 2.75rem);
    border-top: 1px solid rgba(201, 169, 97, 0.32);
    align-items: start;
  }
  .spot:first-child { border-top: 0; padding-top: 0; }
  .spot:last-child { padding-bottom: 0; }
  @media (min-width: 820px) {
    .spot { grid-template-columns: clamp(80px, 11vw, 130px) 1fr; gap: clamp(1.5rem, 3vw, 3rem); }
  }
  .spot-num-wrap { display: flex; align-items: baseline; gap: 0.85rem; }
  @media (min-width: 820px) {
    .spot-num-wrap { flex-direction: column; align-items: flex-start; gap: 0.75rem; padding-top: 0.3rem; }
  }
  .spot-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(3rem, 5vw, 4.5rem);
    line-height: 0.85;
    background: linear-gradient(180deg, var(--color-brand-500), var(--color-mauve-500));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.02em;
  }
  .spot-num-line {
    width: 32px;
    height: 1.5px;
    background: linear-gradient(90deg, var(--color-brand-400), var(--color-mauve-500));
    border-radius: 2px;
  }
  @media (max-width: 819px) {
    .spot-num-line { display: none; }
  }
  .spot-body { display: flex; flex-direction: column; gap: 1rem; min-width: 0; }
  .spot-head { display: flex; flex-direction: column; gap: 0.5rem; }
  .spot-kicker {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mauve-500);
  }
  .spot-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.75rem, 2.6vw, 2.4rem);
    line-height: 1.08;
    letter-spacing: -0.022em;
    color: var(--color-ink-900);
    margin: 0;
    max-width: 26ch;
  }
  .spot-title a {
    color: inherit;
    text-decoration: none;
    background-image: linear-gradient(90deg, var(--color-brand-400), var(--color-mauve-500));
    background-repeat: no-repeat;
    background-size: 0 2px;
    background-position: 0 100%;
    transition: background-size 0.4s cubic-bezier(.2,.8,.2,1) !important;
    padding-bottom: 2px;
  }
  .spot-title a:hover { background-size: 100% 2px; }
  .spot-meta {
    margin: 0;
    padding: 0.85rem 0;
    border-block: 1px dashed rgba(201, 169, 97, 0.3);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }
  @media (min-width: 700px) { .spot-meta { grid-template-columns: repeat(4, 1fr); } }
  .spot-meta > div { padding: 0; }
  .spot-meta > div + div {
    padding-left: clamp(0.75rem, 1.5vw, 1.25rem);
    border-left: 1px dashed rgba(201, 169, 97, 0.3);
  }
  .spot-meta dt {
    font-family: var(--font-sans);
    font-size: 0.56rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-brand-500);
    margin-bottom: 0.25rem;
  }
  .spot-meta dd {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(0.92rem, 1vw, 1.05rem);
    line-height: 1.2;
    color: var(--color-ink-900);
    letter-spacing: -0.005em;
  }
  .spot-lede {
    margin: 0;
    font-size: clamp(0.98rem, 1.05vw, 1.1rem);
    line-height: 1.7;
    color: var(--color-ink-700);
    max-width: 68ch;
  }
  .spot-benefits {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.45rem;
  }
  @media (min-width: 700px) { .spot-benefits { grid-template-columns: 1fr 1fr; gap: 0.65rem 1.5rem; } }
  .spot-benefits li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--color-ink-700);
  }
  .spot-benefits li svg {
    flex-shrink: 0;
    margin-top: 4px;
    color: var(--color-brand-500);
  }
  .spot-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    align-items: center;
    padding-top: 0.5rem;
  }
  .spot-cta {
    display: inline-flex;
