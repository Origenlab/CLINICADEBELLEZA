---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import HeroNavBar from '../../../components/HeroNavBar.astro';
import RelatedCategories from '../../../components/RelatedCategories.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, SITE, catHref } from '../../../consts';

const cat = CATEGORIES.corporal;

const all = await getCollection('servicios');
const items = all
  .filter((s) => s.data.category === 'corporal')
  .sort((a, b) => a.data.order - b.data.order);


// ============ SCHEMAS SEO ============
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Servicios', item: `${SITE.url}/servicios` },
    { '@type': 'ListItem', position: 3, name: 'Tratamientos Corporales', item: `${SITE.url}/servicios/tratamientos-corporales` },
  ],
};
const catalogSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalSpecialty',
  name: 'Tratamientos Corporales — CLIBEL',
  description: 'Radiofrecuencia corporal, reducción de grasa localizada, drenaje linfático y anticelulitis con respaldo médico en CDMX.',
  url: `${SITE.url}/servicios/tratamientos-corporales`,
  provider: { '@id': `${SITE.url}/#clinic` },
  relevantSpecialty: ['Dermatology', 'PhysicalTherapy'],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Catálogo de tratamientos corporales CLIBEL',
    itemListElement: items.map((s) => ({
      '@type': 'MedicalProcedure',
      name: s.data.title,
      description: s.data.description,
      url: `${SITE.url}/servicios/${s.id}`,
    })),
  },
};

// ============ Editorial leds por L4 (humanizados · sección Profundiza) ============
const editorialLedes: Record<string, { lede: string; readMore: string }> = {
  'radiofrecuencia-corporal': {
    lede: 'El protocolo silencioso que produce colágeno nuevo. Sin moretones espectaculares ni cambios visibles al salir de cabina — solo estímulo térmico monitoreado al fibroblasto profundo y respuesta biológica real entre la sesión 3 y la semana 12.',
    readMore: 'Ver protocolo térmico',
  },
  'reduccion-grasa-localizada': {
    lede: 'No es lipo sin lipo y no es perder peso: es esculpir cúmulos rebeldes en peso estable. Combinamos criolipólisis, HIFU, radiofrecuencia y cavitación según tu diagnóstico — ninguna técnica única funciona para todos los casos.',
    readMore: 'Ver las 4 tecnologías',
  },
  'drenaje-linfatico': {
    lede: 'No es masaje relajante. Es técnica médica con presión muy ligera y dirección anatómica precisa, certificada por las escuelas Vodder y Leduc. Aplica en post-cirugía, edema crónico, post-parto y linfedema — no como remedio universal de spa.',
    readMore: 'Ver técnica clínica',
  },
  'masaje-anticelulitis': {
    lede: 'La celulitis tiene cuatro grados clínicos y tres tipos histológicos. Antes de tratarla, la clasificamos. Después la trabajamos con técnica manual + vacumterapia + radiofrecuencia, y te decimos honestamente que el 50% del resultado depende de tu compromiso fuera de cabina.',
    readMore: 'Ver grados clínicos',
  },
};

// ============ CONCERNS — qué resolvemos (cada concern enlaza al L4) ============
const concerns: { title: string; text: string; href?: string; linkLabel?: string }[] = [
  {
    title: 'Flacidez corporal',
    text: 'Piel que perdió tono por pérdida de peso, embarazo o edad. La solución es estímulo térmico al fibroblasto profundo — radiofrecuencia bipolar o multipolar según zona, con paciencia biológica de 6 a 12 semanas para ver colágeno nuevo maduro.',
    href: '/servicios/radiofrecuencia-corporal',
    linkLabel: 'Ver radiofrecuencia corporal',
  },
  {
    title: 'Grasa localizada rebelde',
    text: 'Los cúmulos que dieta y ejercicio no terminan de resolver. Criolipólisis para grasa subcutánea fría, HIFU para profunda, radiofrecuencia para flacidez asociada. No es pérdida de peso — es remodelación de silueta en peso estable.',
    href: '/servicios/reduccion-grasa-localizada',
    linkLabel: 'Ver reducción de grasa',
  },
  {
    title: 'Celulitis grado I a IV',
    text: 'La celulitis tiene clasificación clínica y tipos histológicos distintos. Antes de tratarla la clasificamos; después combinamos masaje + vacumterapia + radiofrecuencia. Honestidad clínica incluida: no se borra, se atenúa y se mantiene a raya.',
    href: '/servicios/masaje-anticelulitis',
    linkLabel: 'Ver tratamiento anticelulitis',
  },
  {
    title: 'Retención y piernas pesadas',
    text: 'Hinchazón crónica de tobillos, sensación de piernas cansadas, retención perimenstrual o por bipedestación prolongada. Drenaje linfático manual real (no masaje cambiado de etiqueta) con técnica Vodder o Leduc.',
    href: '/servicios/drenaje-linfatico',
    linkLabel: 'Ver drenaje linfático',
  },
  {
    title: 'Recuperación posparto',
    text: 'Después de cuarentena médica y con autorización ginecológica. Drenaje linfático para reducir edema, radiofrecuencia para reafirmar abdomen y, si aplica, plan integral coordinado con tu ginecólogo. Compatible con lactancia en la mayoría de casos.',
    href: '/servicios/drenaje-linfatico',
    linkLabel: 'Empezar con drenaje',
  },
  {
    title: 'Recuperación post-quirúrgica',
    text: 'Post-lipoescultura, abdominoplastia o cirugía estética. Drenaje linfático método Leduc desde el día 3–5 según indicación de tu cirujano. Reduce edema, equimosis y previene fibrosis. CLIBEL coordina directamente con tu cirujano.',
    href: '/servicios/drenaje-linfatico',
    linkLabel: 'Ver drenaje post-quirúrgico',
  },
];

// ============ STACK — tecnología y productos ============
const stack = [
  { kicker: 'Equipos clínicos', value: 'Radiofrecuencia bipolar', detail: 'Reafirmación profunda con estimulación de colágeno' },
  { kicker: 'Equipos clínicos', value: 'Ultrasonido focalizado', detail: 'Reducción no invasiva en zonas específicas' },
  { kicker: 'Equipos clínicos', value: 'Presoterapia', detail: 'Drenaje mecánico de retorno linfático y venoso' },
  { kicker: 'Técnicas manuales', value: 'Masaje reductivo', detail: 'Movilización adiposa profunda por terapeutas certificadas' },
  { kicker: 'Técnicas manuales', value: 'Drenaje linfático Vodder', detail: 'Método certificado para descongestión tisular' },
  { kicker: 'Productos', value: 'Activos profesionales', detail: 'Lipolíticos, reafirmantes y descongestivos COFEPRIS' },
];

// ============ PLANES INTEGRALES (combos linkados a L4) ============
const plans: { name: string; sessions: string; frequency: string; includes: { label: string; href?: string }[]; target: string; accent: 'gold' | 'mauve' | 'rose'; primaryHref?: string }[] = [
  {
    name: 'Plan Reafirmación',
    sessions: '8–12 sesiones',
    frequency: '2 por semana · 6 semanas',
    includes: [
      { label: 'Radiofrecuencia corporal multipolar', href: '/servicios/radiofrecuencia-corporal' },
      { label: 'Masaje reductivo dirigido', href: '/servicios/masaje-anticelulitis' },
      { label: 'Activos reafirmantes profesionales' },
    ],
    target: 'Para flacidez visible post-pérdida de peso, post-embarazo o por edad. Abdomen, brazos, muslos internos. Resultado documentado al mes 3 con foto comparativa.',
    accent: 'mauve',
    primaryHref: '/servicios/radiofrecuencia-corporal',
  },
  {
    name: 'Plan Reducción',
    sessions: '6–10 sesiones',
    frequency: '1–2 por semana · 4–6 semanas',
    includes: [
      { label: 'Criolipólisis o HIFU según zona', href: '/servicios/reduccion-grasa-localizada' },
      { label: 'Radiofrecuencia complementaria', href: '/servicios/radiofrecuencia-corporal' },
      { label: 'Drenaje linfático entre sesiones', href: '/servicios/drenaje-linfatico' },
    ],
    target: 'Grasa localizada rebelde a dieta y ejercicio en flancos, abdomen bajo, espalda y muslos. Remodelación en peso estable — no pérdida de peso.',
    accent: 'gold',
    primaryHref: '/servicios/reduccion-grasa-localizada',
  },
  {
    name: 'Plan Posparto · Recuperación',
    sessions: '10–15 sesiones',
    frequency: 'A partir de las 6 semanas posparto',
    includes: [
      { label: 'Drenaje linfático manual Vodder', href: '/servicios/drenaje-linfatico' },
      { label: 'Reafirmación gradual con radiofrecuencia', href: '/servicios/radiofrecuencia-corporal' },
      { label: 'Coordinación con ginecólogo' },
    ],
    target: 'Para mamás que buscan recuperar tono y reducir hinchazón posparto. Respeta lactancia y diástasis abdominal. Inicio con autorización ginecológica.',
    accent: 'rose',
    primaryHref: '/servicios/drenaje-linfatico',
  },
];

// ============ TIMELINE DE RESULTADOS — nuevo en L3 corporal ============
const timeline = [
  {
    when: 'Sesión 01',
    label: 'Diagnóstico y baseline',
    text: 'CLIBEL documenta medidas, fotos clínicas y bioimpedancia. Primera sesión técnica con respuesta inicial visible en circulación y volumen.',
  },
  {
    when: 'Sesión 03',
    label: 'Primer cambio medible',
    text: 'Reducción de centímetros y mejora de textura cutánea. CLIBEL ajusta intensidad y zona según respuesta documentada del tejido.',
  },
  {
    when: 'Sesión 06',
    label: 'Resultado consolidado',
    text: 'Reafirmación visible, reducción confirmada en mediciones y mejora estructural de la piel. Es el punto crítico de evaluación clínica en CLIBEL.',
  },
  {
    when: 'Mantenimiento',
    label: 'Resultado sostenible',
    text: 'CLIBEL diseña plan de mantenimiento mensual o bimestral para sostener resultados a largo plazo, con seguimiento fotográfico cada trimestre.',
  },
];

// ============ AFTERCARE — por fases temporales ============
const aftercare = [
  {
    phase: 'Primeras 24 h',
    title: 'Hidratación intensa',
    text: 'CLIBEL te indica protocolo de hidratación abundante (2.5–3 L), reposo activo y evitar calor extremo. Sin sauna ni vapor en las primeras 24 horas.',
  },
  {
    phase: '7 días',
    title: 'Movimiento controlado',
    text: 'Caminata ligera y rutina de hidratación tópica que CLIBEL te entrega por escrito. Documentamos respuesta y ajustamos el plan en revisión semanal.',
  },
  {
    phase: '30 días',
    title: 'Consolidación',
    text: 'Primera evaluación fotográfica comparativa en CLIBEL. Mediciones documentadas. Si hay respuesta esperada, continuamos plan; si no, replanteamos protocolo.',
  },
  {
    phase: '90 días',
    title: 'Resultados duraderos',
    text: 'CLIBEL evalúa resultado final del plan y propone esquema de mantenimiento personalizado. La trazabilidad se conserva en tu expediente clínico digital.',
  },
];

// ============ FAQS específicas corporales (humanizadas + interlinking) ============
const faqs: { q: string; answerHtml: string }[] = [
  {
    q: '¿Cuántas sesiones de radiofrecuencia necesito para ver firmeza?',
    answerHtml: 'El cambio en textura se nota desde la sesión 3 con un protocolo de 1–2 por semana. La reafirmación clínica completa se documenta entre las sesiones 6 y 10 — los tiempos biológicos del colágeno no se aceleran, son 6 a 12 semanas para madurar. <a href="/servicios/radiofrecuencia-corporal">Conoce el protocolo térmico completo →</a>',
  },
  {
    q: '¿La reducción de grasa localizada es definitiva?',
    answerHtml: 'Las técnicas no invasivas (criolipólisis, HIFU) destruyen adipocitos en zonas específicas — los eliminados no regresan. Las células remanentes pueden volver a llenarse si subes de peso significativamente. Por eso es importante que sea en peso estable + mantenimiento bimestral. <a href="/servicios/reduccion-grasa-localizada">Conoce las 4 modalidades →</a>',
  },
  {
    q: '¿Es seguro hacer tratamientos corporales en lactancia o posparto temprano?',
    answerHtml: 'Después de las 6 semanas posparto y cuarentena médica cumplida, sí: <a href="/servicios/drenaje-linfatico">drenaje linfático manual</a>, masaje reductivo suave y <a href="/servicios/radiofrecuencia-corporal">radiofrecuencia</a> controlada son seguros. Coordinamos con tu ginecóloga si hay diástasis abdominal o cesárea reciente.',
  },
  {
    q: '¿Duele algún tratamiento corporal?',
    answerHtml: 'Nada de lo que aplicamos es doloroso. La radiofrecuencia y el HIFU producen calor confortable; el drenaje es muy suave (presión 15–40 mmHg); el masaje reductivo puede ser intenso pero nunca llega a dolor. Si en algún momento te resulta incómodo, ajustamos intensidad en tiempo real.',
  },
  {
    q: '¿Puedo combinar varios tratamientos corporales?',
    answerHtml: 'Sí, y es lo más eficaz para casos complejos. Combinamos <a href="/servicios/reduccion-grasa-localizada">criolipólisis</a> + <a href="/servicios/radiofrecuencia-corporal">radiofrecuencia</a> para reducción + reafirmación; añadimos <a href="/servicios/drenaje-linfatico">drenaje linfático</a> para acelerar eliminación; integramos <a href="/servicios/masaje-anticelulitis">masaje anticelulitis</a> cuando hay celulitis estructural. El plan se diseña en valoración, no se vende como paquete cerrado.',
  },
  {
    q: '¿Necesito dieta o ejercicio durante el tratamiento?',
    answerHtml: 'Recomendamos alimentación equilibrada y actividad cardiovascular moderada para potenciar resultados — sobre todo en planes de reducción de grasa y anticelulitis donde el componente conductual es crítico. No exigimos dietas extremas ni rutinas de gimnasio. Si quieres, coordinamos con tu nutriólogo.',
  },
  {
    q: '¿Qué pasa si tengo várices o cirugías previas?',
    answerHtml: 'Várices severas o trombosis activa/reciente: contraindicación absoluta para drenaje y masaje reductivo. Várices leves: caso a caso con valoración. Cirugías estéticas previas: seguras después de 3 meses post-operatorios con autorización del cirujano. Implantes mamarios de silicona: contraindica RF en zona torácica, otras zonas sí.',
  },
];
---

<BaseLayout
  title={`${cat.label} en CDMX | CLIBEL`}
  description={`${cat.label} en CLIBEL: radiofrecuencia, reducción de grasa localizada, drenaje linfático y anticelulitis con respaldo médico, tecnología no invasiva certificada y planes integrales personalizados en CDMX.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(catalogSchema)} />

  <!-- ============================ BREADCRUMB ============================ -->
  <Breadcrumb
    kicker="Categoría 02 · Corporales"
    items={[
      { label: 'Servicios', href: '/servicios' },
      { label: 'Tratamientos Corporales' },
    ]}
  />

  <!-- ============================ HERO ============================ -->
  <section class="cat-hero">
    <div aria-hidden="true" class="cat-hero-bg"></div>
    <div aria-hidden="true" class="cat-hero-blob cat-hero-blob-1"></div>
    <div aria-hidden="true" class="cat-hero-blob cat-hero-blob-2"></div>
    <div aria-hidden="true" class="cat-hero-grain"></div>

    <div class="container-x relative">
      <div class="cat-hero-grid">
        <div class="cat-hero-col cat-hero-col--left fade-up">
          <span class="eyebrow-tag">
            <span class="dot" aria-hidden="true"></span>
            Categoría 02 · {cat.badgeLabel} · {items.length} tratamientos
          </span>

          <h1 class="cat-hero-headline">
            <span class="cat-hero-headline-line">Tratamientos</span>
            <span class="cat-hero-headline-line"><em>corporales</em> en CDMX.</span>
          </h1>

          <p class="cat-hero-lede">
            Remodelación, reafirmación y bienestar físico con
            <strong>tecnología no invasiva certificada</strong>. CLIBEL diseña
            planes corporales a medida tras valoración clínica, sin paquetes
            prearmados ni promesas vacías.
          </p>

          <div class="cat-hero-trust">
            <span class="cat-hero-trust-label">Trabajamos con</span>
            <div class="cat-hero-trust-list">
              <span>Venus Concept</span><span aria-hidden="true">·</span>
              <span>BTL</span><span aria-hidden="true">·</span>
              <span>Indiba</span><span aria-hidden="true">·</span>
              <span>Sinclair</span><span aria-hidden="true">·</span>
              <span>Cellulazione</span>
            </div>
          </div>
        </div>

        <div class="cat-hero-col cat-hero-col--right fade-up-delay-2">
          <span class="cat-hero-kicker">Qué hace CLIBEL en corporales</span>

          <p class="cat-hero-paragraph">
            <strong>CLIBEL</strong> es una clínica de belleza con respaldo
            médico real, especializada en remodelación corporal no invasiva
            en Ciudad de México. Combinamos tecnología certificada
            —radiofrecuencia bipolar, criolipólisis, HIFU, presoterapia— con
            técnicas manuales aplicadas por terapeutas formadas y supervisadas
            por personal médico. Cada plan corporal nace de un diagnóstico
            real: medidas, bioimpedancia y fotografía clínica multi-ángulo.
            Sin paquetes prearmados.
          </p>

          <p class="cat-hero-paragraph">
            En esta categoría reunimos los cuatro protocolos corporales más
            solicitados: <a href="/servicios/radiofrecuencia-corporal"><strong>radiofrecuencia</strong></a>
            para reafirmar piel, <a href="/servicios/reduccion-grasa-localizada"><strong>reducción
            de grasa localizada</strong></a> no invasiva,
            <a href="/servicios/drenaje-linfatico"><strong>drenaje linfático</strong></a>
            manual con técnica Vodder/Leduc, y
            <a href="/servicios/masaje-anticelulitis"><strong>masaje reductivo y
            anticelulitis</strong></a> con clasificación por grado clínico.
            Trabajamos con resultados medibles —centímetros, fotografía
            comparativa, respuesta tisular— documentados sesión a sesión en
            tu expediente.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================ NAV TOP ============================ -->
  <HeroNavBar
    label="Otras categorías"
    ariaLabel="Otras categorías de tratamientos CLIBEL"
    variant="cream"
    links={[
      { label: 'Faciales',           href: catHref('facial') },
      { label: 'Depilación láser',   href: catHref('laser') },
      { label: 'Medicina estética',  href: catHref('medicina-estetica') },
      { label: 'Capilares',          href: catHref('capilar') },
    ]}
    cta={{ label: 'Volver al catálogo', href: '/servicios' }}
  />

  <!-- ============================ CATÁLOGO ============================ -->
  <section class="section bg-white">
    <div class="container-x">
      <SectionHeader
        kicker={`Catálogo · ${items.length} tratamientos`}
        title="Los protocolos corporales<br/>que aplica <em>CLIBEL</em>."
        paragraphs={[
          'Cada protocolo corporal de <strong>CLIBEL</strong> nace de un diagnóstico real con bioimpedancia, perímetros y fotografía basal multi-ángulo. Trabajamos remodelación, reafirmación, reducción de grasa, drenaje y recuperación post-parto o post-quirúrgica — siempre con tecnología certificada y técnica supervisada.',
          'Cada sesión registra medidas, parámetros de equipo y respuesta tisular en tu expediente digital. Esa trazabilidad es lo que permite a <strong>CLIBEL</strong> ajustar intensidad, frecuencia y técnica con base en cómo responde tu cuerpo — no según un guion comercial.',
        ]}
        cta={{ label: 'Solicitar valoración', href: '/contacto', variant: 'primary' }}
      />

      <div class="cat-grid">
        {items.map((s) => (
          <ServiceCard
            href={`/servicios/${s.id}`}
            title={s.data.title}
            description={s.data.description}
            category={s.data.category}
            duration={s.data.duration}
            sessions={s.data.sessions}
            icon={s.data.icon}
            featured={s.data.featured}
            benefits={s.data.benefits}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ============================ PROFUNDIZA · interlinking L3 → L4 ============================ -->
  <section class="section bg-[color:var(--color-brand-50)]">
    <div class="container-x">
      <SectionHeader
        marginBottom="md"
        kicker="Profundiza en cada protocolo"
        title="Cada tratamiento corporal<br/>en <em>CLIBEL</em>, en detalle."
        paragraphs={[
          'Estos son los cuatro protocolos corporales que <strong>CLIBEL</strong> aplica como base. Cada uno tiene su propia página clínica con pasos, modalidades, zonas, casos reales, mitos desmontados y comparativas — para que decidas con información completa, no con marketing.',
          'Si no sabes por dónde empezar, la <strong>radiofrecuencia</strong> es la entrada lógica para perfiles con flacidez, y la <strong>reducción de grasa localizada</strong> para cúmulos rebeldes en peso estable. Los demás se integran encima.',
        ]}
      />

      <ol class="spot-list">
        {items.map((s, i) => {
          const meta = editorialLedes[s.id];
          const topBen = (s.data.benefits ?? []).slice(0, 2);
          return (
            <li class="spot reveal">
              <div class="spot-num-wrap" aria-hidden="true">
                <span class="spot-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="spot-num-line"></span>
              </div>

              <div class="spot-body">
                <header class="spot-head">
                  <span class="spot-kicker">{s.data.icon ?? '✦'} {cat.short} · Protocolo {String(i + 1).padStart(2, '0')}</span>
                  <h3 class="spot-title">
                    <a href={`/servicios/${s.id}`}>{s.data.title}</a>
                  </h3>
                </header>

                <dl class="spot-meta">
                  {s.data.duration && (
                    <div>
                      <dt>Duración</dt>
                      <dd>{s.data.duration}</dd>
                    </div>
                  )}
                  {s.data.sessions && (
                    <div>
                      <dt>Frecuencia</dt>
                      <dd>{s.data.sessions.split('·')[0].trim()}</dd>
                    </div>
                  )}
                  {(s.data.protocolSteps?.length ?? 0) > 0 && (
                    <div>
                      <dt>Pasos clínicos</dt>
                      <dd>{s.data.protocolSteps?.length}</dd>
                    </div>
                  )}
                  {(s.data.modalities?.length ?? 0) > 0 && (
                    <div>
                      <dt>Modalidades</dt>
                      <dd>{s.data.modalities?.length}</dd>
                    </div>
                  )}
                </dl>

                <p class="spot-lede">{meta?.lede ?? s.data.description}</p>

                {topBen.length > 0 && (
                  <ul class="spot-benefits">
                    {topBen.map((b) => (
                      <li>
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        <span>{b}</span>
                      </li>
                    ))}
                  </ul>
                )}

                <div class="spot-actions">
                  <a href={`/servicios/${s.id}`} class="spot-cta spot-cta--primary">
                    {meta?.readMore ?? 'Conocer protocolo'}
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
