  <script is:inline define:vars={{ waBase: `https://wa.me/${CONTACT.whatsapp}` }}>
    (function () {
      const form = document.getElementById('corpWaForm');
      if (!form) return;
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const d = new FormData(form);
        const get = (k) => (d.get(k) || '').toString().trim();
        const nombre = get('nombre'), tel = get('telefono'), email = get('email');
        const interes = get('interes'), zona = get('zona'), msg = get('mensaje');
        const acepto = form.querySelector('[name="privacidad"]').checked;

        if (!nombre || !tel || !acepto) {
          form.classList.add('is-invalid');
          return;
        }
        form.classList.remove('is-invalid');

        const lines = [
          'Hola CLIBEL, vengo desde la página de Tratamientos Corporales.',
          '',
          'Nombre: ' + nombre,
          'Teléfono: ' + tel,
        ];
        if (email)   lines.push('Email: ' + email);
        if (interes) lines.push('Me interesa: ' + interes);
        if (zona)    lines.push('Zona principal: ' + zona);
        if (msg)     lines.push('', 'Comentario: ' + msg);

        window.open(waBase + '?text=' + encodeURIComponent(lines.join('\n')), '_blank', 'noopener');
      });
    })();
  </script>

