---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ServiceCard from '../../../components/ServiceCard.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import HeroNavBar from '../../../components/HeroNavBar.astro';
import RelatedCategories from '../../../components/RelatedCategories.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, SITE, CONTACT, catHref } from '../../../consts';

const cat = CATEGORIES.corporal;

const all = await getCollection('servicios');
const items = all
  .filter((s) => s.data.category === 'corporal')
  .sort((a, b) => a.data.order - b.data.order);

const wa = `https://wa.me/${CONTACT.whatsapp}?text=${encodeURIComponent('Hola, me gustaría agendar una cita en CLIBEL para tratamientos corporales.')}`;

// ============ SCHEMAS SEO ============
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Servicios', item: `${SITE.url}/servicios` },
    { '@type': 'ListItem', position: 3, name: 'Tratamientos Corporales', item: `${SITE.url}/servicios/tratamientos-corporales` },
  ],
};
const catalogSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalSpecialty',
  name: 'Tratamientos Corporales — CLIBEL',
  description: 'Radiofrecuencia corporal, reducción de grasa localizada, drenaje linfático y anticelulitis con respaldo médico en CDMX.',
  url: `${SITE.url}/servicios/tratamientos-corporales`,
  provider: { '@id': `${SITE.url}/#clinic` },
  relevantSpecialty: ['Dermatology', 'PhysicalTherapy'],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Catálogo de tratamientos corporales CLIBEL',
    itemListElement: items.map((s) => ({
      '@type': 'MedicalProcedure',
      name: s.data.title,
      description: s.data.description,
      url: `${SITE.url}/servicios/${s.id}`,
    })),
  },
};

// ============ CONCERNS — qué resolvemos ============
const concerns = [
  {
    title: 'Flacidez corporal',
    text: 'CLIBEL combina radiofrecuencia bipolar, ultrasonido focalizado y trabajo manual para estimular colágeno nuevo y reafirmar piel en abdomen, brazos, glúteos y piernas — sin cirugía y con resultados graduales.',
  },
  {
    title: 'Grasa localizada',
    text: 'En CLIBEL diseñamos planes de reducción no invasiva combinando técnicas térmicas y mecánicas para zonas resistentes al ejercicio: abdomen bajo, flancos, espalda baja y muslos internos.',
  },
  {
    title: 'Celulitis y piel de naranja',
    text: 'CLIBEL atiende celulitis adiposa, edematosa y fibrosa con protocolos diferenciados. Combinamos drenaje, presoterapia, masaje reductivo y radiofrecuencia para mejorar textura y firmeza.',
  },
  {
    title: 'Retención de líquidos',
    text: 'Drenaje linfático manual y mecánico aplicado por especialistas formados en CLIBEL para activar circulación, descongestionar tejidos y reducir hinchazón crónica o circunstancial.',
  },
  {
    title: 'Recuperación posparto',
    text: 'CLIBEL diseña protocolos posparto seguros para mamás —respetando lactancia y diástasis— con drenaje, radiofrecuencia controlada y reactivación muscular gradual.',
  },
  {
    title: 'Recuperación post-quirúrgica',
    text: 'Acompañamiento clínico en CLIBEL para drenaje post-liposucción, abdominoplastía o cirugía estética con coordinación directa con tu cirujano y seguimiento documentado.',
  },
];

// ============ STACK — tecnología y productos ============
const stack = [
  { kicker: 'Equipos clínicos', value: 'Radiofrecuencia bipolar', detail: 'Reafirmación profunda con estimulación de colágeno' },
  { kicker: 'Equipos clínicos', value: 'Ultrasonido focalizado', detail: 'Reducción no invasiva en zonas específicas' },
  { kicker: 'Equipos clínicos', value: 'Presoterapia', detail: 'Drenaje mecánico de retorno linfático y venoso' },
  { kicker: 'Técnicas manuales', value: 'Masaje reductivo', detail: 'Movilización adiposa profunda por terapeutas certificadas' },
  { kicker: 'Técnicas manuales', value: 'Drenaje linfático Vodder', detail: 'Método certificado para descongestión tisular' },
  { kicker: 'Productos', value: 'Activos profesionales', detail: 'Lipolíticos, reafirmantes y descongestivos COFEPRIS' },
];

// ============ PLANES INTEGRALES — nuevo en L3 corporal ============
const plans = [
  {
    name: 'Plan Reafirmación',
    sessions: '8–12 sesiones',
    frequency: '2 por semana · 6 semanas',
    includes: ['Radiofrecuencia corporal', 'Masaje reductivo dirigido', 'Activos reafirmantes profesionales'],
    target: 'Flacidez visible post-pérdida de peso, post-embarazo o por edad. Zonas: abdomen, brazos, muslos internos.',
    accent: 'mauve',
  },
  {
    name: 'Plan Reducción',
    sessions: '6–10 sesiones',
    frequency: '1–2 por semana · 4–6 semanas',
    includes: ['Ultrasonido focalizado', 'Radiofrecuencia bipolar', 'Drenaje complementario'],
    target: 'Grasa localizada resistente al ejercicio en flancos, abdomen bajo, espalda y muslos. Sin cirugía.',
    accent: 'gold',
  },
  {
    name: 'Plan Posparto / Recuperación',
    sessions: '10–15 sesiones',
    frequency: 'A partir de las 6 semanas posparto',
    includes: ['Drenaje linfático manual', 'Trabajo abdominal supervisado', 'Reafirmación gradual con RF'],
    target: 'Mamás que buscan recuperar tono y reducir hinchazón posparto, respetando lactancia y diástasis abdominal.',
    accent: 'rose',
  },
];

// ============ TIMELINE DE RESULTADOS — nuevo en L3 corporal ============
const timeline = [
  {
    when: 'Sesión 01',
    label: 'Diagnóstico y baseline',
    text: 'CLIBEL documenta medidas, fotos clínicas y bioimpedancia. Primera sesión técnica con respuesta inicial visible en circulación y volumen.',
  },
  {
    when: 'Sesión 03',
    label: 'Primer cambio medible',
    text: 'Reducción de centímetros y mejora de textura cutánea. CLIBEL ajusta intensidad y zona según respuesta documentada del tejido.',
  },
  {
    when: 'Sesión 06',
    label: 'Resultado consolidado',
    text: 'Reafirmación visible, reducción confirmada en mediciones y mejora estructural de la piel. Es el punto crítico de evaluación clínica en CLIBEL.',
  },
  {
    when: 'Mantenimiento',
    label: 'Resultado sostenible',
    text: 'CLIBEL diseña plan de mantenimiento mensual o bimestral para sostener resultados a largo plazo, con seguimiento fotográfico cada trimestre.',
  },
];

// ============ AFTERCARE — por fases temporales ============
const aftercare = [
  {
    phase: 'Primeras 24 h',
    title: 'Hidratación intensa',
    text: 'CLIBEL te indica protocolo de hidratación abundante (2.5–3 L), reposo activo y evitar calor extremo. Sin sauna ni vapor en las primeras 24 horas.',
  },
  {
    phase: '7 días',
    title: 'Movimiento controlado',
    text: 'Caminata ligera y rutina de hidratación tópica que CLIBEL te entrega por escrito. Documentamos respuesta y ajustamos el plan en revisión semanal.',
  },
  {
    phase: '30 días',
    title: 'Consolidación',
    text: 'Primera evaluación fotográfica comparativa en CLIBEL. Mediciones documentadas. Si hay respuesta esperada, continuamos plan; si no, replanteamos protocolo.',
  },
  {
    phase: '90 días',
    title: 'Resultados duraderos',
    text: 'CLIBEL evalúa resultado final del plan y propone esquema de mantenimiento personalizado. La trazabilidad se conserva en tu expediente clínico digital.',
  },
];

// ============ FAQS específicas corporales ============
const faqs = [
  { q: '¿Cuántas sesiones de radiofrecuencia necesito para ver firmeza?', a: 'En CLIBEL el cambio en textura se nota desde la sesión 3 con un protocolo de 1–2 por semana. La reafirmación clínica completa se documenta entre las sesiones 6 y 10, dependiendo del estado basal de tu piel y tu edad. Cada plan se diseña a medida.' },
  { q: '¿La reducción de grasa localizada es definitiva?', a: 'CLIBEL aplica técnicas no invasivas (ultrasonido focalizado, RF) que destruyen adipocitos en zonas específicas. La grasa eliminada no regresa si mantienes tu peso, pero células remanentes pueden crecer si subes mucho. Por eso CLIBEL incluye plan nutricional sugerido y mantenimiento.' },
  { q: '¿Es seguro hacer tratamientos corporales en lactancia o posparto temprano?', a: 'En CLIBEL trabajamos posparto a partir de las 6 semanas, con protocolos seguros para lactancia: drenaje manual, masaje reductivo y RF controlada sin activos sistémicos. Coordinamos con tu ginecóloga si hay diástasis abdominal o cesárea reciente.' },
  { q: '¿Duele algún tratamiento corporal?', a: 'CLIBEL trabaja con técnicas no invasivas: radiofrecuencia y ultrasonido producen calor confortable, el drenaje es suave y el masaje reductivo puede ser intenso pero nunca doloroso. Si algún protocolo te resulta incómodo, ajustamos intensidad en tiempo real.' },
  { q: '¿Puedo combinar varios tratamientos corporales?', a: 'Sí, y es lo que CLIBEL recomienda. Los planes integrales (Reafirmación, Reducción, Posparto) combinan 2–3 técnicas complementarias para resultados superiores. Cada combinación se diseña según diagnóstico, no como paquete prearmado.' },
  { q: '¿Necesito dieta o ejercicio durante el tratamiento?', a: 'CLIBEL recomienda mantener alimentación equilibrada y actividad física moderada para potenciar resultados, pero NO exigimos dietas extremas ni rutinas de gimnasio. Si quieres, podemos coordinarnos con tu nutriólogo o entrenador.' },
];
---

<BaseLayout
  title={`${cat.label} en CDMX | CLIBEL`}
  description={`${cat.label} en CLIBEL: radiofrecuencia, reducción de grasa localizada, drenaje linfático y anticelulitis con respaldo médico, tecnología no invasiva certificada y planes integrales personalizados en CDMX.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(catalogSchema)} />

  <!-- ============================ BREADCRUMB ============================ -->
  <Breadcrumb
    kicker="Categoría 02 · Corporales"
    items={[
      { label: 'Servicios', href: '/servicios' },
      { label: 'Tratamientos Corporales' },
    ]}
  />

  <!-- ============================ HERO ============================ -->
  <section class="cat-hero">
    <div aria-hidden="true" class="cat-hero-bg"></div>
    <div aria-hidden="true" class="cat-hero-blob cat-hero-blob-1"></div>
    <div aria-hidden="true" class="cat-hero-blob cat-hero-blob-2"></div>
    <div aria-hidden="true" class="cat-hero-grain"></div>

    <div class="container-x relative">
      <div class="cat-hero-grid">
        <div class="cat-hero-col cat-hero-col--left fade-up">
          <span class="eyebrow-tag">
            <span class="dot" aria-hidden="true"></span>
            Categoría 02 · {cat.badgeLabel} · {items.length} tratamientos
          </span>

          <h1 class="cat-hero-headline">
            <span class="cat-hero-headline-line">Tratamientos</span>
            <span class="cat-hero-headline-line"><em>corporales</em> en CDMX.</span>
          </h1>

          <p class="cat-hero-lede">
            Remodelación, reafirmación y bienestar físico con
            <strong>tecnología no invasiva certificada</strong>. CLIBEL diseña
            planes corporales a medida tras valoración clínica, sin paquetes
            prearmados ni promesas vacías.
          </p>

          <div class="cat-hero-trust">
            <span class="cat-hero-trust-label">Trabajamos con</span>
            <div class="cat-hero-trust-list">
              <span>Venus Concept</span><span aria-hidden="true">·</span>
              <span>BTL</span><span aria-hidden="true">·</span>
              <span>Indiba</span><span aria-hidden="true">·</span>
              <span>Sinclair</span><span aria-hidden="true">·</span>
              <span>Cellulazione</span>
            </div>
          </div>
        </div>

        <div class="cat-hero-col cat-hero-col--right fade-up-delay-2">
          <span class="cat-hero-kicker">Qué hace CLIBEL en corporales</span>

          <p class="cat-hero-paragraph">
            <strong>CLIBEL</strong> es una clínica de belleza con respaldo
            médico real, especializada en remodelación corporal no invasiva
            en Ciudad de México. Combinamos tecnología certificada
            —radiofrecuencia bipolar, ultrasonido focalizado, presoterapia— con
            técnicas manuales aplicadas por terapeutas formadas y supervisadas
            por personal médico. Cada plan corporal en CLIBEL se diseña tras un
            diagnóstico clínico que incluye medidas, fotografía y bioimpedancia.
          </p>

          <p class="cat-hero-paragraph">
            En esta categoría <strong>CLIBEL</strong> reúne sus protocolos
            corporales más solicitados: <strong>radiofrecuencia</strong> para
            reafirmar piel, <strong>reducción de grasa localizada</strong>
            no invasiva, <strong>drenaje linfático</strong> manual y mecánico,
            y <strong>masaje reductivo y anticelulitis</strong>. CLIBEL trabaja
            con resultados medibles —centímetros, fotografía comparativa,
            respuesta tisular— documentados sesión a sesión en tu expediente.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================ NAV TOP ============================ -->
  <HeroNavBar
    label="Otras categorías"
    ariaLabel="Otras categorías de tratamientos CLIBEL"
    variant="cream"
    links={[
      { label: 'Faciales',           href: catHref('facial') },
      { label: 'Depilación láser',   href: catHref('laser') },
      { label: 'Medicina estética',  href: catHref('medicina-estetica') },
      { label: 'Capilares',          href: catHref('capilar') },
    ]}
    cta={{ label: 'Volver al catálogo', href: '/servicios' }}
  />

  <!-- ============================ CATÁLOGO ============================ -->
  <section class="section bg-white">
    <div class="container-x">
      <SectionHeader
        kicker={`Catálogo · ${items.length} tratamientos`}
        title="Tratamientos corporales en <em>CLIBEL</em>."
        paragraphs={[
          '<strong>CLIBEL</strong> realiza tratamientos corporales con grado clínico real: cada protocolo se aplica con tecnología certificada, técnicas validadas y respuesta tisular documentada sesión a sesión. En CLIBEL trabajamos remodelación, reafirmación, reducción de grasa localizada, drenaje y recuperación posparto o post-quirúrgica.',
          'Cada plan corporal en <strong>CLIBEL</strong> registra medidas iniciales, fotografía clínica de baseline y parámetros de cada equipo en expediente digital. Esa trazabilidad permite a CLIBEL ajustar intensidad, frecuencia y técnica con base en cómo responde tu cuerpo, no según un guion comercial.',
        ]}
        cta={{ label: 'Solicitar valoración', href: '/contacto', variant: 'primary' }}
      />

      <div class="cat-grid">
        {items.map((s) => (
          <ServiceCard
            href={`/servicios/${s.id}`}
            title={s.data.title}
            description={s.data.description}
            category={s.data.category}
            duration={s.data.duration}
            sessions={s.data.sessions}
            icon={s.data.icon}
            featured={s.data.featured}
            benefits={s.data.benefits}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ============================ CONCERNS ============================ -->
  <section class="section bg-[color:var(--color-brand-50)]">
    <div class="container-x">
      <SectionHeader
        kicker="Qué resolvemos"
        title="Problemas corporales que atiende <em>CLIBEL</em>."
        paragraphs={[
          '<strong>CLIBEL</strong> aborda las preocupaciones corporales más comunes que llegan a consulta: flacidez post-pérdida de peso o por edad, grasa localizada resistente al ejercicio, celulitis en sus diferentes tipos, retención de líquidos, recuperación posparto y post-quirúrgica. Cada motivo de consulta tiene un protocolo clínico distinto en CLIBEL — no aplicamos plantillas.',
          'En <strong>CLIBEL</strong> el diagnóstico define el plan: combinamos radiofrecuencia, ultrasonido, drenaje y trabajo manual según lo que tu cuerpo realmente necesita. No tratamos zonas que no requieren intervención, ni vendemos paquetes sin antes evaluar.',
        ]}
      />

      <div class="concern-grid">
        {concerns.map((c, i) => (
          <article class="concern reveal">
            <span class="concern-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="concern-title">{c.title}</h3>
            <p class="concern-text">{c.text}</p>
            <span class="concern-line" aria-hidden="true"></span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================ TECNOLOGÍA Y STACK ============================ -->
  <section class="section bg-white">
    <div class="container-x">
      <SectionHeader
        kicker="Tecnología y productos"
        title="Lo que <em>CLIBEL</em> usa en cada sesión corporal."
        paragraphs={[
          '<strong>CLIBEL</strong> opera con plataformas corporales de marcas internacionales certificadas —Venus Concept, BTL, Indiba— y técnicas manuales formadas en escuelas clínicas reconocidas (método Vodder, técnica francesa, drenaje sueco). Cada equipo se calibra antes de la sesión y cada protocolo se documenta en expediente.',
          'En <strong>CLIBEL</strong> los productos tópicos profesionales —lipolíticos, reafirmantes, descongestivos— tienen registro COFEPRIS visible con lote y trazabilidad disponibles para el paciente. CLIBEL no usa cosmecéuticos sin respaldo ni equipos imitación.',
        ]}
      />

      <div class="stack-grid">
        {stack.map((item, i) => (
          <article class="stack-item reveal">
            <span class="stack-kicker">{item.kicker}</span>
            <h3 class="stack-value">{item.value}</h3>
            <p class="stack-detail">{item.detail}</p>
            <span class="stack-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================ PLANES INTEGRALES ============================ -->
  <section class="section svc-plans">
    <div class="container-x">
      <SectionHeader
        kicker="Planes integrales"
        title="Combinaciones clínicas que diseña <em>CLIBEL</em>."
        paragraphs={[
          '<strong>CLIBEL</strong> arma planes integrales que combinan 2–3 técnicas corporales complementarias para resultados superiores a cualquier tratamiento aislado. Cada plan en CLIBEL incluye número estimado de sesiones, frecuencia clínica óptima y técnicas que se refuerzan entre sí.',
          'Estos planes son <strong>orientativos</strong>. CLIBEL siempre personaliza el plan final tras tu valoración clínica — adaptamos sesiones, frecuencia, intensidad y combinación de técnicas según tu diagnóstico real, no según un paquete prearmado.',
        ]}
      />

      <div class="plans-grid">
        {plans.map((p, i) => (
          <article class={`plan plan--${p.accent} reveal`}>
            <header class="plan-head">
              <span class="plan-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <div class="plan-title-block">
                <span class="plan-kicker">Plan integral</span>
                <h3 class="plan-name">{p.name}</h3>
              </div>
            </header>

            <div class="plan-meta">
              <div>
                <span class="plan-meta-label">Sesiones</span>
                <span class="plan-meta-value">{p.sessions}</span>
              </div>
              <div>
                <span class="plan-meta-label">Frecuencia</span>
                <span class="plan-meta-value">{p.frequency}</span>
              </div>
            </div>

            <div class="plan-body">
              <span class="plan-includes-label">Incluye</span>
              <ul class="plan-includes">
                {p.includes.map((inc) => (
                  <li>
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    {inc}
                  </li>
                ))}
              </ul>
            </div>

            <p class="plan-target">{p.target}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================ TIMELINE DE RESULTADOS ============================ -->
  <section class="section svc-timeline">
    <div class="container-x">
      <SectionHeader
        kicker="Resultados esperados"
        title="Cuándo verás cambios con <em>CLIBEL</em>."
        paragraphs={[
          'En <strong>CLIBEL</strong> documentamos cada sesión con medidas, fotografía clínica y respuesta tisular. Esta línea de tiempo refleja la respuesta promedio en pacientes de CLIBEL — los tuyos pueden variar según diagnóstico inicial, edad, hábitos y respuesta individual.',
          '<strong>CLIBEL</strong> no promete resultados milagrosos. Te decimos por escrito qué esperar en cada etapa del plan, qué evidencia clínica respalda esa expectativa y cómo se ajusta si tu cuerpo responde diferente a lo previsto.',
        ]}
      />

      <ol class="tl-list">
        {timeline.map((t, i) => (
          <li class="tl-step reveal">
            <div class="tl-step-mark">
              <span class="tl-step-when">{t.when}</span>
              <span class="tl-step-dot" aria-hidden="true"></span>
            </div>
            <div class="tl-step-body">
              <h3 class="tl-step-label">{t.label}</h3>
              <p class="tl-step-text">{t.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============================ AFTERCARE POR FASES ============================ -->
  <section class="section svc-aftercare">
    <div aria-hidden="true" class="svc-aftercare-bg"></div>
    <div aria-hidden="true" class="svc-aftercare-blob"></div>

    <div class="container-x relative">
      <SectionHeader
        kicker="Aftercare por fases"
        title="Cuidados que <em>CLIBEL</em> documenta y supervisa."
        variant="dark"
        paragraphs={[
          'Un tratamiento corporal en <strong>CLIBEL</strong> no termina cuando sales del consultorio: empieza la fase clave donde se consolidan los resultados. CLIBEL entrega protocolo aftercare por fases temporales —24 horas, 7 días, 30 días, 90 días— con indicaciones específicas, señales de alerta y revisión documentada.',
          'En <strong>CLIBEL</strong> abrimos línea directa con tu terapeuta y médico responsable para resolver dudas durante el postratamiento. La consolidación del resultado requiere acompañamiento clínico real, no un PDF genérico — eso es parte del estándar CLIBEL.',
        ]}
      />

      <ol class="after-list">
        {aftercare.map((a, i) => (
          <li class="after-item reveal">
            <span class="after-phase" aria-hidden="true">{a.phase}</span>
            <div class="after-body">
              <span class="after-step-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="after-title">{a.title}</h3>
              <p class="after-text">{a.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============================ FAQ + FORM ============================ -->
  <section class="section bg-white">
    <div class="container-x">
      <SectionHeader
        kicker="Preguntas frecuentes y contacto"
        title="Resuelve dudas o pide tu <em>valoración corporal</em>."
        paragraphs={[
          'Las preguntas más frecuentes que recibe <strong>CLIBEL</strong> sobre tratamientos corporales no invasivos —resultados, seguridad, lactancia, combinaciones— resueltas con criterio clínico. A la derecha puedes enviarnos tus datos: la consulta llega directo al WhatsApp clínico de CLIBEL.',
