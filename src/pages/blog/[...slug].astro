---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((p) => !p.data.draft)
    .map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const fmt = (d: Date) =>
  d.toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  type="article"
  publishedAt={entry.data.publishedAt}
  image={entry.data.image}
>
  <article>
    <!-- Hero -->
    <section class="bg-gradient-to-br from-[color:var(--color-brand-100)] to-[color:var(--color-brand-200)]/40">
      <div class="container-narrow section">
        <nav class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-ink-500)] mb-6">
          <a href="/" class="hover:text-[color:var(--color-mauve-500)]">Inicio</a>
          <span class="mx-2">/</span>
          <a href="/blog" class="hover:text-[color:var(--color-mauve-500)]">Blog</a>
        </nav>
        <p class="kicker">{fmt(entry.data.publishedAt)} · {entry.data.author}</p>
        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl mt-3">{entry.data.title}</h1>
        <p class="mt-5 text-lg text-[color:var(--color-ink-700)]">{entry.data.description}</p>
        <div class="mt-6 flex flex-wrap gap-2">
          {entry.data.tags.map((t) => (
            <span class="text-[10px] uppercase tracking-wider bg-white text-[color:var(--color-mauve-700)] px-3 py-1 rounded-full border border-[color:var(--color-brand-200)]">{t}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- Body -->
    <div class="container-narrow section">
      <div class="prose-clibel">
        <Content />
      </div>

      <div class="mt-12 pt-8 border-t border-[color:var(--color-brand-200)] flex justify-between text-sm">
        <a href="/blog" class="text-[color:var(--color-mauve-500)] hover:underline">← Volver al blog</a>
        {entry.data.updatedAt && (
          <span class="text-[color:var(--color-ink-500)]">Actualizado: {fmt(entry.data.updatedAt)}</span>
        )}
      </div>
    </div>
  </article>

  <CTA />
</BaseLayout>
