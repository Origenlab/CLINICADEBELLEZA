---
const features = [
  {
    icon: '🏥',
    title: 'Especialistas certificados',
    text: 'Médicos y técnicos altamente capacitados con formación continua en medicina estética avanzada.',
  },
  {
    icon: '⚙️',
    title: 'Tecnología de vanguardia',
    text: 'Equipos láser, radiofrecuencia y diagnóstico clínico de última generación, avalados internacionalmente.',
  },
  {
    icon: '💎',
    title: 'Atención personalizada',
    text: 'Cada plan se diseña a partir de un diagnóstico individual: tu piel, tu ritmo, tus objetivos.',
  },
  {
    icon: '🌿',
    title: 'Resultados naturales',
    text: 'Filosofía estética enfocada en realzar tu belleza sin transformaciones extremas ni rasgos artificiales.',
  },
];
---

<section class="section bg-white">
  <div class="container-x">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <span class="kicker">Por qué CLIBEL</span>
      <span class="divider-gold"></span>
      <h2 class="text-4xl sm:text-5xl font-display">La belleza que mereces, con la seguridad que necesitas</h2>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        features.map((f) => (
          <div class="card p-7 h-full text-center">
            <div class="text-4xl mb-4">{f.icon}</div>
            <h3 class="font-display text-xl mb-2">{f.title}</h3>
            <p class="text-sm text-[color:var(--color-ink-500)] leading-relaxed">{f.text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
