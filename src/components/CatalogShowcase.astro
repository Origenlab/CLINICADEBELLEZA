---
import { CATEGORIES, catHref } from '../consts';
import SectionHeader from './SectionHeader.astro';
const cats = Object.values(CATEGORIES);

// Paleta visual por categoría — placeholder hasta tener fotos reales
const placeholderStyles: Record<string, { from: string; to: string; tone: string }> = {
  facial:              { from: '#F2EBDF', to: '#BC8E9C', tone: 'rgba(92,57,70,0.85)' },
  corporal:            { from: '#E8D5C4', to: '#C9A961', tone: 'rgba(74,53,64,0.85)' },
  laser:               { from: '#D9BC9C', to: '#5C3946', tone: 'rgba(31,20,24,0.9)' },
  'medicina-estetica': { from: '#BC8E9C', to: '#5C3946', tone: 'rgba(31,20,24,0.92)' },
  capilar:             { from: '#F2EBDF', to: '#8B5A6B', tone: 'rgba(92,57,70,0.85)' },
};
---

<section class="section bg-white" id="catalogo">
  <div class="container-x">
    <SectionHeader
      kicker="Catálogo"
      title="Todo lo que hacemos en <em>una sola clínica</em>."
      paragraphs={[
        'Cubrimos las cinco áreas críticas del cuidado estético en una sola sede: tratamientos faciales, corporales, depilación láser, medicina estética avanzada y terapias capilares. Cada protocolo se diseña a medida después de tu valoración clínica, con tecnología certificada COFEPRIS y especialistas con formación internacional.',
        'Operamos con marcas de referencia mundial —Allergan, Galderma, Merz, Sculptra y Venus— y documentamos cada procedimiento en tu expediente personal. Más de <strong>25 tratamientos</strong> avalados por protocolos clínicos, opciones para mujeres y hombres, y resultados naturales con respaldo médico real.',
      ]}
      cta={{ label: 'Ver catálogo completo', href: '/servicios', variant: 'outline' }}
    />

    <!-- Grid de cards -->
    <div class="catalog-grid">
      {cats.map((cat, i) => {
        const style = placeholderStyles[cat.slug] ?? placeholderStyles.facial;
        const num = String(i + 1).padStart(2, '0');
        return (
          <article class="catalog-card reveal">
            <!-- Image placeholder -->
            <div
              class="catalog-card-media"
              style={`background: linear-gradient(135deg, ${style.from} 0%, ${style.to} 100%);`}
              aria-label={`${cat.label} — imagen pendiente`}
            >
              <div class="catalog-card-pattern" aria-hidden="true"></div>
              <div class="catalog-card-overlay" style={`background: linear-gradient(180deg, transparent 0%, ${style.tone} 100%);`} aria-hidden="true"></div>

              <span class="catalog-card-num" aria-hidden="true">{num}</span>

              <div class="catalog-card-meta">
                <span class="catalog-card-short">{cat.short}</span>
                <span class="catalog-card-badge">{cat.badgeLabel}</span>
              </div>

              <span class="catalog-card-count">{cat.badgeCount}</span>
            </div>

            <!-- Body -->
            <div class="catalog-card-body">
              <header class="catalog-card-intro">
                <h3 class="catalog-card-title">{cat.label}</h3>
                <p class="catalog-card-desc">{cat.description}</p>
              </header>

              <div class="catalog-card-items">
                {cat.items.slice(0, 4).map((item) => (
                  <a href={item.href} class="catalog-item-btn">
                    <span>{item.label}</span>
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polyline points="9 18 15 12 9 6"/>
                    </svg>
                  </a>
                ))}
              </div>

              <a href={catHref(cat.slug)} class="catalog-card-cta">
                <span>Ver tratamientos</span>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  /* ========== Grid ========== */
  .catalog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 680px) {
    .catalog-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1100px) {
    .catalog-grid { grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  }
  @media (min-width: 1600px) {
    .catalog-grid { grid-template-columns: repeat(5, 1fr); gap: 1.5rem; }
  }

  /* ========== Card ========== */
  .catalog-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: white;
    border-radius: 18px;
    border: 1px solid rgba(232, 213, 196, 0.55);
    box-shadow:
      0 1px 2px rgba(31, 20, 24, 0.03),
      0 14px 32px -20px rgba(31, 20, 24, 0.14);
    transition: all 0.5s cubic-bezier(.2,.8,.2,1);
    overflow: hidden;
  }
  .catalog-card:hover {
    transform: translateY(-6px);
    border-color: rgba(201, 169, 97, 0.55);
    box-shadow:
      0 4px 8px rgba(31, 20, 24, 0.05),
      0 36px 60px -24px rgba(92, 57, 70, 0.28);
  }

  /* ========== Media (image placeholder) ========== */
  .catalog-card-media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }
  .catalog-card-pattern {
    position: absolute; inset: 0;
    background-image:
      repeating-linear-gradient(45deg, transparent 0 28px, rgba(255,255,255,0.06) 28px 29px),
      radial-gradient(60% 50% at 30% 30%, rgba(255,255,255,0.18), transparent 60%);
    mix-blend-mode: overlay;
  }
  .catalog-card-overlay {
    position: absolute; inset: 0;
    pointer-events: none;
  }
  .catalog-card-num {
    position: absolute;
    top: 1rem; left: 1.2rem;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: rgba(255,255,255,0.85);
    letter-spacing: 0.04em;
    line-height: 1;
  }
  .catalog-card-meta {
    position: absolute;
    bottom: 1.1rem;
    left: 1.2rem;
    right: 1.2rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .catalog-card-short {
    font-family: var(--font-display);
    font-size: clamp(2rem, 2.6vw, 2.6rem);
    font-weight: 500;
    color: white;
    line-height: 0.95;
    letter-spacing: -0.02em;
    text-shadow: 0 2px 16px rgba(0,0,0,0.18);
  }
  .catalog-card-badge {
    display: inline-flex;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: white;
    padding: 0.32rem 0.65rem;
    background: rgba(255,255,255,0.18);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: 999px;
    white-space: nowrap;
    margin-bottom: 0.4rem;
  }
  .catalog-card-count {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-900);
    padding: 0.35rem 0.7rem;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(8px);
    border-radius: 999px;
  }

  /* ========== Body ========== */
  .catalog-card-body {
    padding: 1.25rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.95rem;
    flex: 1;
  }

  .catalog-card-intro { margin: 0; }
  .catalog-card-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.25rem, 1.4vw, 1.5rem);
    line-height: 1.15;
    letter-spacing: -0.018em;
    color: var(--color-ink-900);
    margin: 0 0 0.3rem;
  }
  .catalog-card-desc {
    font-size: 0.82rem;
    line-height: 1.45;
    color: var(--color-ink-500);
    margin: 0;
  }

  /* ========== Items botones ========== */
  .catalog-card-items {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    flex: 1;
  }
  .catalog-item-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.55rem 0.75rem;
    background: rgba(250, 247, 242, 0.5);
    border: 1px solid rgba(232, 213, 196, 0.5);
    border-radius: 8px;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--color-ink-800);
    line-height: 1.25;
    transition: all 0.25s cubic-bezier(.2,.8,.2,1);
    text-decoration: none;
  }
  .catalog-item-btn span {
    flex: 1;
    text-align: left;
  }
  .catalog-item-btn svg {
    color: var(--color-brand-500);
    opacity: 0.55;
    transition: all 0.25s ease;
    flex-shrink: 0;
  }
  .catalog-item-btn:hover {
    background: white;
    border-color: var(--color-mauve-500);
    color: var(--color-ink-900);
    transform: translateX(2px);
  }
  .catalog-item-btn:hover svg {
    color: var(--color-mauve-500);
    opacity: 1;
    transform: translateX(2px);
  }

  /* ========== CTA del card ========== */
  .catalog-card-cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.55rem;
    padding: 0.8rem 1rem;
    background: var(--color-ink-900);
    color: var(--color-brand-50);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 10px;
    text-decoration: none;
    transition: all 0.35s cubic-bezier(.2,.8,.2,1);
    overflow: hidden;
    isolation: isolate;
    margin-top: 0.25rem;
  }
  .catalog-card-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-mauve-700) 0%, var(--color-brand-500) 100%);
    opacity: 0;
    transition: opacity 0.35s ease;
    z-index: -1;
  }
  .catalog-card-cta svg {
    transition: transform 0.35s cubic-bezier(.2,.8,.2,1);
  }
  .catalog-card-cta:hover {
    color: white;
    box-shadow: 0 16px 32px -14px rgba(139, 90, 107, 0.5);
  }
  .catalog-card-cta:hover::before { opacity: 1; }
  .catalog-card-cta:hover svg { transform: translateX(4px); }
</style>
