---
import { getCollection } from 'astro:content';
import { SITE, CONTACT, SOCIAL, NAV, CATEGORIES, BRANCHES, PARTNERS, catHref } from '../consts';
const year = new Date().getFullYear();
const cats = Object.values(CATEGORIES);

// Top 4 servicios destacados para el footer
const allServices = await getCollection('servicios');
const featuredServices = allServices
  .filter((s) => s.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);
---

<footer class="ftr">
  <!-- Capa decorativa superior -->
  <div aria-hidden="true" class="ftr-divider"></div>

  <div class="container-x ftr-inner">
    <!-- ====== Top: Brand statement + identidad ====== -->
    <section class="ftr-top">
      <div class="ftr-brand">
        <span class="ftr-mark" aria-hidden="true">C</span>
        <div class="ftr-brand-text">
          <span class="ftr-brand-name">{SITE.name}</span>
          <span class="ftr-brand-tagline">Clínica de Belleza · CDMX desde {SITE.founded}</span>
        </div>
      </div>

      <p class="ftr-statement">
        En <strong>CLIBEL</strong> combinamos medicina estética avanzada, tecnología
        de vanguardia y atención personalizada con respaldo médico real.
        Cuarenta y cinco años atendiendo a las mujeres y hombres de la Ciudad de
        México con criterio clínico, no comercial.
      </p>
    </section>

    <!-- ====== Grid de columnas ====== -->
    <section class="ftr-grid">
      <!-- Catálogo (categorías + destacados) -->
      <div class="ftr-col ftr-col--catalog">
        <h3 class="ftr-h3">Catálogo</h3>
        <ol class="ftr-list ftr-list--numbered">
          {cats.map((cat, i) => (
            <li>
              <span class="ftr-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <a href={catHref(cat.slug)} class="ftr-link">{cat.label}</a>
            </li>
          ))}
        </ol>

        {featuredServices.length > 0 && (
          <div class="ftr-featured">
            <h4 class="ftr-h4">Más solicitados</h4>
            <ul class="ftr-list ftr-list--small">
              {featuredServices.map((s) => (
                <li>
                  <a href={`/servicios/${s.id}`} class="ftr-link-sm">{s.data.title}</a>
                </li>
              ))}
            </ul>
          </div>
        )}

        <a href="/servicios" class="ftr-col-cta">
          Ver catálogo completo
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <!-- Empresa -->
      <div class="ftr-col">
        <h3 class="ftr-h3">Empresa</h3>
        <ul class="ftr-list">
          {NAV.map(n => (
            <li><a href={n.href} class="ftr-link">{n.label}</a></li>
          ))}
        </ul>
        <div class="ftr-legal">
          <a href="/aviso-de-privacidad" class="ftr-legal-link">Aviso de Privacidad</a>
          <a href="/aviso-de-privacidad" class="ftr-legal-link">Términos clínicos</a>
        </div>
      </div>

      <!-- Sucursales -->
      <div class="ftr-col">
        <h3 class="ftr-h3">Sucursales</h3>
        <div class="ftr-branches">
          {BRANCHES.map((b, i) => (
            <article class="ftr-branch">
              <span class="ftr-branch-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <div class="ftr-branch-body">
                <h4 class="ftr-branch-name">{b.name}</h4>
                <p class="ftr-branch-addr">{b.address}</p>
                <p class="ftr-branch-hours">{b.hours}</p>
                <a href={`tel:${b.phone}`} class="ftr-branch-phone">{b.phone}</a>
              </div>
            </article>
          ))}
        </div>
      </div>

      <!-- Contacto + redes -->
      <div class="ftr-col">
        <h3 class="ftr-h3">Contacto</h3>
        <ul class="ftr-contact">
          <li>
            <span class="ftr-contact-label">Teléfono</span>
            <a href={`tel:${CONTACT.phone}`} class="ftr-contact-value">{CONTACT.phoneDisplay}</a>
          </li>
          <li>
            <span class="ftr-contact-label">Email</span>
            <a href={`mailto:${CONTACT.email}`} class="ftr-contact-value">{CONTACT.email}</a>
          </li>
          <li>
            <span class="ftr-contact-label">Horario</span>
            <span class="ftr-contact-value">{CONTACT.hours}</span>
          </li>
        </ul>

        <div class="ftr-social">
          <span class="ftr-social-label">Síguenos</span>
          <div class="ftr-social-links">
            <a href={SOCIAL.instagram} target="_blank" rel="noopener" class="ftr-social-link">Instagram</a>
            <a href={SOCIAL.facebook} target="_blank" rel="noopener" class="ftr-social-link">Facebook</a>
            <a href={SOCIAL.tiktok} target="_blank" rel="noopener" class="ftr-social-link">TikTok</a>
            <a href={SOCIAL.youtube} target="_blank" rel="noopener" class="ftr-social-link">YouTube</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ====== Marcas partners ====== -->
    <section class="ftr-partners" aria-label="Marcas con las que trabajamos">
      <span class="ftr-partners-label">Trabajamos con</span>
      <ul class="ftr-partners-list">
        {PARTNERS.map((p, i) => (
          <li>
            <span>{p}</span>
            {i < PARTNERS.length - 1 && <span class="ftr-partners-sep" aria-hidden="true">·</span>}
          </li>
        ))}
      </ul>
    </section>

    <!-- ====== Bottom legal ====== -->
    <section class="ftr-bottom">
      <p class="ftr-copy">
        © {year} <strong>{SITE.name}</strong> — Clínica de Belleza. Todos los derechos reservados.
      </p>
      <p class="ftr-cofepris">
        Permiso COFEPRIS · {SITE.cofepris} · Hecho con cuidado en CDMX
      </p>
    </section>
  </div>
</footer>

<style>
  /* ============= Base ============= */
  .ftr {
    background: var(--color-ink-900);
    color: var(--color-brand-100);
    position: relative;
    overflow: hidden;
  }
  .ftr-inner {
    position: relative;
    z-index: 1;
    padding-block: clamp(3.5rem, 6vw, 6rem) clamp(1.5rem, 2.5vw, 2.5rem);
  }

  .ftr-divider {
    height: 1px;
    background: linear-gradient(90deg,
      transparent 0%,
      rgba(201, 169, 97, 0.4) 20%,
      rgba(201, 169, 97, 0.4) 80%,
      transparent 100%);
  }

  /* ============= Top: Brand + statement ============= */
  .ftr-top {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 3vw, 3rem);
    padding-bottom: clamp(2.5rem, 4vw, 4rem);
    margin-bottom: clamp(2.5rem, 4vw, 4rem);
    border-bottom: 1px solid rgba(201, 169, 97, 0.18);
    align-items: start;
  }
  @media (min-width: 900px) {
    .ftr-top {
      grid-template-columns: minmax(280px, 1fr) 2fr;
      align-items: center;
    }
  }

  .ftr-brand {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .ftr-mark {
    display: grid;
    place-items: center;
    width: 56px;
    height: 56px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--color-brand-400), var(--color-mauve-500));
    color: white;
    font-family: var(--font-display);
    font-size: 1.7rem;
    font-weight: 700;
    line-height: 1;
    flex-shrink: 0;
    box-shadow:
      0 8px 20px -6px rgba(201, 169, 97, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.2);
  }
  .ftr-brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .ftr-brand-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.75rem, 2.5vw, 2.25rem);
    color: white;
    letter-spacing: -0.015em;
  }
  .ftr-brand-tagline {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-brand-400);
    margin-top: 4px;
  }

  .ftr-statement {
    font-size: clamp(0.95rem, 1.05vw, 1.1rem);
    line-height: 1.7;
    color: rgba(242, 235, 223, 0.78);
    margin: 0;
    max-width: 64ch;
  }
  .ftr-statement strong {
    color: white;
    font-weight: 600;
  }

  /* ============= Grid columnas ============= */
  .ftr-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 3rem);
    padding-bottom: clamp(2.5rem, 4vw, 4rem);
    margin-bottom: clamp(2rem, 3vw, 2.5rem);
    border-bottom: 1px solid rgba(201, 169, 97, 0.18);
  }
  @media (min-width: 640px) {
    .ftr-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .ftr-grid { grid-template-columns: 0.8fr 0.7fr 1.3fr 1fr; gap: clamp(2rem, 3.5vw, 3.5rem); }
  }

  .ftr-col {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    min-width: 0;
  }

  .ftr-h3 {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-brand-400);
    margin: 0 0 0.5rem;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid rgba(201, 169, 97, 0.22);
    position: relative;
  }
  .ftr-h3::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 28px;
    height: 1px;
    background: var(--color-brand-400);
  }

  /* ============= Listas ============= */
  .ftr-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .ftr-list li {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    line-height: 1.3;
  }

  .ftr-list--numbered .ftr-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 0.85rem;
    color: var(--color-brand-400);
    line-height: 1;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    min-width: 22px;
    opacity: 0.7;
    transition: opacity 0.25s ease !important;
  }
  .ftr-list--numbered li:hover .ftr-num { opacity: 1; }

  .ftr-link {
    font-family: var(--font-sans);
    font-size: 0.92rem;
    color: rgba(242, 235, 223, 0.82);
    text-decoration: none;
    line-height: 1.4;
    transition: color 0.25s ease, letter-spacing 0.3s ease !important;
  }
  .ftr-link:hover {
    color: var(--color-brand-400);
    letter-spacing: 0.005em;
  }

  .ftr-col-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 0.5rem;
    padding-top: 1rem;
    border-top: 1px dashed rgba(201, 169, 97, 0.22);
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-brand-400);
    text-decoration: none;
    transition: gap 0.3s ease, color 0.25s ease !important;
  }
  .ftr-col-cta:hover {
    color: white;
    gap: 0.7rem;
  }

  /* ============= Featured (Más solicitados) ============= */
  .ftr-featured {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px dashed rgba(201, 169, 97, 0.22);
  }
  .ftr-h4 {
    font-family: var(--font-sans);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mauve-300);
    margin: 0 0 0.85rem;
  }
  .ftr-list--small {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .ftr-list--small li {
    line-height: 1.3;
  }
  .ftr-link-sm {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 0.92rem;
    color: rgba(242, 235, 223, 0.78);
    text-decoration: none;
    letter-spacing: -0.005em;
    transition: color 0.25s ease, transform 0.3s ease !important;
    display: inline-block;
    position: relative;
  }
  .ftr-link-sm::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 0;
    height: 1px;
    background: var(--color-brand-400);
    transition: width 0.35s cubic-bezier(.2,.8,.2,1) !important;
  }
  .ftr-link-sm:hover {
    color: var(--color-brand-400);
  }
  .ftr-link-sm:hover::after { width: 100%; }

  /* ============= Legal links ============= */
  .ftr-legal {
    margin-top: 0.5rem;
    padding-top: 1rem;
    border-top: 1px dashed rgba(201, 169, 97, 0.22);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .ftr-legal-link {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: rgba(242, 235, 223, 0.55);
    text-decoration: none;
    transition: color 0.25s ease !important;
  }
  .ftr-legal-link:hover { color: var(--color-brand-400); }

  /* ============= Sucursales ============= */
  .ftr-branches {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .ftr-branch {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.85rem;
    align-items: start;
  }
  .ftr-branch-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1rem;
    color: var(--color-brand-400);
    line-height: 1;
    letter-spacing: 0.04em;
    margin-top: 4px;
    opacity: 0.75;
  }
  .ftr-branch-body {
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
    min-width: 0;
  }
  .ftr-branch-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.05rem;
    color: white;
    margin: 0 0 0.15rem;
    letter-spacing: -0.005em;
    line-height: 1.2;
  }
  .ftr-branch-addr {
    font-size: 0.82rem;
    line-height: 1.5;
    color: rgba(242, 235, 223, 0.75);
    margin: 0;
  }
  .ftr-branch-hours {
    font-size: 0.72rem;
    line-height: 1.4;
    color: var(--color-brand-300);
    margin: 0;
    letter-spacing: 0.01em;
  }
  .ftr-branch-phone {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.02rem;
    color: white;
    text-decoration: none;
    margin-top: 0.3rem;
    letter-spacing: -0.005em;
    transition: color 0.25s ease !important;
    align-self: flex-start;
  }
  .ftr-branch-phone:hover { color: var(--color-brand-400); }

  /* ============= Contacto ============= */
  .ftr-contact {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .ftr-contact li {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px dashed rgba(201, 169, 97, 0.15);
  }
  .ftr-contact li:last-child { border-bottom: 0; padding-bottom: 0; }
  .ftr-contact-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-brand-400);
    opacity: 0.85;
  }
  .ftr-contact-value {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.02rem;
    color: white;
    text-decoration: none;
    letter-spacing: -0.005em;
    line-height: 1.3;
    transition: color 0.25s ease !important;
  }
  a.ftr-contact-value:hover { color: var(--color-brand-400); }

  .ftr-social {
    margin-top: 0.5rem;
    padding-top: 1.25rem;
    border-top: 1px dashed rgba(201, 169, 97, 0.22);
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .ftr-social-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-brand-400);
    opacity: 0.85;
  }
  .ftr-social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 1rem;
  }
  .ftr-social-link {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1rem;
    color: rgba(242, 235, 223, 0.85);
    text-decoration: none;
    position: relative;
    transition: color 0.25s ease !important;
  }
  .ftr-social-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 0;
    height: 1px;
    background: var(--color-brand-400);
    transition: width 0.35s cubic-bezier(.2,.8,.2,1) !important;
  }
  .ftr-social-link:hover {
    color: white;
  }
  .ftr-social-link:hover::after {
    width: 100%;
  }

  /* ============= Partners marca ============= */
  .ftr-partners {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-bottom: clamp(2rem, 3vw, 2.5rem);
    margin-bottom: clamp(1.5rem, 2.5vw, 2rem);
    border-bottom: 1px solid rgba(201, 169, 97, 0.18);
    align-items: center;
    text-align: center;
  }
  @media (min-width: 900px) {
    .ftr-partners {
      flex-direction: row;
      align-items: baseline;
      gap: 2rem;
      text-align: left;
    }
  }
  .ftr-partners-label {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-brand-400);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .ftr-partners-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: center;
    gap: 0.35rem 0.85rem;
  }
  @media (min-width: 900px) {
    .ftr-partners-list { justify-content: flex-start; flex: 1; }
  }
  .ftr-partners-list li {
    display: inline-flex;
    align-items: baseline;
    gap: 0.85rem;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1.05rem;
    color: rgba(242, 235, 223, 0.7);
    letter-spacing: -0.005em;
  }
  .ftr-partners-sep {
    color: var(--color-brand-400);
    font-style: normal;
    opacity: 0.6;
  }

  /* ============= Bottom ============= */
  .ftr-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    text-align: center;
  }
  @media (min-width: 768px) {
    .ftr-bottom {
      flex-direction: row;
      text-align: left;
    }
  }
  .ftr-copy {
    font-size: 0.78rem;
    color: rgba(242, 235, 223, 0.6);
    margin: 0;
    letter-spacing: 0.01em;
  }
  .ftr-copy strong {
    color: rgba(242, 235, 223, 0.85);
    font-weight: 600;
  }
  .ftr-cofepris {
    font-size: 0.7rem;
    color: rgba(201, 169, 97, 0.75);
    margin: 0;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
  }
</style>
