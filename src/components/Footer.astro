---
import { SITE, CONTACT, SOCIAL, NAV, CATEGORIES, BRANCHES, PARTNERS } from '../consts';
const year = new Date().getFullYear();
const cats = Object.values(CATEGORIES);
---

<footer class="bg-[color:var(--color-ink-900)] text-[color:var(--color-brand-100)] mt-24">
  <!-- Top: brand + cols -->
  <div class="container-x pt-20 pb-12 grid gap-12 lg:grid-cols-12">
    <!-- Brand col -->
    <div class="lg:col-span-4">
      <div class="flex items-center gap-3 mb-5">
        <span class="grid place-items-center w-12 h-12 rounded-full text-white font-display text-2xl font-bold bg-gradient-to-br from-[color:var(--color-brand-400)] to-[color:var(--color-mauve-500)] shadow-lg">C</span>
        <div class="flex flex-col leading-tight">
          <span class="font-display text-2xl tracking-wide text-white">{SITE.name}</span>
          <span class="text-[10px] uppercase tracking-[0.18em] text-[color:var(--color-brand-300)]">Clínica de Belleza</span>
        </div>
      </div>
      <p class="text-sm leading-relaxed text-[color:var(--color-brand-200)]/85 max-w-sm">
        Medicina estética, depilación láser, tratamientos faciales, corporales
        y capilares en CDMX desde {SITE.founded}. Belleza con criterio médico.
      </p>

      <div class="flex flex-wrap gap-2 mt-5">
        <span class="text-[10px] uppercase tracking-[0.18em] bg-white/5 border border-white/10 px-2.5 py-1 rounded-full">COFEPRIS</span>
        <span class="text-[10px] uppercase tracking-[0.18em] bg-white/5 border border-white/10 px-2.5 py-1 rounded-full">Desde {SITE.founded}</span>
        <span class="text-[10px] uppercase tracking-[0.18em] bg-white/5 border border-white/10 px-2.5 py-1 rounded-full">4.9★ Google</span>
      </div>

      <div class="flex gap-3 mt-7">
        <a href={SOCIAL.instagram} target="_blank" rel="noopener" aria-label="Instagram"
           class="w-10 h-10 grid place-items-center rounded-full border border-white/15 hover:bg-[color:var(--color-brand-400)] hover:text-[color:var(--color-ink-900)] transition">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        <a href={SOCIAL.facebook} target="_blank" rel="noopener" aria-label="Facebook"
           class="w-10 h-10 grid place-items-center rounded-full border border-white/15 hover:bg-[color:var(--color-brand-400)] hover:text-[color:var(--color-ink-900)] transition">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.5 9.87v-6.99H8v-2.88h2.5V9.8c0-2.47 1.47-3.83 3.71-3.83 1.07 0 2.2.19 2.2.19v2.42h-1.24c-1.22 0-1.6.76-1.6 1.54v1.85h2.72l-.43 2.88h-2.29v6.99A10 10 0 0 0 22 12z"/></svg>
        </a>
        <a href={SOCIAL.tiktok} target="_blank" rel="noopener" aria-label="TikTok"
           class="w-10 h-10 grid place-items-center rounded-full border border-white/15 hover:bg-[color:var(--color-brand-400)] hover:text-[color:var(--color-ink-900)] transition">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V8.93a8.16 8.16 0 0 0 4.77 1.52V7.05a4.79 4.79 0 0 1-1.84-.36z"/></svg>
        </a>
        <a href={SOCIAL.youtube} target="_blank" rel="noopener" aria-label="YouTube"
           class="w-10 h-10 grid place-items-center rounded-full border border-white/15 hover:bg-[color:var(--color-brand-400)] hover:text-[color:var(--color-ink-900)] transition">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8zM9.6 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
        </a>
      </div>
    </div>

    <!-- Catálogo -->
    <div class="lg:col-span-3">
      <h3 class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--color-brand-300)] mb-5">Catálogo</h3>
      <ul class="space-y-2.5 text-sm">
        {cats.map(c => (
          <li><a href={`/servicios#${c.slug}`} class="hover:text-[color:var(--color-brand-300)] transition inline-flex items-center gap-2">
            <span class="text-base">{c.icon}</span> {c.label}
          </a></li>
        ))}
        <li class="pt-2 border-t border-white/10 mt-3">
          <a href="/servicios" class="text-[color:var(--color-brand-400)] font-medium text-xs uppercase tracking-[0.14em]">Ver catálogo completo →</a>
        </li>
      </ul>
    </div>

    <!-- Sitio -->
    <div class="lg:col-span-2">
      <h3 class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--color-brand-300)] mb-5">Empresa</h3>
      <ul class="space-y-2.5 text-sm">
        {NAV.map(n => (
          <li><a href={n.href} class="hover:text-[color:var(--color-brand-300)] transition">{n.label}</a></li>
        ))}
        <li class="pt-3 border-t border-white/10 mt-3 space-y-2">
          <a href="/aviso-de-privacidad" class="block text-xs hover:text-[color:var(--color-brand-300)] transition">Aviso de Privacidad</a>
          <a href="/blog" class="block text-xs hover:text-[color:var(--color-brand-300)] transition">Guía CLIBEL</a>
        </li>
      </ul>
    </div>

    <!-- Sucursales -->
    <div class="lg:col-span-3">
      <h3 class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--color-brand-300)] mb-5">Sucursales</h3>
      <div class="space-y-5 text-sm">
        {BRANCHES.map(b => (
          <div class="border-l-2 border-[color:var(--color-brand-400)] pl-4">
            <p class="font-display text-base text-white">{b.name}</p>
            <p class="text-xs text-[color:var(--color-brand-200)]/85 mt-1 leading-relaxed">{b.address}</p>
            <p class="text-[11px] text-[color:var(--color-brand-300)]/80 mt-1">{b.hours}</p>
            <a href={`tel:${b.phone}`} class="text-xs text-[color:var(--color-brand-300)] mt-1 inline-block hover:text-white transition">{b.phone}</a>
          </div>
        ))}
      </div>
      <a href={`mailto:${CONTACT.email}`} class="text-xs text-[color:var(--color-brand-300)] mt-5 inline-block hover:text-white transition">{CONTACT.email}</a>
    </div>
  </div>

  <!-- Trust strip -->
  <div class="border-t border-white/10">
    <div class="container-x py-6 flex flex-wrap items-center justify-center gap-x-8 gap-y-2 text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-brand-200)]/60">
      {PARTNERS.slice(0, 6).map(p => <span>{p}</span>)}
      <span class="text-[color:var(--color-brand-400)]">+ Productos certificados COFEPRIS</span>
    </div>
  </div>

  <!-- Bottom -->
  <div class="border-t border-white/10">
    <div class="container-x py-6 flex flex-col md:flex-row items-center justify-between gap-3 text-xs text-[color:var(--color-brand-200)]/70">
      <p>© {year} {SITE.name} — Clínica de Belleza. Todos los derechos reservados.</p>
      <p>Permiso COFEPRIS · {SITE.cofepris} · Hecho con cuidado en CDMX</p>
    </div>
  </div>
</footer>
