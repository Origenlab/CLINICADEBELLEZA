---
import { PROCESS } from '../consts';
import SectionHeader from './SectionHeader.astro';
---

<section class="section bg-[color:var(--color-ink-900)] text-[color:var(--color-brand-100)] relative overflow-hidden">
  <!-- decorative grid -->
  <div aria-hidden="true" class="absolute inset-0 opacity-[0.06] pointer-events-none"
       style="background-image: linear-gradient(to right, white 1px, transparent 1px), linear-gradient(to bottom, white 1px, transparent 1px); background-size: 80px 80px;"></div>
  <div aria-hidden="true" class="absolute top-0 right-0 w-[40rem] h-[40rem] rounded-full bg-[color:var(--color-mauve-700)]/30 blur-3xl pointer-events-none"></div>

  <div class="container-x relative">
    <SectionHeader
      kicker="Nuestro Proceso"
      title="Del diagnóstico a los <em>resultados</em>, sin sorpresas."
      paragraphs={[
        'Acompañamos todo el ciclo de tu transformación estética con un protocolo claro, documentado y revisado en cada paso. Tu tiempo, tu ritmo y tu seguridad clínica siempre por delante.',
        'Cuatro etapas concretas con responsables nombrados, métricas de seguimiento y posibilidad de ajustar el plan cuando los resultados o tu situación lo requieran.',
      ]}
      variant="dark"
    />

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {PROCESS.map((step, i) => (
        <div class="relative reveal">
          <!-- connector -->
          {i < PROCESS.length - 1 && (
            <div class="hidden lg:block absolute top-7 left-[calc(50%+2rem)] right-[-1.5rem] h-px bg-gradient-to-r from-[color:var(--color-brand-400)] to-transparent"></div>
          )}

          <div class="relative bg-white/[0.03] border border-white/10 rounded-2xl p-6 h-full hover:bg-white/[0.06] hover:border-[color:var(--color-brand-400)]/40 transition-all duration-500">
            <div class="flex items-center gap-3 mb-5">
              <span class="font-display text-3xl text-[color:var(--color-brand-400)] leading-none">{step.n}</span>
              <span class="text-[10px] uppercase tracking-[0.2em] text-[color:var(--color-brand-300)]/70">Paso {i+1}</span>
            </div>
            <h3 class="font-display text-xl text-white mb-3 leading-tight">{step.title}</h3>
            <p class="text-sm text-[color:var(--color-brand-200)]/80 leading-relaxed">{step.text}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 pt-10 border-t border-white/10 flex flex-wrap items-center justify-between gap-6 reveal">
      <p class="text-sm text-[color:var(--color-brand-200)]/85 max-w-xl">
        Cada paso del proceso se documenta en tu expediente clínico digital.
        <strong class="text-white">Trazabilidad total</strong> de productos, dosis y profesional responsable.
      </p>
      <a href="/contacto" class="btn btn-gold">Comienza con tu valoración</a>
    </div>
  </div>
</section>
