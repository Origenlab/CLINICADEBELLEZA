---
import { ADVANTAGES } from '../consts';
import SectionHeader from './SectionHeader.astro';

const icons = [
  // shield-check
  '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>',
  // sparkles
  '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l2 5 5 2-5 2-2 5-2-5-5-2 5-2z"/><path d="M19 14l1 3 3 1-3 1-1 3-1-3-3-1 3-1z"/></svg>',
  // heart-handshake
  '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>',
  // leaf
  '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 4 13V8a4 4 0 0 1 4-4h8a4 4 0 0 1 4 4v0a8 8 0 0 1-9 8z"/><path d="M2 22l8-8"/></svg>',
];
---

<section class="section gradient-soft why-clibel-section">
  <div class="container-x">
    <SectionHeader
      kicker="Por qué CLIBEL"
      title="La diferencia entre <em>cualquier clínica</em> y CLIBEL."
      paragraphs={[
        '45 años atendiendo en CDMX nos enseñó que la belleza no se vende: se construye. Estos son los cuatro principios que nos hacen distintos, sin marketing vacío.',
        'Cada decisión clínica se documenta: producto, lote, dosis y profesional responsable. Trazabilidad real frente a la opacidad que predomina en la industria estética.',
      ]}
      cta={{ label: 'Conoce nuestra filosofía', href: '/nosotros', variant: 'outline' }}
    />

    <div class="why-grid">
      {ADVANTAGES.map((a, i) => (
        <article class="why-card reveal">
          <span class="why-card-num" aria-hidden="true">0{i + 1}</span>

          <div class="why-card-icon" set:html={icons[i]} />

          <span class="why-card-kicker">{a.kicker}</span>
          <h3 class="why-card-title">{a.title}</h3>
          <p class="why-card-text">{a.text}</p>

          <span class="why-card-line" aria-hidden="true"></span>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .why-clibel-section {
    position: relative;
    isolation: isolate;
  }

  .why-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1rem, 1.6vw, 1.5rem);
    width: 100%;
  }
  @media (min-width: 640px) {
    .why-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .why-grid { grid-template-columns: repeat(4, 1fr); }
  }

  /* ===== Card ===== */
  .why-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    padding: clamp(1.5rem, 2vw, 2rem);
    background: linear-gradient(180deg, #FFFFFF 0%, #FBF8F3 100%);
    border: 1px solid rgba(201, 169, 97, 0.22);
    border-radius: 1.25rem;
    overflow: hidden;
    box-shadow:
      0 1px 2px rgba(31, 20, 24, 0.03),
      0 12px 32px -18px rgba(31, 20, 24, 0.12);
    transition: transform 0.45s cubic-bezier(.2,.8,.2,1),
                box-shadow 0.45s ease,
                border-color 0.4s ease,
                background 0.5s ease;
  }
  .why-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(120% 60% at 100% 0%, rgba(201, 169, 97, 0.10), transparent 55%),
      radial-gradient(80% 60% at 0% 100%, rgba(139, 90, 107, 0.08), transparent 60%);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
    z-index: 0;
  }
  .why-card:hover {
    transform: translateY(-8px);
    border-color: rgba(139, 90, 107, 0.4);
    box-shadow:
      0 4px 10px rgba(31, 20, 24, 0.05),
      0 32px 56px -22px rgba(31, 20, 24, 0.25);
  }
  .why-card:hover::before { opacity: 1; }

  .why-card > * { position: relative; z-index: 1; }

  /* Number watermark */
  .why-card-num {
    position: absolute;
    top: 1.1rem;
    right: 1.25rem;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1.1rem;
    color: var(--color-brand-400);
    letter-spacing: 0.04em;
    z-index: 1;
    transition: color 0.4s ease, transform 0.4s ease;
  }
  .why-card:hover .why-card-num {
    color: var(--color-mauve-500);
    transform: translateY(-2px);
  }

  /* Icon */
  .why-card-icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    display: grid;
    place-items: center;
    color: var(--color-mauve-700);
    background: linear-gradient(135deg, rgba(201, 169, 97, 0.18), rgba(139, 90, 107, 0.12));
    border: 1px solid rgba(201, 169, 97, 0.35);
    margin-bottom: 1.5rem;
    transition: transform 0.5s cubic-bezier(.2,.8,.2,1),
                background 0.5s ease,
                color 0.4s ease,
                border-color 0.4s ease;
  }
  .why-card:hover .why-card-icon {
    transform: rotate(-4deg) scale(1.06);
    background: linear-gradient(135deg, var(--color-brand-400), var(--color-mauve-500));
    color: #fff;
    border-color: transparent;
  }

  /* Kicker */
  .why-card-kicker {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-brand-500);
    margin-bottom: 0.5rem;
  }

  /* Title */
  .why-card-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.2rem, 1.4vw, 1.45rem);
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--color-ink-900);
    margin: 0 0 0.85rem;
  }

  /* Text */
  .why-card-text {
    font-size: 0.92rem;
    line-height: 1.65;
    color: var(--color-ink-700);
    margin: 0;
    flex: 1;
  }

  /* Bottom accent line */
  .why-card-line {
    display: block;
    margin-top: 1.5rem;
    width: 32px;
    height: 2px;
    border-radius: 2px;
    background: linear-gradient(90deg, var(--color-brand-400), var(--color-mauve-500));
    transition: width 0.5s cubic-bezier(.2,.8,.2,1);
  }
  .why-card:hover .why-card-line {
    width: 80px;
  }

  /* Mobile fine-tune */
  @media (max-width: 639px) {
    .why-card { padding: 1.4rem; }
    .why-card-icon { width: 50px; height: 50px; margin-bottom: 1.1rem; }
  }
</style>
