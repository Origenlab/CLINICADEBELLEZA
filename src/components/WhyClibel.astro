---
import { ADVANTAGES } from '../consts';

const icons = [
  // shield-check
  '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>',
  // sparkles
  '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l2 5 5 2-5 2-2 5-2-5-5-2 5-2z"/><path d="M19 14l1 3 3 1-3 1-1 3-1-3-3-1 3-1z"/></svg>',
  // heart-handshake
  '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>',
  // leaf
  '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 4 13V8a4 4 0 0 1 4-4h8a4 4 0 0 1 4 4v0a8 8 0 0 1-9 8z"/><path d="M2 22l8-8"/></svg>',
];
---

<section class="section gradient-soft">
  <div class="container-x">
    <div class="max-w-3xl mb-14 reveal">
      <span class="kicker-line">Por qué CLIBEL</span>
      <h2 class="mt-4 text-4xl sm:text-5xl h-display">
        La diferencia entre <em>cualquier clínica</em><br/>y CLIBEL.
      </h2>
      <p class="mt-5 text-[color:var(--color-ink-500)] leading-relaxed">
        45 años atendiendo en CDMX nos enseñó que la belleza no se vende: se
        construye. Estos son los cuatro principios que nos hacen distintos, sin
        marketing vacío.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {ADVANTAGES.map((a, i) => (
        <div class="card p-7 h-full flex flex-col reveal">
          <div class="w-12 h-12 rounded-xl grid place-items-center bg-gradient-to-br from-[color:var(--color-brand-400)] to-[color:var(--color-mauve-500)] text-white shadow-md mb-5"
               set:html={icons[i]} />
          <span class="text-[10px] uppercase tracking-[0.18em] text-[color:var(--color-brand-500)] font-semibold">{a.kicker}</span>
          <h3 class="font-display text-xl mt-1.5 mb-2.5">{a.title}</h3>
          <p class="text-sm text-[color:var(--color-ink-500)] leading-relaxed">{a.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
