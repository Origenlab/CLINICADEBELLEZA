---
import { SECTORS } from '../consts';
import SectionHeader from './SectionHeader.astro';
---

<section class="section bg-white">
  <div class="container-x">
    <SectionHeader
      kicker="A quién atendemos"
      title="Atendemos cada <em>momento</em> de tu vida estética."
      paragraphs={[
        'Tu piel y tu cuerpo cambian con los años, los hábitos y las etapas de vida. Por eso diseñamos protocolos específicos para mujeres, hombres y momentos especiales. Sin lenguaje genérico.',
        'Embarazo, posparto, perimenopausia, recuperación post-quirúrgica, cuidado masculino. Cada etapa tiene protocolos distintos y especialistas con experiencia documentada en ese perfil.',
      ]}
      cta={{ label: 'Ver tratamientos disponibles', href: '/servicios', variant: 'outline' }}
    />

    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {SECTORS.map((s) => (
        <article class="reveal group border border-[color:var(--color-brand-200)] hover:border-[color:var(--color-mauve-500)] rounded-2xl p-6 transition-all hover:shadow-lg hover:shadow-[color:var(--color-mauve-500)]/10 bg-[color:var(--color-brand-50)]">
          <div class="flex items-center gap-3 mb-3">
            <span class="font-display text-2xl text-[color:var(--color-brand-500)]">{s.n}</span>
            <span class="h-px flex-1 bg-[color:var(--color-brand-200)] group-hover:bg-[color:var(--color-mauve-500)]/40 transition-colors"></span>
          </div>
          <h3 class="font-display text-lg leading-tight mb-2 group-hover:text-[color:var(--color-mauve-500)] transition-colors">{s.title}</h3>
          <p class="text-sm text-[color:var(--color-ink-500)] leading-relaxed">{s.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
