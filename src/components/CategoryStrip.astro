---
import { CATEGORIES } from '../consts';

const items = [
  { ...CATEGORIES.facial, icon: '✨', desc: 'Renovación, luminosidad y salud de la piel.' },
  { ...CATEGORIES.corporal, icon: '💆‍♀️', desc: 'Remodelación, reafirmación y bienestar físico.' },
  { ...CATEGORIES.laser, icon: '🔆', desc: 'Eliminación de vello segura, rápida y duradera.' },
  { ...CATEGORIES['medicina-estetica'], icon: '💉', desc: 'Rejuvenecimiento y armonización facial avanzada.' },
  { ...CATEGORIES.capilar, icon: '🌿', desc: 'Fuerza, densidad y vitalidad para tu cabello.' },
];
---

<section class="section">
  <div class="container-x">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <span class="kicker">Áreas de especialidad</span>
      <span class="divider-gold"></span>
      <h2 class="text-4xl sm:text-5xl font-display">Cuidado integral, en un solo lugar</h2>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-5">
      {
        items.map((c) => (
          <a
            href={`/servicios#${c.slug}`}
            class="card p-6 text-center group"
          >
            <div class="text-4xl mb-3 transition-transform duration-500 group-hover:scale-110">{c.icon}</div>
            <h3 class="font-display text-lg mb-2 group-hover:text-[color:var(--color-mauve-500)] transition-colors">{c.label}</h3>
            <p class="text-xs text-[color:var(--color-ink-500)] leading-relaxed">{c.desc}</p>
          </a>
        ))
      }
    </div>
  </div>
</section>
