---
import { CONTACT, SITE } from '../consts';
const wa = `https://wa.me/${CONTACT.whatsapp}?text=${encodeURIComponent(CONTACT.whatsappMessage)}`;
---

<div class="bg-[color:var(--color-ink-900)] text-[color:var(--color-brand-100)] text-xs">
  <div class="container-x flex flex-wrap items-center justify-between gap-y-2 py-2.5">
    <div class="flex flex-wrap items-center gap-x-5 gap-y-1">
      <a href={`tel:${CONTACT.phone}`} class="inline-flex items-center gap-1.5 hover:text-[color:var(--color-brand-300)] transition">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
        {CONTACT.phoneDisplay}
      </a>
      <a href={`mailto:${CONTACT.email}`} class="hidden md:inline-flex items-center gap-1.5 hover:text-[color:var(--color-brand-300)] transition">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        {CONTACT.email}
      </a>
      <span class="hidden lg:inline-flex items-center gap-1.5 text-[color:var(--color-brand-200)]/70">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        {CONTACT.hoursShort}
      </span>
    </div>
    <div class="flex items-center gap-3">
      <span class="hidden md:inline-flex items-center gap-1.5 text-[color:var(--color-brand-300)]">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.39 7.36H22l-6.19 4.49L18.18 22 12 17.27 5.82 22l2.37-8.15L2 9.36h7.61z"/></svg>
        Permiso COFEPRIS · {SITE.cofepris}
      </span>
      <a href={wa} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 bg-[#25D366] text-white px-3 py-1 rounded-full font-medium hover:opacity-90 transition">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/></svg>
        WhatsApp directo
      </a>
    </div>
  </div>
</div>
