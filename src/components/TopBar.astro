---
import { CONTACT } from '../consts';
---

<div class="bg-[color:var(--color-ink-900)] text-[color:var(--color-brand-100)] text-xs">
  <div class="container-x flex flex-wrap items-center justify-between gap-y-2 py-2.5">
    <div class="flex flex-wrap items-center gap-x-5 gap-y-1">
      <span class="inline-flex items-center gap-1.5 text-[color:var(--color-brand-200)]/90">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        {CONTACT.hoursShort}
      </span>
      <span class="hidden md:inline-flex items-center gap-1.5 text-[color:var(--color-brand-200)]/70">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        {CONTACT.address}
      </span>
    </div>
    <div class="flex items-center gap-3">
      <span class="hidden md:inline-flex items-center gap-1.5 text-[color:var(--color-brand-300)]">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.39 7.36H22l-6.19 4.49L18.18 22 12 17.27 5.82 22l2.37-8.15L2 9.36h7.61z"/></svg>
        Médicos certificados · COFEPRIS
      </span>
      <a href="/contacto/" class="inline-flex items-center gap-1.5 bg-[color:var(--color-mauve-500)] text-white px-3 py-1 rounded-full font-medium hover:opacity-90 transition">
        Agenda tu valoración
      </a>
    </div>
  </div>
</div>
