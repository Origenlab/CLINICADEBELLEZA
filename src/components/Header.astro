---
import { NAV, SITE, CONTACT, CATEGORIES } from '../consts';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');

const cats = Object.values(CATEGORIES);
---

<header class="sticky top-0 z-40 bg-[color:var(--color-brand-50)]/90 backdrop-blur-md border-b border-[color:var(--color-brand-200)]/60">
  <div class="container-x flex items-center justify-between h-20">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 shrink-0" aria-label={SITE.name}>
      <span
        class="grid place-items-center w-12 h-12 rounded-full text-white font-display text-2xl font-bold bg-gradient-to-br from-[color:var(--color-brand-400)] to-[color:var(--color-mauve-500)] shadow-lg shadow-[color:var(--color-mauve-500)]/20"
        >C</span>
      <div class="hidden sm:flex flex-col leading-tight">
        <span class="font-display text-2xl tracking-wide text-[color:var(--color-ink-900)]">{SITE.name}</span>
        <span class="text-[10px] uppercase tracking-[0.18em] text-[color:var(--color-mauve-500)] font-medium">Clínica de Belleza</span>
      </div>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-7" aria-label="Navegación principal">
      <a href="/" class:list={['text-sm font-medium tracking-wide transition-colors', isActive('/') ? 'text-[color:var(--color-mauve-500)]' : 'text-[color:var(--color-ink-700)] hover:text-[color:var(--color-mauve-500)]']}>Inicio</a>

      <!-- Mega menu Servicios -->
      <div class="relative group" tabindex="0">
        <button
          class:list={['inline-flex items-center gap-1 text-sm font-medium tracking-wide transition-colors', isActive('/servicios') ? 'text-[color:var(--color-mauve-500)]' : 'text-[color:var(--color-ink-700)] hover:text-[color:var(--color-mauve-500)]']}
          aria-haspopup="true"
        >
          Servicios
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="transition-transform group-hover:rotate-180"><polyline points="6 9 12 15 18 9"/></svg>
        </button>

        <div class="absolute left-1/2 -translate-x-1/2 top-full pt-4 w-[860px] opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all duration-200 z-50">
          <div class="card-glass shadow-2xl rounded-2xl p-7 border border-[color:var(--color-brand-200)]">
            <div class="grid grid-cols-3 gap-7">
              <div class="col-span-2 grid grid-cols-2 gap-x-6 gap-y-5">
                {cats.map((cat) => (
                  <div>
                    <a href={`/servicios#${cat.slug}`} class="group/cat flex items-center gap-2 mb-2.5">
                      <span class="text-xl">{cat.icon}</span>
                      <span class="font-display text-base text-[color:var(--color-ink-900)] group-hover/cat:text-[color:var(--color-mauve-500)] transition-colors">{cat.label}</span>
                    </a>
                    <ul class="space-y-1.5 pl-7">
                      {cat.items.slice(0, 4).map((item) => (
                        <li>
                          <a href={item.href} class="text-xs text-[color:var(--color-ink-500)] hover:text-[color:var(--color-mauve-500)] transition-colors">
                            {item.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>

              <!-- Featured card -->
              <div class="rounded-xl bg-gradient-to-br from-[color:var(--color-mauve-700)] via-[color:var(--color-mauve-500)] to-[color:var(--color-brand-500)] p-5 text-white flex flex-col justify-between min-h-[220px]">
                <div>
                  <span class="text-[10px] uppercase tracking-[0.2em] opacity-80">Diagnóstico</span>
                  <h3 class="font-display text-lg mt-1 leading-tight">Valoración facial digital</h3>
                  <p class="text-xs opacity-90 mt-2 leading-relaxed">Análisis de piel asistido + plan personalizado en 30 min.</p>
                </div>
                <a href="/contacto" class="text-xs font-medium underline underline-offset-4 mt-4 inline-flex items-center gap-1">
                  Reservar sin costo
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                </a>
              </div>
            </div>

            <div class="mt-6 pt-5 border-t border-[color:var(--color-brand-200)] flex items-center justify-between">
              <p class="text-xs text-[color:var(--color-ink-500)]">25+ tratamientos · Médicos certificados · Productos COFEPRIS</p>
              <a href="/servicios" class="text-xs text-[color:var(--color-mauve-500)] font-medium inline-flex items-center gap-1 hover:gap-2 transition-all">
                Ver catálogo completo
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      {NAV.filter(n => !['Inicio', 'Servicios'].includes(n.label)).map((item) => (
        <a
          href={item.href}
          class:list={['text-sm font-medium tracking-wide transition-colors', isActive(item.href) ? 'text-[color:var(--color-mauve-500)]' : 'text-[color:var(--color-ink-700)] hover:text-[color:var(--color-mauve-500)]']}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a href={`tel:${CONTACT.phone}`} class="hidden xl:inline-flex btn btn-outline text-sm py-2 px-4">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
        {CONTACT.phoneDisplay}
      </a>
      <a href="/contacto" class="hidden md:inline-flex btn btn-primary text-sm py-2 px-5">Agendar cita</a>

      <button
        id="navToggle"
        class="lg:hidden grid place-items-center w-10 h-10 rounded-full hover:bg-[color:var(--color-brand-200)]/60 transition"
        aria-label="Abrir menú" aria-controls="mobileNav" aria-expanded="false"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <div id="mobileNav" class="lg:hidden hidden border-t border-[color:var(--color-brand-200)]/60 bg-[color:var(--color-brand-50)] max-h-[80vh] overflow-y-auto">
    <nav class="container-x py-4 flex flex-col gap-1" aria-label="Navegación móvil">
      <a href="/" class="py-3 px-3 rounded-lg text-base font-medium hover:bg-[color:var(--color-brand-200)]/40">Inicio</a>

      <details class="group">
        <summary class="py-3 px-3 rounded-lg text-base font-medium cursor-pointer flex items-center justify-between hover:bg-[color:var(--color-brand-200)]/40">
          <span>Servicios</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="transition-transform group-open:rotate-180"><polyline points="6 9 12 15 18 9"/></svg>
        </summary>
        <div class="pl-3 py-2 space-y-3">
          {cats.map((cat) => (
            <div>
              <a href={`/servicios#${cat.slug}`} class="font-display text-base text-[color:var(--color-mauve-700)]">{cat.icon} {cat.label}</a>
              <ul class="pl-7 mt-1 space-y-1">
                {cat.items.slice(0, 4).map((item) => (
                  <li><a href={item.href} class="text-sm text-[color:var(--color-ink-500)]">{item.label}</a></li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </details>

      {NAV.filter(n => !['Inicio', 'Servicios'].includes(n.label)).map((item) => (
        <a href={item.href} class="py-3 px-3 rounded-lg text-base font-medium hover:bg-[color:var(--color-brand-200)]/40">
          {item.label}
        </a>
      ))}
      <a href="/contacto" class="btn btn-primary mt-4">Agendar cita</a>
    </nav>
  </div>
</header>

<script is:inline>
  const t = document.getElementById('navToggle');
  const m = document.getElementById('mobileNav');
  if (t && m) {
    t.addEventListener('click', () => {
      const open = m.classList.toggle('hidden') === false;
      t.setAttribute('aria-expanded', String(open));
    });
  }
</script>
