---
import { NAV, SITE, CATEGORIES, catHref } from '../consts';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');

const cats = Object.values(CATEGORIES);
---

<header class="hdr">
  <div class="container-x hdr-inner">
    <!-- Logo -->
    <a href="/" class="hdr-logo" aria-label={SITE.name}>
      <span class="hdr-logo-mark" aria-hidden="true">C</span>
      <span class="hdr-logo-text">
        <span class="hdr-logo-name">{SITE.name}</span>
        <span class="hdr-logo-sub">Clínica de Belleza</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hdr-nav" aria-label="Navegación principal">
      <a href="/" class:list={['hdr-link', isActive('/') && 'is-active']}>Inicio</a>

      <!-- Mega menu Servicios -->
      <div class="hdr-mega" tabindex="0">
        <a
          href="/servicios"
          class:list={['hdr-link hdr-link-caret', isActive('/servicios') && 'is-active']}
          aria-haspopup="true"
          aria-expanded="false"
        >
          Servicios
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </a>

        <div class="hdr-mega-panel" role="menu">
          <div class="hdr-mega-grid">
            <!-- Columnas de categorías -->
            <div class="hdr-mega-cats">
              {cats.map((cat, i) => (
                <div class="hdr-mega-cat">
                  <a href={catHref(cat.slug)} class="hdr-mega-cat-head">
                    <span class="hdr-mega-cat-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                    <span class="hdr-mega-cat-name">
                      <span>{cat.label}</span>
                      <small>{cat.badgeCount}</small>
                    </span>
                  </a>
                  <ul class="hdr-mega-cat-items">
                    {cat.items.slice(0, 4).map((item) => (
                      <li>
                        <a href={item.href}>{item.label}</a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>

          </div>

          <!-- Footer del mega -->
          <div class="hdr-mega-foot">
            <p>
              <strong>25+</strong> tratamientos · Médicos certificados · COFEPRIS
            </p>
            <a href="/servicios" class="hdr-mega-foot-link">
              Ver catálogo completo
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>
      </div>

      {NAV.filter(n => !['Inicio', 'Servicios'].includes(n.label)).map((item) => (
        <a
          href={item.href}
          class:list={['hdr-link', isActive(item.href) && 'is-active']}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hdr-actions">
      <a href="/contacto" class="hdr-cta">
        Agendar cita
      </a>

      <button
        id="navToggle"
        type="button"
        class="hdr-toggle"
        aria-label="Abrir menú" aria-controls="mobileNav" aria-expanded="false"
      >
        <span class="hdr-toggle-bar" aria-hidden="true"></span>
        <span class="hdr-toggle-bar" aria-hidden="true"></span>
        <span class="hdr-toggle-bar" aria-hidden="true"></span>
      </button>
    </div>
  </div>
</header>

<!-- ================= Mobile nav (fuera del <header> para escapar al containing block del backdrop-filter) ================= -->
<div id="mobileNav" class="m-nav" aria-hidden="true">
  <div class="m-nav-scrim" id="mNavScrim" aria-hidden="true"></div>

  <aside class="m-nav-drawer" aria-label="Navegación móvil">
    <header class="m-nav-head">
        <a href="/" class="m-nav-logo">
          <span class="hdr-logo-mark" aria-hidden="true">C</span>
          <span class="m-nav-logo-text">
            <span class="hdr-logo-name">{SITE.name}</span>
            <span class="hdr-logo-sub">Clínica de Belleza</span>
          </span>
        </a>
        <button id="navClose" type="button" class="m-nav-close" aria-label="Cerrar menú">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </header>

      <nav class="m-nav-body">
        <a href="/" class:list={['m-nav-link', isActive('/') && 'is-active']}>
          <span>Inicio</span>
        </a>

        <details class="m-nav-acc" open={isActive('/servicios')}>
          <summary class="m-nav-link m-nav-link-acc">
            <span>Servicios</span>
            <span class="m-nav-link-meta">
              <span class="m-nav-badge">25+</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="m-nav-chev" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </span>
          </summary>

          <div class="m-nav-sub">
            <a href="/servicios" class="m-nav-sub-all">
              <span>Todos los tratamientos</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
            </a>

            {cats.map((cat, i) => (
              <div class="m-nav-cat">
                <a href={catHref(cat.slug)} class="m-nav-cat-head">
                  <span class="m-nav-cat-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                  <span class="m-nav-cat-text">
                    <span class="m-nav-cat-name">{cat.label}</span>
                    <span class="m-nav-cat-count">{cat.badgeCount}</span>
                  </span>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                </a>
                <ul class="m-nav-cat-items">
                  {cat.items.slice(0, 3).map((item) => (
                    <li><a href={item.href}>{item.label}</a></li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </details>

        {NAV.filter(n => !['Inicio', 'Servicios'].includes(n.label)).map((item) => (
          <a
            href={item.href}
            class:list={['m-nav-link', isActive(item.href) && 'is-active']}
          >
            <span>{item.label}</span>
          </a>
        ))}
      </nav>

  </aside>
</div>

<style>
  /* ============= HEADER (desktop) ============= */
  .hdr {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.97);
    backdrop-filter: saturate(180%) blur(14px);
    -webkit-backdrop-filter: saturate(180%) blur(14px);
    border-bottom: 1px solid rgba(201, 169, 97, 0.18);
    box-shadow: 0 1px 0 rgba(201, 169, 97, 0.06), 0 6px 24px -16px rgba(31, 20, 24, 0.18);
  }

  .hdr-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 76px;
    gap: 1.5rem;
  }

  /* === Logo === */
  .hdr-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
    text-decoration: none;
    color: inherit;
  }
  .hdr-logo-mark {
    display: grid;
    place-items: center;
    width: 46px; height: 46px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--color-brand-400), var(--color-mauve-500));
    color: white;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1;
    box-shadow:
      0 6px 18px -6px rgba(139, 90, 107, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.25);
  }
  .hdr-logo-text {
    display: none;
    flex-direction: column;
    line-height: 1.1;
  }
  @media (min-width: 480px) {
    .hdr-logo-text { display: flex; }
  }
  .hdr-logo-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.45rem;
    letter-spacing: -0.005em;
    color: var(--color-ink-900);
  }
  .hdr-logo-sub {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-mauve-500);
    margin-top: 1px;
  }

  /* === Nav links === */
  .hdr-nav {
    display: none;
    align-items: center;
    gap: 0.4rem;
  }
  @media (min-width: 1024px) {
    .hdr-nav { display: flex; }
  }

  .hdr-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.55rem 0.9rem;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--color-ink-700);
    border-radius: 999px;
    text-decoration: none;
    transition: color 0.25s ease, background 0.25s ease;
    white-space: nowrap;
  }
  .hdr-link:hover {
    color: var(--color-mauve-700);
    background: rgba(232, 213, 196, 0.4);
  }
  .hdr-link.is-active {
    color: var(--color-mauve-700);
    background: rgba(201, 169, 97, 0.15);
  }
  .hdr-link.is-active::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -3px;
    width: 22px;
    height: 2px;
    background: linear-gradient(90deg, var(--color-brand-400), var(--color-mauve-500));
    border-radius: 2px;
    transform: translateX(-50%);
  }
  .hdr-link-caret svg {
    transition: transform 0.3s ease;
  }
  .hdr-mega:hover .hdr-link-caret svg,
  .hdr-mega:focus-within .hdr-link-caret svg {
    transform: rotate(180deg);
  }

  /* === Mega menu === */
  .hdr-mega {
    position: relative;
  }
  /* Hit area extendida: hace que el bounding-box del trigger se extienda
     hacia abajo cubriendo el gap, para que :hover no se pierda al cruzar
     entre el link y el panel */
  .hdr-mega::after {
    content: '';
    position: absolute;
    left: -1rem;
    right: -1rem;
    top: 100%;
    height: 1.25rem;
    background: transparent;
    pointer-events: auto;
    z-index: 1;
  }

  .hdr-mega-panel {
    position: absolute;
    left: 50%;
    top: calc(100% + 0.55rem);
    transform: translateX(-50%) translateY(-6px);
    width: min(900px, calc(100vw - 3rem));
    background: white;
    border-radius: 1.25rem;
    border: 1px solid rgba(201, 169, 97, 0.25);
    box-shadow:
      0 1px 2px rgba(31, 20, 24, 0.04),
      0 24px 64px -20px rgba(31, 20, 24, 0.28),
      0 8px 18px -12px rgba(92, 57, 70, 0.22);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    /* !important para vencer el kill-switch global de transitions */
    transition:
      opacity 0.22s ease,
      transform 0.3s cubic-bezier(.2,.8,.2,1),
      visibility 0s linear 0.35s !important;
    overflow: hidden;
    z-index: 60;
  }
  /* Bridge ampliado: cubre el espacio entre trigger y panel para que el
     mouse pueda transitar sin perder hover */
  .hdr-mega-panel::before {
    content: '';
    position: absolute;
    top: -1.25rem;
    left: -1rem;
    right: -1rem;
    height: 1.5rem;
    background: transparent;
    pointer-events: auto;
  }
  .hdr-mega:hover .hdr-mega-panel,
  .hdr-mega:focus-within .hdr-mega-panel,
  .hdr-mega-panel:hover {
    opacity: 1 !important;
    visibility: visible !important;
    pointer-events: auto !important;
    transform: translateX(-50%) translateY(0) !important;
    transition:
      opacity 0.22s ease,
      transform 0.3s cubic-bezier(.2,.8,.2,1),
      visibility 0s linear 0s !important;
  }

  .hdr-mega-grid {
    padding: 1.75rem;
  }
  .hdr-mega-cats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem 2.25rem;
  }
  @media (max-width: 900px) {
    .hdr-mega-cats { grid-template-columns: repeat(2, 1fr); }
  }
  .hdr-mega-cat {
    min-width: 0;
  }
  .hdr-mega-cat-head {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding-bottom: 0.55rem;
    margin-bottom: 0.55rem;
    border-bottom: 1px solid rgba(201, 169, 97, 0.25);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.25s ease;
  }
  .hdr-mega-cat-head:hover {
    border-color: var(--color-mauve-500);
  }
  .hdr-mega-cat-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 0.95rem;
    color: var(--color-brand-500);
    letter-spacing: 0.06em;
    line-height: 1;
    padding-top: 2px;
    flex-shrink: 0;
    transition: color 0.25s ease;
  }
  .hdr-mega-cat-head:hover .hdr-mega-cat-num {
    color: var(--color-mauve-500);
  }
  .hdr-mega-cat-name {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
    min-width: 0;
    flex: 1;
  }
  .hdr-mega-cat-name span {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.98rem;
    color: var(--color-ink-900);
    letter-spacing: -0.01em;
  }
  .hdr-mega-cat-head:hover .hdr-mega-cat-name span {
    color: var(--color-mauve-700);
  }
  .hdr-mega-cat-name small {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-brand-500);
    margin-top: 2px;
  }

  .hdr-mega-cat-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .hdr-mega-cat-items a {
    display: block;
    padding: 0.32rem 0;
    padding-left: 2.85rem;
    margin-left: -2.85rem;
    font-size: 0.78rem;
    color: var(--color-ink-500);
    text-decoration: none;
    border-radius: 6px;
    transition: all 0.2s ease;
    position: relative;
  }
  .hdr-mega-cat-items a::before {
    content: '';
    position: absolute;
    left: 2.5rem;
    top: 50%;
    width: 4px;
    height: 1px;
    background: var(--color-brand-400);
    opacity: 0;
    transition: all 0.2s ease;
  }
  .hdr-mega-cat-items a:hover {
    color: var(--color-mauve-700);
    background: rgba(232, 213, 196, 0.25);
    padding-left: 3.1rem;
  }
  .hdr-mega-cat-items a:hover::before {
    opacity: 1;
    width: 12px;
  }

  /* === Mega foot === */
  .hdr-mega-foot {
    border-top: 1px solid rgba(201, 169, 97, 0.22);
    background: var(--color-brand-50);
    padding: 0.85rem 1.75rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .hdr-mega-foot p {
    margin: 0;
    font-size: 0.75rem;
    color: var(--color-ink-500);
  }
  .hdr-mega-foot p strong {
    color: var(--color-mauve-700);
    font-weight: 700;
  }
  .hdr-mega-foot-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-mauve-500);
    text-decoration: none;
    transition: color 0.2s ease, gap 0.25s ease;
  }
  .hdr-mega-foot-link:hover {
    color: var(--color-mauve-700);
    gap: 0.55rem;
  }

  /* === Actions === */
  .hdr-actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-shrink: 0;
  }
  .hdr-phone {
    display: none;
    flex-direction: column;
    align-items: flex-end;
    line-height: 1.1;
    padding: 0.35rem 0.85rem;
    border-left: 1px solid rgba(201, 169, 97, 0.35);
    text-decoration: none;
    transition: color 0.25s ease;
  }
  @media (min-width: 1180px) {
    .hdr-phone { display: inline-flex; }
  }
  .hdr-phone-label {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-mauve-500);
  }
  .hdr-phone-num {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.05rem;
    color: var(--color-ink-900);
    letter-spacing: -0.005em;
    margin-top: 2px;
    transition: color 0.25s ease;
  }
  .hdr-phone:hover .hdr-phone-num { color: var(--color-mauve-700); }

  .hdr-cta {
    display: none;
    align-items: center;
    gap: 0.4rem;
    padding: 0.62rem 1.15rem;
    background: var(--color-ink-900);
    color: var(--color-brand-50);
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(.2,.8,.2,1);
    box-shadow: 0 4px 14px -6px rgba(31, 20, 24, 0.35);
  }
  @media (min-width: 640px) {
    .hdr-cta { display: inline-flex; }
  }
  .hdr-cta:hover {
    background: var(--color-mauve-500);
    transform: translateY(-1px);
    box-shadow: 0 8px 20px -6px rgba(139, 90, 107, 0.55);
  }

  .hdr-toggle {
    display: grid;
    place-items: center;
    width: 42px; height: 42px;
    background: transparent;
    border: 1px solid rgba(201, 169, 97, 0.35);
    border-radius: 999px;
    cursor: pointer;
    position: relative;
    transition: all 0.25s ease;
  }
  @media (min-width: 1024px) {
    .hdr-toggle { display: none; }
  }
  .hdr-toggle:hover {
    background: rgba(232, 213, 196, 0.5);
    border-color: var(--color-mauve-500);
  }
  .hdr-toggle-bar {
    position: absolute;
    left: 11px;
    width: 20px;
    height: 2px;
    background: var(--color-ink-800);
    border-radius: 2px;
    transition: all 0.3s cubic-bezier(.2,.8,.2,1);
  }
  .hdr-toggle-bar:nth-child(1) { top: 14px; }
  .hdr-toggle-bar:nth-child(2) { top: 20px; width: 14px; }
  .hdr-toggle-bar:nth-child(3) { top: 26px; }
  .hdr-toggle[aria-expanded="true"] .hdr-toggle-bar:nth-child(1) {
    top: 20px;
    transform: rotate(45deg);
  }
  .hdr-toggle[aria-expanded="true"] .hdr-toggle-bar:nth-child(2) {
    opacity: 0;
  }
  .hdr-toggle[aria-expanded="true"] .hdr-toggle-bar:nth-child(3) {
    top: 20px;
    transform: rotate(-45deg);
  }

  /* ============= MOBILE NAV ============= */
  .m-nav {
    position: fixed !important;
    inset: 0 !important;
    z-index: 9999 !important;
    display: block !important;
    visibility: hidden;
    pointer-events: none;
  }
  .m-nav.is-open {
    visibility: visible;
    pointer-events: auto;
  }

  .m-nav-scrim {
    position: absolute;
    inset: 0;
    background: rgba(31, 20, 24, 0.6);
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity 0.32s ease !important;
  }
  .m-nav.is-open .m-nav-scrim { opacity: 1; }

  .m-nav-drawer {
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: min(420px, 92vw);
    max-width: 100%;
    background: var(--color-brand-50);
    box-shadow: -24px 0 60px -20px rgba(31, 20, 24, 0.35);
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(.2,.8,.2,1) !important;
    padding-top: env(safe-area-inset-top);
    padding-bottom: env(safe-area-inset-bottom);
    overflow: hidden;
  }
  .m-nav.is-open .m-nav-drawer { transform: translateX(0) !important; }

  /* Scroll lock body cuando drawer abierto */
  :global(body.m-nav-locked) {
    overflow: hidden !important;
  }

  /* Mobile drawer header */
  .m-nav-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid rgba(201, 169, 97, 0.22);
    background: white;
  }
  .m-nav-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: inherit;
  }
  .m-nav-logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .m-nav-logo-text .hdr-logo-name {
    font-size: 1.2rem;
  }
  .m-nav-close {
    display: grid;
    place-items: center;
    width: 40px; height: 40px;
    background: transparent;
    border: 1px solid rgba(201, 169, 97, 0.35);
    border-radius: 999px;
    color: var(--color-ink-800);
    cursor: pointer;
    transition: all 0.25s ease;
  }
  .m-nav-close:hover {
    background: var(--color-ink-900);
    color: white;
    border-color: var(--color-ink-900);
  }

  /* Body scroll */
  .m-nav-body {
    flex: 1;
    overflow-y: auto;
    padding: 1rem 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    -webkit-overflow-scrolling: touch;
  }

  /* Link rows */
  .m-nav-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.95rem 1rem;
    background: white;
    border: 1px solid rgba(201, 169, 97, 0.18);
