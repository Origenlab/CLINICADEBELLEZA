</style>

<script is:inline>
  (function initMobileNav() {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initMobileNav);
      return;
    }

    const toggle = document.getElementById('navToggle');
    const closeBtn = document.getElementById('navClose');
    const scrim = document.getElementById('mNavScrim');
    const mNav = document.getElementById('mobileNav');

    if (!toggle || !mNav) return;
    if (toggle.dataset.bound === '1') return; // anti doble-bind
    toggle.dataset.bound = '1';

    const isOpen = () => mNav.classList.contains('is-open');

    const openMenu = () => {
      mNav.classList.add('is-open');
      mNav.setAttribute('aria-hidden', 'false');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.classList.add('m-nav-locked');
    };

    const closeMenu = () => {
      mNav.classList.remove('is-open');
      mNav.setAttribute('aria-hidden', 'true');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('m-nav-locked');
    };

    const handleToggleClick = (e) => {
      e.preventDefault();
      e.stopPropagation();
      if (isOpen()) closeMenu(); else openMenu();
    };

    toggle.addEventListener('click', handleToggleClick);
    toggle.addEventListener('touchend', handleToggleClick, { passive: false });

    if (closeBtn) {
      closeBtn.addEventListener('click', (e) => {
        e.preventDefault();
        closeMenu();
      });
    }

    if (scrim) {
      scrim.addEventListener('click', closeMenu);
    }

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen()) closeMenu();
    });

    // Cerrar al clickar links internos (no detalles/summary)
    mNav.querySelectorAll('a[href]').forEach((a) => {
      a.addEventListener('click', () => closeMenu());
    });

    // Si pasa a desktop, cerrar
    const mql = window.matchMedia('(min-width: 1024px)');
    const handleMQ = (e) => { if (e.matches) closeMenu(); };
    if (mql.addEventListener) mql.addEventListener('change', handleMQ);
    else if (mql.addListener) mql.addListener(handleMQ);
  })();
</script>
