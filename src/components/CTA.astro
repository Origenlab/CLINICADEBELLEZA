---
interface Props {
  title?: string;
  subtitle?: string;
  primaryHref?: string;
  primaryLabel?: string;
}

const {
  title = '¿Lista para tu primera valoración?',
  subtitle = 'Diagnóstico personalizado, plan a tu medida y la atención humana que mereces. Agenda tu valoración desde el formulario de contacto.',
  primaryHref = '/contacto',
  primaryLabel = 'Agendar valoración',
} = Astro.props;
---

<section class="relative overflow-hidden gradient-mauve-gold text-white">
  <div aria-hidden="true" class="absolute inset-0 opacity-[0.08] pointer-events-none"
       style="background-image: radial-gradient(circle at 20% 30%, white 1px, transparent 1px), radial-gradient(circle at 70% 80%, white 1px, transparent 1px); background-size: 50px 50px, 70px 70px;"></div>

  <div class="container-x relative py-16 lg:py-20">
    <div class="grid lg:grid-cols-[1.2fr_1fr] gap-10 items-center">
      <div>
        <span class="kicker text-[color:var(--color-brand-200)]">CLIBEL · Clínica de Belleza</span>
        <h2 class="mt-3 h-display text-4xl sm:text-5xl lg:text-6xl text-white">
          {title}
        </h2>
        <p class="mt-5 text-[color:var(--color-brand-100)]/95 leading-relaxed text-lg max-w-xl">{subtitle}</p>
      </div>

      <div class="flex flex-col gap-3 lg:items-end">
        <a href={primaryHref} class="btn btn-gold w-full lg:w-auto">{primaryLabel}</a>
        <a href="/servicios" class="btn border border-white/30 text-white hover:bg-white/10 w-full lg:w-auto">
          Ver todos los tratamientos
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
        <p class="text-xs text-[color:var(--color-brand-200)]/80 mt-2 text-center lg:text-right">
          COFEPRIS · Médicos certificados
        </p>
      </div>
    </div>
  </div>
</section>
