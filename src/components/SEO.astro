---
import { SITE } from '../consts';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedAt?: Date;
  canonical?: string;
  noindex?: boolean;
}

const {
  title,
  description = SITE.description,
  keywords = SITE.keywords,
  image = SITE.defaultImage,
  type = 'website',
  publishedAt,
  canonical,
  noindex = false,
} = Astro.props;

const fullTitle = title === SITE.name
  ? SITE.longName
  : `${title} — CLIBEL CDMX`;
const canonicalURL = new URL(canonical ?? Astro.url.pathname, Astro.site).toString();
const imageURL = new URL(image, Astro.site).toString();
---

<!-- Primary -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="keywords" content={keywords} />
<meta name="author" content={SITE.name} />
<meta name="publisher" content="CLIBEL Clínica de Belleza" />
<link rel="canonical" href={canonicalURL} />
{noindex
  ? <meta name="robots" content="noindex, nofollow" />
  : <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
}

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={imageURL} />
<meta property="og:image:alt" content="CLIBEL — Clínica de belleza en CDMX con respaldo médico" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content="CLIBEL Clínica de Belleza" />
<meta property="og:locale" content={SITE.locale} />
{publishedAt && <meta property="article:published_time" content={publishedAt.toISOString()} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL} />
<meta name="twitter:image:alt" content="Clínica de belleza CLIBEL en Ciudad de México" />

<!-- Geo / Local SEO -->
<meta name="geo.region" content="MX-CMX" />
<meta name="geo.placename" content="Ciudad de México" />
<meta name="geo.position" content="19.4326;-99.1332" />
<meta name="ICBM" content="19.4326, -99.1332" />

<!-- Misc -->
<meta name="rating" content="general" />
<meta name="distribution" content="global" />
<meta http-equiv="content-language" content="es-MX" />
