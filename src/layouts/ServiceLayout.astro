---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import HeroNavBar from '../components/HeroNavBar.astro';
import RelatedCategories from '../components/RelatedCategories.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, CONTACT, SITE, catHref, type Category } from '../consts';

interface Props {
  /** ID/slug del servicio (= entry.id) */
  slug: string;
  title: string;
  description: string;
  category: Category;
  duration?: string;
  sessions?: string;
  price?: string;
  benefits?: string[];
  indications?: string[];
  contraindications?: string[];
  icon?: string;
  publishedAt?: Date;
  seoTitle?: string;
  seoDescription?: string;
  heroLede?: string;
  heroTagline?: string;
  protocolSteps?: { n: string; title: string; text: string }[];
  timeline?: { when: string; label: string; text: string }[];
  preCare?: string[];
  postCare?: string[];
  faqs?: { q: string; a: string }[];
  comparison?: { aspect: string; home?: string; spa?: string; clibel: string }[];
  modalities?: { name: string; kicker?: string; profile?: string; text: string; intensity?: string; downtime?: string }[];
  clinicalCases?: { name: string; profile: string; duration?: string; plan: string[]; target: string; accent?: 'gold' | 'mauve' | 'rose' }[];
  treatmentZones?: { name: string; kicker?: string; sessions?: string; text: string; accent?: 'gold' | 'mauve' | 'rose' }[];
  myths?: { myth: string; reality: string }[];
  commitments?: { title: string; text: string; weight?: 'Imprescindible' | 'Recomendado' | 'Opcional' }[];
  safetyProtocol?: { title: string; text: string; kind?: 'producto' | 'protocolo' | 'personal' | 'reversibilidad' }[];
}

const {
  slug,
  title,
  description,
  category,
  duration,
  sessions,
  price,
  benefits = [],
  indications = [],
  contraindications = [],
  icon,
  publishedAt,
  seoTitle,
  seoDescription,
  heroLede,
  heroTagline,
  protocolSteps = [],
  timeline = [],
  preCare = [],
  postCare = [],
  faqs = [],
  comparison = [],
  modalities = [],
  clinicalCases = [],
  treatmentZones = [],
  myths = [],
  commitments = [],
  safetyProtocol = [],
} = Astro.props;

const cat = CATEGORIES[category];

// === Servicios relacionados (misma categoría) ===
const allServices = await getCollection('servicios');
const siblings = allServices
  .filter((s) => s.data.category === category && s.id !== slug)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 5);

// === Otras categorías para cross-linking ===
const otherCategories = (Object.keys(CATEGORIES) as Category[])
  .filter((key) => key !== category)
  .map((key) => {
    const c = CATEGORIES[key];
    return {
      key,
      label: c.label,
      short: c.short,
      description: c.description,
      href: catHref(key),
    };
  });

// === Schemas SEO ===
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Servicios', item: `${SITE.url}/servicios` },
    { '@type': 'ListItem', position: 3, name: cat.label, item: `${SITE.url}${catHref(category)}` },
    { '@type': 'ListItem', position: 4, name: title, item: `${SITE.url}/servicios/${slug}` },
  ],
};

const procedureSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalProcedure',
  name: title,
  description,
  url: `${SITE.url}/servicios/${slug}`,
  bodyLocation: cat.label,
  procedureType: 'NoninvasiveProcedure',
  preparation: preCare.length ? preCare.join('. ') : undefined,
  followup: postCare.length ? postCare.join('. ') : undefined,
  performer: { '@id': `${SITE.url}/#clinic` },
};

const faqSchema = faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;

const finalSeoTitle = seoTitle ?? `${title} en CDMX | CLIBEL`;
const finalSeoDesc = seoDescription ?? description;

// === TOC: secciones disponibles en esta página ===
const toc: { id: string; label: string; n: string }[] = [
  { id: 'resumen', label: 'Resumen clínico', n: 'I' },
  ...(benefits.length > 0 || indications.length > 0 || contraindications.length > 0
    ? [{ id: 'beneficios', label: 'Beneficios e indicaciones', n: 'II' }]
    : []),
  ...(clinicalCases.length > 0 ? [{ id: 'casos', label: 'Casos clínicos', n: '★' }] : []),
  ...(myths.length > 0 ? [{ id: 'mitos', label: 'Mitos vs realidad', n: '❖' }] : []),
  ...(commitments.length > 0 ? [{ id: 'compromisos', label: 'Tu compromiso', n: '◐' }] : []),
  ...(safetyProtocol.length > 0 ? [{ id: 'seguridad', label: 'Protocolo de seguridad', n: '⚕' }] : []),
  ...(treatmentZones.length > 0 ? [{ id: 'zonas', label: 'Zonas de tratamiento', n: '▲' }] : []),
  ...(modalities.length > 0 ? [{ id: 'modalidades', label: 'Modalidades del protocolo', n: '◆' }] : []),
  ...(comparison.length > 0 ? [{ id: 'comparativa', label: 'Comparativa clínica', n: '•' }] : []),
  ...(protocolSteps.length > 0 ? [{ id: 'protocolo', label: 'Protocolo paso a paso', n: 'III' }] : []),
  ...(timeline.length > 0 ? [{ id: 'resultados', label: 'Línea de resultados', n: 'IV' }] : []),
  ...(preCare.length > 0 || postCare.length > 0
    ? [{ id: 'cuidados', label: 'Pre y post sesión', n: 'V' }]
    : []),
  ...(faqs.length > 0 ? [{ id: 'preguntas', label: 'Preguntas frecuentes', n: 'VI' }] : []),
];
---

<BaseLayout
  title={finalSeoTitle}
  description={finalSeoDesc}
  type="article"
  publishedAt={publishedAt}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(procedureSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  <!-- ============================ BREADCRUMB ============================ -->
  <Breadcrumb
    kicker={`Servicio · ${cat.short}`}
    items={[
      { label: 'Servicios', href: '/servicios' },
      { label: cat.label, href: catHref(category) },
      { label: title },
    ]}
  />

  <!-- ============================ HERO ============================ -->
  <section class="svc-hero">
    <div aria-hidden="true" class="svc-hero-bg"></div>
    <div aria-hidden="true" class="svc-hero-blob svc-hero-blob-1"></div>
    <div aria-hidden="true" class="svc-hero-blob svc-hero-blob-2"></div>
    <div aria-hidden="true" class="svc-hero-grain"></div>

    <div class="container-x relative">
      <div class="svc-hero-grid">
        <div class="svc-hero-col svc-hero-col--left fade-up">
          <span class="eyebrow-tag">
            <span class="dot" aria-hidden="true"></span>
            {cat.label} · {heroTagline ?? 'Protocolo CLIBEL'}
          </span>

          <h1 class="svc-hero-headline">{title}</h1>

          <p class="svc-hero-lede">{heroLede ?? description}</p>

          <!-- Info meta strip -->
          <dl class="svc-hero-meta">
            {duration && (
              <div class="svc-hero-meta-item">
                <dt>Duración</dt>
                <dd>{duration}</dd>
              </div>
            )}
            {sessions && (
              <div class="svc-hero-meta-item">
                <dt>Sesiones</dt>
                <dd>{sessions}</dd>
              </div>
            )}
            {price && (
              <div class="svc-hero-meta-item">
                <dt>Inversión</dt>
                <dd>{price}</dd>
              </div>
            )}
            <div class="svc-hero-meta-item">
              <dt>Categoría</dt>
              <dd>{cat.label}</dd>
            </div>
          </dl>

          <div class="svc-hero-actions">
            <a href="/contacto" class="btn btn-primary">Agendar valoración</a>
            <a href="/servicios" class="btn btn-outline">Ver todos los tratamientos</a>
          </div>
        </div>

        <div class="svc-hero-col svc-hero-col--right fade-up-delay-2">
          <span class="svc-hero-kicker">Qué hace CLIBEL en este tratamiento</span>

          <p class="svc-hero-paragraph">
            <strong>CLIBEL</strong> aplica <strong>{title.toLowerCase()}</strong>
            como protocolo clínico, no como servicio comercial. Cada sesión
            parte de valoración previa y se documenta en expediente con
            producto, parámetros y respuesta cutánea — para que tu plan se
            afine sesión a sesión con evidencia, no con suposiciones.
          </p>

          <p class="svc-hero-paragraph">
            En <strong>CLIBEL</strong> trabajamos con técnicas validadas
            internacionalmente, productos con registro COFEPRIS visible y
            personal médico certificado. La trazabilidad es estándar mínimo,
            no extra premium. <a href={catHref(category)}>Ver todos los tratamientos de {cat.label.toLowerCase()} →</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================ NAV TOP (otros servicios de la categoría) ============================ -->
  {siblings.length > 0 && (
    <HeroNavBar
      label={`Otros tratamientos · ${cat.short}`}
      ariaLabel={`Otros tratamientos de ${cat.label}`}
      variant="cream"
      links={siblings.map((s) => ({ label: s.data.title, href: `/servicios/${s.id}` }))}
      cta={{ label: `Ver categoría ${cat.short.toLowerCase()}`, href: catHref(category) }}
    />
  )}

  <!-- ============================ TOC sticky (índice editorial de la página) ============================ -->
  {toc.length > 1 && (
    <nav class="svc-toc" aria-label="Índice de esta página" id="svcToc">
      <div class="container-x svc-toc-inner">
        <span class="svc-toc-label">
          <span class="svc-toc-label-line" aria-hidden="true"></span>
          <em>Índice</em> de la página
        </span>
        <ol class="svc-toc-list">
          {toc.map((t) => (
            <li>
              <a href={`#${t.id}`} class="svc-toc-link" data-toc-id={t.id}>
                <span class="svc-toc-num" aria-hidden="true">{t.n}</span>
                <span class="svc-toc-text">{t.label}</span>
              </a>
            </li>
          ))}
        </ol>
        <a href="/contacto" class="svc-toc-cta">
          Agendar valoración
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>
    </nav>
  )}

  <!-- ============================ BODY MD + meta sticky 2-col ============================ -->
  <section class="section bg-white" id="resumen">
    <div class="container-x">
      <div class="svc-body-grid">
        <article class="svc-body prose-clibel reveal">
          <div class="svc-chapter-mark svc-chapter-mark--inline">
            <span class="svc-chapter-num"><em>I</em></span>
            <span class="svc-chapter-line"></span>
            <span class="svc-chapter-kicker">Capítulo · Resumen clínico</span>
          </div>

          <!-- Stat strip clínico editorial -->
          <dl class="svc-stats">
            {protocolSteps.length > 0 && (
              <div class="svc-stats-item">
                <dt>Pasos clínicos</dt>
                <dd><em>{String(protocolSteps.length).padStart(2, '0')}</em></dd>
              </div>
            )}
            {duration && (
              <div class="svc-stats-item">
                <dt>Duración</dt>
                <dd><em>{duration.replace(/min/i, '').trim()}</em><span>min</span></dd>
              </div>
            )}
            {sessions && (
              <div class="svc-stats-item">
                <dt>Frecuencia</dt>
                <dd class="svc-stats-text">{sessions}</dd>
              </div>
            )}
            <div class="svc-stats-item">
              <dt>Aplica</dt>
              <dd class="svc-stats-text">Personal médico CLIBEL</dd>
            </div>
          </dl>

          <slot />

          {benefits.length > 0 && (
            <section class="svc-block" id="beneficios">
              <span class="svc-chapter" aria-hidden="true">
                <span class="svc-chapter-num"><em>II</em></span>
                <span class="svc-chapter-line"></span>
                <span class="svc-chapter-kicker">Capítulo · Beneficios e indicaciones</span>
              </span>

              <header class="svc-block-head">
                <h2>Beneficios clínicos</h2>
                <p class="svc-block-lede">
                  Lo que <strong>CLIBEL</strong> entrega de forma medible y reproducible con cada sesión. Cada beneficio está validado en la práctica clínica diaria — no son promesas de marketing.
                </p>
              </header>

              <ul class="svc-benefits">
                {benefits.map((b, i) => (
                  <li>
                    <span class="svc-benefits-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                    <span class="svc-benefits-text">{b}</span>
                  </li>
                ))}
              </ul>
            </section>
          )}

          {indications.length > 0 && (
            <section class="svc-block">
              <header class="svc-block-head">
                <h2>Indicado para</h2>
                <p class="svc-block-lede">
                  Perfiles cutáneos y motivos de consulta en los que <strong>CLIBEL</strong> recomienda este tratamiento. La valoración previa confirma si tu caso encaja.
                </p>
              </header>

              <ul class="svc-indic">
                {indications.map((it) => (
                  <li>
                    <span class="svc-indic-icon" aria-hidden="true">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                    </span>
                    <span>{it}</span>
                  </li>
                ))}
              </ul>
            </section>
          )}

          {contraindications.length > 0 && (
            <section class="svc-block svc-contra">
              <div class="svc-contra-grid">
                <header class="svc-contra-head">
                  <span class="svc-contra-tag">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    Importante · Seguridad clínica
                  </span>
                  <h2>Contra-<br/>indicaciones</h2>
                  <p class="svc-contra-lede">
                    Este tratamiento puede no ser adecuado en los siguientes casos. <strong>CLIBEL</strong> valora cada paciente antes de aplicar — si te identificas con alguno, coméntalo en valoración para ajustar el protocolo o sustituirlo por uno más seguro para tu piel.
                  </p>
                  <div class="svc-contra-cta">
                    <a href="/contacto/">
                      Agenda tu valoración
                    </a>
                  </div>
                </header>
                <ul class="svc-contra-list">
                  {contraindications.map((c, i) => (
                    <li>
                      <span class="svc-contra-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                      <span class="svc-contra-text">{c}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </section>
          )}
        </article>

        <!-- Sticky sidebar — widgets modulares (interlinking pro) -->
        <aside class="svc-side">
          <!-- Widget 1: Ficha clínica del tratamiento -->
          <div class="svc-widget svc-widget--main">
            <span class="svc-widget-icon" aria-hidden="true">{icon ?? '✦'}</span>
            <span class="svc-widget-kicker">Ficha clínica · {cat.short}</span>
            <h3 class="svc-widget-title">{title}</h3>

            <dl class="svc-widget-meta">
              {duration && (
                <div>
                  <dt>Duración</dt>
                  <dd>{duration}</dd>
                </div>
              )}
              {sessions && (
                <div>
                  <dt>Sesiones</dt>
                  <dd>{sessions}</dd>
                </div>
              )}
              {price && (
                <div>
                  <dt>Inversión</dt>
                  <dd>{price}</dd>
                </div>
              )}
              <div>
                <dt>Aplica</dt>
                <dd>Personal clínico CLIBEL</dd>
              </div>
              <div>
                <dt>Expediente</dt>
                <dd>Digital · sesión a sesión</dd>
              </div>
            </dl>

            <div class="svc-widget-actions">
              <a href="/contacto" class="btn btn-primary svc-widget-cta">Agendar valoración</a>
            </div>

            <p class="svc-widget-foot">Valoración sin costo · COFEPRIS · {SITE.founded ? `${new Date().getFullYear() - parseInt(SITE.founded)} años` : 'Respaldo médico'}</p>
          </div>

          <!-- Widget 2: Qué incluye cada sesión (derivado del protocolo si existe) -->
          {protocolSteps.length > 0 && (
            <div class="svc-widget">
              <span class="svc-widget-tag">Incluido</span>
              <h4 class="svc-widget-h">Cada sesión incluye</h4>
              <ul class="svc-widget-checks">
                {protocolSteps.map((step) => (
                  <li>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    <span>{step.title}</span>
                  </li>
                ))}
              </ul>
              <a href="#protocolo" class="svc-widget-link">Ver protocolo completo →</a>
            </div>
          )}

          <!-- Widget 3: Respaldo clínico · trust block -->
          <div class="svc-widget svc-widget--trust">
            <span class="svc-widget-tag svc-widget-tag--gold">Respaldo clínico</span>
            <h4 class="svc-widget-h">¿Por qué <em>CLIBEL</em>?</h4>
            <dl class="svc-widget-trust-list">
              <div>
                <dt>COFEPRIS</dt>
                <dd>Registro vigente y productos con trazabilidad por lote</dd>
              </div>
              <div>
                <dt>Experiencia</dt>
                <dd>{SITE.founded ? `${new Date().getFullYear() - parseInt(SITE.founded)} años atendiendo en CDMX` : 'Décadas en CDMX'}</dd>
              </div>
              <div>
                <dt>Personal</dt>
                <dd>Médico certificado · técnicas validadas internacionalmente</dd>
              </div>
              <div>
                <dt>Expediente</dt>
                <dd>Diagnóstico, protocolo y respuesta documentados por escrito</dd>
              </div>
            </dl>
            <div class="svc-widget-link-row">
              <a href="/nosotros" class="svc-widget-link">Sobre CLIBEL →</a>
              <a href="/equipo" class="svc-widget-link">Equipo médico →</a>
            </div>
          </div>

          <!-- Widget 4: Otros tratamientos de la categoría -->
          {siblings.length > 0 && (
            <div class="svc-widget">
              <span class="svc-widget-tag">{cat.short} · Misma categoría</span>
              <h4 class="svc-widget-h">Tratamientos relacionados</h4>
              <ul class="svc-widget-related">
                {siblings.map((s, i) => (
                  <li>
                    <a href={`/servicios/${s.id}`}>
                      <span class="svc-widget-related-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                      <span class="svc-widget-related-body">
                        <span class="svc-widget-related-name">{s.data.title}</span>
                        <span class="svc-widget-related-desc">{s.data.description}</span>
                      </span>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                      </svg>
                    </a>
                  </li>
                ))}
              </ul>
              <a href={catHref(category)} class="svc-widget-link">Ver toda la categoría {cat.short.toLowerCase()} →</a>
            </div>
          )}

          <!-- Widget 5: Cross-link a otras categorías CLIBEL -->
          <div class="svc-widget svc-widget--cross">
            <span class="svc-widget-tag">Cross-link · Servicios CLIBEL</span>
            <h4 class="svc-widget-h">Complementa tu plan</h4>
            <p class="svc-widget-p">
              Este tratamiento se integra con el resto del catálogo <strong>CLIBEL</strong>. Explora otras áreas para construir un plan estético completo:
            </p>
            <ul class="svc-widget-cats">
              {otherCategories.map((c) => (
                <li>
                  <a href={c.href}>
                    <span class="svc-widget-cats-arrow" aria-hidden="true">→</span>
                    <span class="svc-widget-cats-body">
                      <span class="svc-widget-cats-name">{c.label}</span>
                      <span class="svc-widget-cats-desc">{c.description}</span>
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Widget 6: Línea editorial — info de contacto rápido -->
          <div class="svc-widget svc-widget--contact">
            <span class="svc-widget-tag svc-widget-tag--dark">Contacto</span>
            <h4 class="svc-widget-h svc-widget-h--dark">Habla con <em>CLIBEL</em></h4>
            <dl class="svc-widget-contact-list">
              <div>
                <dt>Horario</dt>
                <dd>{CONTACT.hoursShort}</dd>
              </div>
              <div>
                <dt>Ubicación</dt>
                <dd>{CONTACT.address}</dd>
              </div>
            </dl>
            <a href="/contacto" class="svc-widget-link svc-widget-link--gold">Agenda tu valoración →</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ============================ CASOS CLÍNICOS (sección opcional · entre Cap II y Modalidades) ============================ -->
  {clinicalCases.length > 0 && (
    <section class="section svc-cases" id="casos">
      <div class="container-x">
        <div class="svc-chapter-mark svc-chapter-mark--marker">
          <span class="svc-chapter-num"><em>★</em></span>
          <span class="svc-chapter-line"></span>
          <span class="svc-chapter-kicker">Casos clínicos</span>
        </div>

        <SectionHeader
          marginBottom="md"
          kicker="Perfiles que atendemos"
          title={`Cómo <em>CLIBEL</em> trata<br/>cada caso real.`}
          paragraphs={[
            `Estos son los perfiles de paciente más frecuentes que <strong>CLIBEL</strong> atiende para este tratamiento — y el plan clínico tipo para cada uno. No es venta de paquete: es ejemplo de cómo se diseña el protocolo según el caso concreto.`,
            `Tu valoración inicial en <strong>CLIBEL</strong> identifica en qué perfil encajas (o cómo combinas varios) y se traduce en un plan personalizado por escrito antes de empezar.`,
          ]}
        />

        <ol class="svc-cases-grid" data-count={clinicalCases.length}>
