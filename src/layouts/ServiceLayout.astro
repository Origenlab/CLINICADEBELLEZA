    font-size: 0.94rem;
    line-height: 1.55;
    color: var(--color-ink-700);
    padding: 1.1rem 1.15rem;
    border: 1px solid rgba(201, 169, 97, 0.28);
    background: white;
    border-radius: 0.9rem;
    transition: all 0.3s ease !important;
  }
  .svc-indic li:hover {
    border-color: var(--color-mauve-500);
    background: var(--color-brand-50);
    transform: translateY(-2px);
  }
  .svc-indic-icon {
    flex-shrink: 0;
    width: 28px; height: 28px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--color-brand-400), var(--color-mauve-500));
    color: white;
    margin-top: 1px;
    box-shadow: 0 4px 10px -4px rgba(139, 90, 107, 0.4);
  }

  /* Contraindications — 2-col editorial */
  .svc-contra {
    padding: 0;
    background: linear-gradient(180deg, rgba(198, 43, 62, 0.05) 0%, rgba(198, 43, 62, 0.02) 100%);
    border: 1px solid rgba(198, 43, 62, 0.22);
    border-left: 4px solid #c62b3e;
    border-radius: 1.1rem;
    margin-top: clamp(3rem, 5vw, 4.5rem);
    overflow: hidden;
  }
  .svc-contra-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  @media (min-width: 820px) {
    .svc-contra-grid { grid-template-columns: 0.85fr 1.15fr; }
  }
  .svc-contra-head {
    padding: clamp(1.75rem, 2.5vw, 2.25rem);
    background: rgba(198, 43, 62, 0.04);
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    align-items: flex-start;
  }
  @media (min-width: 820px) {
    .svc-contra-head { border-right: 1px solid rgba(198, 43, 62, 0.18); }
  }
  .svc-contra-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 0.45rem 0.9rem;
    border-radius: 999px;
    background: rgba(198, 43, 62, 0.1);
    color: #c62b3e;
    border: 1px solid rgba(198, 43, 62, 0.32);
  }
  .svc-contra h2 {
    margin: 0;
    color: var(--color-ink-900);
    font-size: clamp(1.75rem, 2.4vw, 2.35rem);
    line-height: 1.05;
    letter-spacing: -0.022em;
    font-weight: 500;
    font-family: var(--font-display);
  }
  .svc-contra-lede {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-ink-700);
    text-align: left;
    max-width: 36ch;
  }
  .svc-contra-lede strong { color: var(--color-ink-900); font-weight: 600; }
  .svc-contra-cta {
    margin-top: 0.5rem;
  }
  .svc-contra-cta a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1rem;
    background: white;
    color: #c62b3e;
    border: 1px solid rgba(198, 43, 62, 0.32);
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: all 0.25s ease !important;
  }
  .svc-contra-cta a:hover {
    background: #c62b3e;
    color: white;
    border-color: #c62b3e;
    transform: translateY(-1px);
  }
  .svc-contra-list {
    list-style: none;
    padding: clamp(1.25rem, 2vw, 1.85rem);
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    background: white;
  }
  .svc-contra-list li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.9rem;
    align-items: baseline;
    padding: 0.85rem 0;
    border-bottom: 1px dashed rgba(198, 43, 62, 0.2);
  }
  .svc-contra-list li:last-child { border-bottom: 0; padding-bottom: 0; }
  .svc-contra-list li:first-child { padding-top: 0; }
  .svc-contra-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1.05rem;
    color: #c62b3e;
    opacity: 0.85;
    letter-spacing: 0.04em;
    line-height: 1.2;
    min-width: 1.5rem;
  }
  .svc-contra-text {
    font-size: 0.94rem;
    line-height: 1.55;
    color: var(--color-ink-700);
  }

  /* ===== Sidebar — widgets modulares (flow con body, no sticky para permitir múltiples widgets) ===== */
  .svc-side {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    min-width: 0;
  }

  /* Widget base */
  .svc-widget {
    background: white;
    border: 1px solid rgba(201, 169, 97, 0.26);
    border-radius: 1.1rem;
    padding: clamp(1.25rem, 1.6vw, 1.6rem);
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    box-shadow: 0 1px 2px rgba(31, 20, 24, 0.03), 0 12px 32px -22px rgba(31, 20, 24, 0.12);
  }

  /* Widget — main (ficha clínica) */
  .svc-widget--main {
    background: linear-gradient(180deg, #FFFFFF 0%, var(--color-brand-50) 100%);
    border-color: rgba(201, 169, 97, 0.36);
    padding: clamp(1.5rem, 2vw, 1.85rem);
    gap: 1.1rem;
    box-shadow: 0 1px 2px rgba(31, 20, 24, 0.03), 0 24px 56px -28px rgba(31, 20, 24, 0.18);
  }
  .svc-widget-icon {
    font-size: clamp(2.25rem, 3.5vw, 2.85rem);
    line-height: 1;
    text-align: center;
    margin-bottom: 0;
  }
  .svc-widget-kicker {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mauve-500);
    text-align: center;
  }
  .svc-widget-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.2rem, 1.5vw, 1.45rem);
    line-height: 1.18;
    color: var(--color-ink-900);
    margin: 0;
    text-align: center;
    letter-spacing: -0.015em;
  }
  .svc-widget-meta {
    margin: 0;
    padding-block: 0.85rem;
    border-block: 1px dashed rgba(201, 169, 97, 0.35);
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .svc-widget-meta > div {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.85rem;
  }
  .svc-widget-meta dt {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-brand-500);
  }
  .svc-widget-meta dd {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.9rem;
    color: var(--color-ink-900);
    margin: 0;
    text-align: right;
    letter-spacing: -0.005em;
    max-width: 60%;
    line-height: 1.3;
  }
  .svc-widget-actions { display: flex; flex-direction: column; gap: 0.55rem; }
  .svc-widget-cta { width: 100%; justify-content: center; }
  .svc-widget-wa {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.65rem 1rem;
    background: rgba(37, 211, 102, 0.08);
    color: #1B7A3F;
    border: 1px solid rgba(37, 211, 102, 0.3);
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.25s ease !important;
  }
  .svc-widget-wa:hover { background: #25D366; color: white; border-color: #25D366; }
  .svc-widget-foot {
    margin: 0;
    text-align: center;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-500);
    opacity: 0.85;
  }

  /* Widget tag (label arriba del título) */
  .svc-widget-tag {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    background: rgba(232, 213, 196, 0.45);
    color: var(--color-mauve-700);
    border: 1px solid rgba(201, 169, 97, 0.32);
  }
  .svc-widget-tag--gold {
    background: rgba(201, 169, 97, 0.18);
    color: var(--color-brand-600);
    border-color: rgba(201, 169, 97, 0.45);
  }
  .svc-widget-tag--dark {
    background: var(--color-ink-900);
    color: var(--color-brand-400);
    border-color: var(--color-ink-900);
  }
  .svc-widget-h {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.15rem, 1.4vw, 1.35rem);
    line-height: 1.2;
    color: var(--color-ink-900);
    margin: 0;
    letter-spacing: -0.015em;
  }
  .svc-widget-h em { font-style: italic; color: var(--color-mauve-500); font-weight: 400; }
  .svc-widget-h--dark { color: white; }
  .svc-widget-h--dark em { color: var(--color-brand-400); }
  .svc-widget-p {
    font-size: 0.86rem;
    line-height: 1.6;
    color: var(--color-ink-700);
    margin: 0;
  }
  .svc-widget-p strong { color: var(--color-ink-900); font-weight: 600; }
  .svc-widget-link {
    align-self: flex-start;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-mauve-500);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
    transition: color 0.25s ease !important;
  }
  .svc-widget-link:hover { color: var(--color-mauve-700); }
  .svc-widget-link--gold { color: var(--color-brand-500); }
  .svc-widget-link--gold:hover { color: var(--color-brand-600); }
  .svc-widget-link-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem 1.25rem;
    padding-top: 0.75rem;
    border-top: 1px dashed rgba(201, 169, 97, 0.3);
  }

  /* Widget — checks (incluido en cada sesión) */
  .svc-widget-checks {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .svc-widget-checks li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.86rem;
    line-height: 1.45;
    color: var(--color-ink-700);
  }
  .svc-widget-checks svg {
    flex-shrink: 0;
    margin-top: 4px;
    color: var(--color-brand-500);
    background: rgba(201, 169, 97, 0.18);
    border-radius: 999px;
    padding: 2px;
    width: 18px;
    height: 18px;
  }

  /* Widget — trust list */
  .svc-widget-trust-list {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .svc-widget-trust-list > div {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: 0.85rem;
    align-items: baseline;
    padding-block: 0.55rem;
    border-bottom: 1px dashed rgba(201, 169, 97, 0.28);
  }
  .svc-widget-trust-list > div:last-child { border-bottom: 0; padding-bottom: 0; }
  .svc-widget-trust-list dt {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-brand-500);
  }
  .svc-widget-trust-list dd {
    margin: 0;
    font-size: 0.84rem;
    line-height: 1.45;
    color: var(--color-ink-700);
  }

  /* Widget — related (siblings) */
  .svc-widget-related {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .svc-widget-related li { border-top: 1px dashed rgba(201, 169, 97, 0.28); }
  .svc-widget-related li:first-child { border-top: 0; }
  .svc-widget-related a {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.85rem;
    align-items: center;
    padding: 0.85rem 0;
    text-decoration: none;
    color: var(--color-ink-700);
    transition: color 0.25s ease !important;
  }
  .svc-widget-related a:hover { color: var(--color-ink-900); }
  .svc-widget-related a:hover .svc-widget-related-name { color: var(--color-mauve-500); }
  .svc-widget-related a:hover svg { transform: translateX(3px); color: var(--color-mauve-500); }
  .svc-widget-related-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 0.95rem;
    color: var(--color-brand-500);
    letter-spacing: 0.03em;
    opacity: 0.85;
    line-height: 1;
  }
  .svc-widget-related-body {
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
    min-width: 0;
  }
  .svc-widget-related-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--color-ink-900);
    line-height: 1.2;
    letter-spacing: -0.01em;
    transition: color 0.25s ease !important;
  }
  .svc-widget-related-desc {
    font-size: 0.74rem;
    line-height: 1.4;
    color: var(--color-ink-500);
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .svc-widget-related svg {
    color: var(--color-brand-500);
    transition: transform 0.25s ease, color 0.25s ease !important;
    flex-shrink: 0;
  }

  /* Widget — cross categories */
  .svc-widget--cross {
    background: linear-gradient(180deg, var(--color-brand-50) 0%, white 100%);
  }
  .svc-widget-cats {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .svc-widget-cats li { border-top: 1px dashed rgba(201, 169, 97, 0.3); }
  .svc-widget-cats li:first-child { border-top: 0; }
  .svc-widget-cats a {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.85rem;
    align-items: center;
    padding: 0.85rem 0;
    text-decoration: none;
  }
  .svc-widget-cats a:hover .svc-widget-cats-name { color: var(--color-mauve-500); }
  .svc-widget-cats a:hover .svc-widget-cats-arrow {
    color: var(--color-mauve-500);
    transform: translateX(3px);
  }
  .svc-widget-cats-arrow {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--color-brand-500);
    transition: transform 0.25s ease, color 0.25s ease !important;
    line-height: 1;
  }
  .svc-widget-cats-body {
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
    min-width: 0;
  }
  .svc-widget-cats-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--color-ink-900);
    line-height: 1.2;
    letter-spacing: -0.01em;
    transition: color 0.25s ease !important;
  }
  .svc-widget-cats-desc {
    font-size: 0.74rem;
    line-height: 1.4;
    color: var(--color-ink-500);
  }

  /* Widget — contact (dark) */
  .svc-widget--contact {
    background: var(--color-ink-900);
    border-color: var(--color-ink-900);
    color: var(--color-brand-100);
  }
  .svc-widget-contact-list {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .svc-widget-contact-list > div {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: 0.85rem;
    align-items: baseline;
    padding-block: 0.7rem;
    border-bottom: 1px dashed rgba(201, 169, 97, 0.22);
  }
  .svc-widget-contact-list > div:last-child { border-bottom: 0; padding-bottom: 0; }
  .svc-widget-contact-list dt {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-brand-400);
  }
  .svc-widget-contact-list dd {
    margin: 0;
    font-size: 0.84rem;
    line-height: 1.4;
    color: rgba(242, 235, 223, 0.88);
  }
  .svc-widget-contact-list dd a {
    color: white;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(201, 169, 97, 0.55);
  }
  .svc-widget-contact-list dd a:hover {
    color: var(--color-brand-400);
  }

  /* ============= Section heads (reusable) ============= */
  .svc-section-head {
    max-width: 720px;
    margin: 0 auto clamp(2.5rem, 4vw, 3.25rem);
    text-align: center;
  }
  .svc-section-head .kicker-line {
    justify-content: center;
  }
  .svc-section-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.9rem, 3.5vw, 3.25rem);
    line-height: 1.08;
    letter-spacing: -0.025em;
    color: var(--color-ink-900);
    margin: 1rem 0;
  }
  .svc-section-title em {
    font-style: italic;
    color: var(--color-mauve-500);
    font-weight: 400;
  }
  .svc-section-lede {
    font-size: clamp(0.95rem, 1vw, 1.05rem);
    line-height: 1.7;
    color: var(--color-ink-700);
    margin: 0;
  }
  .svc-section-lede strong { color: var(--color-ink-900); font-weight: 600; }
  .svc-section-head--dark .svc-section-title { color: white; }
  .svc-section-head--dark .svc-section-title em { color: var(--color-brand-400); }
  .svc-section-head--dark .svc-section-lede { color: rgba(242, 235, 223, 0.82); }
  .svc-section-head--dark .svc-section-lede strong { color: white; }
  .svc-section-head--dark .kicker-line { color: var(--color-brand-400); }
  .svc-section-head--dark .kicker-line::before { background: linear-gradient(90deg, var(--color-brand-400), white); }

  /* ============= Protocol Steps section ============= */
  .svc-protocol-section {
    background: var(--color-ink-900);
    color: var(--color-brand-100);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }
  .svc-protocol-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(60% 50% at 80% 0%, rgba(201,169,97,0.08), transparent 60%),
      radial-gradient(50% 50% at 0% 100%, rgba(139,90,107,0.1), transparent 60%);
    pointer-events: none;
    z-index: 0;
  }
  .svc-protocol-section .svc-section-head {
    text-align: center;
  }
  .svc-protocol-section .svc-section-title { color: white; }
  .svc-protocol-section .svc-section-title em { color: var(--color-brand-400); }
  .svc-protocol-section .svc-section-lede { color: rgba(242, 235, 223, 0.82); }
  .svc-protocol-section .svc-section-lede strong { color: white; }
  .svc-protocol-section .kicker-line { color: var(--color-brand-400); }
  .svc-protocol-section .kicker-line::before { background: linear-gradient(90deg, var(--color-brand-400), white); }

  /* ============= Protocolo — stat strip ============= */
  .psteps-meta {
    margin: 0 0 clamp(2rem, 3vw, 2.5rem);
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border-block: 1px solid rgba(201, 169, 97, 0.22);
  }
  @media (min-width: 720px) { .psteps-meta { grid-template-columns: repeat(4, 1fr); } }
  .psteps-meta > div {
    padding: 1rem 1.15rem;
    border-right: 1px solid rgba(201, 169, 97, 0.18);
    border-bottom: 1px solid rgba(201, 169, 97, 0.18);
  }
  .psteps-meta > div:first-child { padding-left: 0; }
  @media (min-width: 720px) {
    .psteps-meta > div { border-bottom: 0; }
    .psteps-meta > div:last-child { border-right: 0; }
  }
  @media (max-width: 719px) {
    .psteps-meta > div:nth-child(2n) { border-right: 0; }
    .psteps-meta > div:nth-last-child(-n+2) { border-bottom: 0; }
  }
  .psteps-meta dt {
    font-family: var(--font-sans);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-brand-400);
    margin-bottom: 0.35rem;
  }
  .psteps-meta dd {
    margin: 0;
    font-family: var(--font-display);
    line-height: 1;
    color: white;
    letter-spacing: -0.02em;
  }
  .psteps-meta dd em {
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.85rem, 3vw, 2.65rem);
    background: linear-gradient(180deg, var(--color-brand-400), var(--color-mauve-300));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .psteps-meta .psteps-meta-text {
    font-style: italic;
    font-weight: 400;
    font-size: clamp(0.9rem, 1vw, 1.05rem);
    line-height: 1.25;
    letter-spacing: -0.005em;
  }

  /* ============= Protocolo — grid de cards densas ============= */
  .psteps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
  }
  @media (min-width: 720px) { .psteps { grid-template-columns: 1fr 1fr; gap: 1rem; } }
  @media (min-width: 1280px) { .psteps { grid-template-columns: repeat(3, 1fr); gap: 1.15rem; } }
  .pstep {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: 1.5rem 1.5rem 1.4rem;
    background: linear-gradient(180deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.015) 100%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.1rem;
    align-items: flex-start;
    transition: all 0.35s cubic-bezier(.2,.8,.2,1) !important;
    overflow: hidden;
  }
  .pstep::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 2px;
    background: linear-gradient(90deg, var(--color-brand-400), var(--color-mauve-300));
    opacity: 0;
    transition: opacity 0.3s ease !important;
  }
  .pstep:hover {
    background: linear-gradient(180deg, rgba(255,255,255,0.07) 0%, rgba(255,255,255,0.025) 100%);
    border-color: rgba(201, 169, 97, 0.42);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -20px rgba(0, 0, 0, 0.5);
  }
  .pstep:hover::before { opacity: 1; }
  .pstep-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2.5rem, 3.8vw, 3.4rem);
    line-height: 0.85;
    background: linear-gradient(180deg, var(--color-brand-400), var(--color-mauve-300));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.015em;
    margin-bottom: 0.2rem;
  }
  .pstep-body { display: flex; flex-direction: column; gap: 0.55rem; max-width: none; width: 100%; }
  .pstep-kicker {
    font-family: var(--font-sans);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-brand-400);
  }
  .pstep-of {
    color: rgba(201, 169, 97, 0.5);
    letter-spacing: 0.18em;
  }
  .pstep-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.15rem, 1.45vw, 1.4rem);
    color: white;
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.015em;
  }
  .pstep-text {
    font-size: clamp(0.88rem, 0.95vw, 0.98rem);
    line-height: 1.65;
    color: rgba(242, 235, 223, 0.78);
    margin: 0;
  }
  .pstep-arrow {
    display: none;
  }
  /* Flecha entre cards solo en desktop entre filas */
  @media (min-width: 1280px) {
    .pstep-arrow {
      display: grid;
      place-items: center;
      position: absolute;
      right: -0.85rem;
      top: 50%;
      transform: translateY(-50%);
      width: 28px;
      height: 28px;
      border-radius: 999px;
      background: var(--color-ink-900);
      border: 1px solid rgba(201, 169, 97, 0.42);
      color: var(--color-brand-400);
      z-index: 2;
    }
    /* Ocultar flecha en última columna de cada fila (3-col) */
    .psteps .pstep:nth-child(3n) .pstep-arrow { display: none; }
  }

  /* ============= Protocolo — footer (trust + CTA) ============= */
  .psteps-foot {
    margin-top: clamp(2.5rem, 4vw, 3.5rem);
    padding-top: clamp(1.75rem, 2.5vw, 2.25rem);
    border-top: 1px solid rgba(201, 169, 97, 0.22);
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: center;
  }
  @media (min-width: 900px) {
    .psteps-foot { grid-template-columns: 1.4fr auto; gap: clamp(2rem, 3vw, 3rem); }
  }
  .psteps-foot-text {
    font-size: clamp(0.92rem, 1vw, 1.05rem);
    line-height: 1.7;
    color: rgba(242, 235, 223, 0.78);
    margin: 0;
    max-width: 64ch;
  }
  .psteps-foot-text strong { color: white; font-weight: 600; }
  .psteps-foot-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    align-items: center;
  }
  .psteps-foot-wa {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.1rem;
    background: rgba(37, 211, 102, 0.12);
    color: #6ce99c;
    border: 1px solid rgba(37, 211, 102, 0.35);
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 0.84rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.25s ease !important;
  }
  .psteps-foot-wa:hover {
    background: #25D366;
    color: white;
    border-color: #25D366;
  }

  /* ============= Timeline — stat strip ============= */
  .tl-meta {
    margin: 0 0 clamp(2rem, 3vw, 2.5rem);
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border-block: 1px solid rgba(201, 169, 97, 0.3);
  }
  @media (min-width: 720px) { .tl-meta { grid-template-columns: repeat(4, 1fr); } }
  .tl-meta > div {
    padding: 1rem 1.15rem;
    border-right: 1px solid rgba(201, 169, 97, 0.22);
    border-bottom: 1px solid rgba(201, 169, 97, 0.22);
  }
  .tl-meta > div:first-child { padding-left: 0; }
  @media (min-width: 720px) {
    .tl-meta > div { border-bottom: 0; }
    .tl-meta > div:last-child { border-right: 0; }
  }
  @media (max-width: 719px) {
    .tl-meta > div:nth-child(2n) { border-right: 0; }
    .tl-meta > div:nth-last-child(-n+2) { border-bottom: 0; }
  }
  .tl-meta dt {
    font-family: var(--font-sans);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mauve-500);
    margin-bottom: 0.35rem;
  }
  .tl-meta dd {
    margin: 0;
    font-family: var(--font-display);
    line-height: 1;
    color: var(--color-ink-900);
    letter-spacing: -0.02em;
  }
  .tl-meta dd em {
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.85rem, 3vw, 2.65rem);
    background: linear-gradient(180deg, var(--color-brand-500), var(--color-mauve-500));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .tl-meta .tl-meta-text {
    font-style: italic;
    font-weight: 400;
    font-size: clamp(0.9rem, 1vw, 1.05rem);
    line-height: 1.25;
    letter-spacing: -0.005em;
  }

  /* ============= Timeline — stepper horizontal con dots conectados ============= */
  .tl-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    counter-reset: tlc;
  }
  @media (min-width: 720px) {
    .tl-list { grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
  }
  @media (min-width: 1100px) {
    .tl-list {
      grid-template-columns: repeat(var(--tl-count, 4), 1fr);
      gap: 0;
    }
  }
  .tl-step {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem;
    background: linear-gradient(180deg, white 0%, var(--color-brand-50) 100%);
    border: 1px solid rgba(201, 169, 97, 0.3);
    border-radius: 1.1rem;
    transition: all 0.35s cubic-bezier(.2,.8,.2,1) !important;
    overflow: visible;
  }
  @media (min-width: 1100px) {
    .tl-step {
      border-radius: 0;
      border-right: 0;
      background: transparent;
      padding: 2rem 1.5rem 0;
    }
    .tl-step:first-child { border-left: 0; padding-left: 0; }
    .tl-step:last-child { border-right: 0; padding-right: 0; }
  }
  .tl-step:hover {
    transform: translateY(-3px);
    border-color: var(--color-mauve-500);
    box-shadow: 0 16px 36px -18px rgba(31, 20, 24, 0.18);
  }
  @media (min-width: 1100px) {
    .tl-step:hover {
      transform: none;
      box-shadow: none;
      border-color: rgba(201, 169, 97, 0.3);
      background: var(--color-brand-50);
    }
    .tl-step:hover .tl-step-dot {
      transform: scale(1.18);
      box-shadow: 0 0 0 5px rgba(201, 169, 97, 0.3), 0 0 0 10px rgba(201, 169, 97, 0.12);
    }
  }

  /* Track con dot + líneas conectoras (sólo desktop horizontal) */
  .tl-step-track {
    display: none;
  }
  @media (min-width: 1100px) {
    .tl-step-track {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 0.25rem;
    }
    .tl-step-line {
      height: 1.5px;
      background: linear-gradient(90deg, transparent, rgba(201, 169, 97, 0.5), rgba(201, 169, 97, 0.5));
    }
    .tl-step-line--after { background: linear-gradient(90deg, rgba(201, 169, 97, 0.5), rgba(201, 169, 97, 0.5), transparent); }
    .tl-step:first-child .tl-step-line--before { visibility: hidden; }
    .tl-step:last-child .tl-step-line--after { visibility: hidden; }
    .tl-step-dot {
      width: 14px;
      height: 14px;
      border-radius: 999px;
      background: var(--color-brand-400);
      box-shadow: 0 0 0 4px rgba(201, 169, 97, 0.2), 0 0 0 8px rgba(201, 169, 97, 0.08);
      transition: transform 0.3s ease, box-shadow 0.3s ease !important;
      justify-self: center;
    }
  }

  .tl-step-body {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    max-width: none;
  }
  .tl-step-kicker {
    font-family: var(--font-sans);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-mauve-500);
  }
  .tl-step-of {
    color: rgba(139, 90, 107, 0.5);
    letter-spacing: 0.18em;
  }
  .tl-step-when {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.5rem, 2.2vw, 2rem);
    line-height: 1;
    letter-spacing: -0.018em;
    background: linear-gradient(180deg, var(--color-brand-500), var(--color-mauve-500));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .tl-step-label {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.1rem, 1.4vw, 1.3rem);
    color: var(--color-ink-900);
    margin: 0;
    line-height: 1.22;
    letter-spacing: -0.015em;
  }
  .tl-step-text {
    font-size: clamp(0.88rem, 0.95vw, 0.97rem);
    line-height: 1.65;
    color: var(--color-ink-700);
    margin: 0;
  }

  /* ============= Protocols pre/post (dark) ============= */
  .svc-protocols {
    background: var(--color-ink-900);
    color: var(--color-brand-100);
    position: relative;
    isolation: isolate;
  }
  .protocol-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 900px) { .protocol-grid { grid-template-columns: 1fr 1fr; gap: 1.75rem; } }
  .protocol {
    padding: clamp(1.5rem, 2vw, 2rem);
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1.25rem;
    transition: all 0.4s ease !important;
  }
  .protocol:hover {
    background: rgba(255,255,255,0.055);
    border-color: rgba(201, 169, 97, 0.45);
    transform: translateY(-4px);
  }
  .protocol-head { display: flex; align-items: baseline; gap: 0.9rem; margin-bottom: 1.25rem; }
  .protocol-tag {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
  }
  .protocol-tag--pre {
    background: rgba(201, 169, 97, 0.15);
    color: var(--color-brand-400);
    border: 1px solid rgba(201, 169, 97, 0.4);
  }
  .protocol-tag--post {
    background: rgba(139, 90, 107, 0.2);
    color: var(--color-mauve-300);
    border: 1px solid rgba(188, 142, 156, 0.45);
  }
  .protocol-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.4rem, 1.8vw, 1.75rem);
    color: white;
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.015em;
  }
  .protocol-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .protocol-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding-block: 0.65rem;
    border-top: 1px dashed rgba(201, 169, 97, 0.18);
    font-size: 0.92rem;
    line-height: 1.5;
    color: rgba(242, 235, 223, 0.85);
  }
  .protocol-list li:first-child { border-top: 0; padding-top: 0; }
  .protocol-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 0.95rem;
    color: var(--color-brand-400);
    line-height: 1.45;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    min-width: 24px;
  }

  /* ============= FAQ + Form ============= */
  .faq-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 3vw, 2.75rem);
    align-items: start;
  }
  @media (min-width: 1024px) {
    .faq-grid { grid-template-columns: 1.15fr 0.85fr; gap: clamp(2.5rem, 4vw, 3.5rem); }
  }
  .faq-col-label {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-brand-500);
    margin-bottom: 1.1rem;
  }
  .faq-list { display: flex; flex-direction: column; gap: 0.6rem; }
  .faq {
    background: white;
    border: 1px solid rgba(201, 169, 97, 0.22);
    border-radius: 1rem;
    overflow: hidden;
    transition: border-color 0.3s ease, background 0.3s ease !important;
  }
  .faq[open] { border-color: var(--color-mauve-500); }
  .faq-sum {
    list-style: none;
    cursor: pointer;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1rem;
    align-items: center;
    padding: 1.1rem 1.25rem;
  }
  .faq-sum::-webkit-details-marker { display: none; }
  .faq-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1rem;
    color: var(--color-brand-500);
    letter-spacing: 0.04em;
    line-height: 1;
    opacity: 0.8;
    min-width: 24px;
  }
  .faq-q {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1rem, 1.1vw, 1.12rem);
    color: var(--color-ink-900);
    line-height: 1.3;
    letter-spacing: -0.005em;
  }
  .faq-plus {
    width: 32px; height: 32px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: var(--color-brand-100);
    color: var(--color-mauve-500);
    transition: transform 0.35s cubic-bezier(.2,.8,.2,1), background 0.3s ease, color 0.3s ease !important;
  }
  .faq[open] .faq-plus {
    transform: rotate(45deg);
    background: var(--color-mauve-500);
    color: white;
  }
  .faq-a {
    padding: 0 1.25rem 1.25rem clamp(3.5rem, 6vw, 4rem);
    font-size: 0.92rem;
    line-height: 1.65;
    color: var(--color-ink-700);
  }

  .faq-form-wrap { position: relative; }
  @media (min-width: 1024px) { .faq-form-wrap { position: sticky; top: clamp(6rem, 10vh, 7.5rem); } }
  .faq-form {
    background: linear-gradient(180deg, #FFFFFF 0%, var(--color-brand-100) 100%);
    border: 1px solid rgba(201, 169, 97, 0.3);
    border-radius: 1.25rem;
    padding: clamp(1.5rem, 2vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 0.95rem;
    box-shadow:
      0 1px 2px rgba(31, 20, 24, 0.03),
      0 24px 56px -28px rgba(31, 20, 24, 0.18);
  }
  .faq-form-kicker {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mauve-500);
  }
  .faq-form-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.45rem, 2vw, 1.85rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-ink-900);
    margin: 0;
  }
  .faq-form-title em { font-style: italic; color: var(--color-mauve-500); font-weight: 400; }
  .faq-form-sub {
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--color-ink-500);
    margin: 0 0 0.5rem;
  }
  .faq-form-sub strong { color: var(--color-ink-900); font-weight: 600; }
  .faq-form-row { display: flex; flex-direction: column; gap: 0.32rem; }
  .faq-form-grid-2 {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
  }
  @media (min-width: 520px) { .faq-form-grid-2 { grid-template-columns: 1fr 1fr; } }
  .faq-form-row label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-ink-700);
    letter-spacing: 0.02em;
  }
  .faq-form-row label span[aria-hidden] { color: var(--color-mauve-500); margin-left: 2px; }
  .faq-form input,
  .faq-form select,
  .faq-form textarea {
    width: 100%;
    padding: 0.7rem 0.9rem;
    font-family: var(--font-sans);
    font-size: 0.92rem;
    color: var(--color-ink-900);
    background: white;
    border: 1px solid rgba(201, 169, 97, 0.35);
    border-radius: 0.65rem;
    outline: none;
    transition: border-color 0.25s ease, box-shadow 0.25s ease, background 0.25s ease !important;
    appearance: none;
    line-height: 1.4;
  }
  .faq-form textarea { resize: vertical; min-height: 80px; }
  .faq-form input:focus,
  .faq-form select:focus,
  .faq-form textarea:focus {
    border-color: var(--color-mauve-500);
    box-shadow: 0 0 0 3px rgba(139, 90, 107, 0.12);
    background: var(--color-brand-50);
  }
  .faq-form.is-invalid input:required:invalid { border-color: #c62b3e; }
  .faq-form-check {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    margin-top: 0.25rem;
    font-size: 0.78rem;
    line-height: 1.45;
    color: var(--color-ink-500);
    cursor: pointer;
  }
  .faq-form-check input[type="checkbox"] {
    width: 16px;
    height: 16px;
    margin-top: 2px;
    accent-color: var(--color-mauve-500);
    flex-shrink: 0;
    cursor: pointer;
  }
  .faq-form-check a { color: var(--color-mauve-500); text-decoration: underline; text-underline-offset: 2px; }
  .faq-form-check a:hover { color: var(--color-mauve-700); }
  .faq-form-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    padding: 0.95rem 1.25rem;
    margin-top: 0.5rem;
    background: #25D366;
    color: white;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.01em;
    border: 0;
    border-radius: 999px;
    cursor: pointer;
    box-shadow:
      0 10px 24px -10px rgba(37, 211, 102, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.25);
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease !important;
  }
  .faq-form-submit:hover {
    background: #1FB855;
    transform: translateY(-2px);
    box-shadow:
      0 16px 32px -10px rgba(37, 211, 102, 0.7),
      inset 0 1px 0 rgba(255, 255, 255, 0.3);
  }
  .faq-form-foot {
    margin: 0;
    text-align: center;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-500);
    opacity: 0.85;
  }
  @media (max-width: 640px) { .faq-form { padding: 1.25rem; } }

  /* ============= TOC sticky compacto (índice editorial · single-line scroll) ============= */
  .svc-toc {
    position: sticky;
    top: 76px; /* debajo del header sticky */
    z-index: 30;
    background: rgba(250, 247, 242, 0.96);
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    border-block: 1px solid rgba(201, 169, 97, 0.22);
  }
  @media (max-width: 900px) {
    .svc-toc { top: 64px; }
  }
  .svc-toc.is-stuck {
    box-shadow: 0 6px 18px -14px rgba(31, 20, 24, 0.2);
    border-bottom-color: rgba(201, 169, 97, 0.38);
  }
  .svc-toc-inner {
    display: flex;
    align-items: center;
    gap: clamp(0.6rem, 1.2vw, 1rem);
    padding-block: 0.4rem;
    min-height: 38px;
    flex-wrap: nowrap;
  }
  .svc-toc-label {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-sans);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-mauve-500);
    white-space: nowrap;
    padding-right: 0.85rem;
    border-right: 1px solid rgba(201, 169, 97, 0.32);
    flex-shrink: 0;
  }
  .svc-toc-label em {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 0.85rem;
    color: var(--color-brand-500);
    letter-spacing: 0;
    text-transform: none;
  }
  .svc-toc-label-line {
    width: 16px;
    height: 1.5px;
    background: linear-gradient(90deg, var(--color-brand-400), var(--color-mauve-500));
  }
  .svc-toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    align-items: center;
    gap: clamp(0.55rem, 1vw, 1rem);
    flex-wrap: nowrap;
    flex: 1 1 auto;
    overflow-x: auto;
    scrollbar-width: none;
    min-width: 0;
    /* Fade laterales para indicar scroll */
    mask-image: linear-gradient(90deg, transparent 0, #000 12px, #000 calc(100% - 24px), transparent 100%);
    -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 12px, #000 calc(100% - 24px), transparent 100%);
  }
  .svc-toc-list::-webkit-scrollbar { display: none; }
  .svc-toc-link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
    padding: 0.22rem 0;
    color: var(--color-ink-500);
    font-size: 0.74rem;
    line-height: 1.2;
    letter-spacing: 0.005em;
    text-decoration: none;
    white-space: nowrap;
    border-bottom: 1.5px solid transparent;
    transition: color 0.25s ease, border-color 0.25s ease !important;
  }
  .svc-toc-link:hover {
    color: var(--color-ink-900);
    border-bottom-color: var(--color-brand-400);
  }
  .svc-toc-link.is-active {
    color: var(--color-ink-900);
    border-bottom-color: var(--color-mauve-500);
  }
  .svc-toc-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 0.82rem;
    color: var(--color-brand-500);
    letter-spacing: 0.02em;
    line-height: 1;
    opacity: 0.85;
  }
  .svc-toc-link.is-active .svc-toc-num { color: var(--color-mauve-500); opacity: 1; }
  .svc-toc-text {
    font-family: var(--font-sans);
    font-weight: 500;
  }
  .svc-toc-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.32rem;
    padding: 0.38rem 0.85rem;
    border-radius: 999px;
    background: var(--color-ink-900);
    color: var(--color-brand-50);
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    white-space: nowrap;
    text-decoration: none;
    transition: background 0.25s ease, transform 0.25s ease !important;
    flex-shrink: 0;
  }
  .svc-toc-cta:hover {
    background: var(--color-mauve-700);
    transform: translateY(-1px);
  }
  /* Tablet: ocultar texto descriptivo, mantener solo num + marker */
  @media (max-width: 1100px) {
    .svc-toc-text { display: none; }
    .svc-toc-link { gap: 0; padding: 0.2rem 0.18rem; }
    .svc-toc-num { font-size: 0.95rem; }
  }
  /* Mobile: aún más compacto */
  @media (max-width: 900px) {
    .svc-toc-label { display: none; }
    .svc-toc-cta { display: none; }
    .svc-toc-inner { padding-block: 0.35rem; min-height: 34px; gap: 0.5rem; }
    .svc-toc-list { gap: 0.6rem; }
    .svc-toc-num { font-size: 0.9rem; }
  }

  /* ============= Chapter marks (numeración editorial encima de cada sección) ============= */
  .svc-chapter-mark,
  .svc-chapter {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    margin-bottom: clamp(1.25rem, 2vw, 2rem);
  }
  .svc-chapter { margin-top: clamp(2.5rem, 4vw, 3.5rem); }
  .svc-chapter-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.4rem, 1.8vw, 1.65rem);
    line-height: 1;
    color: var(--color-brand-500);
    letter-spacing: 0.03em;
    min-width: 2.25rem;
  }
  .svc-chapter-num em {
    font-style: italic;
    background: linear-gradient(180deg, var(--color-brand-500), var(--color-mauve-500));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .svc-chapter-line {
    flex: 0 0 56px;
    height: 1.5px;
    background: linear-gradient(90deg, var(--color-brand-400) 0%, transparent 100%);
  }
  .svc-chapter-kicker {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-mauve-500);
  }
  .svc-chapter-mark--dark .svc-chapter-num em {
    background: linear-gradient(180deg, var(--color-brand-400), var(--color-mauve-300));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .svc-chapter-mark--dark .svc-chapter-line {
    background: linear-gradient(90deg, var(--color-brand-400) 0%, transparent 100%);
  }
  .svc-chapter-mark--dark .svc-chapter-kicker {
    color: var(--color-brand-400);
  }
  .svc-chapter-mark--inline {
    margin-top: 0;
    margin-bottom: clamp(1rem, 1.5vw, 1.5rem);
  }
  .svc-chapter-mark--inline + :global(h2) {
    margin-top: 0 !important;
  }

  /* Refinamiento espaciado sections (más editorial) */
  .svc-protocol-section {
    padding-block: clamp(4rem, 6vw, 6.5rem);
  }
  .svc-protocols {
    padding-block: clamp(5rem, 8vw, 8.5rem);
  }
  #resultados.section {
    padding-block: clamp(4rem, 6vw, 6.5rem);
  }

  /* Scroll offset para anchor links (header 76px + TOC compacto ~38px) */
  #resumen, #beneficios, #casos, #mitos, #compromisos, #seguridad, #zonas, #modalidades, #comparativa, #protocolo, #resultados, #cuidados, #preguntas {
    scroll-margin-top: 124px;
  }
  @media (max-width: 900px) {
    #resumen, #beneficios, #casos, #mitos, #compromisos, #seguridad, #zonas, #modalidades, #comparativa, #protocolo, #resultados, #cuidados, #preguntas {
      scroll-margin-top: 104px;
    }
  }

  /* ============= Protocolo de seguridad clínica (sección dark · invasivos) ============= */
  .svc-safety {
    background: var(--color-ink-900);
    color: var(--color-brand-100);
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding-block: clamp(4rem, 6vw, 6.5rem);
  }
  .svc-safety-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(60% 50% at 80% 0%, rgba(198,43,62,0.06), transparent 60%),
      radial-gradient(50% 50% at 0% 100%, rgba(201,169,97,0.10), transparent 60%);
    pointer-events: none;
    z-index: 0;
  }
  .svc-safety-grid {
    list-style: none;
    padding: 0;
    margin: clamp(1.5rem, 2.5vw, 2.25rem) 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 720px) { .svc-safety-grid { grid-template-columns: repeat(2, 1fr); gap: 1.15rem; } }
  @media (min-width: 1100px) { .svc-safety-grid { grid-template-columns: repeat(4, 1fr); } }
  .svc-safety-item {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1.5rem;
    background: linear-gradient(180deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.015) 100%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    transition: all 0.35s cubic-bezier(.2,.8,.2,1) !important;
    overflow: hidden;
  }
  .svc-safety-item::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 2px;
    background: linear-gradient(90deg, var(--color-brand-400), var(--color-mauve-300));
    opacity: 0;
    transition: opacity 0.3s ease !important;
  }
  .svc-safety-item:hover {
    background: linear-gradient(180deg, rgba(255,255,255,0.07) 0%, rgba(255,255,255,0.025) 100%);
    border-color: rgba(201, 169, 97, 0.42);
    transform: translateY(-3px);
  }
  .svc-safety-item:hover::before { opacity: 1; }
  .svc-safety-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .svc-safety-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: 1.85rem;
    line-height: 0.85;
    background: linear-gradient(180deg, var(--color-brand-400), var(--color-mauve-300));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.015em;
  }
  .svc-safety-kind {
    display: inline-flex;
    align-items: center;
    padding: 0.32rem 0.75rem;
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 0.56rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .svc-safety-kind--producto {
    background: rgba(201, 169, 97, 0.15);
    color: var(--color-brand-400);
    border: 1px solid rgba(201, 169, 97, 0.4);
  }
  .svc-safety-kind--protocolo {
    background: rgba(139, 90, 107, 0.18);
    color: var(--color-mauve-300);
    border: 1px solid rgba(188, 142, 156, 0.45);
  }
  .svc-safety-kind--personal {
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-brand-200);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }
  .svc-safety-kind--reversibilidad {
    background: rgba(37, 134, 60, 0.15);
    color: #6ce99c;
    border: 1px solid rgba(37, 134, 60, 0.4);
  }
  .svc-safety-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.1rem, 1.4vw, 1.3rem);
    color: white;
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.015em;
  }
  .svc-safety-text {
    margin: 0;
    font-size: clamp(0.88rem, 0.95vw, 0.97rem);
    line-height: 1.6;
    color: rgba(242, 235, 223, 0.78);
  }

  /* ============= Compromisos del paciente (sección opcional · expectativa de adherencia) ============= */
  .svc-commit {
    background: linear-gradient(180deg, var(--color-brand-50) 0%, white 100%);
    padding-block: clamp(4rem, 6vw, 6.5rem);
  }
  .svc-commit-grid {
    list-style: none;
    padding: 0;
    margin: clamp(1.5rem, 2.5vw, 2.25rem) 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 700px) { .svc-commit-grid { grid-template-columns: repeat(2, 1fr); gap: 1.15rem; } }
  @media (min-width: 1100px) { .svc-commit-grid { grid-template-columns: repeat(3, 1fr); } }
  .svc-commit-item {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.4rem 1.4rem 1.45rem;
    background: white;
    border: 1px solid rgba(201, 169, 97, 0.3);
    border-radius: 1rem;
    transition: all 0.3s cubic-bezier(.2,.8,.2,1) !important;
    overflow: hidden;
  }
  .svc-commit-item--imprescindible {
    border-left: 4px solid #c62b3e;
  }
  .svc-commit-item--recomendado {
    border-left: 4px solid var(--color-brand-500);
  }
  .svc-commit-item--opcional {
    border-left: 4px solid rgba(139, 90, 107, 0.45);
  }
  .svc-commit-item:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 36px -18px rgba(31, 20, 24, 0.16);
  }
  .svc-commit-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .svc-commit-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: 1.65rem;
    line-height: 0.85;
    background: linear-gradient(180deg, var(--color-brand-500), var(--color-mauve-500));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.015em;
  }
  .svc-commit-weight {
    display: inline-flex;
    align-items: center;
    padding: 0.32rem 0.7rem;
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 0.56rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .svc-commit-weight--imprescindible {
    background: rgba(198, 43, 62, 0.1);
    color: #c62b3e;
    border: 1px solid rgba(198, 43, 62, 0.3);
  }
  .svc-commit-weight--recomendado {
    background: rgba(201, 169, 97, 0.14);
    color: var(--color-brand-600);
    border: 1px solid rgba(201, 169, 97, 0.32);
  }
  .svc-commit-weight--opcional {
    background: rgba(139, 90, 107, 0.1);
    color: var(--color-mauve-700);
    border: 1px solid rgba(139, 90, 107, 0.3);
  }
  .svc-commit-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.1rem, 1.4vw, 1.3rem);
    color: var(--color-ink-900);
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.015em;
  }
  .svc-commit-text {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--color-ink-700);
  }

  /* ============= Mitos vs Realidad (sección opcional · desmontar misinformación) ============= */
  .svc-myths {
    background: white;
    padding-block: clamp(4rem, 6vw, 6.5rem);
  }
  .svc-myths-grid {
    list-style: none;
    padding: 0;
    margin: clamp(1.5rem, 2.5vw, 2.25rem) 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.1rem;
  }
  @media (min-width: 900px) { .svc-myths-grid { grid-template-columns: repeat(2, 1fr); gap: 1.25rem; } }
  .svc-myth {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    background: white;
    border: 1px solid rgba(201, 169, 97, 0.3);
    border-radius: 1rem;
    overflow: hidden;
    transition: all 0.3s ease !important;
  }
  .svc-myth:hover {
    border-color: var(--color-mauve-500);
    transform: translateY(-3px);
    box-shadow: 0 18px 36px -18px rgba(31, 20, 24, 0.16);
  }
  .svc-myth-myth,
  .svc-myth-reality {
    padding: 1.4rem 1.4rem 1.45rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .svc-myth-myth {
    background: linear-gradient(180deg, rgba(198, 43, 62, 0.05) 0%, rgba(198, 43, 62, 0.02) 100%);
    border-bottom: 1px dashed rgba(201, 169, 97, 0.3);
  }
  .svc-myth-reality {
    background: linear-gradient(180deg, rgba(37, 134, 60, 0.05) 0%, rgba(37, 134, 60, 0.02) 100%);
  }
  .svc-myth-tag {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    gap: 0.45rem;
    padding: 0.42rem 0.85rem;
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .svc-myth-tag--myth {
    background: rgba(198, 43, 62, 0.1);
    color: #c62b3e;
    border: 1px solid rgba(198, 43, 62, 0.32);
  }
  .svc-myth-tag--reality {
    background: rgba(37, 134, 60, 0.1);
    color: #1b7a3f;
    border: 1px solid rgba(37, 134, 60, 0.32);
  }
  .svc-myth-tag svg { flex-shrink: 0; }
  .svc-myth-text {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-ink-800);
  }
  .svc-myth-myth .svc-myth-text {
    font-style: italic;
    color: var(--color-ink-700);
  }
  .svc-myth-reality .svc-myth-text {
    font-weight: 500;
  }

  /* ============= Zonas de tratamiento (sección opcional · áreas anatómicas) ============= */
  .svc-zones {
    background: linear-gradient(180deg, white 0%, var(--color-brand-50) 100%);
    padding-block: clamp(4rem, 6vw, 6.5rem);
  }
  .svc-zones-grid {
    list-style: none;
    padding: 0;
    margin: clamp(1.5rem, 2.5vw, 2.25rem) 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 700px) { .svc-zones-grid { grid-template-columns: repeat(2, 1fr); gap: 1.15rem; } }
  @media (min-width: 1024px) { .svc-zones-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1400px) {
    .svc-zones-grid[data-count="4"],
    .svc-zones-grid[data-count="8"] { grid-template-columns: repeat(4, 1fr); }
  }
  .svc-zone {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1.4rem 1.4rem 1.35rem;
    background: white;
    border: 1px solid rgba(201, 169, 97, 0.3);
    border-radius: 1rem;
    transition: all 0.3s cubic-bezier(.2,.8,.2,1) !important;
    overflow: hidden;
  }
  .svc-zone::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 3px;
    background: linear-gradient(90deg, var(--color-brand-400), var(--color-mauve-500));
  }
  .svc-zone--mauve::before { background: linear-gradient(90deg, var(--color-mauve-500), var(--color-mauve-700)); }
  .svc-zone--rose::before { background: linear-gradient(90deg, #d4889a, var(--color-mauve-500)); }
  .svc-zone:hover {
    border-color: var(--color-mauve-500);
    transform: translateY(-4px);
    box-shadow: 0 18px 36px -18px rgba(31, 20, 24, 0.16);
  }
  .svc-zone-head {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: start;
    gap: 0.85rem;
  }
  .svc-zone-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2rem, 2.8vw, 2.5rem);
    line-height: 0.85;
    background: linear-gradient(180deg, var(--color-brand-500), var(--color-mauve-500));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.015em;
  }
  .svc-zone-titles {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }
  .svc-zone-kicker {
    font-family: var(--font-sans);
    font-size: 0.56rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mauve-500);
  }
  .svc-zone-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.1rem, 1.4vw, 1.3rem);
    color: var(--color-ink-900);
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.015em;
  }
  .svc-zone-text {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--color-ink-700);
  }
  .svc-zone-sessions {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    background: rgba(201, 169, 97, 0.14);
    border: 1px solid rgba(201, 169, 97, 0.32);
    color: var(--color-brand-600);
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    margin-top: auto;
  }
  .svc-zone-sessions svg { flex-shrink: 0; opacity: 0.85; }

  /* ============= Casos clínicos / perfiles de paciente ============= */
  .svc-cases {
    background: linear-gradient(180deg, white 0%, var(--color-brand-50) 100%);
    padding-block: clamp(4rem, 6vw, 6.5rem);
  }
  .svc-cases-grid {
