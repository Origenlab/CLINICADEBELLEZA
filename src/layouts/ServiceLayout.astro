---
import BaseLayout from './BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { CATEGORIES, CONTACT } from '../consts';

interface Props {
  title: string;
  description: string;
  category: keyof typeof CATEGORIES;
  duration?: string;
  sessions?: string;
  benefits?: string[];
  indications?: string[];
  contraindications?: string[];
  icon?: string;
  publishedAt?: Date;
}

const {
  title, description, category, duration, sessions,
  benefits = [], indications = [], contraindications = [], icon, publishedAt,
} = Astro.props;

const cat = CATEGORIES[category];
const wa = `https://wa.me/${CONTACT.whatsapp}?text=${encodeURIComponent(`Hola, me interesa el tratamiento de ${title} en CLIBEL.`)}`;
---

<BaseLayout title={title} description={description} type="article" publishedAt={publishedAt}>
  <!-- Breadcrumb hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-[color:var(--color-brand-100)] to-[color:var(--color-brand-200)]/40">
    <div class="container-x py-16 lg:py-20">
      <nav class="text-xs uppercase tracking-[0.18em] text-[color:var(--color-ink-500)] mb-6" aria-label="Migas">
        <a href="/" class="hover:text-[color:var(--color-mauve-500)]">Inicio</a>
        <span class="mx-2">/</span>
        <a href="/servicios" class="hover:text-[color:var(--color-mauve-500)]">Servicios</a>
        <span class="mx-2">/</span>
        <span class="text-[color:var(--color-mauve-500)]">{cat.label}</span>
      </nav>

      <div class="grid lg:grid-cols-[1fr_280px] gap-10 items-start">
        <div>
          <span class="kicker">{cat.label}</span>
          <h1 class="mt-3 font-display text-4xl sm:text-5xl lg:text-6xl">{title}</h1>
          <p class="mt-5 text-lg text-[color:var(--color-ink-700)] leading-relaxed max-w-2xl">{description}</p>

          <div class="mt-7 flex flex-wrap gap-3">
            <a href="/contacto" class="btn btn-primary">Agendar valoración</a>
            <a href={wa} target="_blank" rel="noopener" class="btn btn-outline">WhatsApp</a>
          </div>
        </div>

        <!-- Info card -->
        <aside class="card p-6 sticky top-24">
          <div class="text-5xl mb-4 text-center">{icon ?? '✨'}</div>
          <dl class="space-y-3 text-sm">
            {duration && (
              <div class="flex justify-between border-b border-[color:var(--color-brand-200)] pb-2">
                <dt class="text-[color:var(--color-ink-500)]">Duración</dt>
                <dd class="font-medium">{duration}</dd>
              </div>
            )}
            {sessions && (
              <div class="flex justify-between border-b border-[color:var(--color-brand-200)] pb-2">
                <dt class="text-[color:var(--color-ink-500)]">Sesiones</dt>
                <dd class="font-medium">{sessions}</dd>
              </div>
            )}
            <div class="flex justify-between">
              <dt class="text-[color:var(--color-ink-500)]">Categoría</dt>
              <dd class="font-medium">{cat.label}</dd>
            </div>
          </dl>
        </aside>
      </div>
    </div>
  </section>

  <!-- Body -->
  <article class="container-narrow section">
    <div class="prose-clibel">
      <slot />
    </div>

    {benefits.length > 0 && (
      <section class="mt-12">
        <h2 class="font-display text-3xl mb-6">Beneficios</h2>
        <ul class="grid sm:grid-cols-2 gap-3">
          {benefits.map((b) => (
            <li class="flex gap-3 items-start bg-[color:var(--color-brand-100)] rounded-xl p-4">
              <span class="shrink-0 mt-0.5 w-6 h-6 rounded-full grid place-items-center bg-[color:var(--color-brand-400)] text-white">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span class="text-[color:var(--color-ink-700)]">{b}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    {indications.length > 0 && (
      <section class="mt-12">
        <h2 class="font-display text-3xl mb-6">Indicado para</h2>
        <ul class="space-y-2">
          {indications.map((i) => (
            <li class="flex gap-3 items-start text-[color:var(--color-ink-700)]">
              <span class="text-[color:var(--color-mauve-500)] mt-1">●</span>
              <span>{i}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    {contraindications.length > 0 && (
      <section class="mt-12 bg-[color:var(--color-brand-100)] rounded-2xl p-7">
        <h2 class="font-display text-2xl mb-4 text-[color:var(--color-mauve-700)]">Importante</h2>
        <p class="text-sm text-[color:var(--color-ink-700)] mb-3">
          Este tratamiento puede no ser adecuado en los siguientes casos. Siempre consulta con nuestros especialistas:
        </p>
        <ul class="space-y-2 text-sm">
          {contraindications.map((c) => (
            <li class="flex gap-2 text-[color:var(--color-ink-700)]"><span>•</span><span>{c}</span></li>
          ))}
        </ul>
      </section>
    )}
  </article>

  <CTA
    title="¿Te interesa este tratamiento?"
    subtitle="Agenda una valoración personalizada y nuestros especialistas diseñarán un plan a tu medida."
  />
</BaseLayout>
